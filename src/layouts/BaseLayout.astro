---
import "@/styles/global.css";
import "@/styles/mobile.css";
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  buildOrganizationSchema,
  buildLocalBusinessSchema,
  buildWebSiteSchema,
  buildBreadcrumbSchema,
  buildFaqSchema,
  buildProductSchema,
} from "@/lib/schema";
import { SITE_URL, SITE_NAME } from "@/data/site";

export interface BreadcrumbItem { name: string; href?: string; }
export interface FaqSeoItem     { question: string; answer: string; }
export interface ProductSeo {
  name:        string;
  slug:        string;
  description: string;
  image:       string;
  price:       string;
}

export interface Props {
  title:         string;
  description:   string;
  canonical?:    string;
  ogImage?:      string;
  pageType?:     "home" | "product" | "category" | "page";
  breadcrumbs?:  BreadcrumbItem[];
  faqItems?:     FaqSeoItem[];
  product?:      ProductSeo;
  schemaMarkup?: string;
}

const {
  title,
  description,
  canonical    = Astro.url.href,
  ogImage      = "/img/og-brincolins.jpg",
  pageType     = "page",
  breadcrumbs,
  faqItems,
  product,
  schemaMarkup,
} = Astro.props;

const SITE = SITE_URL;

// ── Slug → display name map para BreadcrumbList ──
const slugNames: Record<string, string> = {
  'inflables': 'Inflables',
  'servicios': 'Servicios',
  'cobertura': 'Cobertura',
  'blog': 'Blog',
  'nosotros': 'Nosotros',
  'contacto': 'Contacto',
  'directorio': 'Directorio',
  'cotizar': 'Cotizar',
  'fiestas-infantiles': 'Fiestas Infantiles',
  'preguntas-frecuentes': 'Preguntas Frecuentes',
  'dragones-rojos': 'Dragones Rojos',
  'castillo-princesas': 'Castillo de Princesas',
  'mini-jungla': 'Mini Jungla',
  'gusanitos': 'Gusanitos',
  'mini-castillo': 'Mini Castillo',
  'barco-pirata': 'Barco Pirata',
  'extremo': 'Extremo',
  'castillo-blanco': 'Castillo Blanco',
  'renta-de-inflables': 'Renta de Inflables',
  'paquetes-de-fiesta': 'Paquetes de Fiesta',
  'mobiliario-para-fiestas': 'Mobiliario para Fiestas',
  'iluminacion-eventos': 'Iluminación para Eventos',
  'cdmx': 'CDMX',
  'edomex': 'Estado de México',
  'coyoacan': 'Coyoacán',
  'benito-juarez': 'Benito Juárez',
  'miguel-hidalgo': 'Miguel Hidalgo',
  'alvaro-obregon': 'Álvaro Obregón',
  'tlalpan': 'Tlalpan',
  'cuauhtemoc': 'Cuauhtémoc',
  'azcapotzalco': 'Azcapotzalco',
  'iztapalapa': 'Iztapalapa',
  'xochimilco': 'Xochimilco',
  'gustavo-a-madero': 'Gustavo A. Madero',
  'iztacalco': 'Iztacalco',
  'venustiano-carranza': 'Venustiano Carranza',
  'cuajimalpa': 'Cuajimalpa',
  'magdalena-contreras': 'Magdalena Contreras',
  'tlahuac': 'Tláhuac',
  'milpa-alta': 'Milpa Alta',
  'naucalpan': 'Naucalpan',
  'tlalnepantla': 'Tlalnepantla',
  'ecatepec': 'Ecatepec',
  'huixquilucan': 'Huixquilucan',
  'atizapan': 'Atizapán',
  'cuautitlan-izcalli': 'Cuautitlán Izcalli',
  'coacalco': 'Coacalco',
  'metepec': 'Metepec',
  'toluca': 'Toluca',
  'texcoco': 'Texcoco',
  'nezahualcoyotl': 'Nezahualcóyotl',
  'chalco': 'Chalco',
  'tecamac': 'Tecámac',
  'nicolas-romero': 'Nicolás Romero',
  'tultitlan': 'Tultitlán',
  'polanco': 'Polanco',
};

// ── Schemas via lib/schema.ts ─────────────────────────────────────────────────
const urlPath      = new URL(canonical, SITE).pathname;
const pathSegments = urlPath.split('/').filter(Boolean);

const breadcrumbSchemaObj = buildBreadcrumbSchema(pathSegments, slugNames);
const breadcrumbSchema    = breadcrumbSchemaObj ? JSON.stringify(breadcrumbSchemaObj) : null;

const schemaFaq     = buildFaqSchema(faqItems ?? []);
const schemaProduct = product
  ? buildProductSchema({
      name:        product.name,
      description: product.description,
      image:       product.image,
      price:       product.price,
      canonical,
    })
  : null;

const ogType = (pageType === "product") ? "og:product" : "website";
---

<!doctype html>
<html lang="es-MX">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">

  <!-- Critical CSS Inline (LCP optimization) -->
  <style>
    :root {
      --topbar-height: 36px;
      --header-height: 64px;
      --c-primary: #FF3D00;
      --c-secondary: #1A1A2E;
      --font-head: 'Outfit', system-ui, -apple-system, sans-serif;
      --font-body: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    html { scroll-behavior: smooth; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-body); color: #1A1A2E; background: #ffffff; }
    main { display: block; }
    /* overflow-x: clip NO crea scroll-container */
    html, body { overflow-x: clip !important; }
  </style>

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="BRINCOLINS">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">
  <link rel="canonical" href={canonical}>

  <meta name="geo.region"    content="MX-CMX">
  <meta name="geo.placename" content="Ciudad de México">
  <meta name="geo.position"  content="19.4326;-99.1332">
  <meta name="ICBM"          content="19.4326, -99.1332">

  <meta property="og:type"         content={ogType}>
  <meta property="og:url"          content={canonical}>
  <meta property="og:title"        content={title}>
  <meta property="og:description"  content={description}>
  <meta property="og:image"        content={`${SITE}${ogImage}`}>
  <meta property="og:image:width"  content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale"       content="es_MX">
  <meta property="og:site_name"    content={SITE_NAME}>

  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image"       content={`${SITE}${ogImage}`}>

  <link rel="icon" href="/favicon.ico" sizes="any">
  <meta name="theme-color" content="#FF3D00">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(buildOrganizationSchema())} />
  <script type="application/ld+json" set:html={JSON.stringify(buildLocalBusinessSchema())} />
  <script type="application/ld+json" set:html={JSON.stringify(buildWebSiteSchema())} />
  {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
  {schemaFaq && <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />}
  {schemaProduct && <script type="application/ld+json" set:html={JSON.stringify(schemaProduct)} />}
  {schemaMarkup && <script type="application/ld+json" set:html={schemaMarkup} />}

  <!-- Measure TopBar height dynamically for hero padding -->
  <script is:inline>
    (function(){
      function setHeights(){
        var tb = document.querySelector('.topbar');
        var hdr = document.getElementById('hdr');
        var h = tb ? tb.offsetHeight : 36;
        var hh = hdr ? hdr.offsetHeight : 70;
        document.documentElement.style.setProperty('--topbar-height', h + 'px');
        document.documentElement.style.setProperty('--header-height', hh + 'px');
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setHeights);
      } else {
        setHeights();
      }
      window.addEventListener('resize', setHeights, {passive:true});
    })();
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <TopBar />
  <div class="hdr-stack">
    <Header />
    <slot name="breadcrumbs" />
  </div>

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <!-- Sticky CTA Mobile -->
  <div class="sticky-cta-mobile">
    <a href="https://wa.me/5531281706?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable%20para%20mi%20fiesta." class="sticky-cta__wa" target="_blank" rel="nofollow noopener noreferrer">
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp
    </a>
    <a href="/cotizar/" class="sticky-cta__cotizar">
      Cotizar Gratis
    </a>
  </div>

  <!-- FAQ accordion script -->
  <script is:inline>
    document.querySelectorAll('.faq__question').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item   = btn.closest('.faq__item');
        var answer = item ? item.querySelector('.faq__answer') : null;
        var icon   = btn.querySelector('.faq__icon');
        var isOpen = answer && answer.classList.contains('faq__answer--open');
        document.querySelectorAll('.faq__answer--open').forEach(function(a) { a.classList.remove('faq__answer--open'); });
        document.querySelectorAll('.faq__question').forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
        document.querySelectorAll('.faq__icon').forEach(function(i) { i.textContent = '+'; });
        if (!isOpen && answer) {
          answer.classList.add('faq__answer--open');
          btn.setAttribute('aria-expanded', 'true');
          if (icon) icon.textContent = '\u2212';
        }
      });
    });
  </script>
</body>
</html>
