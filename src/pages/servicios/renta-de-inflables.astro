---
import PageLayout from "@/layouts/PageLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Gallery4x4 from "@/components/Gallery4x4.astro";
import PricingCards from "@/components/PricingCards.astro";

const title = "Renta de Inflables para Fiestas en CDMX | BRINCOLINS CDMX";
const description = "Renta de inflables para fiestas infantiles en CDMX. Incluye entrega, instalación, motor, limpieza, seguro y recolección. Cotiza hoy por WhatsApp.";

const galleryImages = [
  { src: "/img/inflables/castillo-blanco-v3.avif", alt: "Inflable castillo blanco para renta en fiestas CDMX" },
  { src: "/img/inflables/barco-pirata-v3.avif", alt: "Inflable barco pirata para eventos infantiles CDMX" },
  { src: "/img/inflables/extremo-v3.avif", alt: "Inflable extremo con obstáculos para fiestas grandes" },
  { src: "/img/inflables/castillo-princesas-v3.avif", alt: "Inflable castillo de princesas para niñas en CDMX" },
  { src: "/img/inflables/mini-castillo-v3.avif", alt: "Mini castillo inflable para fiestas infantiles" },
  { src: "/img/inflables/gusanitos-v3.avif", alt: "Inflable gusanitos para los más pequeños" },
  { src: "/img/inflables/mini-jungla-v3.avif", alt: "Inflable mini jungla para niños en CDMX" },
  { src: "/img/inflables/castillo-blanco-v5.avif", alt: "Castillo blanco inflable en evento al aire libre" },
];

const pricingPackages = [
  {
    name: "Inflable Básico",
    price: "$1,200",
    priceNote: "por evento (4 horas)",
    description: "Ideal para fiestas pequeñas con los más chiquitos. Incluye mini castillo o gusanitos.",
    features: [
      { text: "Mini castillo o gusanitos", included: true },
      { text: "Entrega e instalación", included: true },
      { text: "Motor de inflado continuo", included: true },
      { text: "Limpieza y sanitización", included: true },
      { text: "Seguro incluido", included: true },
      { text: "Recolección al finalizar", included: true },
      { text: "Inflable grande o extremo", included: false },
    ],
    ctaHref: "/contacto/",
  },
  {
    name: "Inflable Clásico",
    badge: "Popular",
    highlight: true,
    price: "$1,800",
    priceNote: "por evento (5 horas)",
    description: "El favorito de nuestros clientes. Castillos y barcos para todas las edades.",
    features: [
      { text: "Castillo, barco pirata o princesas", included: true },
      { text: "Entrega e instalación", included: true },
      { text: "Motor de inflado continuo", included: true },
      { text: "Limpieza y sanitización", included: true },
      { text: "Seguro incluido", included: true },
      { text: "Recolección al finalizar", included: true },
      { text: "5 horas de servicio", included: true },
    ],
    ctaHref: "/contacto/",
  },
  {
    name: "Inflable Extremo",
    price: "$2,800",
    priceNote: "por evento (5 horas)",
    description: "Para fiestas grandes con adolescentes y adultos. Circuito de obstáculos completo.",
    features: [
      { text: "Inflable extremo con obstáculos", included: true },
      { text: "Entrega e instalación", included: true },
      { text: "Motor de inflado continuo", included: true },
      { text: "Limpieza y sanitización", included: true },
      { text: "Seguro incluido", included: true },
      { text: "Recolección al finalizar", included: true },
      { text: "Ideal para todas las edades", included: true },
    ],
    ctaHref: "/contacto/",
  },
  {
    name: "Inflable Acuático",
    price: "$3,500",
    priceNote: "por evento (5 horas)",
    description: "Perfecto para fiestas de verano. Tobogán con zona de splash incluida.",
    features: [
      { text: "Inflable acuático con tobogán", included: true },
      { text: "Entrega e instalación", included: true },
      { text: "Motor de inflado continuo", included: true },
      { text: "Conexión de agua incluida", included: true },
      { text: "Seguro incluido", included: true },
      { text: "Recolección al finalizar", included: true },
      { text: "Manguera y adaptadores", included: true },
    ],
    ctaHref: "/contacto/",
  },
];

const faqs = [
  { question: "¿Qué incluye la renta de un inflable?", answer: "Cada renta incluye entrega a domicilio, instalación profesional, motor de inflado continuo, limpieza y sanitización previa, seguro contra accidentes y recolección al finalizar tu evento. No hay costos ocultos." },
  { question: "¿Cuánto cuesta rentar un inflable en CDMX?", answer: "Nuestros precios van desde $1,200 MXN para inflables básicos hasta $3,500 MXN para inflables extremos y acuáticos. El precio final depende del modelo, tamaño y duración del evento. Contáctanos por WhatsApp para una cotización personalizada." },
  { question: "¿Cuál es el área de cobertura para la entrega?", answer: "Cubrimos toda la Ciudad de México y zona metropolitana, incluyendo Naucalpan, Tlalnepantla, Ecatepec, Coacalco, Nezahualcóyotl y Huixquilucan. Para zonas alejadas puede aplicar un cargo adicional por traslado." },
  { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos reservar con al menos 5 días de anticipación, especialmente en temporada alta (abril-junio y noviembre-diciembre). Para fines de semana, te sugerimos apartar con 2 semanas de anticipación para garantizar disponibilidad del modelo que deseas." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Servicios", href: "/servicios" },
    { name: "Renta de Inflables" },
  ]}
  faqItems={faqs}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Servicios",href:"/servicios/"},{label:"Renta de Inflables"}]} />
  </Fragment>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Servicio principal</span>
          <h1 class="hero__title">Renta de <span class="highlight">inflables</span> para fiestas en CDMX</h1>
          <p class="hero__desc">Haz de tu fiesta infantil un evento inolvidable con nuestros inflables profesionales. Servicio completo con entrega, instalación y recolección en toda la Ciudad de México.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">
              Solicitar cotización
            </a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <img src="/img/inflables/castillo-blanco-v4.avif" alt="Renta de inflables para fiestas infantiles en CDMX - BRINCOLINS" width="600" height="338" style="border-radius: var(--r-card); width:100%; height:auto; margin-bottom:1.5rem;" />
          <p class="hero__copy-text">En BRINCOLINS ofrecemos el servicio más completo de renta de inflables en la Ciudad de México. Cada renta incluye transporte de ida y vuelta, instalación profesional por nuestro equipo capacitado, motor eléctrico de inflado continuo, limpieza y sanitización del inflable antes de cada evento, y seguro de responsabilidad civil para que tu fiesta sea 100% segura.</p>
          <p class="hero__copy-text">Contamos con más de 15 modelos de inflables para todas las edades: desde mini castillos para los más pequeños hasta inflables extremos para adolescentes y adultos. Nuestro servicio cubre toda la CDMX y zona metropolitana, con horarios flexibles y precios accesibles que se adaptan a cualquier presupuesto familiar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GALERÍA -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Galería"
        title="Nuestros inflables en acción"
        subtitle="Mira cómo lucen nuestros inflables en eventos reales."
        copy1="Cada inflable que rentamos está diseñado para ofrecer diversión segura y horas de entretenimiento para niños de todas las edades. Desde castillos clásicos hasta circuitos extremos, nuestro catálogo tiene opciones para todo tipo de fiesta."
        copy2="Todos los inflables que ves en las fotos están disponibles para renta en CDMX y zona metropolitana. Contáctanos por WhatsApp para conocer la disponibilidad del modelo que más te guste para la fecha de tu evento."
      />
      <Gallery4x4 images={galleryImages} />
    </div>
  </section>

  <!-- PRECIOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Precios"
        title="Precios de renta de inflables"
        subtitle="Opciones para cada presupuesto. Todo incluido."
        copy1="Nuestros precios incluyen entrega, instalación, motor de inflado, limpieza, sanitización, seguro de responsabilidad civil y recolección. No hay costos ocultos ni sorpresas al momento de pagar."
        copy2="El precio final puede variar según la distancia de entrega y la duración del evento. Contáctanos para recibir una cotización personalizada según las necesidades de tu fiesta."
      />
      <PricingCards packages={pricingPackages} />
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Beneficios"
        title="¿Por qué rentar con BRINCOLINS?"
        subtitle="Todo incluido, sin sorpresas ni costos ocultos."
        copy1="Nuestro servicio de renta de inflables está diseñado para que tú no te preocupes por nada. Desde el momento en que confirmas tu reservación, nuestro equipo se encarga de cada detalle: coordinamos la hora de entrega, instalamos el inflable en el espacio que nos indiques y verificamos que todo funcione perfectamente antes de retirarnos."
        copy2="Al finalizar tu evento, regresamos a recoger el inflable sin que tengas que mover un dedo. Además, todos nuestros inflables pasan por un riguroso proceso de limpieza y desinfección después de cada uso, garantizando la higiene y seguridad de los niños en cada fiesta."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Entrega y recolección gratis</h3>
            <p class="why-card__desc">Llevamos y recogemos el inflable en tu domicilio sin costo adicional en toda la CDMX y zona metropolitana.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #2962FF, #448AFF);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación profesional</h3>
            <p class="why-card__desc">Nuestro equipo capacitado instala y asegura el inflable correctamente, verificando anclajes y motor antes de retirarse.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #69F0AE);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Seguro incluido</h3>
            <p class="why-card__desc">Todos nuestros inflables cuentan con seguro de responsabilidad civil para proteger a los pequeños durante el evento.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #AA00FF, #D500F9);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Limpieza y sanitización</h3>
            <p class="why-card__desc">Cada inflable se limpia y desinfecta antes de cada evento con productos seguros para niños.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Proceso"
        title="¿Cómo funciona la renta?"
        subtitle="4 pasos sencillos para tener tu inflable."
        copy1="Rentar un inflable con BRINCOLINS es muy fácil. Nuestro proceso está pensado para que ahorres tiempo y te concentres en lo que realmente importa: disfrutar la fiesta con tu familia y amigos."
        copy2="Desde la cotización hasta la recolección del inflable, te acompañamos en cada paso. Nuestro equipo de atención al cliente está disponible por WhatsApp para resolver cualquier duda que tengas antes, durante y después del evento."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Elige tu inflable</h3>
            <p class="why-card__desc">Explora nuestro catálogo y selecciona el inflable ideal para tu fiesta. Tenemos opciones para todas las edades y espacios.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #2962FF, #448AFF);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Cotiza por WhatsApp</h3>
            <p class="why-card__desc">Envíanos un mensaje con la fecha, dirección y modelo que te interesa. Te respondemos en menos de 30 minutos con tu cotización.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #69F0AE);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Confirma y aparta</h3>
            <p class="why-card__desc">Aparta tu fecha con un anticipo del 50%. Aceptamos transferencia bancaria, depósito en OXXO y efectivo.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #AA00FF, #D500F9);">
            <span class="why-card__img-label"></span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Disfruta tu fiesta</h3>
            <p class="why-card__desc">Llegamos puntualmente, instalamos todo y al terminar recogemos. Tú solo disfruta el evento con tus invitados.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes"
        subtitle="Resolvemos tus dudas sobre la renta de inflables."
        copy1="Sabemos que organizar una fiesta implica muchas decisiones. Aquí respondemos las preguntas más comunes que recibimos de nuestros clientes para que tengas toda la información antes de reservar."
        copy2="Si tu pregunta no aparece aquí, no dudes en escribirnos por WhatsApp. Nuestro equipo está listo para ayudarte con cualquier detalle sobre el servicio, disponibilidad de modelos o cobertura en tu zona."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Listo para hacer tu fiesta inolvidable?"
    subtitle="Cotiza tu inflable hoy y aparta tu fecha antes de que se agote la disponibilidad."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
  />

</PageLayout>
