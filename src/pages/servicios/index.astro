---
import PageLayout    from "@/layouts/PageLayout.astro";
import QuickNav      from "@/components/QuickNav.astro";
import Breadcrumbs   from "@/components/Breadcrumbs.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ServiceFeature from "@/components/ServiceFeature.astro";
import ServicesSidebar from "@/components/ServicesSidebar.astro";
import CtaBanner     from "@/components/CtaBanner.astro";

const title       = "Servicios para Fiestas en CDMX | BRINCOLINS";
const description = "Renta de inflables, mobiliario e iluminación para fiestas en CDMX. Paquetes todo incluido con entrega e instalación. Un solo proveedor para toda tu fiesta infantil.";

/* ─── CATÁLOGO DE SERVICIOS (para el grid) ───────────────────────── */
const servicios = [
  {
    icon: "🎪",
    name: "Renta de Inflables",
    badge: "Servicio principal",
    badgeColor: "#FF3D00",
    desc: "Más de 8 modelos: castillos, toboganes, circuitos y más. Entrega e instalación incluida en toda la ZMVM.",
    tag1: "desde $800 MXN",
    tag2: "8+ modelos",
    href: "/servicios/renta-de-inflables/",
    image: "/img/inflables/dragones-rojos.avif",
    waMsg: "Hola BRINCOLINS, quiero cotizar la renta de un inflable.",
  },
  {
    icon: "🎁",
    name: "Paquetes de Fiesta",
    badge: "Ahorra hasta 25%",
    badgeColor: "#7C3AED",
    desc: "Combos todo incluido con precio cerrado: inflable + mobiliario + iluminación. Sin sorpresas al final.",
    tag1: "desde $2,500 MXN",
    tag2: "Todo incluido",
    href: "/servicios/paquetes-de-fiesta/",
    image: "/img/servicios/paquetes-fiesta-completo-cdmx.avif",
    waMsg: "Hola BRINCOLINS, quiero cotizar un paquete de fiesta todo incluido.",
  },
  {
    icon: "🪑",
    name: "Mobiliario para Fiestas",
    badge: "Complemento esencial",
    badgeColor: "#0369a1",
    desc: "Mesas, sillas, toldos y mantelería. Completa tu evento con un solo proveedor para todo.",
    tag1: "Cotización gratis",
    tag2: "Entrega incluida",
    href: "/servicios/mobiliario-para-fiestas/",
    image: "/img/servicios/mobiliario-fiestas-cdmx.avif",
    waMsg: "Hola BRINCOLINS, quiero cotizar mobiliario para mi fiesta.",
  },
  {
    icon: "💡",
    name: "Iluminación para Eventos",
    badge: "Ambientación premium",
    badgeColor: "#b45309",
    desc: "Series LED, neón, luz UV y proyección profesional para que tu evento brille de día y de noche.",
    tag1: "Cotización gratis",
    tag2: "Instalación incluida",
    href: "/servicios/iluminacion-eventos/",
    image: "/img/servicios/iluminacion-eventos-cdmx.avif",
    waMsg: "Hola BRINCOLINS, quiero cotizar iluminación para mi evento.",
  },
  {
    icon: "🏟️",
    name: "Inflables para Eventos",
    badge: "Empresas y escuelas",
    badgeColor: "#15803d",
    desc: "2 a 20+ inflables simultáneos con coordinación logística completa para kermeses y eventos corporativos.",
    tag1: "Cotización personalizada",
    tag2: "2–20+ inflables",
    href: "/servicios/inflables-para-eventos/",
    image: "/img/inflables/extremo.avif",
    waMsg: "Hola BRINCOLINS, quiero cotizar inflables para un evento corporativo o escolar.",
  },
];

const WA = "5531281706";

/* ─── PREGUNTAS FRECUENTES ───────────────────────────────────────── */
const faqs = [
  {
    question: "¿Qué incluye cada servicio de BRINCOLINS?",
    answer: "Todos nuestros servicios incluyen transporte, instalación profesional, mantenimiento durante el evento y recolección al finalizar. Los inflables también incluyen motor inflador, sanitización certificada y seguro de responsabilidad civil. Los paquetes incluyen todos los elementos del combo con un solo precio cerrado y un solo responsable."
  },
  {
    question: "¿Puedo contratar varios servicios juntos?",
    answer: "Sí, y es la forma más conveniente. Nuestros paquetes de fiesta combinan inflable + mobiliario + iluminación con hasta 25% de descuento vs. contratar por separado. Si tienes necesidades específicas, también armamos paquetes a la medida — cuéntanos qué buscas por WhatsApp y en minutos te tenemos una cotización."
  },
  {
    question: "¿Cuánto cuesta la entrega e instalación?",
    answer: "La entrega e instalación están incluidas en el precio de todos nuestros servicios dentro de la ZMVM — no hay cargos ocultos. Para zonas fuera de la ZMVM, aplica un cargo adicional según la distancia que cotizamos de forma transparente antes de confirmar tu reserva."
  },
  {
    question: "¿Con cuánta anticipación debo contratar?",
    answer: "Recomendamos con al menos 3-7 días para garantizar disponibilidad del servicio o inflable de tu preferencia, especialmente en fines de semana. Para eventos grandes (kermeses, eventos corporativos con múltiples servicios) sugerimos 2-3 semanas de anticipación. En casos de urgencia, escríbenos — a veces tenemos disponibilidad en 24-48 horas."
  },
  {
    question: "¿Cómo funciona el proceso de reserva?",
    answer: "Es sencillo: 1) Contáctanos por WhatsApp con el servicio que necesitas, la fecha y la zona; 2) Te enviamos disponibilidad y cotización en minutos; 3) Para apartar la fecha se requiere un anticipo del 50%; 4) El saldo restante se liquida el día del evento. Aceptamos transferencia, efectivo y tarjeta."
  },
  {
    question: "¿Tienen seguro de responsabilidad civil?",
    answer: "Sí. Todos nuestros servicios están respaldados por seguro de responsabilidad civil. Nuestro equipo tiene capacitación en protocolos de seguridad para el montaje y desmontaje. Los inflables son inspeccionados antes de cada evento y cumplen con normas de fabricación con PVC de grado comercial."
  },
  {
    question: "¿Atienden en toda la CDMX y Estado de México?",
    answer: "Atendemos toda la Zona Metropolitana del Valle de México: las 16 alcaldías de CDMX y los principales municipios del Estado de México (Naucalpan, Tlalnepantla, Ecatepec, Coacalco, Tultitlán, Atizapán, Cuautitlán Izcalli, Nezahualcóyotl, Chalco, entre otros). La entrega está incluida en toda esta zona."
  },
  {
    question: "¿Qué pasa si llueve el día de mi evento?",
    answer: "Para eventos al aire libre en días de lluvia, evaluamos la situación contigo el mismo día. Si la lluvia hace imposible el uso seguro del inflable, coordinamos un reagendamiento sin penalización. Por eso siempre recomendamos tener un plan B: espacio techado o fecha de respaldo. Hablamos abiertamente de esto al momento de la reserva."
  },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  faqItems={faqs}
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Servicios" },
  ]}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Servicios"}]} />
  </Fragment>

  <!-- ═══════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════ -->
  <section class="hero" style="padding:clamp(5rem,8vw,6rem) 0 clamp(2rem,4vw,3rem);">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Proveedor integral para fiestas</span>
          <h1 class="hero__title">
            Todos los Servicios para tu
            <span class="highlight">Fiesta Perfecta</span> en CDMX
          </h1>
          <div class="hero__ctas">
            <a href="/cotizar/" class="btn btn-primary btn-lg">Cotizar mi evento</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver catálogo de inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            <strong>BRINCOLINS</strong> es el proveedor integral para fiestas y eventos en CDMX y
            Estado de México. No solo rentamos inflables — ofrecemos
            <strong>mobiliario, iluminación y paquetes completos</strong> para que
            solo tengas que llamar a una empresa y descansar.
          </p>
          <p class="hero__copy-text">
            Más de 20 años de experiencia, entrega puntual, instalación profesional
            y seguro de responsabilidad civil en todos nuestros servicios.
            <strong>Un solo proveedor para todo tu evento.</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <!-- ═══════════════════════════════════════════════
       CATÁLOGO DE SERVICIOS (grid)
  ════════════════════════════════════════════════════ -->
  <section class="section" style="padding-top:1.5rem;">
    <div class="container">
      <SectionHeader
        badge="Catálogo de servicios"
        title="5 Servicios para tu Fiesta o Evento en CDMX"
        subtitle="Desde inflables hasta mobiliario e iluminación — todo con entrega, instalación y seguro incluidos."
        copy1="Cada servicio está diseñado para complementarse. Contrata uno o combínalos todos en uno de nuestros paquetes todo incluido con precio cerrado y hasta 25% de descuento. Cubrimos toda la Zona Metropolitana del Valle de México."
        copy2="Nuestros 5 servicios están disponibles para fiestas infantiles, quinceañeras, bodas, eventos corporativos y kermeses escolares. Escríbenos por WhatsApp para una cotización en minutos."
      />
      <div class="svc-grid">
        {servicios.map(s => (
          <article class="svc-card">
            <a href={s.href} class="svc-card__media">
              <img src={s.image} alt={s.name} width="720" height="480" loading="lazy" />
              <span class="svc-card__badge" style={`background:${s.badgeColor};`}>{s.badge}</span>
            </a>
            <div class="svc-card__body">
              <div class="svc-card__icon-row">
                <span class="svc-card__icon">{s.icon}</span>
                <h3 class="svc-card__name"><a href={s.href}>{s.name}</a></h3>
              </div>
              <p class="svc-card__desc">{s.desc}</p>
              <div class="svc-card__tags">
                <span class="svc-card__tag">{s.tag1}</span>
                <span class="svc-card__tag">{s.tag2}</span>
              </div>
              <div class="svc-card__actions">
                <a href={s.href} class="btn btn-outline btn-sm">Ver servicio</a>
                <a
                  href={`https://wa.me/${WA}?text=${encodeURIComponent(s.waMsg)}`}
                  target="_blank"
                  rel="nofollow noopener noreferrer"
                  class="btn btn-wa btn-sm"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><use href="#i-wa"/></svg>
                  Cotizar
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       01 — RENTA DE INFLABLES
  ════════════════════════════════════════════════════ -->
  <section class="section section--alt featured-section">
    <div class="container">
      <SectionHeader
        badge="🎪 Servicio principal"
        title="Renta de Inflables para Fiestas en CDMX"
        subtitle="El corazón de cada fiesta · más de 8 modelos · entrega e instalación incluida"
        copy1="La renta de inflables es nuestro servicio estrella con más de 20 años de experiencia. Contamos con 8 modelos distintos para todas las edades, tamaños y presupuestos: desde el Mini Castillo compacto para bebés hasta el Circuito Extremo de 12 metros para adolescentes y adultos."
        copy2="Todos los inflables incluyen motor inflador silencioso, sanitización certificada, seguro de responsabilidad civil y técnico durante el evento. Fabricados con PVC de grado comercial y certificados en seguridad. Entrega en toda CDMX y Estado de México."
      />
      <div class="featured-layout">
        <div class="featured-layout__main">
          <ServiceFeature
            name="Renta de Inflables"
            href="/servicios/renta-de-inflables/"
            badge="Servicio principal"
            accentColor="#FF3D00"
            price="desde $800"
            priceNote="por evento · instalación incluida"
            description="El servicio más solicitado de BRINCOLINS. Más de 8 modelos de inflables para fiestas infantiles, bodas, XV años, kermeses y eventos corporativos en toda la ZMVM. Cada inflable incluye entrega, instalación, motor inflador, sanitización certificada y seguro de responsabilidad civil."
            features={[
              { icon: "🎪", text: "8+ modelos: castillos, toboganes y circuitos" },
              { icon: "🚚", text: "Entrega a domicilio sin costo en toda la ZMVM" },
              { icon: "⚡", text: "Instalación profesional en 15-30 minutos" },
              { icon: "🧼", text: "Sanitización certificada antes de cada evento" },
              { icon: "🔒", text: "Seguro de responsabilidad civil incluido" },
              { icon: "👨‍🔧", text: "Técnico supervisor disponible durante el evento" },
            ]}
            stat1={{ icon: "🎪", value: "8+", label: "Modelos" }}
            stat2={{ icon: "👦", value: "1-18 años", label: "Edades" }}
            stat3={{ icon: "👥", value: "hasta 15", label: "Capacidad" }}
            stat4={{ icon: "⚡", value: "20 min", label: "Instalación" }}
            image="/img/inflables/dragones-rojos.avif"
            imageAlt="Renta de inflables para fiestas en CDMX — Dragones Rojos"
            gallery={[
              { src: "/img/inflables/castillo-princesas.avif", alt: "Castillo de Princesas en fiesta infantil" },
              { src: "/img/inflables/barco-pirata.avif", alt: "Barco Pirata inflable para cumpleaños" },
            ]}
            waMessage="Hola BRINCOLINS, quiero cotizar la renta de un inflable para mi fiesta."
            trust={["🔒 50% anticipo", "🧼 Sanitizado", "🏙️ CDMX y Edomex"]}
          />
        </div>
        <div class="featured-layout__sidebar">
          <ServicesSidebar current="renta-de-inflables" waMessage="Hola BRINCOLINS, quiero cotizar la renta de un inflable para mi fiesta." />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       02 — PAQUETES DE FIESTA
  ════════════════════════════════════════════════════ -->
  <section class="section featured-section">
    <div class="container">
      <SectionHeader
        badge="🎁 Todo incluido"
        title="Paquetes de Fiesta — Ahorra hasta 25%"
        subtitle="Inflable + mobiliario + iluminación · precio cerrado · sin sorpresas al final"
        copy1="Los paquetes de fiesta son la forma más inteligente de organizar tu evento. Combinamos los servicios que más se complementan en combos con precio cerrado, eliminando la coordinación con múltiples proveedores y generando ahorros de hasta 25% vs. contratar cada cosa por separado."
        copy2="Contamos con tres niveles: Paquete Básico para 15-30 invitados, Paquete Intermedio para 30-60 invitados y Paquete Premium para 60-100+ invitados. Cada paquete incluye inflable, mesas, sillas y un kit de iluminación. Todo entregado, instalado y retirado por nuestro equipo."
      />
      <div class="featured-layout">
        <div class="featured-layout__main">
          <ServiceFeature
            name="Paquetes de Fiesta"
            href="/servicios/paquetes-de-fiesta/"
            badge="Ahorra hasta 25%"
            accentColor="#7C3AED"
            price="desde $2,500"
            priceNote="todo incluido · precio cerrado"
            description="La solución completa para organizar tu fiesta sin complicaciones. Un solo proveedor, un solo cobro, un solo punto de contacto. Nuestros paquetes combinan inflable + mobiliario + iluminación en tres niveles según el tamaño de tu evento, con descuentos de hasta 25% sobre el precio individual de cada servicio."
            features={[
              { icon: "🎪", text: "Inflable incluido en todos los paquetes" },
              { icon: "🪑", text: "Mesas y sillas para todos los invitados" },
              { icon: "💡", text: "Kit de iluminación LED para ambientación" },
              { icon: "💰", text: "Ahorro de hasta 25% vs. contratar por separado" },
              { icon: "📋", text: "Precio cerrado — sin cobros sorpresa el día del evento" },
              { icon: "👨‍💼", text: "Un coordinador responsable de todo el montaje" },
            ]}
            stat1={{ icon: "🎁", value: "3 niveles", label: "Paquetes" }}
            stat2={{ icon: "👥", value: "15-100+", label: "Invitados" }}
            stat3={{ icon: "💰", value: "hasta 25%", label: "Descuento" }}
            stat4={{ icon: "👨‍💼", value: "1 proveedor", label: "Coordinación" }}
            image="/img/servicios/paquetes-fiesta-completo-cdmx.avif"
            imageAlt="Paquetes de fiesta todo incluido en CDMX — inflable, mobiliario e iluminación"
            gallery={[
              { src: "/img/servicios/mobiliario-fiestas-cdmx.avif", alt: "Mobiliario incluido en paquetes de fiesta" },
              { src: "/img/servicios/iluminacion-eventos-cdmx.avif", alt: "Iluminación incluida en paquetes de fiesta" },
            ]}
            waMessage="Hola BRINCOLINS, quiero cotizar un paquete de fiesta todo incluido."
            trust={["💰 Ahorra hasta 25%", "📋 Precio cerrado", "👨‍💼 Un solo responsable"]}
          />
        </div>
        <div class="featured-layout__sidebar">
          <ServicesSidebar current="paquetes-de-fiesta" waMessage="Hola BRINCOLINS, quiero cotizar un paquete de fiesta todo incluido." />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       03 — MOBILIARIO
  ════════════════════════════════════════════════════ -->
  <section class="section section--alt featured-section">
    <div class="container">
      <SectionHeader
        badge="🪑 Complemento esencial"
        title="Mobiliario para Fiestas — Mesas, Sillas y Toldos"
        subtitle="Plegables · mantelería · toldos 3×6 y 6×6 · entrega e instalación incluida"
        copy1="El mobiliario correcto hace que tu evento sea cómodo para todos los invitados. Contamos con mesas y sillas plegables de alta resistencia, toldos de 3×6 y 6×6 metros para exteriores, y mantelería en múltiples colores para darle un toque profesional a tu celebración."
        copy2="Todo el mobiliario se entrega limpio, en perfecto estado y se instala en el lugar que indiques. Al final del evento, nosotros recogemos todo. Disponible por separado o incluido en nuestros paquetes de fiesta. Cotización en minutos por WhatsApp."
      />
      <div class="featured-layout">
        <div class="featured-layout__main">
          <ServiceFeature
            name="Mobiliario para Fiestas"
            href="/servicios/mobiliario-para-fiestas/"
            badge="Complemento esencial"
            accentColor="#0369a1"
            price="Cotización gratis"
            priceNote="según cantidad · entrega incluida"
            description="Mesas, sillas, toldos y mantelería para completar tu evento de principio a fin. Todo el mobiliario es plegable, de alta resistencia y se entrega en perfectas condiciones. Disponible para todos los tipos de eventos: fiestas infantiles, bodas, XV años, reuniones y eventos corporativos en toda la ZMVM."
            features={[
              { icon: "🪑", text: "Mesas y sillas plegables de alta resistencia" },
              { icon: "⛺", text: "Toldos 3×6 m y 6×6 m para exteriores" },
              { icon: "🎀", text: "Mantelería y cubresillas en múltiples colores" },
              { icon: "🚚", text: "Entrega, instalación y recolección incluidas" },
              { icon: "✨", text: "Mobiliario entregado limpio y en perfecto estado" },
              { icon: "📦", text: "Disponible por separado o en paquetes de fiesta" },
            ]}
            stat1={{ icon: "🪑", value: "Mesas+sillas", label: "Tipo" }}
            stat2={{ icon: "⛺", value: "3×6 y 6×6 m", label: "Toldos" }}
            stat3={{ icon: "⚡", value: "30 min", label: "Montaje" }}
            stat4={{ icon: "🎀", value: "Mantelería", label: "Extra" }}
            image="/img/servicios/mobiliario-fiestas-cdmx.avif"
            imageAlt="Renta de mobiliario para fiestas en CDMX — mesas, sillas y toldos"
            gallery={[
              { src: "/img/servicios/paquetes-fiesta-completo-cdmx.avif", alt: "Mobiliario en paquete de fiesta completo" },
              { src: "/img/inflables/dragones-rojos.avif", alt: "Inflable con mobiliario para evento familiar" },
            ]}
            waMessage="Hola BRINCOLINS, quiero cotizar mobiliario para mi fiesta."
            trust={["🚚 Entrega incluida", "✨ Estado impecable", "📦 Con o sin paquete"]}
          />
        </div>
        <div class="featured-layout__sidebar">
          <ServicesSidebar current="mobiliario-para-fiestas" waMessage="Hola BRINCOLINS, quiero cotizar mobiliario para mi fiesta." />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       04 — ILUMINACIÓN
  ════════════════════════════════════════════════════ -->
  <section class="section featured-section">
    <div class="container">
      <SectionHeader
        badge="💡 Ambientación premium"
        title="Iluminación para Eventos — LED, Neón y Proyección"
        subtitle="Series LED · guirnaldas · luz UV · reflectores · transforma cualquier espacio"
        copy1="La iluminación correcta transforma por completo el ambiente de tu evento. Contamos con series LED de colores, guirnaldas cálidas para jardines, neón y luz UV para fiestas temáticas nocturnas, y proyección profesional para quincañeras y bodas."
        copy2="Cada kit se diseña según el espacio y el tipo de evento para garantizar el ambiente que buscas. La iluminación puede contratarse de forma independiente o como parte de nuestros paquetes de fiesta. Instalación profesional en menos de 1 hora."
      />
      <div class="featured-layout">
        <div class="featured-layout__main">
          <ServiceFeature
            name="Iluminación para Eventos"
            href="/servicios/iluminacion-eventos/"
            badge="Ambientación premium"
            accentColor="#b45309"
            price="Cotización gratis"
            priceNote="según el tipo de evento"
            description="Iluminación profesional que transforma cualquier espacio en el escenario perfecto para tu celebración. Desde guirnaldas cálidas para jardines familiares hasta proyección profesional para quinceañeras y bodas. Diseñamos el esquema de iluminación según tu espacio, horario y estilo de evento."
            features={[
              { icon: "💡", text: "Series LED de colores para interiores y exteriores" },
              { icon: "🌟", text: "Guirnaldas cálidas y focos Edison para jardines" },
              { icon: "🌈", text: "Neón y luz UV para fiestas temáticas nocturnas" },
              { icon: "🔦", text: "Reflectores y proyección profesional para bodas" },
              { icon: "🎨", text: "Diseño de esquema personalizado por evento" },
              { icon: "🚚", text: "Instalación en menos de 1 hora · retiro incluido" },
            ]}
            stat1={{ icon: "💡", value: "LED+Neón+UV", label: "Tipos" }}
            stat2={{ icon: "🌙", value: "Día y noche", label: "Horario" }}
            stat3={{ icon: "⚡", value: "< 1 hora", label: "Instalación" }}
            stat4={{ icon: "🎨", value: "Personalizado", label: "Diseño" }}
            image="/img/servicios/iluminacion-eventos-cdmx.avif"
            imageAlt="Iluminación profesional para eventos y fiestas en CDMX — LED, neón y proyección"
            gallery={[
              { src: "/img/servicios/guirnaldas-luz-eventos.avif", alt: "Guirnaldas de luz para eventos en jardín" },
              { src: "/img/servicios/neon-fiesta-uv.avif", alt: "Iluminación neón y UV para fiesta temática" },
            ]}
            waMessage="Hola BRINCOLINS, quiero cotizar iluminación para mi evento."
            trust={["💡 Instalación profesional", "🎨 Diseño personalizado", "🚚 Retiro incluido"]}
          />
