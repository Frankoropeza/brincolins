---
import PageLayout from "@/layouts/PageLayout.astro";

const title = "Página no encontrada | BRINCOLINS";
const description = "La página que buscas no existe o cambió de dirección. Encuentra tu inflable ideal en el catálogo o cotiza por WhatsApp.";
---

<PageLayout title={title} description={description} pageType="page">

  <section class="section nf">
    <div class="container nf__wrap">
      <p class="nf__code" aria-hidden="true">404</p>
      <h1 class="nf__title">Esta página se desinfló</h1>
      <p class="nf__text">
        La dirección que buscas no existe o cambió de lugar. Pero la fiesta sigue:
        encuentra tu inflable ideal o escríbenos y te ayudamos en minutos.
      </p>
      <div class="nf__ctas">
        <a href="/inflables/" class="btn btn-primary btn-lg">Ver catálogo de inflables</a>
        <a href="/cotizar/" class="btn btn-outline btn-lg">Cotizar mi fiesta</a>
        <a href="https://wa.me/5531281706?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
           class="btn btn-wa btn-lg" target="_blank" rel="nofollow noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><use href="#i-wa"/></svg>
          WhatsApp
        </a>
      </div>
      <nav class="nf__links" aria-label="Páginas populares">
        <a href="/">Inicio</a>
        <a href="/precios/">Precios</a>
        <a href="/cobertura/">Cobertura</a>
        <a href="/fiestas-infantiles/">Fiestas infantiles</a>
        <a href="/preguntas-frecuentes/">Preguntas frecuentes</a>
        <a href="/blog/">Blog</a>
      </nav>
    </div>
  </section>

</PageLayout>

<style>
  .nf { padding: clamp(3rem, 8vw, 6rem) 0; }
  .nf__wrap { max-width: 640px; text-align: center; }
  .nf__code {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(4rem, 14vw, 7rem);
    line-height: 1;
    margin: 0 0 .5rem;
    background: linear-gradient(135deg, #FF3D00, #FF6B00);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .nf__title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    color: var(--c-text);
    margin: 0 0 .75rem;
  }
  .nf__text { color: var(--c-text-muted); line-height: 1.7; margin: 0 0 1.75rem; }
  .nf__ctas { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }
  .nf__links {
    display: flex; gap: .5rem 1.25rem; justify-content: center; flex-wrap: wrap;
    padding-top: 1.5rem; border-top: 1px solid var(--c-border);
  }
  .nf__links a {
    color: var(--c-primary); font-weight: 600; font-size: .9rem; text-decoration: none;
  }
  .nf__links a:hover { text-decoration: underline; }
</style>
