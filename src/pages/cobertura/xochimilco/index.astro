---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Xochimilco | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Xochimilco con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Xochimilco. Instalación profesional y precios accesibles.";

const colonias = [
  "Xochimilco Centro",
  "San Gregorio Atlapulco",
  "Tulyehualco",
  "Tepepan",
  "Santiago Tepalcatlalpan",
  "Santa Cruz Acalpixca",
  "San Lucas Xochimanca",
  "Barrio La Lupita",
  "Santa María Nativitas",
  "San Mateo Xalpa",
  "San Lorenzo Atemoaya",
  "Xochitepec"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Xochimilco?", answer: "El envío está incluido en el precio para las principales colonias de Xochimilco Centro y zonas urbanas. Para localidades más alejadas como San Andrés Ahuayucan o Santa Cruz Acalpixca puede aplicar un cargo adicional de $100-$150. Confirma tu dirección al cotizar." },
  { question: "¿Pueden instalar en jardines o espacios rurales en Xochimilco?", answer: "Sí. Xochimilco tiene una combinación de zonas urbanas y semi-rurales con terrenos amplios. Para áreas en chinampas o zonas rurales, es importante confirmar el acceso vehicular previo. Nuestro equipo lleva equipo de nivelación para terrenos irregulares." },
  { question: "¿Qué inflables son más populares para las fiestas en Xochimilco?", answer: "En Xochimilco los más rentados son los Dragones Rojos por su capacidad para grupos grandes, y el Castillo de Princesas para cumpleaños de niñas. El Inflable Extremo es muy popular para las fiestas grandes con muchos niños en los amplios espacios de la zona." },
  { question: "¿Pueden entregar en colonias como San Gregorio Atlapulco o Santiago Tulyehualco?", answer: "Sí, cubrimos toda la alcaldía Xochimilco incluyendo San Gregorio Atlapulco, Santiago Tulyehualco y las principales localidades. Para zonas más alejadas, puede aplicar un pequeño cargo de envío. Confírmanos la dirección y te informamos." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Xochimilco" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Xochimilco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Xochimilco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Xochimilco</span></h1>
          <p class="hero__desc">Renta de inflables en Xochimilco CDMX. Entrega accesible en Xochimilco Centro, San Gregorio, Tulyehualco, Tepepan y toda la alcaldía. Servicio profesional en la alcaldía chinampera.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Xochimilco es una de las alcaldías más emblemáticas de la Ciudad de México, famosa por sus chinampas, canales y tradición festiva. BRINCOLINS atiende toda la alcaldía con un cargo de envío accesible de $100 a $150. Los grandes jardines y espacios abiertos de Xochimilco son ideales para inflables de todos los tamaños.</p>
          <p class="hero__copy-text">Conocemos perfectamente los accesos a Xochimilco: la Calzada Xochimilco, el Periférico Sur y las rutas internas de los pueblos. Para colonias como San Gregorio Atlapulco y Tulyehualco, planificamos la ruta con anticipación. Instalación profesional incluida y retiro al terminar tu fiesta.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Xochimilco"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos Xochimilco Centro y todos sus pueblos y colonias circundantes. La alcaldía tiene una geografía especial con canales y zonas verdes únicas en la CDMX."
        copy2="El cargo de $100-$150 aplica para toda la alcaldía. Para pueblos más alejados como San Mateo Xalpa, el costo puede ser ligeramente mayor; confirmamos antes de la reserva."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Xochimilco"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Xochimilco salimos con anticipación para garantizar la puntualidad. Conocemos las rutas alternas para evitar el tráfico en el acceso principal de la alcaldía."
        copy2="Los pueblos de Xochimilco tienen espacios comunitarios amplios y una fuerte cultura de fiestas. Si organizas un evento grande, contáctanos para recomendarte el inflable adecuado para el espacio disponible."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$100–$150</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">En Xochimilco aplicamos un cargo de $100 a $150 de envío según la colonia y distancia desde nuestro almacén.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Xochimilco"
        subtitle="Selección perfecta para los jardines y espacios únicos de la alcaldía lacustre."
        copy1="Xochimilco tiene espacios únicos en la CDMX: desde zonas urbanas bien conectadas hasta amplias áreas semi-rurales con terrenos generosos perfectos para eventos al aire libre."
        copy2="¿Evento cerca de los canales o en una localidad específica? Confirma tu dirección exacta y te orientamos sobre el mejor inflable para tu espacio."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en Xochimilco. Alta capacidad y colores llamativos. Perfecto para los amplios jardines y espacios al aire libre de la alcaldía.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El más solicitado para cumpleaños de niñas en Xochimilco. Sus colores vibrantes destacan especialmente en los jardines verdes de la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Eventos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para las fiestas grandes de Xochimilco. El modelo de mayor capacidad de BRINCOLINS, ideal para eventos familiares y comunitarios.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Xochimilco"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Xochimilco y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Xochimilco?"
    subtitle="Cotiza tu inflable con entrega accesible en Xochimilco Centro, San Gregorio, Tulyehualco y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
