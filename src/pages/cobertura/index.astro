const faqs = [
  {
    question: "¿El costo de entrega está incluido en el precio del inflable?",
    answer: "En la mayoría de las alcaldías céntricas de la Ciudad de México, la entrega está incluida sin costo adicional: Benito Juárez, Cuauhtémoc, Miguel Hidalgo, Coyoacán, Álvaro Obregón, entre otras. Para alcaldías más alejadas y municipios del Estado de México se aplica un cargo de envío que varía según la distancia. Consúltanos por WhatsApp para confirmar el costo exacto a tu zona.",
  },
  {
    question: "¿Cuánto tiempo tardan en llegar a mi evento?",
