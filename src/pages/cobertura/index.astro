---
import PageLayout from "@/layouts/PageLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";
import ZonaCard from "@/components/ZonaCard.astro";

const title = "Zonas de Cobertura | Renta de Inflables en CDMX y Edomex — BRINCOLINS";
const description = "Renta de inflables con entrega a domicilio en las 16 alcaldías de la Ciudad de México y 15 municipios del Estado de México. Consulta precios de envío y colonias con cobertura.";

const WA = "5547868402";
const waBase = `https://wa.me/${WA}?text=`;

const alcaldias = [
  { slug: "alvaro-obregon",       emoji: "", name: "Álvaro Obregón",       description: "Entregamos en Santa Fe, San Ángel, Pedregal y todo Álvaro Obregón con instalación incluida.",       colonias: ["Santa Fe", "San Ángel", "Pedregal", "Lomas Altas"],        envio: "Incluido", gradient: "linear-gradient(135deg, #1565C0, #0288D1)" },
  { slug: "azcapotzalco",         emoji: "", name: "Azcapotzalco",          description: "Cobertura total en Del Gas, Clavería, Pasteros y colonias industriales de Azcapotzalco.",           colonias: ["Del Gas", "Clavería", "Pasteros", "Santa Bárbara"],         envio: "Incluido", gradient: "linear-gradient(135deg, #7C3AED, #9C27B0)" },
  { slug: "benito-juarez",        emoji: "", name: "Benito Juárez",          description: "Zona más solicitada. Del Valle, Narvarte, Nápoles y Portales con entrega sin costo adicional.",    colonias: ["Del Valle", "Narvarte", "Nápoles", "Portales"],             envio: "Incluido", gradient: "linear-gradient(135deg, #FF3D00, #FF6D00)" },
  { slug: "coyoacan",             emoji: "", name: "Coyoacán",               description: "Renta de inflables en Coyoacán Centro, Pedregal, Villa Coapa, Copilco y colonias aledañas.",        colonias: ["Coyoacán Centro", "Pedregal", "Villa Coapa", "Copilco"],    envio: "Incluido", gradient: "linear-gradient(135deg, #2E7D32, #00C853)" },
  { slug: "cuajimalpa",           emoji: "", name: "Cuajimalpa",             description: "Cubrimos Santa Fe, Cuajimalpa Centro, Contadero y El Molinito con puntualidad garantizada.",        colonias: ["Santa Fe", "Cuajimalpa Centro", "Contadero", "El Molinito"], envio: "Incluido", gradient: "linear-gradient(135deg, #00796B, #009688)" },
  { slug: "cuauhtemoc",           emoji: "", name: "Cuauhtémoc",            description: "Centro Histórico, Roma, Condesa y Juárez: entrega rápida en el corazón de la Ciudad de México.",   colonias: ["Centro Histórico", "Roma Norte", "Condesa", "Juárez"],      envio: "Incluido", gradient: "linear-gradient(135deg, #B71C1C, #E53935)" },
  { slug: "gustavo-a-madero",     emoji: "", name: "Gustavo A. Madero",      description: "Inflables en Lindavista, Vallejo, Tepeyac, La Villa y toda la alcaldía de GAM.",                   colonias: ["Lindavista", "Vallejo", "Tepeyac", "Aragón"],               envio: "Incluido", gradient: "linear-gradient(135deg, #E65100, #FF6F00)" },
  { slug: "iztacalco",            emoji: "", name: "Iztacalco",              description: "Entrega en Pantitlán, Agrícola Oriental, Granjas México y colonias de Iztacalco.",                  colonias: ["Pantitlán", "Agrícola Oriental", "Granjas México", "Viaducto"], envio: "Incluido", gradient: "linear-gradient(135deg, #0288D1, #01579B)" },
  { slug: "iztapalapa",           emoji: "", name: "Iztapalapa",             description: "Renta de inflables en Ermita, UAM, Santa Martha y todas las colonias de Iztapalapa.",               colonias: ["Ermita Iztapalapa", "UAM", "Santa Martha", "Peñón"],        envio: "$100–$150", gradient: "linear-gradient(135deg, #558B2F, #7CB342)" },
  { slug: "magdalena-contreras",  emoji: "", name: "Magdalena Contreras",    description: "Llegamos a La Magdalena, San Jerónimo, Barranca del Muerto y colonias de la delegación.",         colonias: ["La Magdalena", "San Jerónimo", "Barranca del Muerto", "El Rosal"], envio: "Incluido", gradient: "linear-gradient(135deg, #4A148C, #6A1B9A)" },
  { slug: "miguel-hidalgo",       emoji: "", name: "Miguel Hidalgo",         description: "Polanco, Lomas de Chapultepec, Anzures y las colonias más exclusivas de la ciudad.",               colonias: ["Polanco", "Lomas de Chapultepec", "Tacuba", "Anzures"],     envio: "Incluido", gradient: "linear-gradient(135deg, #E91E8C, #7C3AED)" },
  { slug: "milpa-alta",           emoji: "", name: "Milpa Alta",             description: "Cobertura en Milpa Alta Centro, San Pedro Atocpan y San Pablo Oztotepec con programación.",        colonias: ["Milpa Alta Centro", "San Pedro Atocpan", "San Pablo Oztotepec", "Villa Milpa Alta"], envio: "$200–$300", gradient: "linear-gradient(135deg, #827717, #F9A825)" },
  { slug: "tlahuac",              emoji: "", name: "Tláhuac",                description: "Inflables en Tláhuac Centro, La Nopalera, Zapotitla y Los Olivos con entrega programada.",         colonias: ["Tláhuac Centro", "La Nopalera", "Zapotitla", "Los Olivos"],  envio: "$100–$200", gradient: "linear-gradient(135deg, #1B5E20, #388E3C)" },
  { slug: "tlalpan",              emoji: "", name: "Tlalpan",               description: "Villa Coapa, Pedregal de San Nicolás, Ajusco y toda la alcaldía de Tlalpan.",                      colonias: ["Villa Coapa", "Pedregal de San Nicolás", "Topilejo", "Ajusco"], envio: "Incluido", gradient: "linear-gradient(135deg, #1565C0, #0D47A1)" },
  { slug: "venustiano-carranza",  emoji: "", name: "Venustiano Carranza",    description: "Jardín Balbuena, Moctezuma, Merced y colonias cercanas al aeropuerto con entrega puntual.",       colonias: ["Jardín Balbuena", "Moctezuma", "Aeropuerto", "Merced"],     envio: "Incluido", gradient: "linear-gradient(135deg, #00695C, #00897B)" },
  { slug: "xochimilco",           emoji: "", name: "Xochimilco",             description: "Renta de inflables en Xochimilco Centro, San Gregorio, Tulyehualco y Tepepan.",                   colonias: ["Xochimilco Centro", "San Gregorio", "Tulyehualco", "Tepepan"], envio: "$100–$150", gradient: "linear-gradient(135deg, #006064, #0097A7)" },
];

const municipios = [
  { slug: "naucalpan",          emoji: "", name: "Naucalpan",              description: "Satélite, Lomas Verdes, Interlomas y San Rafael: renta de inflables en el municipio más grande del poniente.",  colonias: ["Satélite", "Lomas Verdes", "Interlomas", "San Rafael"],              envio: "$150–$250", gradient: "linear-gradient(135deg, #7C3AED, #9C27B0)" },
  { slug: "tlalnepantla",       emoji: "", name: "Tlalnepantla",          description: "Entrega en Tlalnepantla Centro, Las Américas, Vallejo y zona industrial del municipio.",                        colonias: ["Centro", "Las Américas", "Vallejo", "Industrial"],                   envio: "$150–$250", gradient: "linear-gradient(135deg, #1565C0, #0288D1)" },
  { slug: "ecatepec",           emoji: "", name: "Ecatepec",               description: "Ciudad Azteca, San Cristóbal, Las Américas y todo Ecatepec con inflables entregados a domicilio.",              colonias: ["Ciudad Azteca", "Las Américas", "San Cristóbal", "Ecatepec Centro"], envio: "$200–$350", gradient: "linear-gradient(135deg, #E65100, #FF6F00)" },
  { slug: "nezahualcoyotl",     emoji: "", name: "Nezahualcóyotl",        description: "Ciudad Neza, Jardines de Morelos, Los Reyes y colonias de Nezahualcóyotl con entrega puntual.",                colonias: ["Ciudad Neza", "Jardines de Morelos", "Los Reyes", "Benito Juárez"],  envio: "$200–$300", gradient: "linear-gradient(135deg, #2E7D32, #00C853)" },
  { slug: "huixquilucan",       emoji: "", name: "Huixquilucan",           description: "La Herradura, Interlomas, Jesús del Monte: inflables para las zonas residenciales más exclusivas del Edomex.",  colonias: ["Interlomas", "La Herradura", "El Molinito", "Jesús del Monte"],      envio: "$150–$250", gradient: "linear-gradient(135deg, #E91E8C, #7C3AED)" },
  { slug: "atizapan",           emoji: "", name: "Atizapán de Zaragoza",   description: "Renta de inflables en Ciudad López Mateos, Rancho Contento y colonias de Atizapán.",                           colonias: ["Cd. López Mateos", "Rancho Contento", "Satélite", "Las Fuentes"],    envio: "$200–$300", gradient: "linear-gradient(135deg, #B71C1C, #E53935)" },
  { slug: "cuautitlan-izcalli", emoji: "", name: "Cuautitlán Izcalli",   description: "Izcalli Centro, Hacienda del Parque y Ojo de Agua con entrega programada de inflables.",                        colonias: ["Izcalli Centro", "Hacienda del Parque", "Ojo de Agua", "Cumbria"],   envio: "$250–$400", gradient: "linear-gradient(135deg, #0288D1, #01579B)" },
  { slug: "coacalco",           emoji: "", name: "Coacalco",               description: "Coacalco Centro, Bosques de Morelos y La Quebrada con inflables entregados a domicilio.",                       colonias: ["Coacalco Centro", "Bosques de Morelos", "La Quebrada", "San Crisanto"], envio: "$200–$300", gradient: "linear-gradient(135deg, #00796B, #009688)" },
  { slug: "toluca",             emoji: "", name: "Toluca",                 description: "Llegamos a Toluca Centro, San Mateo Atenco, Zinacantepec y zonas del Valle de Toluca.",                         colonias: ["Toluca Centro", "San Mateo Atenco", "Zinacantepec", "Almoloya"],     envio: "$400–$600", gradient: "linear-gradient(135deg, #4A148C, #6A1B9A)" },
  { slug: "metepec",            emoji: "", name: "Metepec",                description: "Metepec Centro, San Salvador la Gavia y Pilares: inflables para los eventos más elegantes del Valle.",          colonias: ["Metepec Centro", "San Salvador la Gavia", "Pilares", "Coaxustenco"], envio: "$400–$600", gradient: "linear-gradient(135deg, #827717, #F9A825)" },
  { slug: "texcoco",            emoji: "", name: "Texcoco",               description: "Renta de inflables en Texcoco Centro, San Miguel Coatlinchán y municipios del Oriente.",                        colonias: ["Texcoco Centro", "San Miguel Coatlinchán", "Atenco", "Chiconcuac"], envio: "$250–$400", gradient: "linear-gradient(135deg, #1B5E20, #388E3C)" },
  { slug: "chalco",             emoji: "", name: "Chalco",                 description: "Chalco Centro, Valle de Chalco y San Gregorio con entrega de inflables a domicilio en el Oriente.",             colonias: ["Chalco Centro", "Valle de Chalco", "San Gregorio", "Tlapala"],       envio: "$250–$400", gradient: "linear-gradient(135deg, #558B2F, #7CB342)" },
  { slug: "nicolas-romero",     emoji: "", name: "Nicolás Romero",         description: "Ciudad Cuauhtémoc, El Progreso y colonias de Nicolás Romero con servicio de entrega a domicilio.",              colonias: ["Nicolás Romero Centro", "Ciudad Cuauhtémoc", "El Progreso", "La Aurora"], envio: "$250–$400", gradient: "linear-gradient(135deg, #006064, #0097A7)" },
  { slug: "tecamac",            emoji: "", name: "Tecámac",                description: "Ciudad Real, Real del Sol y Tecámac Centro: inflables con entrega en el norte del Estado de México.",           colonias: ["Ciudad Real", "Real del Sol", "Tecámac Centro", "Ozumbilla"],        envio: "$250–$400", gradient: "linear-gradient(135deg, #E91E63, #C2185B)" },
  { slug: "tultitlan",          emoji: "", name: "Tultitlán",              description: "San Pablo de las Salinas, Lechería y Tultitlán Centro con inflables entregados en tiempo y forma.",             colonias: ["Tultitlán Centro", "San Pablo de las Salinas", "Lechería", "Buenavista"], envio: "$200–$300", gradient: "linear-gradient(135deg, #FF3D00, #FF6D00)" },
];

const faqs = [
  {
    question: "¿El costo de entrega está incluido en el precio del inflable?",
    answer: "En la mayoría de las alcaldías céntricas de la Ciudad de México, la entrega está incluida sin costo adicional: Benito Juárez, Cuauhtémoc, Miguel Hidalgo, Coyoacán, Álvaro Obregón, entre otras. Para alcaldías más alejadas y municipios del Estado de México se aplica un cargo de envío que varía según la distancia. Consúltanos por WhatsApp para confirmar el costo exacto a tu zona.",
  },
  {
    question: "¿Cuánto tiempo tardan en llegar a mi evento?",
    answer: "Nuestro equipo llega siempre a la hora acordada en la cotización. Para zonas céntricas de CDMX, la instalación toma entre 30 y 60 minutos desde la salida del almacén. Para zonas del Estado de México o alcaldías más alejadas, coordinamos la salida con anticipación para garantizar puntualidad absoluta.",
  },
  {
    question: "¿Puedo reservar si no aparece mi colonia en la lista?",
    answer: "¡Sí! Las colonias que mostramos son solo una muestra de nuestra cobertura. Si tu colonia no aparece, escríbenos por WhatsApp con tu dirección completa y verificamos disponibilidad. Frecuentemente cubrimos zonas adicionales sin costo extra o con un pequeño cargo de envío.",
  },
  {
    question: "¿Hacen entregas los fines de semana y días festivos?",
    answer: "Sí. Operamos los 7 días de la semana, incluyendo sábados, domingos y días festivos. De hecho, los fines de semana son nuestros días con más eventos. Solo asegúrate de reservar con anticipación ya que la disponibilidad se llena rápido, especialmente en temporada alta.",
  },
  {
    question: "¿Qué pasa si vivo en una zona sin acceso vehicular o interior de condominio?",
    answer: "No hay problema. Nuestro equipo está preparado para acceder a condominios, unidades habitacionales, jardines privados e incluso lugares con acceso restringido. Solo indícanos el tipo de acceso al momento de cotizar para coordinar el ingreso correctamente.",
  },
];

const schemaLD = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Inflables BRINCOLINS",
  "url": "https://brincolins.com/cobertura/",
  "provider": {
    "@type": "LocalBusiness",
    "name": "BRINCOLINS",
    "telephone": "+525547868402",
    "url": "https://brincolins.com",
  },
  "areaServed": [
    ...alcaldias.map(a => ({ "@type": "City", "name": a.name, "containedInPlace": { "@type": "Country", "name": "México" } })),
    ...municipios.map(m => ({ "@type": "City", "name": m.name, "containedInPlace": { "@type": "State", "name": "Estado de México" } })),
  ],
  "serviceType": "Renta de inflables para fiestas a domicilio",
  "description": "Entregamos inflables e instalamos en domicilio en las 16 alcaldías de CDMX y 15 municipios del Estado de México.",
};
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[{ name: "Inicio", href: "/" }, { name: "Cobertura" }]}
  faqItems={faqs}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Cobertura"}]} />
  </Fragment>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLD)} />

  <!--═══════════════ HERO ═══════════════ -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <!-- Col izquierda -->
        <div>
          <span class="hero__badge">Cobertura total ZMVM</span>
          <h1 class="hero__title">
            Renta de Inflables con <span class="highlight">Entrega a Domicilio</span> en CDMX y Edomex
          </h1>
          <p class="hero__desc">
            Cubrimos las <strong>16 alcaldías</strong> de la Ciudad de México y los <strong>15 principales municipios</strong> del Estado de México. Llegamos a tu evento con el inflable instalado y listo.
          </p>

          <div class="hero__ctas">
            <a href="/contacto/" class="btn btn-primary btn-lg">Consultar mi zona</a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Solicitar cotización</a>
          </div>
        </div>

        <!-- Col derecha — copy SEO -->
        <div class="hero__copy">
          <p class="hero__copy-text">
            <strong>BRINCOLINS</strong> es la empresa de renta de inflables con mayor cobertura en la <strong>Zona Metropolitana del Valle de México</strong>. Contamos con una flota de transporte especializada y rutas logísticas optimizadas para garantizar entrega puntual en las <strong>16 alcaldías de la Ciudad de México</strong>: desde <strong>Polanco y Condesa</strong> hasta <strong>Xochimilco y Tláhuac</strong>. Incluye instalación profesional, motor inflador, supervisión de seguridad y recolección al finalizar el evento.
          </p>
          <p class="hero__copy-text">
            Para el <strong>Estado de México</strong>, llegamos a <strong>Naucalpan, Tlalnepantla, Ecatepec, Huixquilucan, Nezahualcóyotl, Atizapán, Cuautitlán Izcalli, Metepec y Toluca</strong>, entre otros municipios. Entrega de lunes a domingo, incluyendo días festivos. Reserva con mínimo 24 horas de anticipación y recibe confirmación inmediata vía WhatsApp.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ ALCALDÍAS CDMX ═══════════════ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Ciudad de México"
        title="Las 16 Alcaldías de CDMX"
        subtitle="Cobertura total en la Ciudad de México. Entrega incluida en la mayoría de las zonas."
        copy1="Cubrimos las 16 alcaldías de la Ciudad de México sin excepción. En las alcaldías céntricas como Benito Juárez, Cuauhtémoc, Miguel Hidalgo, Coyoacán y Álvaro Obregón, el costo de entrega está incluido en el precio del inflable. Lleva el inflable directamente a tu domicilio, jardín, salón o espacio del evento."
        copy2="Cada alcaldía tiene sus propias colonias y particularidades logísticas. Haz clic en tu alcaldía para ver las colonias con cobertura, tiempos estimados de entrega, costos y los inflables más solicitados en esa zona."
      />

      <div class="grid-4">
        {alcaldias.map(a => (
          <ZonaCard
            slug={a.slug}
            emoji={a.emoji}
            name={a.name}
            description={a.description}
            colonias={a.colonias}
            envio={a.envio}
            gradient={a.gradient}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ MUNICIPIOS EDOMEX ═══════════════ -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Estado de México"
        title="15 Municipios del Estado de México"
        subtitle="También llegamos a los principales municipios del Edomex con entrega programada."
        copy1="Nuestra cobertura en el Estado de México abarca los 15 municipios con mayor densidad de población y actividad económica de la entidad. Desde la zona poniente (Naucalpan, Huixquilucan, Atizapán) hasta la zona oriente (Ecatepec, Nezahualcóyotl, Chalco, Texcoco), llegamos a tu evento con el mismo nivel de servicio."
        copy2="Para municipios del Edomex se aplica un cargo de envío adicional que varía según la distancia desde nuestro almacén central en CDMX. El tiempo de entrega es mayor, por lo que recomendamos coordinar la salida con al menos 2-3 horas de anticipación al inicio del evento."
      />

      <div class="grid-4">
        {municipios.map(m => (
          <ZonaCard
            slug={m.slug}
            emoji={m.emoji}
            name={m.name}
            description={m.description}
            colonias={m.colonias}
            envio={m.envio}
            gradient={m.gradient}
            tipo="edomex"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ COSTOS DE ENVÍO ═══════════════ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Costos de envío"
        title="¿Cuánto cuesta la entrega?"
        subtitle="Entrega gratuita en zonas céntricas de CDMX. Cargo adicional en zonas alejadas y Edomex."
        copy1="Nuestro objetivo es que el costo de envío nunca sea una barrera para rentar un inflable. Por eso ofrecemos entrega gratuita en todas las alcaldías céntricas de la Ciudad de México. Para zonas más alejadas, el cargo es mínimo y siempre transparente antes de confirmar tu reserva."
        copy2="El precio del envío depende de la distancia a tu domicilio desde nuestro almacén. Al cotizar por WhatsApp, te informamos el costo exacto de inmediato. Sin sorpresas, sin cargos ocultos."
      />

      <div class="grid-3" style="max-width:960px; margin:0 auto;">
        <div class="envio-card">
          <div class="envio-card__icon" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            
          </div>
          <h3 class="envio-card__title">Zona A — Gratis</h3>
          <p class="envio-card__precio">$0 MXN</p>
          <p class="envio-card__desc">Alcaldías céntricas de CDMX: Benito Juárez, Cuauhtémoc, Miguel Hidalgo, Coyoacán, Álvaro Obregón, Azcapotzalco, Venustiano Carranza, Cuajimalpa, GAM, Iztacalco, Tlalpan y Magdalena Contreras.</p>
        </div>
        <div class="envio-card">
          <div class="envio-card__icon" style="background:linear-gradient(135deg,#FF6F00,#E65100);">
            
          </div>
          <h3 class="envio-card__title">Zona B — Bajo costo</h3>
          <p class="envio-card__precio">$100–$300 MXN</p>
          <p class="envio-card__desc">Alcaldías alejadas de CDMX (Iztapalapa, Tláhuac, Xochimilco, Milpa Alta) y municipios cercanos de Edomex: Naucalpan, Tlalnepantla, Huixquilucan, Coacalco, Tultitlán.</p>
        </div>
        <div class="envio-card">
          <div class="envio-card__icon" style="background:linear-gradient(135deg,#FF3D00,#B71C1C);">
            
          </div>
          <h3 class="envio-card__title">Zona C — Edomex lejano</h3>
          <p class="envio-card__precio">$300–$600 MXN</p>
          <p class="envio-card__desc">Municipios más alejados del Edomex: Ecatepec, Nezahualcóyotl, Chalco, Texcoco, Toluca, Metepec, Nicolás Romero, Tecámac, Cuautitlán Izcalli y Atizapán.</p>
        </div>
      </div>

      <p style="text-align:center; margin-top:2rem; color:var(--c-text-muted); font-size:.9rem;">
        * Los precios de envío son aproximados. El costo exacto se confirma al cotizar según tu dirección específica.
      </p>
    </div>
  </section>

  <!-- ═══════════════ CTA BANNER ═══════════════ -->
  <CtaBanner
    title="¿Tu zona tiene cobertura?"
    subtitle="Escríbenos tu colonia y te confirmamos disponibilidad, precio de envío y fecha al instante."
    btnText="Consultar por WhatsApp"
    btnHref={`${waBase}${encodeURIComponent("Hola BRINCOLINS, quiero saber si entregan en mi zona y el costo de envío.")}`}
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

  <!-- ═══════════════ FAQ ═══════════════ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Preguntas frecuentes"
        title="Dudas sobre cobertura y envío"
        subtitle="Todo lo que necesitas saber sobre nuestra logística de entrega."
        copy1="La entrega puntual es uno de nuestros principales compromisos. Sabemos que tu fiesta tiene un horario fijo y no podemos fallar. Por eso contamos con rutas optimizadas y personal dedicado a la logística de cada evento."
        copy2="Si tienes alguna duda que no está aquí resuelta, escríbenos directamente por WhatsApp. Nuestro equipo responde en minutos con información precisa sobre tu zona y disponibilidad."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

</PageLayout>

