    "name": "BRINCOLINS",
    "telephone": "+525547868402",
    "url": "https://brincolins.com",
  },
  "areaServed": [
    ...alcaldias.map(a => ({ "@type": "City", "name": a.name, "containedInPlace": { "@type": "Country", "name": "México" } })),
