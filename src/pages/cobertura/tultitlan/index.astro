---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Tultitlán | BRINCOLINS";
const description = "Renta de inflables en Tultitlán, Edomex. Entrega incluida en Tultitlán Centro, San Mateo y Buenavista. Desde $800 MXN con instalación y seguro.";

const colonias = [
  "Tultitlán Centro",
  "San Pablo de las Salinas",
  "Lechería",
  "Buenavista",
  "Cuautitlán",
  "Lomas de San Sebastián",
  "San Mateo Cuautepec",
  "Miguel Hidalgo",
  "Los Reyes Acaquilpan",
  "San Francisco Chilpan",
  "El Triunfo",
  "Santa Ana Tlacotenco"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Tultitlán?", answer: "El cargo de envío para Tultitlán es de $200 a $300. El monto exacto se informa al cotizar según tu colonia." },
  { question: "¿Qué inflables son más populares en Tultitlán?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Tultitlán?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Tultitlán." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Tultitlán" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Tultitlán</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Tultitlán</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Tultitlán</span></h1>
          <p class="hero__desc">Renta de inflables en Tultitlán, Estado de México. Entrega en Tultitlán Centro, San Pablo de las Salinas, Lechería, Buenavista y todo el municipio. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Tultitlán es un municipio industrial y residencial del norte del Estado de México con una fuerte demanda de servicios para eventos familiares. BRINCOLINS cubre Tultitlán con un cargo de $200 a $300 y servicio profesional. Atendemos Tultitlán Centro, San Pablo de las Salinas, Lechería y todas las colonias.</p>
          <p class="hero__copy-text">La autopista Chamapa-Lechería y el Periférico Norte son nuestras rutas principales para Tultitlán. Conocemos los accesos de los principales conjuntos habitacionales y colonias del municipio. Instalación profesional y retiro incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Tultitlán"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Tultitlán de Mariano Escobedo, desde el Centro hasta las colonias industriales y residenciales del municipio."
        copy2="El cargo de $200-$300 aplica para todo Tultitlán. Para colonias en los límites con Cuautitlán Izcalli o Coacalco, el costo puede variar ligeramente."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Tultitlán"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Tultitlán tiene excelentes vías de acceso: autopista Chamapa, Periférico Norte y carretera federal. Esto nos permite llegar puntualmente desde nuestro almacén."
        copy2="Los eventos en Tultitlán son frecuentes los fines de semana en colonias como Lechería y San Pablo de las Salinas. Reserva con anticipación para garantizar disponibilidad."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$300</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $300 para Tultitlán según la colonia y distancia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Tultitlán"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Tultitlán y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Tultitlán?"
    subtitle="Cotiza tu inflable con entrega en Tultitlán Centro, San Pablo de las Salinas, Lechería y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />
</PageLayout>
