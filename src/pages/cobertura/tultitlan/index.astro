---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Tultitlán | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Tultitlán con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Tultitlán. Instalación profesional y precios accesibles.";

const colonias = [
  "Tultitlán Centro",
  "San Pablo de las Salinas",
  "Lechería",
  "Buenavista",
  "Cuautitlán",
  "Lomas de San Sebastián",
  "San Mateo Cuautepec",
  "Miguel Hidalgo",
  "Los Reyes Acaquilpan",
  "San Francisco Chilpan",
  "El Triunfo",
  "Santa Ana Tlacotenco"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Tultitlán?", answer: "El cargo de envío a Tultitlán varía entre $150 y $250 dependiendo de la colonia. Tultitlán Centro, San Pablo de las Salinas y Lechería tienen el cargo base. Para colonias más al norte o alejadas, puede ser ligeramente mayor." },
  { question: "¿Cubren San Pablo de las Salinas y Buenavista en Tultitlán?", answer: "Sí, cubrimos toda la extensión de Tultitlán incluyendo San Pablo de las Salinas, Buenavista, Lechería, Tultitlán Centro y todas las colonias del municipio. El cargo de envío aplica por ser Edomex." },
  { question: "¿Pueden entregar en fraccionamientos y unidades habitacionales de Tultitlán?", answer: "Sí. Tultitlán tiene varios desarrollos habitacionales bien consolidados. Para los que tienen acceso controlado, coordinamos el registro de nuestro vehículo con 24h de anticipación." },
  { question: "¿Qué inflables recomiendan para eventos en Tultitlán?", answer: "Los Dragones Rojos y el Inflable Extremo son los más solicitados en Tultitlán por su alta capacidad para grupos numerosos de niños. Para fiestas de niñas, el Castillo de Princesas es el favorito. Tenemos modelos para todo tipo de espacio y presupuesto." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Tultitlán" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Tultitlán</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Tultitlán</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Tultitlán</span></h1>
          <p class="hero__desc">Renta de inflables en Tultitlán, Estado de México. Entrega en Tultitlán Centro, San Pablo de las Salinas, Lechería, Buenavista y todo el municipio. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Tultitlán es un municipio industrial y residencial del norte del Estado de México con una fuerte demanda de servicios para eventos familiares. BRINCOLINS cubre Tultitlán con un cargo de $200 a $300 y servicio profesional. Atendemos Tultitlán Centro, San Pablo de las Salinas, Lechería y todas las colonias.</p>
          <p class="hero__copy-text">La autopista Chamapa-Lechería y el Periférico Norte son nuestras rutas principales para Tultitlán. Conocemos los accesos de los principales conjuntos habitacionales y colonias del municipio. Instalación profesional y retiro incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Tultitlán"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Tultitlán de Mariano Escobedo, desde el Centro hasta las colonias industriales y residenciales del municipio."
        copy2="El cargo de $200-$300 aplica para todo Tultitlán. Para colonias en los límites con Cuautitlán Izcalli o Coacalco, el costo puede variar ligeramente."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Tultitlán"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Tultitlán tiene excelentes vías de acceso: autopista Chamapa, Periférico Norte y carretera federal. Esto nos permite llegar puntualmente desde nuestro almacén."
        copy2="Los eventos en Tultitlán son frecuentes los fines de semana en colonias como Lechería y San Pablo de las Salinas. Reserva con anticipación para garantizar disponibilidad."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$300</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $300 para Tultitlán según la colonia y distancia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Tultitlán"
        subtitle="Los favoritos para fiestas familiares en San Pablo de las Salinas, Lechería y toda la zona."
        copy1="Tultitlán es un municipio del norte del Edomex en crecimiento constante, con familias que demandan inflables para fiestas de cumpleaños, XV años y kermeses escolares."
        copy2="¿Fraccionamiento o colonia específica en Tultitlán? Confirma tu dirección y te calculamos el costo exacto de envío y disponibilidad."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Tultitlán. Alta capacidad y colores vibrantes para fiestas familiares en San Pablo de las Salinas y Lechería.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Grupos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para eventos con muchos niños en Tultitlán. El circuito de obstáculos más completo de BRINCOLINS para kermeses y fiestas grandes.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">La elección preferida para cumpleaños de niñas en Tultitlán. Diseño temático y colorido que hace brillar cualquier celebración en la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Tultitlán"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Tultitlán y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Tultitlán?"
    subtitle="Cotiza tu inflable con entrega en Tultitlán Centro, San Pablo de las Salinas, Lechería y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
