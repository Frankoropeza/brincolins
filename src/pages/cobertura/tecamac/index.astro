---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Tecámac | BRINCOLINS";
const description = "Renta de inflables en Tecámac, Edomex. Entrega incluida en Ojo de Agua, Los Héroes y Tecámac Centro. Desde $800 MXN con instalación y seguro.";

const colonias = [
  "Ciudad Real",
  "Real del Sol",
  "Tecámac Centro",
  "Ozumbilla",
  "San Pedro Atzompa",
  "Tonanitla",
  "Santa Cruz Tecámac",
  "Los Héroes Tecámac",
  "San Juan Pueblo Nuevo",
  "Hacienda La Trinidad",
  "Real Minas",
  "Bosques del Valle"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Tecámac?", answer: "El cargo de envío a Tecámac varía entre $200 y $350 dependiendo de la colonia. Ciudad Real, Real del Sol y Tecámac Centro tienen el cargo base. Ozumbilla y colonias más alejadas al norte pueden tener un costo ligeramente mayor." },
  { question: "¿Pueden entregar en los fraccionamientos nuevos de Ciudad Real y Real del Sol?", answer: "Sí. Ciudad Real y Real del Sol son fraccionamientos modernos con accesos bien definidos. Conocemos la vialidad de la zona y tenemos experiencia entregando en ambos desarrollos. Para casetas de seguridad, coordinamos el registro con 24h de anticipación." },
  { question: "¿Qué inflables funcionan mejor en los fraccionamientos de Tecámac?", answer: "Los fraccionamientos de Tecámac tienen áreas comunes y jardines bien planeados. Los Dragones Rojos y el Castillo de Princesas son los más solicitados. Para áreas comunes más amplias, el Inflable Extremo es perfecto para grupos de 20+ niños." },
  { question: "¿Con cuánta anticipación hay que reservar para Tecámac?", answer: "Recomendamos reservar con 2-3 semanas de anticipación. Tecámac tiene alta demanda los fines de semana, especialmente en los fraccionamientos nuevos. En temporadas altas, reserva con un mes para garantizar disponibilidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Tecámac" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Tecámac</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Tecámac</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Tecámac</span></h1>
          <p class="hero__desc">Renta de inflables en Tecámac, Estado de México. Entrega en Ciudad Real, Real del Sol, Tecámac Centro, Ozumbilla y todo el municipio. Servicio profesional garantizado.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Tecámac es uno de los municipios con mayor crecimiento del norte del Estado de México, con grandes conjuntos habitacionales como Ciudad Real y Real del Sol que concentran miles de familias con alta demanda de servicios para eventos. BRINCOLINS cubre Tecámac con un cargo de $250 a $400 y servicio profesional de instalación.</p>
          <p class="hero__copy-text">La autopista México-Pachuca es nuestra ruta principal para llegar a Tecámac. Conocemos los accesos de Ciudad Real, Real del Sol y los principales conjuntos del municipio. Instalación profesional y retiro incluidos. Reserva con anticipación para fines de semana.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Tecámac"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Tecámac, incluyendo los grandes conjuntos habitacionales de Ciudad Real y Real del Sol, además del Centro y los pueblos del municipio."
        copy2="El cargo de $250-$400 aplica para todo el municipio. Para los conjuntos más alejados del norte del municipio, el costo puede ser el extremo superior del rango."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Tecámac"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="La autopista México-Pachuca nos da acceso directo a Tecámac. Salimos con suficiente anticipación para compensar el tráfico de la zona norte."
        copy2="Los grandes conjuntos habitacionales de Tecámac tienen áreas comunes y jardines ideales para eventos con inflables. Para accesos con caseta, coordinamos previamente."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$250–$400</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $250 a $400 para Tecámac según la colonia y distancia desde nuestro almacén.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Tecámac"
        subtitle="Selección perfecta para los modernos fraccionamientos de Ciudad Real y Real del Sol."
        copy1="Tecámac es uno de los municipios de mayor crecimiento en el norte del Edomex, con fraccionamientos modernos como Ciudad Real y Real del Sol con espacios bien planeados para eventos."
        copy2="¿Fraccionamiento con caseta de seguridad? Registramos nuestro vehículo con 24h de anticipación para garantizar una entrega sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en los fraccionamientos de Tecámac. Alta capacidad para grupos de niños en las áreas comunes y jardines de Ciudad Real y Real del Sol.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">La elección preferida para cumpleaños de niñas en Tecámac. Colores vibrantes y diseño temático que destaca en los jardines de la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Áreas comunes grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para las áreas comunes amplias en los fraccionamientos de Tecámac. El modelo de mayor capacidad para eventos con muchos niños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Tecámac"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Tecámac y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Tecámac?"
    subtitle="Cotiza tu inflable con entrega en Ciudad Real, Real del Sol, Tecámac Centro y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
