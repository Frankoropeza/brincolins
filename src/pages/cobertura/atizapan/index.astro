---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Atizapán de Zaragoza | BRINCOLINS";
const description = "Renta de inflables en Atizapán de Zaragoza, Edomex. Entrega incluida en Lomas de Atizapán, Ciudad López Mateos y Chiluca. Desde $800 MXN.";

const colonias = [
  "Cd. López Mateos",
  "Rancho Contento",
  "Satélite",
  "Las Fuentes",
  "La Loma",
  "Bosque del Lago",
  "San Andrés Atenco",
  "Jilotzingo",
  "El Arenal",
  "Mirasol",
  "Las Huertas",
  "Santa Mónica"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Atizapán de Zaragoza?", answer: "El cargo de envío a Atizapán varía entre $150 y $250 dependiendo de la colonia. Ciudad López Mateos, Rancho Contento y Las Fuentes tienen el cargo base. Colonias más alejadas pueden tener un costo mayor. Te confirmamos al cotizar." },
  { question: "¿Pueden entregar en fraccionamientos cerrados de Atizapán?", answer: "Sí. Tenemos experiencia entregando en los fraccionamientos cerrados de Atizapán. Solo necesitamos los datos del residente y el nombre del fraccionamiento para registrar nuestro vehículo con 24h de anticipación en la caseta de seguridad." },
  { question: "¿Cubren Ciudad López Mateos completo?", answer: "Sí, toda Ciudad López Mateos — desde las colonias más cercanas al Boulevard hasta las más alejadas — está dentro de nuestra cobertura en Atizapán. El cargo de envío se aplica por ser municipio del Estado de México." },
  { question: "¿Con cuánta anticipación reservar para Atizapán en temporada alta?", answer: "Recomendamos reservar con 2-3 semanas de anticipación para fines de semana normales. En temporada alta (Semana Santa, verano, diciembre) la disponibilidad se llena rápido — reserva con un mes de margen para garantizar tu fecha." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Atizapán de Zaragoza" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Atizapán de Zaragoza</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Atizapán de Zaragoza</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Atizapán de Zaragoza</span></h1>
          <p class="hero__desc">Renta de inflables en Atizapán de Zaragoza, Edomex. Entrega en Ciudad López Mateos, Rancho Contento, Satélite, Las Fuentes y todo el municipio. Servicio profesional garantizado.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Atizapán de Zaragoza es un municipio residencial del Estado de México con zonas como Ciudad López Mateos, Rancho Contento y colonias satelitales de alta demanda de servicios para eventos. BRINCOLINS cubre todo Atizapán con un cargo de envío de $200 a $300 y servicio profesional de instalación.</p>
          <p class="hero__copy-text">El municipio tiene acceso por la autopista México-Querétaro y el Boulevard Manuel Ávila Camacho. Conocemos las rutas y los accesos de los fraccionamientos de la zona. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Atizapán de Zaragoza"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Atizapán de Zaragoza, incluyendo Ciudad López Mateos, Rancho Contento y las colonias residenciales de la parte norte del municipio."
        copy2="Para colonias en zonas más elevadas o con acceso por carretera secundaria, confirmamos el acceso al momento de cotizar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Atizapán de Zaragoza"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Atizapán utilizamos la autopista México-Querétaro como ruta principal. Planificamos la salida con anticipación para compensar el tráfico de la zona."
        copy2="Ciudad López Mateos y Satélite tienen excelente infraestructura vial. Para colonias más internas del municipio, usamos rutas secundarias que conocemos bien."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$300</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $300 para Atizapán de Zaragoza según la colonia y distancia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Atizapán"
        subtitle="Los favoritos para fiestas en Ciudad López Mateos, Rancho Contento y toda la zona."
        copy1="Atizapán de Zaragoza tiene una mezcla de colonias residenciales clásicas y fraccionamientos modernos con jardines bien establecidos, perfectos para inflables de todos los tamaños."
        copy2="¿Fraccionamiento con caseta de seguridad? Coordina el registro de nuestro vehículo con 24h de anticipación y garantizamos una entrega sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en Atizapán. Funciona perfecto en los jardines de Ciudad López Mateos y Rancho Contento. Alta capacidad y gran diversión.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El más solicitado para fiestas de niñas en toda Atizapán. Colores vibrantes y diseño temático que hace brillar cualquier cumpleaños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Eventos premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">Para los eventos más cuidados en Atizapán. Diseño neutro y elegante que combina con cualquier decoración en fraccionamientos residenciales.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Atizapán de Zaragoza"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Atizapán de Zaragoza y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Atizapán de Zaragoza?"
    subtitle="Cotiza tu inflable con entrega en Ciudad López Mateos, Rancho Contento, Satélite y todo Atizapán."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
