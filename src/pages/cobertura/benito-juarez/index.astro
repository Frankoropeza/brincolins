---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Benito Juárez | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Benito Juárez con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Benito Juárez. Instalación profesional y precios accesibles.";

const colonias = [
  "Del Valle",
  "Narvarte Oriente",
  "Narvarte Poniente",
  "Nápoles",
  "Portales Norte",
  "Portales Oriente",
  "Álamos",
  "Insurgentes Mixcoac",
  "Independencia",
  "Piedad Narvarte",
  "Florida",
  "Extremadura Insurgentes"
];

const faqs = [
  { question: "¿Pueden instalar inflables en edificios con azotea en Narvarte o Del Valle?", answer: "Sí, es una solicitud muy frecuente en Benito Juárez. Necesitamos acceso al elevador de servicio, una toma de 110V a menos de 5m y mínimo 3×3m libres. Evaluamos el espacio vía foto por WhatsApp antes de confirmar la reserva." },
  { question: "¿Pueden entregar en edificios con portería o acceso controlado en Benito Juárez?", answer: "Sí, tenemos amplia experiencia en los edificios con portería de Del Valle, Narvarte e Insurgentes. Solo necesitamos el nombre del residente y el número de departamento para coordinar la entrada de nuestro equipo con 24h de anticipación." },
  { question: "¿Qué inflable funciona mejor en departamentos pequeños con terraza en Portales?", answer: "Para departamentos con terraza compacta en Portales y Álamos recomendamos el Mini Castillo (3×3m) o los Gusanitos para bebés. Evaluamos vía foto del espacio antes de confirmar. Si la terraza mide menos de 2.5×2.5m, puede que ningún inflable sea seguro." },
  { question: "¿Cuánto tiempo antes debo reservar en Benito Juárez?", answer: "Benito Juárez es nuestra zona de mayor demanda en CDMX — los fines de semana se agotan rápido. Reserva con al menos 2 semanas de anticipación. En temporadas altas (Semana Santa, verano, diciembre) reserva con 3 semanas para garantizar disponibilidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Benito Juárez" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Benito Juárez</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Benito Juárez</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Benito Juárez</span></h1>
          <p class="hero__desc">Llevamos inflables y brincolines a la alcaldía Benito Juárez: Del Valle, Narvarte, Nápoles, Portales, Insurgentes y más. Zona con mayor demanda en CDMX — envío gratis y servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La alcaldía Benito Juárez es nuestra zona de mayor demanda en toda la Ciudad de México. Del Valle, Narvarte e Insurgentes concentran una enorme cantidad de eventos infantiles, fiestas de cumpleaños y reuniones familiares que requieren inflables de calidad. BRINCOLINS conoce perfectamente las calles, los accesos de los edificios y las áreas comunes de toda la alcaldía.</p>
          <p class="hero__copy-text">Cada entrega en Benito Juárez incluye traslado, instalación profesional y retiro, todo sin costo de envío. Nuestros inflables están certificados y desinfectados. Atendemos desde pequeños departamentos con azotea hasta grandes jardines en Del Valle y Portales. Reserva con anticipación — Benito Juárez se agenda rápido los fines de semana.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Benito Juárez"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Benito Juárez es la alcaldía con más solicitudes de renta de inflables en la CDMX. Cubrimos todas sus colonias, desde las más céntricas hasta las más alejadas del Periférico."
        copy2="¿Tu colonia no aparece? Escríbenos — todas las colonias dentro de Benito Juárez tienen envío incluido sin excepción."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Benito Juárez"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Benito Juárez tiene buena conectividad vial: Insurgentes, Periférico y el Viaducto nos permiten llegar rápidamente desde nuestro almacén. En horas pico programamos rutas alternas para cumplir el horario acordado."
        copy2="Para eventos en edificios o condominios, coordinamos el acceso con portería. Solo necesitamos el nombre del residente y el número de departamento para coordinar la entrada del equipo de instalación."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío completamente incluido en el precio para todas las colonias de Benito Juárez. Es nuestra zona de mayor demanda y operamos sin cargo adicional.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Benito Juárez"
        subtitle="Modelos para todo tipo de espacio: azoteas en Narvarte, jardines en Del Valle y patios en Portales."
        copy1="Benito Juárez es nuestra alcaldía de mayor demanda. La diversidad de espacios — desde terrazas compactas en Narvarte hasta amplios jardines en Del Valle — requiere inflables de diferentes tamaños."
        copy2="¿Azotea, terraza o jardín? Cuéntanos las medidas de tu espacio y te decimos exactamente qué modelo funciona para tu evento en Benito Juárez."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado BJ</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El más solicitado en Del Valle y Narvarte. Ocupa 5×4m y es ideal para jardines en casas o áreas comunes de condominios en Benito Juárez.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El hit para cumpleaños de niñas en Portales, Álamos e Insurgentes. Colores vivos que hacen brillar cualquier festejo en Benito Juárez.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/mini-castillo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#7C3AED,#9C27B0);">
            <span class="inflable-rec-card__tag">Azoteas y terrazas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Mini Castillo</h3>
            <p class="inflable-rec-card__desc">El modelo para terrazas y azoteas de los edificios en Narvarte y Del Valle. Solo 3×3m de base. El más fácil de instalar en espacios reducidos.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Benito Juárez"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Benito Juárez y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Benito Juárez?"
    subtitle="Cotiza tu inflable con envío gratis en Del Valle, Narvarte, Nápoles, Portales y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
