---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Renta de Inflables en Naucalpan y Satélite | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Naucalpan y Satélite con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Naucalpan y Satélite. Instalación profesional y precios accesibles.";

const colonias = [
  "Ciudad Satélite", "Interlomas", "Lomas Verdes", "Echegaray",
  "Valle Dorado", "San Mateo", "La Florida", "Las Américas",
  "Jardines de San Mateo", "Club de Golf Bellavista",
  "Lomas de Tecamachalco", "Hacienda de Echegaray",
];

const faqs = [
  { question: "¿Cuánto cuesta el envío de inflables a Naucalpan?", answer: "La entrega en las principales colonias de Naucalpan (Satélite, Echegaray, Lomas Verdes, Valle Dorado) está incluida en el precio del inflable. No cobramos flete adicional para estas zonas." },
  { question: "¿Atienden eventos en Interlomas y Lomas de Tecamachalco?", answer: "Sí, Interlomas y Lomas de Tecamachalco están dentro de nuestra zona de cobertura con entrega sin costo. Conocemos los accesos de los principales fraccionamientos y condominios de la zona." },
  { question: "¿Pueden instalar en salones de eventos de Ciudad Satélite?", answer: "Por supuesto. Hemos trabajado en múltiples salones de eventos de Satélite y alrededores. Coordinamos con el personal del salón para cumplir sus reglamentos de acceso y horarios." },
  { question: "¿Cuánto tiempo antes debo reservar para un evento en Naucalpan?", answer: "Recomendamos reservar con al menos 1-2 semanas de anticipación, especialmente para fines de semana. En temporada alta (abril-junio y noviembre-diciembre) sugerimos 3-4 semanas de anticipación para garantizar disponibilidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura" },
    { name: "Naucalpan" },
  ]}
  faqItems={faqs}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Naucalpan</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Naucalpan</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Naucalpan, Satélite e Interlomas</span></h1>
          <p class="hero__desc">Llevamos inflables y brincolines a todo Naucalpan de Juárez: Ciudad Satélite, Interlomas, Lomas Verdes, Echegaray y más. Entrega incluida y servicio profesional garantizado.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">
              Solicitar cotización
            </a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Naucalpan de Juárez es uno de los municipios con mayor demanda de renta de inflables en el Estado de México. Colonias como Ciudad Satélite, Echegaray y Lomas Verdes cuentan con amplios jardines y espacios residenciales perfectos para instalar brincolines de todos los tamaños. Interlomas y Lomas de Tecamachalco, por su parte, tienen fraccionamientos modernos con áreas comunes ideales para eventos.</p>
          <p class="hero__copy-text">Nuestro equipo de logística tiene rutas optimizadas para llegar a cualquier punto de Naucalpan con puntualidad. Conocemos los accesos de los principales fraccionamientos cerrados, las regulaciones de los condominios y los horarios permitidos de carga y descarga en cada zona. Tu inflable llega a tiempo, se instala profesionalmente y se retira al finalizar el evento.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias que cubrimos en Naucalpan"
        subtitle="Entrega directa en estas zonas."
        copy1="Cubrimos las colonias más importantes de Naucalpan de Juárez, desde las zonas residenciales de Satélite y Echegaray hasta los desarrollos modernos de Interlomas. Cada entrega incluye instalación profesional y retiro al finalizar."
        copy2="Si tu colonia no aparece en la lista pero está dentro del municipio de Naucalpan o zonas aledañas como Huixquilucan o Atizapán, contáctanos. Es muy probable que podamos atenderte sin costo adicional de envío."
      />
      <div class="coverage__badges">
        {colonias.map(z => <span class="coverage__badge">{z}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Información de entrega en Naucalpan"
        subtitle="Todo lo que necesitas saber sobre nuestro servicio."
        copy1="Naucalpan tiene la ventaja de estar muy bien conectado con la Ciudad de México a través de las autopistas México-Toluca y Chamapa. Esto nos permite garantizar tiempos de entrega competitivos incluso en horas de alta demanda vial."
        copy2="Para eventos en fraccionamientos cerrados como los de Interlomas o Club de Golf Bellavista, coordinamos previamente el acceso con la caseta de seguridad. Solo necesitamos los datos del residente y el nombre del fraccionamiento para gestionar la entrada de nuestro equipo."
      />
      <div class="grid-3" style="max-width:900px; margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Entrega sin costo</h3>
            <p class="why-card__desc">En colonias principales de Naucalpan y Satélite.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Naucalpan"
        subtitle="Selección perfecta para los espacios de Satélite, Interlomas y Lomas Verdes."
        copy1="Naucalpan tiene una mezcla única: residencias clásicas en Ciudad Satélite con jardines generosos, y desarrollos modernos en Interlomas con áreas comunes y salones de eventos. Tenemos inflables para cada tipo."
        copy2="¿Evento en fraccionamiento cerrado en Interlomas o Club de Golf? Coordinamos el acceso con anticipación — solo necesitamos los datos del residente."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Estética premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">El favorito en las residencias de Satélite e Interlomas. Diseño elegante y neutro que combina con cualquier decoración de evento en zonas residenciales de Naucalpan.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El inflable más solicitado en todo Naucalpan. Perfecto para los jardines amplios de Lomas Verdes y Valle Dorado. Grupos grandes de niños, garantía total.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Eventos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para kermeses en Satélite o eventos en clubes de Naucalpan. El modelo de mayor capacidad con circuito de obstáculos para muchos niños simultáneamente.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Naucalpan"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Naucalpan es uno de los municipios que más atendemos en el Estado de México. A lo largo de los años hemos resuelto todo tipo de situaciones logísticas en la zona, desde instalaciones en roof gardens de Interlomas hasta eventos en parques de Satélite."
        copy2="Estas son las preguntas más frecuentes que recibimos de clientes en Naucalpan. Si la tuya no aparece aquí, escríbenos por WhatsApp y te respondemos en minutos."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Naucalpan o Satélite?"
    subtitle="Cotiza tu inflable con entrega gratuita en todo el municipio de Naucalpan."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
