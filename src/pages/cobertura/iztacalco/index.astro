---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Iztacalco | BRINCOLINS";
const description = "Renta de inflables en Iztacalco, CDMX. Entrega incluida en Pantitlán, Agrícola Oriental y Granjas México. Desde $800 MXN con seguro. Cotiza hoy.";

const colonias = [
  "Pantitlán",
  "Agrícola Oriental",
  "Granjas México",
  "Viaducto Piedad",
  "Jardín Balbuena",
  "Militar Marte",
  "Campamento 2 de Octubre",
  "Infonavit Iztacalco",
  "La Viga",
  "Agrícola Pantitlán",
  "Zapotla",
  "Gabriel Ramos Millán"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Iztacalco?", answer: "El envío está completamente incluido en el precio para todas las colonias de Iztacalco: Agrícola Oriental, Jardín Balbuena, Canal de Sur, Viaducto Piedad, La Asunción y todas las demás. Sin cargos adicionales." },
  { question: "¿Pueden entregar inflables en unidades habitacionales de Iztacalco?", answer: "Sí. Atendemos regularmente a clientes en las unidades habitacionales de Iztacalco. Coordinamos el acceso con la administración del conjunto para los horarios de carga y descarga, y la autorización del uso del área común o jardín." },
  { question: "¿Cubren la zona de Jardín Balbuena y Viaducto Piedad?", answer: "Sí. Jardín Balbuena, Viaducto Piedad y toda la alcaldía Iztacalco están cubiertos con entrega sin costo adicional. Son zonas con buena conectividad vial que nos permiten llegar puntualmente." },
  { question: "¿Qué inflables recomiendan para eventos en Iztacalco con muchos niños?", answer: "Para eventos con muchos niños en Iztacalco, los Dragones Rojos y el Inflable Extremo son los más solicitados por su alta capacidad (6-8 niños simultáneos). Para niños menores de 5 años, los Gusanitos son perfectos y seguros." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Iztacalco" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Iztacalco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Iztacalco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Iztacalco</span></h1>
          <p class="hero__desc">Renta de inflables en Iztacalco CDMX. Entrega incluida en Pantitlán, Agrícola Oriental, Granjas México, Viaducto y toda la alcaldía. Instalación profesional garantizada.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Iztacalco es una alcaldía estratégicamente ubicada en el oriente de la CDMX, colindante con Iztapalapa, Venustiano Carranza y Benito Juárez. BRINCOLINS cubre toda la alcaldía con entregas puntuales en Pantitlán, Agrícola Oriental, Granjas México y el Viaducto. Conocemos las rutas más eficientes para llegar a tiempo.</p>
          <p class="hero__copy-text">Las colonias de Iztacalco combinan zonas populares con áreas más residenciales cerca del Viaducto. Tenemos inflables para todos los espacios: desde patios pequeños hasta jardines amplios en Granjas México. Envío incluido, instalación completa y atención 7 días a la semana.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Iztacalco"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Iztacalco. La alcaldía es compacta y bien comunicada, lo que nos permite garantizar entregas rápidas en toda la zona."
        copy2="Iztacalco limita con varias alcaldías de alta demanda. Si necesitas servicio en zonas limítrofes con Venustiano Carranza o Benito Juárez, también podemos atenderte."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Iztacalco"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Iztacalco tiene accesos directos por el Viaducto, el Eje 3 Oriente y la Calzada Ignacio Zaragoza, lo que facilita las entregas incluso en horas de alta demanda vial."
        copy2="Para eventos en unidades habitacionales o condominios, coordinamos previamente el acceso. Solo necesitamos el nombre del residente y la dirección exacta para garantizar una entrega sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío completamente incluido en todas las colonias de Iztacalco.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Iztacalco"
        subtitle="Los favoritos para fiestas familiares en Agrícola Oriental, Balbuena y toda la alcaldía."
        copy1="Iztacalco tiene una tradición de fiestas familiares llenas de niños. La conectividad vial de la alcaldía nos facilita llegar puntualmente a cualquier colonia."
        copy2="¿Fiesta en unidad habitacional? Coordina el acceso con tu administración y nosotros nos encargamos del resto."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en Iztacalco. Alta capacidad y colores vibrantes. Funciona perfectamente en patios, jardines y áreas comunes de la alcaldía.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">La reina de los inflables en fiestas de niñas en Iztacalco. Diseño temático con colores pastel que alegra cualquier celebración.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito niños</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El aventurero más popular entre los niños de Iztacalco. Diseño de galeón que hace de cualquier cumpleaños una fiesta épica.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Iztacalco"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Iztacalco y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Iztacalco?"
    subtitle="Cotiza tu inflable con entrega incluida en Pantitlán, Granjas México, Viaducto y toda Iztacalco."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
