---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Nezahualcóyotl | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Nezahualcóyotl con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Nezahualcóyotl. Instalación profesional y precios accesibles.";

const colonias = [
  "Ciudad Neza",
  "Jardines de Morelos",
  "Los Reyes",
  "Benito Juárez",
  "Ciudad Lago",
  "Metropolitana",
  "Evolución",
  "Impulsora",
  "Valle de Aragón III Sección",
  "Bordo Xochiaca",
  "Tamaulipas",
  "Nezahualcóyotl Centro"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Nezahualcóyotl?", answer: "El cargo de envío a Nezahualcóyotl varía entre $150 y $250 dependiendo de la colonia. Ciudad Neza, Jardines de Morelos y Las Águilas tienen el cargo base. Colonias más alejadas pueden tener un costo ligeramente mayor. Confirma al cotizar." },
  { question: "¿Pueden llevar inflables a salones de fiestas en Neza?", answer: "Sí. Nezahualcóyotl tiene una gran cantidad de salones de fiestas y somos proveedor habitual en varios de ellos. Coordinamos directamente con el administrador del salón para la entrega y montaje. Es una de las zonas con mayor demanda de inflables en el Edomex." },
  { question: "¿Tienen inflables para fiestas grandes en Nezahualcóyotl?", answer: "Por supuesto. Para fiestas con muchos niños en Neza, los Dragones Rojos y el Inflable Extremo son los más solicitados por su alta capacidad (6-8 niños simultáneos). El Barco Pirata también es muy popular para cumpleaños temáticos en la zona." },
  { question: "¿Cubren toda Neza, incluyendo Benito Juárez y Los Reyes?", answer: "Sí, cubrimos todo el municipio de Nezahualcóyotl — desde Ciudad Neza Centro hasta Benito Juárez, Los Reyes, Jardines de Morelos y todas las demás colonias. El cargo de envío aplica por ser Edomex." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Nezahualcóyotl" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Nezahualcóyotl</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Nezahualcóyotl</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Nezahualcóyotl</span></h1>
          <p class="hero__desc">Renta de inflables en Nezahualcóyotl (Neza), Edomex. Entrega en Ciudad Neza, Jardines de Morelos, Los Reyes, Benito Juárez y todo el municipio. Precios accesibles.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Nezahualcóyotl, conocido como Neza, es un municipio densamente poblado del Estado de México con una fuerte cultura de fiestas familiares y eventos infantiles. BRINCOLINS cubre todo el municipio con un servicio de calidad y cargo de envío de $200 a $300. Atendemos desde Ciudad Neza hasta Jardines de Morelos y Los Reyes.</p>
          <p class="hero__copy-text">Neza tiene buenas vías de acceso desde la CDMX: el Viaducto, el Periférico Oriente y la Calzada Ignacio Zaragoza. Nuestros equipos conocen las rutas más eficientes para llegar puntualmente. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Nezahualcóyotl"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Nezahualcóyotl, desde las colonias más cercanas a la CDMX hasta las zonas más internas del municipio. Neza tiene una gran variedad de espacios para eventos."
        copy2="El cargo de $200-$300 aplica para todo el municipio. Colonias más cercanas a Iztapalapa o Chimalhuacán tienen el cargo menor."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Nezahualcóyotl"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Neza utilizamos las principales vialidades de acceso: Viaducto, Periférico Oriente y la Autopista México-Puebla. Planificamos la ruta según el tráfico del día."
        copy2="Nezahualcóyotl es un municipio muy activo los fines de semana. Recomendamos reservar con anticipación para garantizar disponibilidad, especialmente en sábados."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$300</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $300 para Nezahualcóyotl. El municipio es grande; el costo se ajusta según la colonia específica.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Nezahualcóyotl"
        subtitle="Los favoritos para fiestas y eventos en Neza, Jardines de Morelos y toda la zona."
        copy1="Nezahualcóyotl es uno de los municipios con mayor demanda de renta de inflables en el Edomex. Las fiestas familiares en Neza se caracterizan por ser grandes y llenas de niños."
        copy2="¿Salón de fiestas o casa con patio en Neza? Coordinamos con el salón directamente o te entregamos donde tú elijas."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado Neza</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Nezahualcóyotl. Alta capacidad para grupos numerosos de niños. Ideal para patios, jardines y salones de fiestas de toda la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito temático</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El diseño pirata arrasa en las fiestas de Neza. Perfecto para cumpleaños temáticos y eventos con niños de 4 a 12 años.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Grupos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para los eventos más grandes en Nezahualcóyotl. El circuito de obstáculos más completo de BRINCOLINS para grupos numerosos de niños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Nezahualcóyotl"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Nezahualcóyotl y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Nezahualcóyotl?"
    subtitle="Cotiza tu inflable con entrega en Ciudad Neza, Jardines de Morelos, Los Reyes y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
