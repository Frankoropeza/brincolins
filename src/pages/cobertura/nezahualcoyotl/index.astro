---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Nezahualcóyotl | BRINCOLINS";
const description = "Renta de inflables en Nezahualcóyotl, Edomex. Servicio profesional con entrega programada. Renta de inflables en Nezahualcóyotl (Neza), Edomex. Entreg";

const colonias = [
  "Ciudad Neza",
  "Jardines de Morelos",
  "Los Reyes",
  "Benito Juárez",
  "Ciudad Lago",
  "Metropolitana",
  "Evolución",
  "Impulsora",
  "Valle de Aragón III Sección",
  "Bordo Xochiaca",
  "Tamaulipas",
  "Nezahualcóyotl Centro"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Nezahualcóyotl?", answer: "En Nezahualcóyotl el cargo es de $200 a $300 de envío. El monto exacto se confirma según tu colonia específica." },
  { question: "¿Qué inflables son más populares en Nezahualcóyotl?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Nezahualcóyotl?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Nezahualcóyotl." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Nezahualcóyotl" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Nezahualcóyotl</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🏘️ Nezahualcóyotl</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Nezahualcóyotl</span></h1>
          <p class="hero__desc">Renta de inflables en Nezahualcóyotl (Neza), Edomex. Entrega en Ciudad Neza, Jardines de Morelos, Los Reyes, Benito Juárez y todo el municipio. Precios accesibles.</p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20un%20inflable%20en%20Nezahualcoyotl."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">Cotizar por WhatsApp</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Nezahualcóyotl, conocido como Neza, es un municipio densamente poblado del Estado de México con una fuerte cultura de fiestas familiares y eventos infantiles. BRINCOLINS cubre todo el municipio con un servicio de calidad y cargo de envío de $200 a $300. Atendemos desde Ciudad Neza hasta Jardines de Morelos y Los Reyes.</p>
          <p class="hero__copy-text">Neza tiene buenas vías de acceso desde la CDMX: el Viaducto, el Periférico Oriente y la Calzada Ignacio Zaragoza. Nuestros equipos conocen las rutas más eficientes para llegar puntualmente. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Nezahualcóyotl"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Nezahualcóyotl, desde las colonias más cercanas a la CDMX hasta las zonas más internas del municipio. Neza tiene una gran variedad de espacios para eventos."
        copy2="El cargo de $200-$300 aplica para todo el municipio. Colonias más cercanas a Iztapalapa o Chimalhuacán tienen el cargo menor."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Nezahualcóyotl"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Neza utilizamos las principales vialidades de acceso: Viaducto, Periférico Oriente y la Autopista México-Puebla. Planificamos la ruta según el tráfico del día."
        copy2="Nezahualcóyotl es un municipio muy activo los fines de semana. Recomendamos reservar con anticipación para garantizar disponibilidad, especialmente en sábados."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$300</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $300 para Nezahualcóyotl. El municipio es grande; el costo se ajusta según la colonia específica.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Nezahualcóyotl"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Nezahualcóyotl y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Nezahualcóyotl?"
    subtitle="Cotiza tu inflable con entrega en Ciudad Neza, Jardines de Morelos, Los Reyes y todo el municipio."
    btnText="Cotizar para Nezahualcóyotl"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20inflable%20en%20Nezahualcoyotl."
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
    whatsapp={true}
    external={true}
  />
</PageLayout>
