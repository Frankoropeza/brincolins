---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Gustavo A. Madero | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Gustavo A. Madero con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Gustavo A. Madero. Instalación profesional y precios accesibles.";

const colonias = [
  "Lindavista",
  "Vallejo",
  "Tepeyac Insurgentes",
  "La Villa",
  "Aragón",
  "Martín Carrera",
  "San Bartolo Atepehuacan",
  "Gustavo A. Madero",
  "Cuautepec",
  "Zacatenco",
  "Pensador Mexicano",
  "Nueva Atzacoalco"
];

const faqs = [
  { question: "¿Cubren colonias lejanas de GAM como Cuautepec o Nueva Atzacoalco?", answer: "Sí. Cubrimos toda la alcaldía, incluyendo Cuautepec, Nueva Atzacoalco, San Bartolo y las colonias del norte de GAM. Para estas zonas programamos salidas más tempranas para garantizar puntualidad en tu evento." },
  { question: "¿Pueden llevar inflables a kermeses escolares en Gustavo A. Madero?", answer: "Sí, atendemos kermeses en escuelas de toda la alcaldía. Para eventos escolares coordinamos directamente con la dirección de la escuela. Tenemos paquetes multi-inflable especiales para kermeses — ver /servicios/inflables-para-eventos/ para más detalles." },
  { question: "¿Qué inflable es más popular para fiestas con muchos niños en GAM?", answer: "Los Dragones Rojos y el Barco Pirata son los más rentados en GAM porque permiten que varios niños jueguen al mismo tiempo. Para grupos de 20+ niños, el Inflable Extremo es la mejor opción por su gran capacidad y circuito de obstáculos." },
  { question: "¿Atienden en unidades habitacionales como Aragón o Vallejo?", answer: "Sí. Tenemos experiencia en unidades habitacionales de toda la alcaldía. Coordinamos con la administración del conjunto para horarios de carga y permisos de acceso al área común o jardín. Solo necesitamos el nombre del solicitante y número de unidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Gustavo A. Madero" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Gustavo A. Madero</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Gustavo A. Madero</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Gustavo A. Madero</span></h1>
          <p class="hero__desc">Renta de inflables en Gustavo A. Madero CDMX. Envío incluido en Lindavista, Vallejo, Tepeyac, La Villa, Aragón y toda la alcaldía GAM. Servicio profesional garantizado.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La alcaldía Gustavo A. Madero es una de las más grandes de la CDMX y una zona de altísima demanda para renta de inflables. Colonias como Lindavista, Vallejo y La Villa tienen una fuerte tradición de fiestas familiares y eventos infantiles. BRINCOLINS cubre toda la alcaldía con puntualidad y experiencia, conociendo cada colonia y sus particularidades.</p>
          <p class="hero__copy-text">En GAM atendemos desde casas con jardín en Lindavista hasta eventos en unidades habitacionales de Aragón y Vallejo. Nuestros equipos planifican las rutas con anticipación para evitar el tráfico del Eje Central y el Circuito Interior. Envío incluido, instalación completa y retiro al finalizar tu evento.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Gustavo A. Madero"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la extensa alcaldía Gustavo A. Madero, desde Lindavista y Vallejo en el sur hasta Cuautepec en el norte. Conocemos cada colonia y sus condiciones de acceso."
        copy2="GAM es una de las alcaldías más grandes de la CDMX. Si tu colonia no aparece en la lista, escríbenos — todas las colonias de GAM tienen envío incluido."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Gustavo A. Madero"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="La alcaldía GAM tiene excelentes accesos por el Eje Central, el Circuito Interior y el Anillo Periférico. Para colonias del norte como Cuautepec, planificamos salidas más tempranas para garantizar puntualidad."
        copy2="Conocemos bien las unidades habitacionales de Vallejo y Aragón. Coordinamos con la administración de los conjuntos para los horarios de carga y descarga cuando es necesario."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido en el precio para todas las colonias de Gustavo A. Madero: Lindavista, Vallejo, La Villa, Tepeyac, Aragón y más.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Gustavo A. Madero"
        subtitle="Los favoritos en Lindavista, Vallejo, La Villa y toda la alcaldía GAM."
        copy1="GAM tiene una gran tradición de fiestas familiares con muchos niños. Los modelos más populares son los de mayor capacidad, para que todos los niños puedan divertirse al mismo tiempo."
        copy2="¿Kermesse escolar o evento grande? Revisa nuestros paquetes multi-inflable diseñados para eventos con 20+ niños en la alcaldía."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado GAM</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Gustavo A. Madero. Colores llamativos, resistente y con espacio para que varios niños brinquen al mismo tiempo. El hit de Lindavista a Cuautepec.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito temático</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El galeón pirata más popular de la alcaldía. Diseño dramático que entusiasma a niños de 4 a 12 años y convierte cualquier fiesta en una aventura.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Kermeses y eventos</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">El más grande de BRINCOLINS. Circuito de obstáculos y tobogán para grupos numerosos. Indispensable para kermeses escolares en GAM.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Gustavo A. Madero"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Gustavo A. Madero y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Gustavo A. Madero?"
    subtitle="Cotiza tu inflable con entrega incluida en Lindavista, Vallejo, La Villa, Aragón y toda la alcaldía GAM."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
