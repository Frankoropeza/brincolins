---
import PageLayout from "@/layouts/PageLayout.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Renta de Inflables en Polanco, Lomas y Santa Fe | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Polanco, Lomas y Santa Fe con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Polanco, Lomas y Santa Fe. Instalación profesional y precios accesibles.";

const colonias = [
  "Polanco I Sección", "Polanco II Sección", "Polanco III Sección",
  "Polanco IV Sección", "Polanco V Sección", "Lomas de Chapultepec",
  "Santa Fe", "Bosques de las Lomas", "Lomas de Bezares",
  "Anzures", "Reforma", "Chapultepec",
  "Palmas", "Virreyes", "Lomas Altas", "Bosque Real",
];

const faqs = [
  { question: "¿Entregan inflables en Polanco sin costo adicional?", answer: "Sí, la entrega en Polanco, Lomas de Chapultepec, Anzures y colonias cercanas está incluida en el precio. No cobramos flete adicional para estas zonas." },
  { question: "¿Pueden instalar un inflable en un departamento de Polanco?", answer: "Sí, siempre que el departamento cuente con terraza o roof garden con espacio suficiente. Necesitamos acceso al elevador de servicio y una toma eléctrica cercana. Coordinamos con la administración del edificio." },
  { question: "¿Qué inflables recomiendan para jardines en Lomas de Chapultepec?", answer: "Los jardines de Lomas suelen ser amplios, así que cualquier modelo funciona perfecto. Los más solicitados en la zona son el Castillo Blanco por su estética elegante y el inflable Extremo para fiestas con niños mayores." },
  { question: "¿Cubren también Santa Fe y Bosques de las Lomas?", answer: "Sí, toda la zona de Santa Fe, Bosques de las Lomas y Bosque Real está dentro de nuestra cobertura con entrega sin costo. Incluso cubrimos los centros comerciales y salones de eventos de la zona." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura" },
    { name: "Polanco" },
  ]}
  faqItems={faqs}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Polanco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Polanco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Polanco, Lomas y Santa Fe</span></h1>
          <p class="hero__desc">Entregamos e instalamos inflables en Polanco, Lomas de Chapultepec, Santa Fe y todas las colonias de la zona poniente de CDMX. Servicio profesional con los más altos estándares de calidad.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">
              Solicitar cotización
            </a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Polanco, Lomas de Chapultepec y Santa Fe son zonas donde las fiestas infantiles se celebran con altos estándares de calidad. Los jardines amplios de Lomas, las terrazas y roof gardens de Polanco, y los salones de Santa Fe son espacios ideales para instalar inflables de primera línea. Nuestro equipo conoce las particularidades logísticas de cada colonia.</p>
          <p class="hero__copy-text">Coordinamos directamente con administraciones de edificios, seguridad de fraccionamientos cerrados y personal de salones de eventos para garantizar una instalación sin contratiempos. Llevamos años atendiendo eventos en esta zona y conocemos las rutas de acceso, los horarios de carga y descarga, y los requisitos específicos de cada ubicación.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias que cubrimos en la zona Polanco-Lomas"
        subtitle="Entrega directa en estas zonas sin costo adicional."
        copy1="Nuestra cobertura abarca toda la zona poniente de la Ciudad de México, desde Polanco y Anzures hasta Santa Fe y Bosque Real. Cada colonia tiene sus particularidades de acceso y nosotros las conocemos todas."
        copy2="Si tu evento es en un fraccionamiento cerrado, edificio de departamentos o salón de eventos privado, no te preocupes. Coordinamos todo el acceso logístico para que el inflable llegue puntual y sin complicaciones a tu ubicación exacta."
      />
      <div class="coverage__badges">
        {colonias.map(z => <span class="coverage__badge">{z}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Información de entrega en Polanco y Lomas"
        subtitle="Todo lo que necesitas saber sobre nuestro servicio en la zona."
        copy1="Polanco y Lomas de Chapultepec son zonas con regulaciones específicas de carga y descarga. Nuestro equipo está familiarizado con los horarios permitidos y las vías de acceso de cada colonia, lo que garantiza una instalación eficiente y sin multas."
        copy2="Para edificios con elevador de servicio o accesos controlados, coordinamos previamente con la administración. Te pedimos los datos de contacto del responsable del inmueble para agendar la entrega sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px; margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Entrega sin costo</h3>
            <p class="why-card__desc">En todas las colonias de Polanco, Lomas y Santa Fe.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Polanco y Lomas"
        subtitle="Selección premium para los eventos exclusivos de Polanco, Lomas de Chapultepec y Santa Fe."
        copy1="Polanco, Lomas de Chapultepec y Santa Fe tienen estándares específicos para eventos. Nuestros inflables premium están seleccionados especialmente para estas zonas de alto nivel."
        copy2="¿Roof garden o jardín en Lomas? Evalúa el espacio con fotos y te recomendamos el modelo más adecuado para tu evento."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Estética premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">El más solicitado en Polanco y Lomas de Chapultepec. Diseño neutral y elegante que combina con cualquier decoración en zonas exclusivas.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El hit para cumpleaños de niñas en Polanco y Bosques de las Lomas. Diseño temático y colores pastel que encajan con cualquier fiesta sofisticada.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El inflable más solicitado a nivel general. Perfecto para jardines en Lomas y Bosques de las Lomas con grupos mixtos de niños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Polanco y Lomas"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="La zona de Polanco y Lomas tiene particularidades que no existen en otras áreas de la ciudad. Edificios de lujo, fraccionamientos cerrados y regulaciones de ruido son factores que manejamos con experiencia."
        copy2="Si tu pregunta no aparece aquí, escríbenos por WhatsApp y te respondemos al instante. Nuestro equipo conoce esta zona a detalle y puede resolver cualquier duda logística."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Fiesta en Polanco o Lomas?"
    subtitle="Cotiza tu inflable con entrega gratuita en toda la zona poniente de CDMX."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />


  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
