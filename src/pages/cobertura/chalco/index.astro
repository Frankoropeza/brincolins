---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Chalco | BRINCOLINS";
const description = "Renta de inflables en Chalco, Edomex. Servicio profesional con entrega programada. Renta de inflables en Chalco y Valle de Chalco, Estado de Mé";

const colonias = [
  "Chalco Centro",
  "Valle de Chalco Solidaridad",
  "San Gregorio Cuautzingo",
  "Tlapala",
  "Mixquic",
  "San Pablo Atlazalpa",
  "San Andrés Tláhuac",
  "Xico",
  "Los Reyes Acaquilpan",
  "Santa Catarina Yecapixtla",
  "El Triunfo",
  "Del Bosque"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Chalco?", answer: "En Chalco el cargo de envío es de $250 a $400 según la colonia. El monto exacto se informa al cotizar." },
  { question: "¿Qué inflables son más populares en Chalco?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Chalco?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Chalco." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Chalco" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Chalco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🌅 Chalco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Chalco</span></h1>
          <p class="hero__desc">Renta de inflables en Chalco y Valle de Chalco, Estado de México. Entrega en Chalco Centro, Valle de Chalco, San Gregorio, Tlapala y todo el municipio. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20un%20inflable%20en%20Chalco."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">Cotizar por WhatsApp</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Chalco y Valle de Chalco Solidaridad son municipios del oriente del Estado de México con una gran densidad de población y alta demanda de servicios para eventos. BRINCOLINS llega hasta Chalco con un cargo de $250 a $400, atendiendo Chalco Centro, Valle de Chalco y toda la región oriente.</p>
          <p class="hero__copy-text">La autopista México-Puebla y la carretera Federal 115 son nuestras rutas de acceso a Chalco. Los espacios en Valle de Chalco son ideales para eventos con inflables: jardines amplios y áreas comunitarias bien acondicionadas. Instalación profesional y retiro incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Chalco"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos Chalco Centro y Valle de Chalco, además de los municipios circundantes de la región oriente del Estado de México."
        copy2="El cargo de $250-$400 aplica para toda la zona. Para municipios más alejados como Tlalmanalco o Ozumba, el costo puede ser mayor; consultamos."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Chalco"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Usamos la autopista México-Puebla para llegar a Chalco. Es una ruta directa que nos permite garantizar entregas puntuales incluso desde la CDMX."
        copy2="Valle de Chalco tiene una enorme demanda de servicios para eventos los fines de semana. Reserva con anticipación para garantizar disponibilidad del inflable que necesitas."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$250–$400</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $250 a $400 para Chalco y Valle de Chalco según la colonia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Chalco"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Chalco y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Chalco?"
    subtitle="Cotiza tu inflable con entrega en Chalco Centro, Valle de Chalco, San Gregorio y toda la zona oriente."
    btnText="Cotizar para Chalco"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20inflable%20en%20Chalco."
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
    whatsapp={true}
    external={true}
  />
</PageLayout>
