---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Chalco | BRINCOLINS";
const description = "Renta de inflables en Chalco, Edomex. Entrega incluida en Chalco Centro, Valle de Chalco y Xico. Desde $800 MXN con instalación y seguro.";

const colonias = [
  "Chalco Centro",
  "Valle de Chalco Solidaridad",
  "San Gregorio Cuautzingo",
  "Tlapala",
  "Mixquic",
  "San Pablo Atlazalpa",
  "San Andrés Tláhuac",
  "Xico",
  "Los Reyes Acaquilpan",
  "Santa Catarina Yecapixtla",
  "El Triunfo",
  "Del Bosque"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Chalco y Valle de Chalco?", answer: "El cargo de envío a Chalco varía entre $200 y $350 dependiendo de la colonia. Chalco Centro y zonas limítrofes con el CDMX tienen costo menor. Valle de Chalco y colonias más alejadas pueden tener un costo mayor. Te confirmamos exacto al cotizar." },
  { question: "¿Cubren Valle de Chalco Solidaridad?", answer: "Sí, cubrimos Valle de Chalco Solidaridad además del municipio de Chalco. Por ser una zona extensa, el cargo de envío puede variar según la colonia específica dentro del Valle. Confirma tu dirección y te indicamos el costo puntual." },
  { question: "¿Qué inflables recomiendan para fiestas en Chalco con muchos niños?", answer: "Para las fiestas con muchos niños en Chalco recomendamos los Dragones Rojos o el Inflable Extremo por su alta capacidad. Son los modelos más solicitados en la zona por familias numerosas que quieren que todos los niños se diviertan al mismo tiempo." },
  { question: "¿Con cuánta anticipación hay que reservar para Chalco?", answer: "Por la distancia desde nuestro almacén, recomendamos reservar con al menos 2-3 semanas de anticipación para coordinar la logística. En temporadas altas reserva con un mes para garantizar disponibilidad y tiempo de entrega." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Chalco" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Chalco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Chalco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Chalco</span></h1>
          <p class="hero__desc">Renta de inflables en Chalco y Valle de Chalco, Estado de México. Entrega en Chalco Centro, Valle de Chalco, San Gregorio, Tlapala y todo el municipio. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Chalco y Valle de Chalco Solidaridad son municipios del oriente del Estado de México con una gran densidad de población y alta demanda de servicios para eventos. BRINCOLINS llega hasta Chalco con un cargo de $250 a $400, atendiendo Chalco Centro, Valle de Chalco y toda la región oriente.</p>
          <p class="hero__copy-text">La autopista México-Puebla y la carretera Federal 115 son nuestras rutas de acceso a Chalco. Los espacios en Valle de Chalco son ideales para eventos con inflables: jardines amplios y áreas comunitarias bien acondicionadas. Instalación profesional y retiro incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Chalco"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos Chalco Centro y Valle de Chalco, además de los municipios circundantes de la región oriente del Estado de México."
        copy2="El cargo de $250-$400 aplica para toda la zona. Para municipios más alejados como Tlalmanalco o Ozumba, el costo puede ser mayor; consultamos."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Chalco"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Usamos la autopista México-Puebla para llegar a Chalco. Es una ruta directa que nos permite garantizar entregas puntuales incluso desde la CDMX."
        copy2="Valle de Chalco tiene una enorme demanda de servicios para eventos los fines de semana. Reserva con anticipación para garantizar disponibilidad del inflable que necesitas."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$250–$400</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $250 a $400 para Chalco y Valle de Chalco según la colonia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Chalco"
        subtitle="Los favoritos para fiestas familiares en Chalco Centro y Valle de Chalco."
        copy1="Chalco y Valle de Chalco son municipios con gran tradición de fiestas familiares y comunitarias. Los espacios amplios de la zona son perfectos para nuestros modelos de mayor capacidad."
        copy2="¿Tu evento es en Valle de Chalco o una colonia específica? Comparte la dirección exacta y calculamos el costo de envío y tiempo de llegada."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Chalco. Resistente, colorido y de alta capacidad para las fiestas grandes de la zona. El favorito de las familias en Chalco.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito temático</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El diseño pirata arrasa en las fiestas de Chalco. Niños de 4 a 12 años se vuelven locos con este inflable de aventura.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Eventos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para las fiestas grandes en los amplios espacios de Chalco y Valle de Chalco. El mayor y más completo de BRINCOLINS.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Chalco"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Chalco y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Chalco?"
    subtitle="Cotiza tu inflable con entrega en Chalco Centro, Valle de Chalco, San Gregorio y toda la zona oriente."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
