---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Iztapalapa | BRINCOLINS";
const description = "Renta de inflables en Iztapalapa. Renta de inflables en Iztapalapa CDMX. Entrega a bajo costo en Ermita, UAM Iztapalapa, Santa Martha,";

const colonias = [
  "Ermita Iztapalapa",
  "UAM Iztapalapa",
  "Santa Martha Acatitla",
  "Peñón de los Baños",
  "Iztapalapa Centro",
  "San Lorenzo Tezonco",
  "Lomas de Zaragoza",
  "Paraje Zacatepec",
  "San Juanico",
  "Teotongo",
  "Aculco",
  "Ejército de Oriente"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Iztapalapa?", answer: "En Iztapalapa aplicamos un cargo de $100 a $150 de envío, dependiendo de la colonia específica. Este costo se informa antes de confirmar tu reserva." },
  { question: "¿Qué inflables son más populares en Iztapalapa?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Iztapalapa?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Iztapalapa." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Iztapalapa" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Iztapalapa</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🌇 Iztapalapa</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Iztapalapa</span></h1>
          <p class="hero__desc">Renta de inflables en Iztapalapa CDMX. Entrega a bajo costo en Ermita, UAM Iztapalapa, Santa Martha, Peñón y toda la alcaldía. Precios accesibles y servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Iztapalapa es la alcaldía más poblada de la CDMX y tiene una de las mayores demandas de renta de inflables de toda la capital. BRINCOLINS cubre toda la alcaldía con un costo de envío accesible de $100 a $150, que refleja la distancia adicional desde nuestro almacén. Atendemos Ermita, UAM, Santa Martha, Peñón y todas las colonias de la alcaldía.</p>
          <p class="hero__copy-text">A pesar de la distancia, nuestro equipo de logística optimiza las rutas para llegar puntualmente a Iztapalapa. Conocemos los principales accesos: la Calzada Ermita, el Eje 6 Sur y la Autopista México-Puebla. Tu inflable llegará a tiempo, instalado profesionalmente y listo para tu fiesta.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Iztapalapa"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la alcaldía Iztapalapa con sus numerosas colonias y unidades habitacionales. Desde Ermita hasta las zonas más lejanas de la alcaldía."
        copy2="El cargo de envío de $100-$150 aplica para toda la alcaldía. Para zonas fronterizas con Nezahualcóyotl o Chalco, el costo puede ser ligeramente mayor; contáctanos para confirmar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Iztapalapa"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Iztapalapa programamos salidas más tempranas para evitar el tráfico del Eje Central y la Calzada Ermita. Te confirmamos la hora de llegada con anticipación para que puedas organizar tu evento."
        copy2="Trabajamos en todos los tipos de espacios de Iztapalapa: casas con patio, unidades habitacionales, jardines vecinales y áreas comunitarias. Nuestros equipos están preparados para cualquier tipo de instalación."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$100–$150</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">En Iztapalapa aplicamos un cargo de envío de $100 a $150 dependiendo de la colonia. Este costo cubre el traslado adicional por la distancia y se informa antes de confirmar tu reserva.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Iztapalapa"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Iztapalapa y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Iztapalapa?"
    subtitle="Cotiza tu inflable con entrega accesible en Ermita, UAM, Santa Martha y toda Iztapalapa."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />
</PageLayout>
