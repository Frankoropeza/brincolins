---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Iztapalapa | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Iztapalapa con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Iztapalapa. Instalación profesional y precios accesibles.";

const colonias = [
  "Ermita Iztapalapa",
  "UAM Iztapalapa",
  "Santa Martha Acatitla",
  "Peñón de los Baños",
  "Iztapalapa Centro",
  "San Lorenzo Tezonco",
  "Lomas de Zaragoza",
  "Paraje Zacatepec",
  "San Juanico",
  "Teotongo",
  "Aculco",
  "Ejército de Oriente"
];

const faqs = [
  { question: "¿Pueden llevar inflables directamente a salones de fiestas en Iztapalapa?", answer: "Sí. Somos proveedor habitual de varios salones de fiestas en Iztapalapa. Si tu salón ya tiene el espacio, nosotros llevamos el inflable y coordinamos con el administrador. Lleva nuestro contacto de WhatsApp a tu salón y lo cerramos en minutos." },
  { question: "¿El cargo de envío aplica a todas las colonias de Iztapalapa?", answer: "El cargo de envío de $100–$150 aplica según la colonia. Ermita, UAM y Santa Martha tienen el costo base. Colonias más alejadas hacia el oriente pueden tener un cargo ligeramente mayor. Te confirmamos el costo exacto al cotizar." },
  { question: "¿Tienen inflables grandes para fiestas con muchos niños en Iztapalapa?", answer: "Sí. Para eventos con 20 o más niños recomendamos el Extremo o los Dragones Rojos: son los modelos de mayor capacidad, con espacio para 6–8 niños simultáneamente. Perfectos para kermeses escolares y fiestas de vecindad en la alcaldía." },
  { question: "¿Con cuánta anticipación debo reservar para un fin de semana en Iztapalapa?", answer: "Recomendamos reservar con al menos 2 semanas de anticipación. Iztapalapa es una zona de alta demanda los fines de semana. En temporadas altas (Semana Santa, vacaciones de verano y diciembre) la disponibilidad se llena rápido — reserva con 3–4 semanas de margen." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Iztapalapa" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Iztapalapa</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Iztapalapa</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Iztapalapa</span></h1>
          <p class="hero__desc">Renta de inflables en Iztapalapa CDMX. Entrega a bajo costo en Ermita, UAM Iztapalapa, Santa Martha, Peñón y toda la alcaldía. Precios accesibles y servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Iztapalapa es la alcaldía más poblada de la CDMX y tiene una de las mayores demandas de renta de inflables de toda la capital. BRINCOLINS cubre toda la alcaldía con un costo de envío accesible de $100 a $150, que refleja la distancia adicional desde nuestro almacén. Atendemos Ermita, UAM, Santa Martha, Peñón y todas las colonias de la alcaldía.</p>
          <p class="hero__copy-text">A pesar de la distancia, nuestro equipo de logística optimiza las rutas para llegar puntualmente a Iztapalapa. Conocemos los principales accesos: la Calzada Ermita, el Eje 6 Sur y la Autopista México-Puebla. Tu inflable llegará a tiempo, instalado profesionalmente y listo para tu fiesta.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Iztapalapa"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la alcaldía Iztapalapa con sus numerosas colonias y unidades habitacionales. Desde Ermita hasta las zonas más lejanas de la alcaldía."
        copy2="El cargo de envío de $100-$150 aplica para toda la alcaldía. Para zonas fronterizas con Nezahualcóyotl o Chalco, el costo puede ser ligeramente mayor; contáctanos para confirmar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Iztapalapa"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Iztapalapa programamos salidas más tempranas para evitar el tráfico del Eje Central y la Calzada Ermita. Te confirmamos la hora de llegada con anticipación para que puedas organizar tu evento."
        copy2="Trabajamos en todos los tipos de espacios de Iztapalapa: casas con patio, unidades habitacionales, jardines vecinales y áreas comunitarias. Nuestros equipos están preparados para cualquier tipo de instalación."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$100–$150</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">En Iztapalapa aplicamos un cargo de envío de $100 a $150 dependiendo de la colonia. Este costo cubre el traslado adicional por la distancia y se informa antes de confirmar tu reserva.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Iztapalapa"
        subtitle="Los modelos de mayor capacidad para fiestas grandes en la alcaldía."
        copy1="Iztapalapa es la alcaldía más poblada de la CDMX, y sus fiestas suelen ser grandes y llenas de niños. Nuestros modelos de mayor capacidad son los favoritos en la zona."
        copy2="¿Necesitas inflables para una kermesse o evento con muchos niños? Consulta nuestros paquetes multi-inflable en la página de servicios para eventos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en Iztapalapa. Colores llamativos, alta capacidad y diversión garantizada para grupos grandes de niños en cualquier tipo de espacio.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito temático</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El diseño pirata es un hit en fiestas infantiles en Iztapalapa. Súper popular para niños de 4–12 años con ganas de aventura y diversión temática.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Kermeses y eventos</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">El modelo de mayor capacidad. Circuito de obstáculos para grupos numerosos. Ideal para kermeses escolares y fiestas grandes en patios amplios de Iztapalapa.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Iztapalapa"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Iztapalapa y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Iztapalapa?"
    subtitle="Cotiza tu inflable con entrega accesible en Ermita, UAM, Santa Martha y toda Iztapalapa."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
