---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Nicolás Romero | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Nicolás Romero con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Nicolás Romero. Instalación profesional y precios accesibles.";

const colonias = [
  "Nicolás Romero Centro",
  "Ciudad Cuauhtémoc",
  "El Progreso",
  "La Aurora",
  "El Mirador",
  "Prados de la Sierra",
  "Valle Verde",
  "Las Misiones",
  "Ampliación San Pedro Cholula",
  "San José el Vidrio",
  "Monte Olímpico",
  "San Isidro"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Nicolás Romero?", answer: "El cargo de envío a Nicolás Romero varía entre $200 y $350 dependiendo de la colonia. Nicolás Romero Centro y Ciudad Cuauhtémoc tienen el cargo base. El Progreso y colonias más alejadas al norte pueden tener un costo mayor." },
  { question: "¿Cubren Ciudad Cuauhtémoc y El Progreso en Nicolás Romero?", answer: "Sí, cubrimos toda la extensión del municipio incluyendo Ciudad Cuauhtémoc, El Progreso, La Aurora y Nicolás Romero Centro. Para las colonias más alejadas, planificamos salidas más tempranas para garantizar puntualidad." },
  { question: "¿Con cuánta anticipación hay que reservar para Nicolás Romero?", answer: "Por la distancia al norte del Edomex, recomendamos reservar con 2-3 semanas de anticipación en temporada regular. Para temporadas altas reserva con un mes. La logística al norte del Estado de México requiere mayor coordinación." },
  { question: "¿Pueden llevar inflables a kermeses en Nicolás Romero?", answer: "Sí, atendemos kermeses escolares y eventos comunitarios en Nicolás Romero. Para kermeses coordinamos directamente con la escuela o el organizador. Tenemos paquetes multi-inflable especiales — ver /servicios/inflables-para-eventos/ para detalles." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Nicolás Romero" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Nicolás Romero</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Nicolás Romero</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Nicolás Romero</span></h1>
          <p class="hero__desc">Renta de inflables en Nicolás Romero, Estado de México. Entrega en Nicolás Romero Centro, Ciudad Cuauhtémoc, El Progreso, La Aurora y todo el municipio. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Nicolás Romero es un municipio del noroeste del Estado de México con zonas residenciales en expansión y una creciente demanda de servicios para eventos. BRINCOLINS cubre Nicolás Romero con un cargo de $250 a $400. Atendemos el Centro, Ciudad Cuauhtémoc, El Progreso y todas las colonias del municipio.</p>
          <p class="hero__copy-text">El municipio tiene acceso por la carretera Federal 57 y el Boulevard Manuel Ávila Camacho. Planificamos las rutas para garantizar puntualidad. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Nicolás Romero"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Nicolás Romero, desde el Centro hasta los nuevos desarrollos residenciales que han crecido en los últimos años."
        copy2="Para colonias en zonas elevadas o de acceso difícil, confirmamos el tipo de vehículo disponible para la entrega al momento de cotizar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Nicolás Romero"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Nicolás Romero usamos la carretera Federal 57 como ruta principal. La salida se programa con anticipación para compensar el tráfico de la zona."
        copy2="El municipio ha crecido rápidamente con nuevos fraccionamientos. Si tu fraccionamiento es reciente, confirma la dirección exacta para que podamos planificar la ruta correctamente."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$250–$400</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $250 a $400 para Nicolás Romero según la colonia y distancia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Nicolás Romero"
        subtitle="Los favoritos para fiestas familiares en Ciudad Cuauhtémoc, El Progreso y toda la zona."
        copy1="Nicolás Romero es un municipio en crecimiento al norte del Edomex con gran demanda de renta de inflables para fiestas familiares, cumpleaños y kermeses escolares."
        copy2="¿Colonia específica en Nicolás Romero? Confirma tu dirección y te calculamos el costo de envío y el tiempo de llegada exacto."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en Nicolás Romero. Alta capacidad y colores llamativos para las fiestas familiares en Ciudad Cuauhtémoc y toda la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El más solicitado para cumpleaños de niñas en Nicolás Romero. Diseño temático y colorido que convierte cualquier festejo en una celebración especial.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito niños</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El diseño pirata es muy popular en Nicolás Romero. Ideal para cumpleaños temáticos de niños de 4 a 12 años en los amplios espacios de la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Nicolás Romero"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Nicolás Romero y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Nicolás Romero?"
    subtitle="Cotiza tu inflable con entrega en Nicolás Romero Centro, Ciudad Cuauhtémoc, El Progreso y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
