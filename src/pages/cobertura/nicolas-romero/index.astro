---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Nicolás Romero | BRINCOLINS";
const description = "Renta de inflables en Nicolás Romero, Edomex. Servicio profesional con entrega programada. Renta de inflables en Nicolás Romero, Estado de México. Ent";

const colonias = [
  "Nicolás Romero Centro",
  "Ciudad Cuauhtémoc",
  "El Progreso",
  "La Aurora",
  "El Mirador",
  "Prados de la Sierra",
  "Valle Verde",
  "Las Misiones",
  "Ampliación San Pedro Cholula",
  "San José el Vidrio",
  "Monte Olímpico",
  "San Isidro"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Nicolás Romero?", answer: "En Nicolás Romero el cargo es de $250 a $400 de envío según la colonia. El monto se confirma al cotizar." },
  { question: "¿Qué inflables son más populares en Nicolás Romero?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Nicolás Romero?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Nicolás Romero." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Nicolás Romero" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Nicolás Romero</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🌳 Nicolás Romero</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Nicolás Romero</span></h1>
          <p class="hero__desc">Renta de inflables en Nicolás Romero, Estado de México. Entrega en Nicolás Romero Centro, Ciudad Cuauhtémoc, El Progreso, La Aurora y todo el municipio. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20un%20inflable%20en%20Nicolas%20Romero."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">Cotizar por WhatsApp</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Nicolás Romero es un municipio del noroeste del Estado de México con zonas residenciales en expansión y una creciente demanda de servicios para eventos. BRINCOLINS cubre Nicolás Romero con un cargo de $250 a $400. Atendemos el Centro, Ciudad Cuauhtémoc, El Progreso y todas las colonias del municipio.</p>
          <p class="hero__copy-text">El municipio tiene acceso por la carretera Federal 57 y el Boulevard Manuel Ávila Camacho. Planificamos las rutas para garantizar puntualidad. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Nicolás Romero"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Nicolás Romero, desde el Centro hasta los nuevos desarrollos residenciales que han crecido en los últimos años."
        copy2="Para colonias en zonas elevadas o de acceso difícil, confirmamos el tipo de vehículo disponible para la entrega al momento de cotizar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Nicolás Romero"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Nicolás Romero usamos la carretera Federal 57 como ruta principal. La salida se programa con anticipación para compensar el tráfico de la zona."
        copy2="El municipio ha crecido rápidamente con nuevos fraccionamientos. Si tu fraccionamiento es reciente, confirma la dirección exacta para que podamos planificar la ruta correctamente."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$250–$400</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $250 a $400 para Nicolás Romero según la colonia y distancia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Nicolás Romero"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Nicolás Romero y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Nicolás Romero?"
    subtitle="Cotiza tu inflable con entrega en Nicolás Romero Centro, Ciudad Cuauhtémoc, El Progreso y todo el municipio."
    btnText="Cotizar para Nicolás Romero"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20inflable%20en%20Nicolas%20Romero."
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
    whatsapp={true}
    external={true}
  />
</PageLayout>
