---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Tláhuac | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Tláhuac con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Tláhuac. Instalación profesional y precios accesibles.";

const colonias = [
  "Tláhuac Centro",
  "La Nopalera",
  "Zapotitla",
  "Los Olivos",
  "San Andrés Mixquic",
  "San Pedro Tláhuac",
  "San Juan Ixtayopan",
  "Santa Cecilia Tepetlapa",
  "Santiago Zapotitla",
  "San Nicolás Tetelco",
  "Selene",
  "Del Mar"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Tláhuac?", answer: "En Tláhuac aplicamos un cargo de envío de $100 a $200 dependiendo de la colonia. Las zonas más accesibles como Tláhuac Centro tienen el cargo menor. Te confirmamos el costo exacto al momento de cotizar con tu dirección." },
  { question: "¿Cubren San Andrés Mixquic y las colonias rurales de Tláhuac?", answer: "Sí, cubrimos toda la alcaldía incluyendo San Andrés Mixquic, Ixtayopan y las colonias más al sur. Para estas zonas el cargo de envío puede ser mayor y recomendamos coordinar con 3-4 días de anticipación." },
  { question: "¿Pueden instalar en jardines o terrenos en Tláhuac?", answer: "Sí. Tláhuac tiene muchas casas con jardines amplios y terrenos generosos, ideales para nuestros modelos grandes. Para terrenos con pendiente o irregulares, nuestro equipo lleva equipo de nivelación para garantizar seguridad." },
  { question: "¿Qué inflables son los más populares en Tláhuac?", answer: "En Tláhuac los más rentados son los Dragones Rojos por su alta capacidad y el Barco Pirata por su diseño temático. Para fiestas de XV años o eventos más grandes, el Inflable Extremo es la mejor opción con espacio para grupos numerosos." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Tláhuac" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Tláhuac</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Tláhuac</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Tláhuac</span></h1>
          <p class="hero__desc">Renta de inflables en Tláhuac CDMX. Entrega a Tláhuac Centro, La Nopalera, Zapotitla, Los Olivos y toda la alcaldía. Cargo de envío accesible y servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Tláhuac es una alcaldía del suroriente de la CDMX con una fuerte tradición de festividades y eventos comunitarios. BRINCOLINS cubre toda la alcaldía con un cargo de envío de $100 a $200 que refleja la distancia adicional. Atendemos Tláhuac Centro, La Nopalera, Zapotitla, Los Olivos y todas las colonias del municipio.</p>
          <p class="hero__copy-text">La alcaldía Tláhuac tiene amplios espacios al aire libre y una cultura de fiestas familiares muy arraigada. Nuestros equipos conocen las principales rutas de acceso y planifican con anticipación para llegar puntualmente. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Tláhuac"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias y pueblos de Tláhuac. La alcaldía combina zonas urbanas modernas con pueblos de gran tradición como San Andrés Mixquic."
        copy2="El cargo de envío varía entre $100 y $200 según la distancia. Para los pueblos más alejados como San Nicolás Tetelco, el cargo puede ser ligeramente mayor."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Tláhuac"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Tláhuac utilizamos la Calzada Tláhuac y el Periférico Oriente como rutas principales. Salimos con suficiente anticipación para llegar puntualmente incluso en días de mucho tráfico."
        copy2="Tláhuac tiene espacios comunitarios amplios en sus pueblos tradicionales. Si necesitas un inflable para un evento comunitario o en un jardín grande, tenemos las opciones perfectas para ti."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$100–$200</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">En Tláhuac aplicamos un cargo de envío de $100 a $200 según la colonia y la distancia desde nuestro almacén.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Tláhuac"
        subtitle="Los favoritos para fiestas familiares en Tláhuac Centro, Mixquic y toda la alcaldía."
        copy1="Tláhuac tiene amplios espacios y jardines donde los inflables grandes pueden brillar. La alcaldía combina zonas urbanas y semi-rurales con tipos de eventos muy variados."
        copy2="¿Tu evento es en San Andrés Mixquic o una zona alejada? Confírmanos la dirección y te decimos el costo de envío y disponibilidad."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Tláhuac. Resistente, colorido y con espacio para varios niños jugando simultáneamente. El favorito en toda la alcaldía.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Temático popular</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El favorito temático en Tláhuac. Los niños se vuelven locos con el diseño de galeón pirata en los jardines y espacios de la alcaldía.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Eventos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para kermeses y eventos con muchos niños en los amplios terrenos de Tláhuac. El circuito más completo de BRINCOLINS.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Tláhuac"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Tláhuac y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Tláhuac?"
    subtitle="Cotiza tu inflable con entrega programada en Tláhuac Centro, La Nopalera, Zapotitla y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
