---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Tláhuac | BRINCOLINS";
const description = "Renta de inflables en Tláhuac. Renta de inflables en Tláhuac CDMX. Entrega a Tláhuac Centro, La Nopalera, Zapotitla, Los Olivos y t";

const colonias = [
  "Tláhuac Centro",
  "La Nopalera",
  "Zapotitla",
  "Los Olivos",
  "San Andrés Mixquic",
  "San Pedro Tláhuac",
  "San Juan Ixtayopan",
  "Santa Cecilia Tepetlapa",
  "Santiago Zapotitla",
  "San Nicolás Tetelco",
  "Selene",
  "Del Mar"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Tláhuac?", answer: "En Tláhuac aplicamos un cargo de $100 a $200 de envío. El monto exacto depende de tu colonia y se informa antes de confirmar." },
  { question: "¿Qué inflables son más populares en Tláhuac?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Tláhuac?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Tláhuac." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Tláhuac" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Tláhuac</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🌾 Tláhuac</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Tláhuac</span></h1>
          <p class="hero__desc">Renta de inflables en Tláhuac CDMX. Entrega a Tláhuac Centro, La Nopalera, Zapotitla, Los Olivos y toda la alcaldía. Cargo de envío accesible y servicio profesional.</p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20un%20inflable%20en%20Tlahuac."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">Cotizar por WhatsApp</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Tláhuac es una alcaldía del suroriente de la CDMX con una fuerte tradición de festividades y eventos comunitarios. BRINCOLINS cubre toda la alcaldía con un cargo de envío de $100 a $200 que refleja la distancia adicional. Atendemos Tláhuac Centro, La Nopalera, Zapotitla, Los Olivos y todas las colonias del municipio.</p>
          <p class="hero__copy-text">La alcaldía Tláhuac tiene amplios espacios al aire libre y una cultura de fiestas familiares muy arraigada. Nuestros equipos conocen las principales rutas de acceso y planifican con anticipación para llegar puntualmente. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Tláhuac"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias y pueblos de Tláhuac. La alcaldía combina zonas urbanas modernas con pueblos de gran tradición como San Andrés Mixquic."
        copy2="El cargo de envío varía entre $100 y $200 según la distancia. Para los pueblos más alejados como San Nicolás Tetelco, el cargo puede ser ligeramente mayor."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Tláhuac"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Tláhuac utilizamos la Calzada Tláhuac y el Periférico Oriente como rutas principales. Salimos con suficiente anticipación para llegar puntualmente incluso en días de mucho tráfico."
        copy2="Tláhuac tiene espacios comunitarios amplios en sus pueblos tradicionales. Si necesitas un inflable para un evento comunitario o en un jardín grande, tenemos las opciones perfectas para ti."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$100–$200</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">En Tláhuac aplicamos un cargo de envío de $100 a $200 según la colonia y la distancia desde nuestro almacén.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Tláhuac"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Tláhuac y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Tláhuac?"
    subtitle="Cotiza tu inflable con entrega programada en Tláhuac Centro, La Nopalera, Zapotitla y toda la alcaldía."
    btnText="Cotizar para Tláhuac"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20necesito%20inflable%20en%20Tlahuac."
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
    whatsapp={true}
    external={true}
  />
</PageLayout>
