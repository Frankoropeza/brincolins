---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Metepec | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Metepec con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Metepec. Instalación profesional y precios accesibles.";

const colonias = [
  "Metepec Centro",
  "San Salvador la Gavia",
  "Pilares",
  "Coaxustenco",
  "San Jorge Pueblo Nuevo",
  "San Jerónimo Chicahualco",
  "La Asunción",
  "Santa María Magdalena Ocotitlán",
  "San Lucas Tunco",
  "El Calvario",
  "Barbabosa",
  "Del Parque"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Metepec?", answer: "Por la distancia adicional desde nuestro almacén, el cargo de envío a Metepec varía entre $350 y $500 MXN. Metepec Centro y San Salvador la Gavia tienen el costo base. Colonias más alejadas pueden tener un cargo mayor. Confirma tu dirección al cotizar." },
  { question: "¿Atienden las colonias residenciales premium de Metepec como Pilares y Coaxustenco?", answer: "Sí. Pilares, San Salvador la Gavia, Coaxustenco y otras colonias residenciales de Metepec están dentro de nuestra cobertura. Por ser una zona premium, garantizamos personal presentable y equipos en perfectas condiciones." },
  { question: "¿Con cuánta anticipación hay que reservar para Metepec?", answer: "Por la distancia, recomendamos reservar con al menos 3-4 semanas de anticipación. La logística de Metepec requiere mayor coordinación. Para temporadas altas (verano, diciembre) reserva con 5-6 semanas de margen para garantizar disponibilidad y logística." },
  { question: "¿Qué inflables recomiendan para las residencias exclusivas de Metepec?", answer: "Para los eventos en las colonias premium de Metepec, el Castillo Blanco es nuestra recomendación por su estética sofisticada. Para cumpleaños de niñas el Castillo de Princesas es el favorito. Para eventos grandes, los Dragones Rojos o el Extremo por su capacidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Metepec" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Metepec</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Metepec</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Metepec</span></h1>
          <p class="hero__desc">Renta de inflables en Metepec, Estado de México. Entrega en Metepec Centro, San Salvador la Gavia, Pilares, Coaxustenco y toda la zona residencial del Valle de Toluca.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Metepec es uno de los municipios más exclusivos del Estado de México, conocido por sus colonias residenciales de alto nivel y su artesanía del árbol de la vida. BRINCOLINS llega hasta Metepec con un servicio de calidad y un cargo de envío de $400 a $600. Atendemos Metepec Centro, San Salvador la Gavia, Pilares y todas las colonias del municipio.</p>
          <p class="hero__copy-text">Las residencias y jardines de Metepec son perfectos para eventos con inflables. Las colonias residenciales tienen amplios espacios al aire libre y excelentes condiciones para instalación. Coordinamos con los fraccionamientos cerrados para garantizar el acceso sin contratiempos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Metepec"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias y fraccionamientos de Metepec, incluyendo las zonas residenciales premium y los pueblos con historia del municipio."
        copy2="Para fraccionamientos cerrados de alto nivel en Metepec, coordinamos el acceso previamente. Garantizamos un servicio a la altura de las expectativas de la zona."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Metepec"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Metepec usamos la autopista México-Toluca y la carretera Toluca-Metepec. La distancia desde la CDMX es de aproximadamente 70 km con condiciones viales normales."
        copy2="En Metepec los eventos suelen ser en residencias con jardín. Tenemos inflables de todos los tamaños para adaptarnos al espacio disponible, desde brincolines compactos hasta grandes combinados."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$400–$600</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $400 a $600 para Metepec, municipio exclusivo del Valle de Toluca. Se coordina con anticipación.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Metepec"
        subtitle="Selección premium para las residencias exclusivas del Valle de Toluca."
        copy1="Metepec es una de las zonas residenciales más exclusivas del Edomex, conocida por sus colonias como Pilares y San Salvador la Gavia. Ofrecemos servicio premium adaptado a los estándares de la zona."
        copy2="¿Evento en Metepec? Por la distancia recomendamos reservar con al menos 3 semanas de anticipación para garantizar disponibilidad y logística."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Estética premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">El modelo más elegante de BRINCOLINS. Diseño neutro y sofisticado para las residencias exclusivas de Pilares, San Salvador la Gavia y Metepec Centro.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El hit para cumpleaños de niñas en Metepec. Colores vibrantes y diseño temático que destaca en los amplios jardines de la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El inflable favorito para eventos con grupos de niños en Metepec. Capacidad alta y colores llamativos para jardines amplios del Valle de Toluca.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Metepec"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Metepec y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Metepec?"
    subtitle="Cotiza tu inflable con entrega en Metepec Centro, San Salvador la Gavia, Pilares y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
