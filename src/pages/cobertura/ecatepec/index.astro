---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Ecatepec | BRINCOLINS";
const description = "Renta de inflables en Ecatepec, Edomex. Entrega incluida en Ecatepec Centro, Ciudad Azteca y Jardines de Morelos. Desde $800 MXN con seguro.";

const colonias = [
  "Ciudad Azteca",
  "Las Américas",
  "San Cristóbal Ecatepec",
  "Ecatepec Centro",
  "Jardines de Morelos",
  "José López Portillo",
  "Valle de Aragón",
  "San Agustín",
  "Lomas de Carrizal",
  "Santa Clara Coatitla",
  "Los Olivos",
  "Xalostoc"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Ecatepec?", answer: "En Ecatepec el cargo de envío es de $200 a $350 según la colonia. El costo exacto se confirma al cotizar." },
  { question: "¿Qué inflables son más populares en Ecatepec?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Ecatepec?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Ecatepec." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Ecatepec" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Ecatepec</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🌃 Ecatepec</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Ecatepec</span></h1>
          <p class="hero__desc">Renta de inflables en Ecatepec de Morelos, Edomex. Entrega a Ciudad Azteca, Las Américas, San Cristóbal, Ecatepec Centro y todo el municipio. Servicio profesional con cargo accesible.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Ecatepec de Morelos es uno de los municipios más grandes y poblados del Estado de México, con millones de habitantes y una enorme demanda de servicios para eventos. BRINCOLINS cubre todo Ecatepec con entregas puntuales y profesionales. Desde Ciudad Azteca hasta las colonias del norte del municipio, llegamos a tiempo.</p>
          <p class="hero__copy-text">El municipio de Ecatepec tiene buenas vías de acceso: el Circuito Exterior Mexiquense, la autopista México-Pachuca y la Calzada San Juan de Aragón. Con un cargo de $200 a $350 de envío, garantizamos instalación profesional y retiro incluidos. Contáctanos para una cotización inmediata.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Ecatepec"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Ecatepec es un municipio extenso con decenas de colonias. Cubrimos desde Ciudad Azteca al sur hasta las colonias del norte del municipio."
        copy2="El cargo de $200-$350 varía según la distancia exacta. Ciudad Azteca y Las Américas (más cercanas a la CDMX) tienen el cargo menor; colonias del norte pueden tener el cargo mayor."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Ecatepec"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Ecatepec usamos el Circuito Exterior Mexiquense y la autopista México-Pachuca. Salimos con suficiente anticipación para garantizar puntualidad incluso con tráfico."
        copy2="Conocemos las colonias de Ecatepec y planificamos rutas eficientes. Para zonas de difícil acceso, coordinamos previamente para garantizar la entrega sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$350</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $350 para Ecatepec según la colonia. El municipio es extenso; el costo refleja la distancia específica.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Ecatepec"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Ecatepec y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Ecatepec?"
    subtitle="Cotiza tu inflable con entrega en Ciudad Azteca, Las Américas, San Cristóbal y todo Ecatepec."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />
</PageLayout>
