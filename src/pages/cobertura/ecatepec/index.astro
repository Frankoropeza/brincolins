---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Ecatepec | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Ecatepec con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Ecatepec. Instalación profesional y precios accesibles.";

const colonias = [
  "Ciudad Azteca",
  "Las Américas",
  "San Cristóbal Ecatepec",
  "Ecatepec Centro",
  "Jardines de Morelos",
  "José López Portillo",
  "Valle de Aragón",
  "San Agustín",
  "Lomas de Carrizal",
  "Santa Clara Coatitla",
  "Los Olivos",
  "Xalostoc"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Ecatepec?", answer: "El cargo de envío a Ecatepec varía entre $150 y $300 dependiendo de la colonia. Ciudad Azteca, Las Américas y San Cristóbal tienen el cargo base. Colonias más alejadas hacia el norte de Ecatepec pueden tener un costo ligeramente mayor." },
  { question: "¿Pueden llevar inflables a salones de fiestas en Ecatepec?", answer: "Sí, somos proveedor habitual de salones de fiestas en Ecatepec. Si tu salón ya tiene el espacio, coordinamos con el administrador para la entrega y montaje. Lleva nuestro contacto de WhatsApp a tu salón de preferencia." },
  { question: "¿Cubren Ciudad Azteca y Las Américas en Ecatepec?", answer: "Sí, toda la zona de Ciudad Azteca, Las Américas y el Metro Ecatepec está dentro de nuestra cobertura. Son colonias con muy buena accesibilidad que nos permiten llegar puntualmente en la mayoría de horarios." },
  { question: "¿Tienen inflables para eventos con muchos niños en Ecatepec?", answer: "Sí. Para fiestas grandes en Ecatepec recomendamos los Dragones Rojos o el Inflable Extremo, con capacidad para 6-8 niños simultáneos. Para kermeses escolares o eventos corporativos, consulta nuestros paquetes multi-inflable." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Ecatepec" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Ecatepec</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Ecatepec</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Ecatepec</span></h1>
          <p class="hero__desc">Renta de inflables en Ecatepec de Morelos, Edomex. Entrega a Ciudad Azteca, Las Américas, San Cristóbal, Ecatepec Centro y todo el municipio. Servicio profesional con cargo accesible.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Ecatepec de Morelos es uno de los municipios más grandes y poblados del Estado de México, con millones de habitantes y una enorme demanda de servicios para eventos. BRINCOLINS cubre todo Ecatepec con entregas puntuales y profesionales. Desde Ciudad Azteca hasta las colonias del norte del municipio, llegamos a tiempo.</p>
          <p class="hero__copy-text">El municipio de Ecatepec tiene buenas vías de acceso: el Circuito Exterior Mexiquense, la autopista México-Pachuca y la Calzada San Juan de Aragón. Con un cargo de $200 a $350 de envío, garantizamos instalación profesional y retiro incluidos. Contáctanos para una cotización inmediata.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Ecatepec"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Ecatepec es un municipio extenso con decenas de colonias. Cubrimos desde Ciudad Azteca al sur hasta las colonias del norte del municipio."
        copy2="El cargo de $200-$350 varía según la distancia exacta. Ciudad Azteca y Las Américas (más cercanas a la CDMX) tienen el cargo menor; colonias del norte pueden tener el cargo mayor."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Ecatepec"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Ecatepec usamos el Circuito Exterior Mexiquense y la autopista México-Pachuca. Salimos con suficiente anticipación para garantizar puntualidad incluso con tráfico."
        copy2="Conocemos las colonias de Ecatepec y planificamos rutas eficientes. Para zonas de difícil acceso, coordinamos previamente para garantizar la entrega sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$350</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $350 para Ecatepec según la colonia. El municipio es extenso; el costo refleja la distancia específica.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Ecatepec"
        subtitle="Los favoritos para fiestas y kermeses en Ciudad Azteca, Las Américas y toda la zona."
        copy1="Ecatepec es el municipio más poblado del Edomex y uno de los de mayor demanda de inflables. La zona tiene una gran tradición de fiestas familiares con muchos niños."
        copy2="¿Salón de fiestas o casa con jardín en Ecatepec? Coordinamos la entrega directamente con el administrador del salón si así lo prefieres."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado Ecatepec</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Ecatepec. Alta capacidad para grupos numerosos de niños. Funciona en patios, jardines y salones de fiestas de toda la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito temático</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El diseño pirata es un hit en Ecatepec. Encanta a niños de 4 a 12 años y convierte cualquier fiesta en una aventura épica.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Kermeses</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para kermeses escolares y eventos grandes en Ecatepec. El modelo de mayor capacidad, ideal para grupos numerosos de niños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Ecatepec"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Ecatepec y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Ecatepec?"
    subtitle="Cotiza tu inflable con entrega en Ciudad Azteca, Las Américas, San Cristóbal y todo Ecatepec."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
