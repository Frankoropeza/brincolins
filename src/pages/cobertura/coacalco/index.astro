---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Coacalco | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Coacalco con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Coacalco. Instalación profesional y precios accesibles.";

const colonias = [
  "Coacalco Centro",
  "Bosques de Morelos",
  "La Quebrada",
  "San Crisanto",
  "Jazmín",
  "Los Reyes Acaquilpan",
  "San Francisco Cuautlalpan",
  "Coacalco de Berriozábal Centro",
  "La Aurora",
  "Residencial Bonito",
  "San Andrés",
  "Portal del Sol"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Coacalco?", answer: "El cargo de envío a Coacalco varía entre $150 y $250 dependiendo de la colonia. Coacalco Centro, Bosques de Morelos y La Quebrada tienen el cargo base. Te confirmamos el costo exacto al cotizar con tu dirección." },
  { question: "¿Pueden entregar en los fraccionamientos de Coacalco?", answer: "Sí. Coacalco tiene varios fraccionamientos residenciales bien establecidos. Para los que tienen acceso controlado, coordinamos el registro de nuestro vehículo con 24h de anticipación. Solo necesitamos datos del residente y nombre del fraccionamiento." },
  { question: "¿Cubren Bosques de Morelos y San Crisanto?", answer: "Sí, Bosques de Morelos, San Crisanto, La Quebrada y todas las colonias de Coacalco están dentro de nuestra cobertura en el Estado de México. El cargo de envío aplica por la distancia desde nuestro almacén." },
  { question: "¿Qué inflables son más populares en Coacalco?", answer: "En Coacalco los más solicitados son los Dragones Rojos por su alta capacidad y el Castillo de Princesas para cumpleaños de niñas. El Inflable Extremo es muy popular para eventos con muchos niños en los jardines y áreas comunes de la zona." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Coacalco" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Coacalco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Coacalco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Coacalco</span></h1>
          <p class="hero__desc">Renta de inflables en Coacalco de Berriozábal, Edomex. Entrega en Coacalco Centro, Bosques de Morelos, La Quebrada, San Crisanto y todo el municipio. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Coacalco de Berriozábal es un municipio residencial del norte del Estado de México, colindante con Ecatepec y Tultitlán. BRINCOLINS llega a todo Coacalco con un cargo de envío de $200 a $300. Atendemos Coacalco Centro, Bosques de Morelos, La Quebrada y todas las colonias del municipio.</p>
          <p class="hero__copy-text">El municipio tiene buen acceso por el Circuito Exterior Mexiquense y la autopista México-Pachuca. Planificamos las rutas para garantizar puntualidad. Instalación profesional incluida y retiro al terminar. Contáctanos para cotizar tu evento en Coacalco.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Coacalco"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Coacalco de Berriozábal, incluyendo sus colonias residenciales y zonas más populares. El municipio tiene buena conectividad que facilita la entrega."
        copy2="El cargo de $200-$300 aplica para todo el municipio. Para zonas limítrofes con Ecatepec, el costo puede variar ligeramente."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Coacalco"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Coacalco tiene accesos por el Circuito Exterior Mexiquense y carreteras secundarias bien mantenidas. Optimizamos la ruta según el tráfico del día de tu evento."
        copy2="Los eventos en Coacalco son frecuentes los fines de semana. Reserva con anticipación para garantizar la disponibilidad del inflable que necesitas."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$200–$300</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $200 a $300 para Coacalco de Berriozábal según la colonia.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Coacalco"
        subtitle="Los favoritos para fiestas en Bosques de Morelos, La Quebrada y toda la zona."
        copy1="Coacalco tiene fraccionamientos residenciales bien consolidados con espacios adecuados para inflables de todos los tamaños. La zona norte del Edomex tiene gran demanda de renta de inflables."
        copy2="¿Fraccionamiento con acceso controlado? Coordina el registro con 24h de anticipación y llegamos sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en Coacalco. Alta capacidad y colores vivos. Funciona perfecto en jardines de fraccionamientos y casas de la zona norte del Edomex.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El más solicitado para cumpleaños de niñas en Coacalco. Sus colores y diseño temático hacen de cualquier fiesta una celebración especial.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Eventos con grupos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para fiestas con muchos niños en Coacalco. El modelo de mayor capacidad de BRINCOLINS, ideal para eventos en áreas comunes de fraccionamientos.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Coacalco"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Coacalco y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Coacalco?"
    subtitle="Cotiza tu inflable con entrega en Coacalco Centro, Bosques de Morelos, La Quebrada y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
