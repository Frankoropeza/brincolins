---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Tlalnepantla | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Tlalnepantla con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Tlalnepantla. Instalación profesional y precios accesibles.";

const colonias = [
  "Centro Tlalnepantla",
  "Las Américas",
  "Vallejo",
  "Industrial",
  "San Javier",
  "La Romana",
  "Lomas de San Miguel",
  "Cuautitlán",
  "San Lucas Tepetlacalco",
  "Tenayo",
  "Buenavista",
  "El Mirador"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Tlalnepantla?", answer: "El cargo de envío a Tlalnepantla varía entre $150 y $250 dependiendo de la colonia. Tlalnepantla Centro, Las Américas y Vallejo Industrial tienen el cargo base. Para colonias más alejadas al norte de la vía del tren, puede ser ligeramente mayor." },
  { question: "¿Atienden eventos corporativos en la zona industrial de Tlalnepantla?", answer: "Sí. La zona industrial de Tlalnepantla es una de nuestras áreas de trabajo para eventos corporativos, kermeses de empresa y días familiares. Tenemos paquetes multi-inflable para este tipo de eventos — ver /servicios/inflables-para-eventos/." },
  { question: "¿Cubren las zonas residenciales de Tlalnepantla como Industrial y Las Américas?", answer: "Sí. Cubrimos toda la extensión del municipio: tanto las zonas industriales como las residenciales de Tlalnepantla Centro, Las Américas, Industrial Vallejo y las colonias habitacionales del municipio." },
  { question: "¿Pueden llevar varios inflables para una kermesse en Tlalnepantla?", answer: "Sí. Gestionamos paquetes multi-inflable para kermeses escolares y eventos corporativos en Tlalnepantla. Coordinamos el montaje de 2-4 unidades con logística incluida. Consulta disponibilidad con 3+ semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Tlalnepantla" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Tlalnepantla</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Tlalnepantla</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Tlalnepantla</span></h1>
          <p class="hero__desc">Renta de inflables en Tlalnepantla de Baz, Edomex. Entrega programada en Centro, Las Américas, Vallejo, Industrial y todo el municipio. Servicio profesional con cargo de envío accesible.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Tlalnepantla de Baz es uno de los municipios más industriales y poblados del Estado de México, con una mezcla de zonas residenciales, comerciales e industriales. BRINCOLINS cubre todo el municipio con entregas puntuales. Atendemos desde las colonias del Centro hasta Las Américas y la zona industrial de Vallejo.</p>
          <p class="hero__copy-text">La excelente conectividad de Tlalnepantla — autopista Chamapa, Periférico Norte y Boulevard Manuel Ávila Camacho — nos permite llegar puntualmente con un cargo de envío de $150 a $250. Instalación profesional y retiro incluidos en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Tlalnepantla"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todo Tlalnepantla de Baz, desde el Centro hasta las colonias residenciales en los cerros y las zonas industriales del norte del municipio."
        copy2="El costo de $150-$250 aplica para todo el municipio. Para colonias en los límites con Naucalpan o Cuautitlán, confirmamos el costo al momento de cotizar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Tlalnepantla"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Tlalnepantla tiene excelentes vías de acceso: el Boulevard Manuel Ávila Camacho, la autopista Chamapa-Lechería y el Periférico Norte. Optimizamos la ruta según el horario de entrega."
        copy2="Para eventos en zonas industriales o en edificios con políticas de acceso específicas, coordinamos previamente con el solicitante para garantizar la entrada del equipo."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$150–$250</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $150 a $250 para Tlalnepantla según la colonia. Se informa antes de confirmar la reserva.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Tlalnepantla"
        subtitle="Los favoritos para fiestas familiares y eventos corporativos en Tlalnepantla."
        copy1="Tlalnepantla es un municipio con doble identidad: zona industrial que nos contrata para kermeses de empresa, y zona residencial con gran demanda de inflables para fiestas familiares."
        copy2="¿Kermesse de empresa o evento corporativo en Tlalnepantla? Tenemos paquetes multi-inflable especialmente diseñados para estos casos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Tlalnepantla. Alta capacidad para grupos grandes. Funciona perfecto tanto en jardines residenciales como en áreas de eventos corporativos.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Eventos corporativos</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">El favorito para kermeses de empresa en Tlalnepantla. El circuito de obstáculos más completo de BRINCOLINS para grupos numerosos en espacios abiertos.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito fiestas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El hit en fiestas familiares de Tlalnepantla. Diseño temático de aventura que entusiasma a niños de todas las edades en la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Tlalnepantla"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Tlalnepantla y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Tlalnepantla?"
    subtitle="Cotiza tu inflable con entrega programada en Centro, Las Américas, Vallejo y todo Tlalnepantla."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
