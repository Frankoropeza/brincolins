---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Texcoco | BRINCOLINS";
const description = "Renta de inflables en Texcoco, Edomex. Entrega incluida en Texcoco Centro, San Miguel Coatlinchán y Huexotla. Desde $800 MXN con seguro.";

const colonias = [
  "Texcoco Centro",
  "San Miguel Coatlinchán",
  "Atenco",
  "Chiconcuac",
  "Tepetlaoxtoc",
  "Papalotla",
  "San Andrés de las Peras",
  "Santa Cruz de Abajo",
  "Montecillo",
  "La Purísima",
  "Tlaminca",
  "San Bernardino"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Texcoco?", answer: "El cargo de envío a Texcoco varía entre $200 y $350 dependiendo de la colonia. Texcoco Centro tiene el cargo base. Colonias como San Miguel Coatlinchán, Atenco o Chiconcuac pueden tener un costo mayor según la distancia exacta." },
  { question: "¿Cubren San Miguel Coatlinchán, Atenco y municipios aledaños?", answer: "Sí, además de Texcoco Centro cubrimos San Miguel Coatlinchán, Atenco y algunas localidades aledañas. Para municipios vecinos como Chiconcuac, confirma tu dirección exacta y te calculamos el costo de envío correspondiente." },
  { question: "¿Tienen inflables adecuados para eventos en espacios rurales de Texcoco?", answer: "Sí. El oriente del Estado de México tiene muchos espacios amplios y jardines generosos. Los inflables grandes como el Inflable Extremo y los Dragones Rojos brillan en los amplios terrenos de la zona. Nuestro equipo lleva equipo de nivelación para terrenos irregulares." },
  { question: "¿Con cuánta anticipación reservar para Texcoco?", answer: "Por la distancia al oriente del Edomex, recomendamos reservar con 2-3 semanas de anticipación. La logística al oriente requiere mayor coordinación. En temporadas altas reserva con al menos un mes para garantizar disponibilidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Texcoco" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Texcoco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Texcoco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Texcoco</span></h1>
          <p class="hero__desc">Renta de inflables en Texcoco, Estado de México. Entrega en Texcoco Centro, San Miguel Coatlinchán, Atenco, Chiconcuac y todo el municipio. Servicio profesional y puntual.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Texcoco de Mora es un municipio histórico del oriente del Estado de México, con zonas universitarias, pueblos tradicionales y colonias residenciales. BRINCOLINS cubre Texcoco con un cargo de envío de $250 a $400. Atendemos Texcoco Centro, San Miguel Coatlinchán, Atenco y todos los municipios de la zona oriente.</p>
          <p class="hero__copy-text">La carretera Federal 142 y la autopista Texcoco-Peñón nos permiten llegar con puntualidad a la zona. Conocemos los accesos de Texcoco Centro y los pueblos aledaños. Instalación profesional incluida en el precio del inflable.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Texcoco"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos Texcoco Centro y todos los municipios y colonias de la región oriente del Estado de México. Desde Atenco hasta Tepetlaoxtoc y Chiconcuac."
        copy2="El cargo de $250-$400 aplica para Texcoco y los municipios cercanos. Para zonas más alejadas del oriente del Edomex, consultamos el costo."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Texcoco"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Para Texcoco usamos la autopista Texcoco-Peñón y la Federal 142. La ruta es directa y nos permite garantizar puntualidad en la entrega."
        copy2="Los pueblos de la región texcocana tienen espacios amplios para eventos. Si planeas un evento grande en un área comunitaria, contáctanos para recomendarte el inflable adecuado."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$250–$400</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $250 a $400 para Texcoco según la colonia y distancia desde nuestro almacén.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Texcoco"
        subtitle="Los favoritos para fiestas y eventos en Texcoco Centro y toda la zona oriente."
        copy1="Texcoco y el oriente del Edomex tienen amplios espacios y tradición de fiestas familiares grandes. Los inflables encuentran en esta zona los jardines perfectos para lucirse al máximo."
        copy2="¿Localidad rural o terreno amplio en Texcoco? Confirma tu dirección y te calculamos el tiempo de llegada y costo exacto de envío."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en Texcoco. Alta capacidad y colores vivos. Los amplios espacios del oriente del Edomex son perfectos para este inflable.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Temático popular</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">El diseño pirata es muy popular en las fiestas del oriente. Ideal para cumpleaños temáticos y eventos con niños de todas las edades en Texcoco.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Espacios grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para los amplios terrenos de Texcoco y zonas rurales del oriente. El modelo más grande de BRINCOLINS para grupos numerosos de niños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Texcoco"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Texcoco y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Texcoco?"
    subtitle="Cotiza tu inflable con entrega en Texcoco Centro, San Miguel Coatlinchán, Atenco y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
