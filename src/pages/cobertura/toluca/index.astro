---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Toluca | BRINCOLINS";
const description = "Renta de inflables en Toluca, Edomex. Entrega incluida en Toluca Centro, Metepec y Zinacantepec. Desde $800 MXN con instalación y seguro.";

const colonias = [
  "Toluca Centro",
  "San Mateo Atenco",
  "Zinacantepec",
  "Almoloya de Juárez",
  "Metepec",
  "Lerma",
  "Ocoyoacac",
  "Xonacatlán",
  "San Pedro Totoltepec",
  "Santiago Miltepec",
  "Barrio La Merced",
  "Colonia Morelos"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Toluca?", answer: "Por ser la ciudad más distante que cubrimos, el cargo de envío a Toluca varía entre $400 y $600 MXN. Este costo refleja el traslado adicional de aproximadamente 65 km desde nuestro almacén. Te confirmamos el costo exacto con tu dirección." },
  { question: "¿Qué zonas de Toluca atienden?", answer: "Atendemos Toluca Centro, San Mateo Atenco, Zinacantepec, Almoloya de Juárez y zonas aledañas. Para municipios colindantes como Metepec, tenemos una página específica con información de esa zona." },
  { question: "¿Con cuánta anticipación hay que reservar para Toluca?", answer: "Por la distancia, recomendamos reservar con 4-6 semanas de anticipación. La logística a Toluca requiere mayor coordinación y disponibilidad de vehículos. Para temporadas altas, reserva con 6-8 semanas de margen." },
  { question: "¿Qué inflables recomiendan para Toluca?", answer: "Para Toluca recomendamos los modelos con mayor relación costo-capacidad para que el cargo de envío valga la pena. Los Dragones Rojos y el Inflable Extremo son la mejor inversión para eventos con muchos niños. Para fiestas de niñas, el Castillo de Princesas es el favorito." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Toluca" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Toluca</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Toluca</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Toluca</span></h1>
          <p class="hero__desc">Renta de inflables en Toluca, Estado de México. Entrega en Toluca Centro, San Mateo Atenco, Zinacantepec, Almoloya y toda la zona metropolitana de Toluca. Servicio profesional.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Toluca es la capital del Estado de México y una ciudad con gran demanda de servicios de entretenimiento para eventos. BRINCOLINS llega hasta Toluca con un cargo de envío de $400 a $600 que cubre el traslado desde la CDMX. Atendemos Toluca Centro, San Mateo Atenco, Zinacantepec y toda la zona metropolitana del Valle de Toluca.</p>
          <p class="hero__copy-text">La autopista México-Toluca permite llegar a la capital mexiquense en aproximadamente 1 hora desde nuestro almacén. Coordinamos la entrega con suficiente anticipación y garantizamos puntualidad. Instalación profesional y retiro incluidos. Para Toluca, recomendamos reservar con al menos 2 semanas de anticipación.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Toluca"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos Toluca Centro y los principales municipios del Valle de Toluca: Zinacantepec, Almoloya, San Mateo Atenco y más. Es una zona amplia con muchas oportunidades para eventos."
        copy2="El cargo de $400-$600 es un rango base. Para municipios más alejados del Valle de Toluca como Ixtlahuaca o Villa Victoria, el costo puede ser mayor; consultamos caso por caso."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Toluca"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Usamos la autopista México-Toluca como ruta principal. Salimos con suficiente anticipación para garantizar puntualidad, considerando el tráfico en la autopista especialmente los fines de semana."
        copy2="Para Toluca y el Valle de Toluca, la reserva con anticipación es fundamental. Los fines de semana son muy concurridos y nuestra agenda se llena rápido para esta zona."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$400–$600</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $400 a $600 para Toluca por la distancia desde la CDMX. Se coordina con anticipación para garantizar disponibilidad.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Toluca"
        subtitle="Selección de alto impacto para hacer valer el traslado desde la CDMX."
        copy1="Toluca es la ciudad más lejana de nuestra cobertura, pero la servimos con el mismo nivel de profesionalismo. Para que el cargo de envío valga la pena, recomendamos nuestros modelos de mayor capacidad."
        copy2="¿Evento en Toluca? Reserva con al menos 4 semanas de anticipación para coordinar correctamente la logística del traslado."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Mejor relación costo</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El modelo con mejor relación capacidad-precio para Toluca. Alta capacidad para grupos grandes de niños que justifica el traslado desde la CDMX.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El favorito para fiestas de niñas en Toluca. Colores vibrantes y diseño temático que hace de cualquier cumpleaños una celebración especial.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Mayor capacidad</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">El modelo más grande de BRINCOLINS para Toluca. Para eventos y kermeses con muchos niños donde el inflable se aprovecha al máximo.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Toluca"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Toluca y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Toluca?"
    subtitle="Cotiza tu inflable con entrega en Toluca Centro, San Mateo Atenco, Zinacantepec y todo el Valle de Toluca."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
