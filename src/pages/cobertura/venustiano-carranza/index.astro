---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Venustiano Carranza | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Venustiano Carranza con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Venustiano Carranza. Instalación profesional y precios accesibles.";

const colonias = [
  "Jardín Balbuena",
  "Moctezuma I Sección",
  "Moctezuma II Sección",
  "Aeropuerto",
  "Merced",
  "Tepito",
  "Peñón de los Baños",
  "El Parque",
  "Valle Gómez",
  "Nicolás Bravo",
  "Morelos",
  "Magdalena Mixhuca"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Venustiano Carranza?", answer: "El envío está completamente incluido en el precio para todas las colonias de Venustiano Carranza: Jamaica, Morelos, Aeropuerto, Moctezuma, Peñón de los Baños, Jardín Balbuena y todas las demás." },
  { question: "¿Pueden instalar inflables en casas con patio en Venustiano Carranza?", answer: "Sí. En Venustiano Carranza los patios interiores y jardines son el tipo de espacio más común para nuestros eventos. Para evaluar si el inflable cabe, mándanos una foto del espacio y en minutos te confirmamos cuál modelo es el más adecuado." },
  { question: "¿Cubren la zona de Aeropuerto y Peñón de los Baños?", answer: "Sí, toda la zona del Aeropuerto y Peñón de los Baños está cubierta con entrega incluida. Conocemos bien la vialidad de la zona, incluyendo los accesos por el Circuito Interior y el Eje 1 Norte." },
  { question: "¿Atienden eventos en Jamaica y colonias populares de Venustiano Carranza?", answer: "Por supuesto. Jamaica y Morelos son dos de las colonias con mayor demanda de inflables en la alcaldía. Atendemos desde pequeñas fiestas de cumpleaños hasta eventos más grandes en salones de la zona." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Venustiano Carranza" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Venustiano Carranza</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Venustiano Carranza</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Venustiano Carranza</span></h1>
          <p class="hero__desc">Renta de inflables en Venustiano Carranza CDMX. Entrega incluida en Jardín Balbuena, Moctezuma, Merced, zona aeropuerto y toda la alcaldía. Servicio profesional garantizado.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La alcaldía Venustiano Carranza tiene zonas muy variadas: desde la elegante Jardín Balbuena con sus amplios jardines hasta las colonias históricas de la Merced y Tepito. BRINCOLINS cubre toda la alcaldía con envío incluido, conociendo perfectamente las rutas y accesos de cada zona.</p>
          <p class="hero__copy-text">Somos especialistas en entregas en la zona del aeropuerto internacional y sus alrededores. Conocemos los accesos a Moctezuma, Peñón de los Baños y las colonias industriales de la alcaldía. Instalación profesional, equipos desinfectados y retiro puntual al terminar el evento.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Venustiano Carranza"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Venustiano Carranza, desde Jardín Balbuena al poniente hasta el Aeropuerto al oriente. La alcaldía tiene gran variedad de espacios para eventos."
        copy2="Para colonias históricas con calles angostas como Tepito y Merced, usamos vehículos adecuados. Confirmamos el tipo de acceso al momento de cotizar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Venustiano Carranza"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Venustiano Carranza tiene excelentes accesos: Circuito Interior, Viaducto y la Calzada Ignacio Zaragoza. La cercanía con el aeropuerto hace que muchas rutas sean muy eficientes."
        copy2="Para colonias con calles angostas o restricciones de circulación, utilizamos vehículos de menor tamaño cuando es necesario. Siempre llegamos puntualmente al horario acordado."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío completamente incluido en todas las colonias de Venustiano Carranza.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Venustiano Carranza"
        subtitle="Los favoritos para cumpleaños y fiestas familiares en Jamaica, Morelos y toda la alcaldía."
        copy1="Venustiano Carranza es una alcaldía con gran tradición de fiestas familiares. Los inflables se instalan en patios, jardines y salones de toda la zona con puntualidad garantizada."
        copy2="¿Patio pequeño en Jamaica o espacio de salón? Mándanos foto y te recomendamos el inflable que mejor funcione para tu evento."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El más rentado en Venustiano Carranza. Colores brillantes y gran capacidad. El hit de las fiestas en Jamaica y Morelos.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Temático popular</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">Diseño de aventura pirata que entusiasma a niños de todas las edades. Muy solicitado en cumpleaños y eventos familiares en Venustiano Carranza.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">La reina de las fiestas de niñas en la alcaldía. Colores vivos y diseño temático que convierte cualquier cumpleaños en un evento mágico.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Venustiano Carranza"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Venustiano Carranza y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Venustiano Carranza?"
    subtitle="Cotiza tu inflable con entrega incluida en Jardín Balbuena, Moctezuma, Merced y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
