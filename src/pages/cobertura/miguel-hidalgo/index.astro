---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Miguel Hidalgo | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Miguel Hidalgo con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Miguel Hidalgo. Instalación profesional y precios accesibles.";

const colonias = [
  "Polanco I Sección",
  "Polanco II Sección",
  "Lomas de Chapultepec",
  "Anzures",
  "Tacuba",
  "Irrigación",
  "Verónica Anzures",
  "Popotla",
  "Daniel Garza",
  "Granada",
  "Pensil Norte",
  "Pensil Sur"
];

const faqs = [
  { question: "¿Pueden instalar inflables en roof gardens de edificios en Polanco?", answer: "Sí, es una de nuestras solicitudes más frecuentes en Polanco. Necesitamos acceso al elevador de carga, una toma de 110V dentro de 5m y confirmación del espacio disponible. Evaluamos vía foto antes de confirmar." },
  { question: "¿Tienen experiencia en residencias con seguridad privada en Lomas de Chapultepec?", answer: "Llevamos más de 5 años entregando en Lomas de Chapultepec y zonas aledañas. Coordinamos el acceso con 24–48h de anticipación enviando datos del conductor y vehículo. El proceso es fluido para nuestros clientes habituales de la zona." },
  { question: "¿Qué modelo recomiendan para fiestas en Polanco o Lomas?", answer: "Para eventos en zonas premium recomendamos el Castillo Blanco: estética elegante con colores neutros que combina con cualquier decoración. Para cumpleaños de niñas, el Castillo de Princesas es el favorito. Para grupos mixtos con niños mayores, los Dragones Rojos." },
  { question: "¿Pueden llevar varios inflables a un evento en Miguel Hidalgo?", answer: "Sí. Gestionamos paquetes multi-inflable para residencias en Lomas, salones en Polanco o eventos corporativos en la zona. Coordinamos el montaje de 2 a 4 unidades con un coordinador asignado. Consulta disponibilidad con al menos 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Miguel Hidalgo" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Miguel Hidalgo</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Miguel Hidalgo</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Miguel Hidalgo</span></h1>
          <p class="hero__desc">Renta de inflables en Miguel Hidalgo CDMX. Entrega incluida en Polanco, Lomas de Chapultepec, Anzures, Tacuba, Irrigación y toda la alcaldía. Servicio premium para eventos exclusivos.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Miguel Hidalgo es una de las alcaldías más exclusivas de la Ciudad de México, con zonas como Polanco, Lomas de Chapultepec y Las Lomas que concentran eventos de gran nivel. BRINCOLINS ofrece servicio premium en toda la alcaldía: inflables de primera calidad, equipos perfectamente desinfectados y equipos de instalación profesionales que conocen los estándares de cada zona.</p>
          <p class="hero__copy-text">Tenemos experiencia trabajando en las residencias de Lomas, los hoteles de Polanco y los salones de eventos de Anzures. Para fraccionamientos cerrados y residencias con seguridad privada, coordinamos el acceso con anticipación. Todo incluido en el precio: traslado, instalación, supervisión y retiro.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Miguel Hidalgo"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Miguel Hidalgo, desde las exclusivas zonas de Lomas y Polanco hasta las colonias populares de Tacuba y Popotla."
        copy2="Para residencias en Lomas de Chapultepec y fraccionamientos cerrados, coordinamos previamente el acceso. Requerimos los datos del residente para gestionar la entrada de nuestro equipo."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Miguel Hidalgo"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Miguel Hidalgo tiene excelentes vías de acceso: Periférico, Reforma, Mariano Escobedo y el Anillo Periférico. Para Polanco y Anzures, preferimos el Circuito Interior en horarios de baja congestión."
        copy2="Nuestros equipos van uniformados y presentables. Para eventos en zonas de alto nivel como Polanco y Lomas, garantizamos que el personal de instalación cumple con los estándares de presentación que estas zonas requieren."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío completamente incluido en todas las colonias de Miguel Hidalgo: Polanco, Lomas de Chapultepec, Tacuba, Anzures y más.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Miguel Hidalgo"
        subtitle="Selección premium para los espacios exclusivos de Polanco y Lomas."
        copy1="Miguel Hidalgo concentra algunos de los eventos infantiles más cuidados de la CDMX. Nuestros clientes en Polanco y Lomas buscan inflables con buena presencia visual y calidad garantizada."
        copy2="¿Tienes un espacio específico en mente? Compártenos las medidas y te decimos exactamente qué modelo funciona mejor en tu residencia o salón."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Estética premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">El modelo más elegante de BRINCOLINS. Diseño neutro y sofisticado que encaja perfecto en residencias de Lomas de Chapultepec y salones de Polanco.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El favorito en cumpleaños de niñas en Polanco y Anzures. Colores pastel y diseño temático que combina con cualquier decoración de fiesta.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El inflable más solicitado a nivel general. Perfecto para jardines en Lomas y eventos con grupos mixtos de niños de distintas edades.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Miguel Hidalgo"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Miguel Hidalgo y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Miguel Hidalgo?"
    subtitle="Cotiza tu inflable con entrega incluida en Polanco, Lomas de Chapultepec, Anzures y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card {
      display: block;
      text-decoration: none;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.08);
      
      background: var(--color-bg-card, #fff);
      color: inherit;
    }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
