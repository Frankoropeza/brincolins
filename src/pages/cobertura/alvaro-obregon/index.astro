---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Álvaro Obregón y Santa Fe CDMX";
const description = "Entregamos inflables en Álvaro Obregón, Santa Fe, San Ángel y Pedregal. Precios desde $800 MXN con instalación incluida. Cotiza por WhatsApp.";

const colonias = [
  "Santa Fe", "San Ángel", "Pedregal", "Lomas Altas", "Altavista",
  "Tetelpan", "Merced Gómez", "Axotla", "Las Águilas", "Olivar del Conde",
  "San Jerónimo Aculco", "Tizapán"
];

const faqs = [
  { question: "¿Pueden instalar inflables en residencias con jardín en San Ángel o Lomas Altas?", answer: "Sí, San Ángel y Lomas Altas tienen jardines amplios ideales para nuestros inflables. Coordinamos el acceso a fraccionamientos cerrados con 24h de anticipación. Solo necesitamos el nombre del residente." },
  { question: "¿Tienen experiencia en eventos en Santa Fe CDMX?", answer: "Sí. Los condominios y residencias de Santa Fe son una zona de alta demanda para BRINCOLINS. Tenemos experiencia en roof gardens y áreas comunes con normas estrictas de acceso. Evaluamos tu espacio vía foto antes de confirmar." },
  { question: "¿Cubren el Pedregal y Altavista en Álvaro Obregón?", answer: "Sí. El Pedregal de Álvaro Obregón, Altavista y Axotla están dentro de nuestra cobertura con entrega sin costo adicional. Los jardines amplios del Pedregal son perfectos para inflables grandes como el Extremo o los Dragones Rojos." },
  { question: "¿Qué inflable recomiendan para una casa en Olivar del Conde o Tetelpan?", answer: "Para jardines medianos en Olivar del Conde o Tetelpan, los Dragones Rojos son la opción ideal. Si el espacio es más compacto, el Mini Castillo encaja en patios de 3×3m. Mándanos foto del espacio y te recomendamos al instante." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Álvaro Obregón" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Álvaro Obregón</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Álvaro Obregón</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Álvaro Obregón</span></h1>
          <p class="hero__desc">Llevamos inflables y brincolines a toda la alcaldía Álvaro Obregón: Santa Fe, San Ángel, Pedregal, Lomas Altas y más. Entrega incluida, instalación profesional y atención todos los días.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La alcaldía Álvaro Obregón cuenta con algunas de las zonas residenciales más exclusivas de la CDMX: Santa Fe con sus modernos desarrollos, San Ángel con sus amplias casas coloniales, y el Pedregal con jardines espectaculares. BRINCOLINS conoce perfectamente estas zonas y garantiza entregas puntuales en todos los fraccionamientos y accesos controlados de la alcaldía.</p>
          <p class="hero__copy-text">Nuestro servicio en Álvaro Obregón incluye traslado desde nuestro almacén, instalación profesional del inflable, supervisión técnica durante el evento y retiro al finalizar — todo sin costo adicional de envío. Contamos con inflables para todo tipo de espacios: desde jardines compactos en Tetelpan hasta eventos grandes en Santa Fe. Escríbenos y te cotizamos en minutos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Álvaro Obregón"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la alcaldía Álvaro Obregón, con especial atención a las colonias de mayor demanda como Santa Fe, San Ángel e Interlomas. Cada entrega incluye instalación y retiro sin costo adicional."
        copy2="Si tu colonia no aparece en esta lista pero está dentro de la alcaldía o zonas limítrofes como Cuajimalpa o Magdalena Contreras, contáctanos — probablemente podamos atenderte sin cargo extra."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Álvaro Obregón"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Álvaro Obregón tiene excelentes accesos viales: Periférico, Viaducto y la autopista México-Toluca nos permiten llegar puntualmente. Conocemos los accesos de Santa Fe, los condominios de San Ángel y las calles cerradas del Pedregal."
        copy2="Para eventos en fraccionamientos con caseta de seguridad, coordinamos el acceso previamente. Solo necesitamos el nombre del residente y la colonia para gestionar la entrada sin demoras."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido en el precio para todas las colonias de Álvaro Obregón.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Álvaro Obregón"
        subtitle="Selección perfecta para jardines de San Ángel, Pedregal, Santa Fe y Lomas Altas."
        copy1="Álvaro Obregón tiene gran variedad de espacios: residencias coloniales en San Ángel, roof gardens en Santa Fe y amplios jardines en el Pedregal. Tenemos el modelo perfecto para cada tipo."
        copy2="¿No sabes cuál encaja? Mándanos foto del espacio por WhatsApp y te recomendamos el inflable ideal."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">San Ángel premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">Diseño elegante y neutro. El favorito en residencias de San Ángel y Santa Fe donde se busca estética cuidada para el evento.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El más solicitado en Álvaro Obregón. Jardines en el Pedregal y Altavista son el escenario perfecto para este modelo de gran capacidad.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/mini-castillo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#7C3AED,#9C27B0);">
            <span class="inflable-rec-card__tag">Espacios compactos</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Mini Castillo</h3>
            <p class="inflable-rec-card__desc">Para patios compactos en Olivar del Conde o Tetelpan. Solo necesita 3×3m libres. Perfecto para niños de 2 a 7 años.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Álvaro Obregón"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Álvaro Obregón es una de las alcaldías con mayor variedad de espacios para eventos: desde jardines en unidades habitacionales hasta residencias con amplias terrazas en Santa Fe y San Ángel."
        copy2="Estas son las preguntas más comunes de nuestros clientes en Álvaro Obregón. ¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Álvaro Obregón?"
    subtitle="Cotiza tu inflable con entrega incluida en Santa Fe, San Ángel, Pedregal y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
