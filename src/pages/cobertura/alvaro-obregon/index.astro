---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Álvaro Obregón, Santa Fe y San Ángel | BRINCOLINS";
const description = "Renta de inflables en Álvaro Obregón CDMX. Entrega incluida en Santa Fe, San Ángel, Pedregal, Lomas Altas y toda la alcaldía. Instalación profesional.";

const colonias = [
  "Santa Fe", "San Ángel", "Pedregal", "Lomas Altas", "Altavista",
  "Tetelpan", "Merced Gómez", "Axotla", "Las Águilas", "Olivar del Conde",
  "San Jerónimo Aculco", "Tizapán"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Álvaro Obregón?", answer: "El envío está incluido en el precio del inflable para las colonias principales de Álvaro Obregón: Santa Fe, San Ángel, Pedregal, Lomas Altas y Altavista. No hay cargos adicionales de flete." },
  { question: "¿Qué inflables son más populares en Álvaro Obregón?", answer: "Los más solicitados en esta alcaldía son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos mucha demanda de combinados con alberca y tobogán para eventos en jardines amplios de Santa Fe y San Ángel." },
  { question: "¿Atienden fines de semana en Álvaro Obregón?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos. La alcaldía Álvaro Obregón es una de nuestras zonas de mayor demanda en sábados y domingos." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con al menos 1 semana de anticipación. Para fines de semana y temporada alta (vacaciones de verano, Semana Santa y diciembre), lo ideal es reservar con 2-3 semanas para garantizar disponibilidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Álvaro Obregón" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Álvaro Obregón</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">📍 Álvaro Obregón</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Álvaro Obregón</span></h1>
          <p class="hero__desc">Llevamos inflables y brincolines a toda la alcaldía Álvaro Obregón: Santa Fe, San Ángel, Pedregal, Lomas Altas y más. Entrega incluida, instalación profesional y atención todos los días.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La alcaldía Álvaro Obregón cuenta con algunas de las zonas residenciales más exclusivas de la CDMX: Santa Fe con sus modernos desarrollos, San Ángel con sus amplias casas coloniales, y el Pedregal con jardines espectaculares. BRINCOLINS conoce perfectamente estas zonas y garantiza entregas puntuales en todos los fraccionamientos y accesos controlados de la alcaldía.</p>
          <p class="hero__copy-text">Nuestro servicio en Álvaro Obregón incluye traslado desde nuestro almacén, instalación profesional del inflable, supervisión técnica durante el evento y retiro al finalizar — todo sin costo adicional de envío. Contamos con inflables para todo tipo de espacios: desde jardines compactos en Tetelpan hasta eventos grandes en Santa Fe. Escríbenos y te cotizamos en minutos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Álvaro Obregón"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la alcaldía Álvaro Obregón, con especial atención a las colonias de mayor demanda como Santa Fe, San Ángel e Interlomas. Cada entrega incluye instalación y retiro sin costo adicional."
        copy2="Si tu colonia no aparece en esta lista pero está dentro de la alcaldía o zonas limítrofes como Cuajimalpa o Magdalena Contreras, contáctanos — probablemente podamos atenderte sin cargo extra."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Álvaro Obregón"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Álvaro Obregón tiene excelentes accesos viales: Periférico, Viaducto y la autopista México-Toluca nos permiten llegar puntualmente. Conocemos los accesos de Santa Fe, los condominios de San Ángel y las calles cerradas del Pedregal."
        copy2="Para eventos en fraccionamientos con caseta de seguridad, coordinamos el acceso previamente. Solo necesitamos el nombre del residente y la colonia para gestionar la entrada sin demoras."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido en el precio para todas las colonias de Álvaro Obregón.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Álvaro Obregón"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Álvaro Obregón es una de las alcaldías con mayor variedad de espacios para eventos: desde jardines en unidades habitacionales hasta residencias con amplias terrazas en Santa Fe y San Ángel."
        copy2="Estas son las preguntas más comunes de nuestros clientes en Álvaro Obregón. ¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Álvaro Obregón?"
    subtitle="Cotiza tu inflable con entrega incluida en Santa Fe, San Ángel, Pedregal y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />
</PageLayout>
