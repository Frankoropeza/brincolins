---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Magdalena Contreras | BRINCOLINS";
const description = "Renta de inflables en Magdalena Contreras, CDMX. Entrega incluida en La Magdalena, San Jerónimo y Barranca Seca. Desde $800 MXN con seguro.";

const colonias = [
  "La Magdalena",
  "San Jerónimo Aculco",
  "San Jerónimo Lídice",
  "Barranca del Muerto",
  "El Rosal",
  "Pedregal de San Nicolás",
  "Las Cruces",
  "Pueblo Quieto",
  "San Bernabé Ocotepec",
  "Las Águilas",
  "Tetelpan",
  "San Jerónimo Miacatlán"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Magdalena Contreras?", answer: "El envío está incluido para las principales colonias de Magdalena Contreras. Para zonas más apartadas en las lomas, contáctanos para confirmar costo." },
  { question: "¿Qué inflables son más populares en Magdalena Contreras?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Magdalena Contreras?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Magdalena Contreras." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Magdalena Contreras" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Magdalena Contreras</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Magdalena Contreras</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Magdalena Contreras</span></h1>
          <p class="hero__desc">Renta de inflables en Magdalena Contreras CDMX. Entrega incluida en La Magdalena, San Jerónimo, Barranca del Muerto, El Rosal y toda la alcaldía. Servicio profesional en la alcaldía verde de la CDMX.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La Magdalena Contreras es una de las alcaldías más verdes y tranquilas de la Ciudad de México, con amplios jardines y espacios abiertos perfectos para eventos con inflables. BRINCOLINS cubre toda la alcaldía con envío incluido: desde San Jerónimo hasta La Magdalena Centro y las zonas residenciales de Barranca del Muerto.</p>
          <p class="hero__copy-text">La alcaldía tiene algunas zonas de acceso complicado por su topografía, pero nuestro equipo conoce perfectamente las rutas. Para colonias en laderas o con calles angostas, coordinamos previamente para garantizar que el inflable llegue sin problemas. Instalación profesional y retiro incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Magdalena Contreras"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la alcaldía Magdalena Contreras, incluyendo sus colonias boscosas y residenciales. La zona sur de la alcaldía tiene espacios privilegiados para eventos al aire libre."
        copy2="Para las zonas más elevadas de la alcaldía, como San Bernabé Ocotepec, contáctanos para confirmar el tipo de vehículo disponible para la entrega."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Magdalena Contreras"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="La Magdalena Contreras tiene accesos por el Periférico Sur y la Calzada Desierto de los Leones. Planificamos las rutas con anticipación para evitar el tráfico y llegar a tiempo."
        copy2="La topografía de la alcaldía puede ser un reto, pero tenemos experiencia entregando inflables en zonas con pendientes y calles estrechas. Siempre confirmamos el acceso antes de la entrega."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido para las principales colonias de Magdalena Contreras: La Magdalena, San Jerónimo, Barranca del Muerto y El Rosal.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Magdalena Contreras"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Magdalena Contreras y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Magdalena Contreras?"
    subtitle="Cotiza tu inflable con entrega incluida en La Magdalena, San Jerónimo, Barranca del Muerto y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />
</PageLayout>
