---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en La Magdalena Contreras | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en La Magdalena Contreras con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en La Magdalena Contreras. Instalación profesional y precios accesibles.";

const colonias = [
  "La Magdalena",
  "San Jerónimo Aculco",
  "San Jerónimo Lídice",
  "Barranca del Muerto",
  "El Rosal",
  "Pedregal de San Nicolás",
  "Las Cruces",
  "Pueblo Quieto",
  "San Bernabé Ocotepec",
  "Las Águilas",
  "Tetelpan",
  "San Jerónimo Miacatlán"
];

const faqs = [
  { question: "¿Cubren San Jerónimo Aculco y Pedregal de San Nicolás en La Magdalena Contreras?", answer: "Sí. San Jerónimo Aculco, Pedregal de San Nicolás y todas las colonias de La Magdalena Contreras están dentro de nuestra cobertura. El envío está incluido en el precio para toda la alcaldía." },
  { question: "¿Pueden instalar en terrenos con pendiente en La Magdalena Contreras?", answer: "La Magdalena Contreras es una alcaldía montañosa con muchos terrenos en pendiente. Nuestro equipo lleva niveladores y anclas para instalación segura en terrenos irregulares. Si la pendiente es pronunciada (más de 15°), te informamos antes de confirmar." },
  { question: "¿Qué accesos usan para llegar a La Magdalena Contreras?", answer: "Principalmente Insurgentes Sur y la carretera Picacho-Ajusco nos dan acceso a las colonias principales. Para zonas más internas y elevadas, planificamos salidas más tempranas para garantizar puntualidad en tu evento." },
  { question: "¿Tienen inflables adecuados para los jardines de La Contreras?", answer: "Sí. Las casas en La Magdalena Contreras suelen tener jardines bien establecidos y espacio generoso. Los Dragones Rojos y el Castillo de Princesas son los más rentados en la zona. Para eventos grandes, el Inflable Extremo es la mejor opción." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Magdalena Contreras" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Magdalena Contreras</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Magdalena Contreras</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Magdalena Contreras</span></h1>
          <p class="hero__desc">Renta de inflables en Magdalena Contreras CDMX. Entrega incluida en La Magdalena, San Jerónimo, Barranca del Muerto, El Rosal y toda la alcaldía. Servicio profesional en la alcaldía verde de la CDMX.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La Magdalena Contreras es una de las alcaldías más verdes y tranquilas de la Ciudad de México, con amplios jardines y espacios abiertos perfectos para eventos con inflables. BRINCOLINS cubre toda la alcaldía con envío incluido: desde San Jerónimo hasta La Magdalena Centro y las zonas residenciales de Barranca del Muerto.</p>
          <p class="hero__copy-text">La alcaldía tiene algunas zonas de acceso complicado por su topografía, pero nuestro equipo conoce perfectamente las rutas. Para colonias en laderas o con calles angostas, coordinamos previamente para garantizar que el inflable llegue sin problemas. Instalación profesional y retiro incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Magdalena Contreras"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la alcaldía Magdalena Contreras, incluyendo sus colonias boscosas y residenciales. La zona sur de la alcaldía tiene espacios privilegiados para eventos al aire libre."
        copy2="Para las zonas más elevadas de la alcaldía, como San Bernabé Ocotepec, contáctanos para confirmar el tipo de vehículo disponible para la entrega."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Magdalena Contreras"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="La Magdalena Contreras tiene accesos por el Periférico Sur y la Calzada Desierto de los Leones. Planificamos las rutas con anticipación para evitar el tráfico y llegar a tiempo."
        copy2="La topografía de la alcaldía puede ser un reto, pero tenemos experiencia entregando inflables en zonas con pendientes y calles estrechas. Siempre confirmamos el acceso antes de la entrega."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido para las principales colonias de Magdalena Contreras: La Magdalena, San Jerónimo, Barranca del Muerto y El Rosal.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en La Magdalena Contreras"
        subtitle="Selección perfecta para los jardines y espacios de la alcaldía serrana."
        copy1="La Magdalena Contreras tiene algo especial: casas con jardines reales en un ambiente más tranquilo que el resto de la ciudad. Los inflables encajan perfectamente en este tipo de espacios."
        copy2="¿Jardín con pendiente o terreno irregular? No te preocupes — llevamos equipo de nivelación y lo instalamos de forma segura."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito en los jardines de La Contreras. Colores vibrantes y espacio para varios niños jugando al mismo tiempo en terrenos planos.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El más solicitado para cumpleaños de niñas en toda la alcaldía. Destaca especialmente en los jardines verdes del sur de la ciudad.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Eventos grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Para los jardines más amplios de La Magdalena Contreras. El circuito más completo de BRINCOLINS, perfecto para grupos numerosos de niños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Magdalena Contreras"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Magdalena Contreras y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Magdalena Contreras?"
    subtitle="Cotiza tu inflable con entrega incluida en La Magdalena, San Jerónimo, Barranca del Muerto y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
