---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Cuautitlán Izcalli | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Cuautitlán Izcalli con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Cuautitlán Izcalli. Instalación profesional y precios accesibles.";

const colonias = [
  "Izcalli Centro",
  "Hacienda del Parque",
  "Ojo de Agua",
  "Cumbria",
  "Cuautitlán Izcalli Centro",
  "Santiago Cuautlalpan",
  "San Juan Atlamica",
  "San Buenaventura",
  "URBI Villa Cuautitlán",
  "Banthí Izcalli",
  "Las Alamedas",
  "Villas del Campo"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Cuautitlán Izcalli?", answer: "El cargo de envío a Cuautitlán Izcalli varía entre $200 y $350 dependiendo de la colonia. Izcalli Centro, Hacienda del Parque y Ojo de Agua tienen el cargo base. Para Cumbria y zonas más alejadas el costo puede ser ligeramente mayor." },
  { question: "¿Pueden entregar en los fraccionamientos planeados de Izcalli?", answer: "Sí. Cuautitlán Izcalli es un municipio muy bien planeado con amplias avenidas y fácil acceso. Hemos entregado en Izcalli Centro, Ciudad Cuauhtémoc y otros fraccionamientos. Para los que tienen caseta de seguridad, coordinamos el acceso con anticipación." },
  { question: "¿Qué inflables recomiendan para las amplias áreas comunes en Izcalli?", answer: "Los fraccionamientos de Cuautitlán Izcalli suelen tener áreas comunes amplias perfectas para nuestros modelos grandes. Los Dragones Rojos y el Inflable Extremo son los más solicitados por ser los de mayor capacidad. Para eventos con más de 20 niños son ideales." },
  { question: "¿Con cuánta anticipación hay que reservar para Cuautitlán Izcalli?", answer: "Recomendamos reservar con 2-3 semanas de anticipación. Cuautitlán Izcalli tiene alta demanda los fines de semana. En temporadas altas (Semana Santa, verano, diciembre) reserva con un mes de anticipación para asegurar disponibilidad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Cuautitlán Izcalli" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Cuautitlán Izcalli</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Cuautitlán Izcalli</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Cuautitlán Izcalli</span></h1>
          <p class="hero__desc">Renta de inflables en Cuautitlán Izcalli, Edomex. Entrega en Izcalli Centro, Hacienda del Parque, Ojo de Agua, Cumbria y todo el municipio. Servicio profesional con envío programado.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Cuautitlán Izcalli es un municipio moderno del norte del Estado de México, con colonias residenciales bien planificadas como Izcalli Centro y Hacienda del Parque. BRINCOLINS llega hasta Cuautitlán Izcalli con un servicio profesional y un cargo de envío de $250 a $400 que cubre la distancia adicional.</p>
          <p class="hero__copy-text">El municipio tiene excelente conectividad por la autopista México-Querétaro. Planificamos la entrega con anticipación para garantizar puntualidad. Instalación completa y retiro al finalizar. Reserva con suficiente tiempo para asegurar disponibilidad en tu fecha.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Cuautitlán Izcalli"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Cuautitlán Izcalli, desde Izcalli Centro hasta las zonas residenciales más nuevas como Cumbria y Hacienda del Parque."
        copy2="El cargo de $250-$400 es fijo para todo el municipio. Para colonias en los límites con Cuautitlán de García Barragán o Tultitlán, confirmamos el costo al cotizar."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Cuautitlán Izcalli"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="La autopista México-Querétaro es nuestra ruta principal para llegar a Cuautitlán Izcalli. Es una ruta directa que nos permite garantizar tiempos de entrega razonables."
        copy2="Recomendamos reservar con 2-3 semanas de anticipación para asegurar disponibilidad en Cuautitlán Izcalli, especialmente para fines de semana."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$250–$400</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $250 a $400 para Cuautitlán Izcalli por la distancia desde nuestro almacén central.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Cuautitlán Izcalli"
        subtitle="Selección perfecta para los fraccionamientos y amplias áreas de Izcalli."
        copy1="Cuautitlán Izcalli es uno de los municipios más ordenados del Edomex con amplios fraccionamientos y áreas comunes. Sus espacios bien planeados son ideales para instalar inflables de todos los tamaños."
        copy2="¿Área común de fraccionamiento o jardín privado? Tenemos el inflable perfecto para cada tipo de espacio en Cuautitlán Izcalli."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Eventos premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">Diseño elegante para los eventos en los fraccionamientos residenciales de Cuautitlán Izcalli. Neutro y sofisticado para cualquier celebración.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El más solicitado en Izcalli. Alta capacidad y mucha diversión. Perfecto para las amplias áreas comunes de los fraccionamientos de la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">La elección número uno para cumpleaños de niñas en Cuautitlán Izcalli. Colorido y temático para hacer de la fiesta una experiencia especial.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Cuautitlán Izcalli"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Cuautitlán Izcalli y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Cuautitlán Izcalli?"
    subtitle="Cotiza tu inflable con entrega en Izcalli Centro, Hacienda del Parque, Ojo de Agua y todo el municipio."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
