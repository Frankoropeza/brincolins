---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Huixquilucan | Inflables para Fiestas | Estado de México";
const description = "Renta de inflables en Huixquilucan con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Huixquilucan. Instalación profesional y precios accesibles.";

const colonias = [
  "Interlomas",
  "La Herradura",
  "El Molinito",
  "Jesús del Monte",
  "Lomas de Bezares",
  "Bosque Real",
  "Santa Fe de las Lomas",
  "Hacienda de las Palmas",
  "Pedregal de las Animas",
  "Fraccionamiento La Herradura",
  "Zacamulpa",
  "San Cristóbal Texcalucan"
];

const faqs = [
  { question: "¿Cuánto es el cargo de envío a Huixquilucan e Interlomas?", answer: "El cargo de envío a Huixquilucan varía entre $150 y $250 dependiendo de la zona. Interlomas, La Herradura y El Molinito tienen el cargo base. Jesús del Monte y zonas más altas pueden tener un costo adicional." },
  { question: "¿Tienen experiencia en fraccionamientos de lujo en La Herradura e Interlomas?", answer: "Sí. Huixquilucan es una de nuestras zonas premium en Edomex. Llevamos años entregando en La Herradura, Interlomas y Club de Golf Bellavista. Coordinamos el acceso con las casetas de seguridad con 24-48h de anticipación." },
  { question: "¿Qué modelo de inflable recomiendan para residencias en La Herradura?", answer: "Para los eventos en La Herradura y fraccionamientos de lujo en Huixquilucan, el Castillo Blanco es nuestra recomendación estrella por su estética elegante y neutro. Para fiestas infantiles temáticas, el Castillo de Princesas o los Dragones Rojos son los más solicitados." },
  { question: "¿Pueden llevar varios inflables a un evento grande en Huixquilucan?", answer: "Sí. Gestionamos paquetes multi-inflable para eventos en residencias de La Herradura y salones de Interlomas. Coordinamos el montaje de 2-4 unidades con un coordinador asignado. Consulta disponibilidad con al menos 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Huixquilucan" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Huixquilucan</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Huixquilucan</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Huixquilucan</span></h1>
          <p class="hero__desc">Renta de inflables en Huixquilucan, Edomex. Entrega en La Herradura, Interlomas, Jesús del Monte, El Molinito y todo el municipio. Servicio premium para las zonas residenciales más exclusivas.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Huixquilucan alberga algunas de las zonas residenciales más exclusivas del área metropolitana: La Herradura, Interlomas y Jesús del Monte. BRINCOLINS tiene amplia experiencia en estas zonas, conociendo los accesos de los fraccionamientos cerrados, los reglamentos internos y las expectativas de calidad de los eventos en estas colonias.</p>
          <p class="hero__copy-text">Nuestro servicio en Huixquilucan incluye inflatables premium, equipos de instalación uniformados y presentables, y coordinación previa con los accesos de seguridad. Cargo de envío de $150 a $250 según la zona. Instalación profesional y retiro al finalizar tu evento.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Huixquilucan"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la zona residencial de Huixquilucan: Interlomas, La Herradura, Jesús del Monte y los fraccionamientos exclusivos de la zona poniente."
        copy2="Para fraccionamientos cerrados como Bosque Real o Hacienda de las Palmas, coordinamos el acceso con la caseta de seguridad. Requerimos los datos del residente con anticipación."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Huixquilucan"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Huixquilucan tiene acceso por la autopista México-Toluca, el Periférico y el Boulevard Magnocentro. Para Interlomas y La Herradura, conocemos los accesos de cada fraccionamiento."
        copy2="Para eventos en zonas residenciales de alto nivel, garantizamos que nuestros equipos van uniformados y con todo el material necesario. Coordinamos previamente para cumplir con los reglamentos internos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">$150–$250</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Cargo de envío de $150 a $250 para Huixquilucan. Las zonas residenciales premium de Interlomas y La Herradura tienen el cargo menor.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Huixquilucan"
        subtitle="Selección premium para La Herradura, Interlomas y los fraccionamientos de lujo."
        copy1="Huixquilucan concentra algunas de las residencias más exclusivas del Edomex en La Herradura, Interlomas y Club de Golf Bellavista. Nuestro servicio premium se adapta a los estándares de estas zonas."
        copy2="¿Fraccionamiento con acceso controlado? Coordinamos el registro con 24-48h de anticipación para garantizar una entrada sin contratiempos."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Estética premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">El modelo elegante por excelencia. Neutro, sofisticado y perfecto para las residencias de La Herradura e Interlomas en Huixquilucan.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El favorito en cumpleaños de niñas en Huixquilucan. Diseño temático y colorido que hace brillar cualquier fiesta en las residencias de la zona.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El inflable más solicitado en general. Perfecto para los amplios jardines de La Herradura y eventos con grupos mixtos de niños de distintas edades.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Huixquilucan"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido eventos en Huixquilucan y conocemos las particularidades del municipio. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Huixquilucan?"
    subtitle="Cotiza tu inflable con entrega en La Herradura, Interlomas, Jesús del Monte y todo Huixquilucan."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
