---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Azcapotzalco | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Azcapotzalco con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Azcapotzalco. Instalación profesional y precios accesibles.";

const colonias = [
  "Del Gas", "Clavería", "Pasteros", "Santa Bárbara", "Ángel Zimbrón",
  "Tezozomoc", "San Álvaro", "Popotla", "Reynosa Tamaulipas",
  "Pensador Mexicano", "Cosmopolita", "Nextengo"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Azcapotzalco?", answer: "El envío está incluido en el precio para todas las colonias de Azcapotzalco: Del Gas, Pasteros, Tezozomoc, San Marcos, Coltongo y todas las demás. No hay cargo adicional de flete." },
  { question: "¿Qué tipo de espacios son más comunes para eventos en Azcapotzalco?", answer: "En Azcapotzalco la mayoría de nuestros eventos son en casas con patio o jardín, salones de fiestas y áreas comunes de unidades habitacionales. Los jardines en colonias como San Marcos y Del Gas son perfectos para inflables medianos y grandes." },
  { question: "¿Pueden llevar inflables a kermeses en escuelas de Azcapotzalco?", answer: "Sí. Atendemos kermeses escolares en Azcapotzalco con regularidad. Coordinamos directamente con la dirección de la escuela para el acceso y montaje. Para kermeses recomendamos reservar con 3-4 semanas de anticipación." },
  { question: "¿Cubren la zona industrial de Azcapotzalco para eventos corporativos?", answer: "Sí. También atendemos eventos corporativos en la zona industrial de Azcapotzalco — activaciones, kermeses de empresa y días familiares. Consulta nuestros paquetes para eventos en /servicios/inflables-para-eventos/." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Azcapotzalco" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Azcapotzalco</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Azcapotzalco</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Azcapotzalco</span></h1>
          <p class="hero__desc">Renta de inflables y brincolines en toda la alcaldía Azcapotzalco: Del Gas, Clavería, Pasteros, Santa Bárbara y más. Envío sin costo, instalación profesional y servicio 7 días.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Azcapotzalco es una alcaldía con fuerte tradición familiar y gran densidad de colonias populares con patios y jardines ideales para eventos infantiles. BRINCOLINS atiende toda la alcaldía con un servicio de entrega puntual: conocemos las calles de Clavería, los accesos de Del Gas y las particularidades de cada colonia para garantizar que tu inflable llegue a tiempo.</p>
          <p class="hero__copy-text">Nuestro servicio en Azcapotzalco incluye traslado, instalación, supervisión y retiro, todo sin costo de envío. Contamos con inflables de todos los tamaños: pequeños para interiores y patios compactos, medianos para jardines familiares y grandes para eventos en canchas o áreas al aire libre. Contáctanos y recibe tu cotización al instante.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Azcapotzalco"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Atendemos todas las colonias de Azcapotzalco sin excepción. Desde las zonas más céntricas como Clavería y Del Gas hasta colonias más alejadas como Nextengo y Cosmopolita."
        copy2="¿Tu colonia no aparece? Escríbenos — si está dentro de la alcaldía o en zonas limítrofes de GAM o Miguel Hidalgo, con toda seguridad podemos atenderte."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Azcapotzalco"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="La alcaldía Azcapotzalco tiene excelente conectividad: el Periférico Norte, la Calzada Vallejo y el Anillo Periférico nos permiten llegar rápidamente a cualquier punto de la alcaldía. Optimizamos nuestras rutas para cumplir el horario acordado."
        copy2="Nuestros equipos llegan con todo el material necesario: el inflable, el compresor, las extensiones y los elementos de seguridad. La instalación toma entre 30 y 90 minutos según el tamaño del inflable."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío sin costo en todas las colonias de Azcapotzalco.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Azcapotzalco"
        subtitle="Los favoritos para fiestas familiares y eventos en la alcaldía del norte."
        copy1="Azcapotzalco tiene una mezcla única de colonias residenciales con jardines bien establecidos y zonas industriales que nos contratan para eventos corporativos y kermeses."
        copy2="Para kermeses escolares o eventos corporativos en Azcapotzalco, revisa nuestros paquetes multi-inflable."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El número uno en Azcapotzalco. Resistente, colorido y con capacidad para grupos grandes. El favorito en fiestas del norte de la ciudad.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/barco-pirata/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#0277BD,#01579B);">
            <span class="inflable-rec-card__tag">Favorito temático</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Barco Pirata</h3>
            <p class="inflable-rec-card__desc">Diseño de galeón que encanta a niños de 4 a 12 años. Muy popular en las fiestas familiares de colonias como Del Gas y Pasteros.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Kermeses</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">El modelo de mayor capacidad. Perfecto para kermeses escolares y eventos con muchos niños en los amplios espacios de Azcapotzalco.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Azcapotzalco"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Llevamos años atendiendo eventos en Azcapotzalco. Conocemos las particularidades de cada colonia y hemos trabajado en todo tipo de espacios: desde patios pequeños hasta jardines amplios y áreas comunitarias."
        copy2="¿Tienes una duda específica sobre tu evento? Escríbenos por WhatsApp y te respondemos rápidamente con toda la información que necesitas."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Azcapotzalco?"
    subtitle="Cotiza tu inflable con entrega incluida en Del Gas, Clavería, Pasteros y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08); transition: transform 0.2s, box-shadow 0.2s; background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
