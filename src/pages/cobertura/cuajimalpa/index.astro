---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Cuajimalpa | BRINCOLINS";
const description = "Renta de inflables en Cuajimalpa. Renta de inflables en Cuajimalpa CDMX. Entrega puntual en Santa Fe, Cuajimalpa Centro, Contadero, El";

const colonias = [
  "Santa Fe",
  "Cuajimalpa Centro",
  "Contadero",
  "El Molinito",
  "La Venta",
  "San Pablo Chimalpa",
  "Palo Alto",
  "Cuajimalpa de Morelos",
  "Las Lomas de Bezares",
  "Zedec Santa Fe",
  "Bosques de las Lomas",
  "La Mexicana"
];

const faqs = [
  { question: "¿Cuánto cuesta el envío a Cuajimalpa?", answer: "El envío está incluido para Santa Fe, Cuajimalpa Centro, Contadero y El Molinito. Para zonas más apartadas de la alcaldía podría aplicar un pequeño cargo adicional; contáctanos para confirmar." },
  { question: "¿Qué inflables son más populares en Cuajimalpa?", answer: "Los más solicitados son los Dragones Rojos, el Castillo de Princesas y el Barco Pirata. También tenemos toboganes, combinados con alberca y temáticos para todo tipo de fiestas." },
  { question: "¿Atienden fines de semana en Cuajimalpa?", answer: "Sí, operamos los 7 días de la semana, incluyendo fines de semana y días festivos en toda la zona de Cuajimalpa." },
  { question: "¿Cuánto tiempo antes debo reservar?", answer: "Recomendamos reservar con 1-2 semanas de anticipación. Para fines de semana y temporadas altas (Semana Santa, verano, diciembre), lo ideal es reservar con 3 semanas de anticipación." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Cuajimalpa" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Cuajimalpa</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🌲 Cuajimalpa</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Cuajimalpa</span></h1>
          <p class="hero__desc">Renta de inflables en Cuajimalpa CDMX. Entrega puntual en Santa Fe, Cuajimalpa Centro, Contadero, El Molinito y toda la alcaldía. Instalación profesional garantizada.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Cuajimalpa es una alcaldía con zonas muy diversas: desde los modernos corporativos y torres residenciales de Santa Fe hasta los pueblos pintorescos de Cuajimalpa Centro y Contadero. BRINCOLINS atiende toda la alcaldía con inflables adecuados para cada tipo de espacio, desde terrazas en Santa Fe hasta jardines en Contadero.</p>
          <p class="hero__copy-text">Nuestros equipos conocen los accesos de los desarrollos corporativos y residenciales de Santa Fe, así como las rutas alternas para Cuajimalpa Centro cuando hay tráfico en la autopista. Envío incluido, instalación profesional y atención 7 días. Reserva con anticipación para fines de semana.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Colonias"
        title="Colonias con cobertura en Cuajimalpa"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Cuajimalpa, desde el moderno corredor Santa Fe hasta los pueblos con historia de la zona alta de la alcaldía."
        copy2="Para zonas de alta altitude como San Mateo Tlaltenango, contáctanos para confirmar disponibilidad y tiempo de entrega. Generalmente podemos atenderte sin problema."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🚚 Entrega"
        title="Servicio de entrega en Cuajimalpa"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Cuajimalpa tiene accesos por la autopista México-Toluca y el Periférico. Para Santa Fe usamos preferentemente el Boulevard Manuel Ávila Camacho. Para Cuajimalpa Centro planificamos rutas que evitan el tráfico de la autopista."
        copy2="En Santa Fe coordinamos accesos con las administraciones de los edificios residenciales. Para Torres y condominios con horarios de carga, es importante avisarnos con anticipación para programar la entrega en el horario permitido."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido en el precio para las colonias principales de Cuajimalpa: Santa Fe, Cuajimalpa Centro, Contadero y El Molinito.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes sobre Cuajimalpa"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Cuajimalpa y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Cuajimalpa?"
    subtitle="Cotiza tu inflable con entrega incluida en Santa Fe, Cuajimalpa Centro, Contadero y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />
</PageLayout>
