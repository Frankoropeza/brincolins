---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Cuajimalpa | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Cuajimalpa con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Cuajimalpa. Instalación profesional y precios accesibles.";

const colonias = [
  "Santa Fe",
  "Cuajimalpa Centro",
  "Contadero",
  "El Molinito",
  "La Venta",
  "San Pablo Chimalpa",
  "Palo Alto",
  "Cuajimalpa de Morelos",
  "Las Lomas de Bezares",
  "Zedec Santa Fe",
  "Bosques de las Lomas",
  "La Mexicana"
];

const faqs = [
  { question: "¿Cubren Santa Fe del lado de Cuajimalpa?", answer: "Sí. Santa Fe (en la parte correspondiente a Cuajimalpa) está dentro de nuestra zona de cobertura con entrega incluida en el precio. Conocemos los accesos de los fraccionamientos y torres residenciales de la zona." },
  { question: "¿Pueden instalar inflables en zonas con terreno irregular en Cuajimalpa?", answer: "Cuajimalpa tiene zonas con pendientes y terrenos irregulares, especialmente en el Contadero y áreas cercanas al bosque. Nuestro equipo evalúa el terreno y usa niveladores cuando es necesario. Si la pendiente es mayor a 15°, te informamos antes de confirmar." },
  { question: "¿El acceso a Cuajimalpa por la carretera México-Toluca es problemático?", answer: "Los accesos a Cuajimalpa pueden tener tráfico en horas pico. Programamos entregas temprano por la mañana o coordinamos horarios fuera del tráfico. Para eventos con hora de inicio específica, confirma el horario con 48h de anticipación." },
  { question: "¿Qué inflable recomiendan para un jardín amplio en Contadero o Cuajimalpa Centro?", answer: "Para los jardines amplios del Contadero y Cuajimalpa Centro, los Dragones Rojos y el Inflable Extremo son perfectos — tienen espacio para 6 a 8 niños simultáneamente. Para jardines más compactos, el Castillo Princesas o el Mini Castillo son ideales." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Cuajimalpa" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Cuajimalpa</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Cuajimalpa</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Cuajimalpa</span></h1>
          <p class="hero__desc">Renta de inflables en Cuajimalpa CDMX. Entrega puntual en Santa Fe, Cuajimalpa Centro, Contadero, El Molinito y toda la alcaldía. Instalación profesional garantizada.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Cuajimalpa es una alcaldía con zonas muy diversas: desde los modernos corporativos y torres residenciales de Santa Fe hasta los pueblos pintorescos de Cuajimalpa Centro y Contadero. BRINCOLINS atiende toda la alcaldía con inflables adecuados para cada tipo de espacio, desde terrazas en Santa Fe hasta jardines en Contadero.</p>
          <p class="hero__copy-text">Nuestros equipos conocen los accesos de los desarrollos corporativos y residenciales de Santa Fe, así como las rutas alternas para Cuajimalpa Centro cuando hay tráfico en la autopista. Envío incluido, instalación profesional y atención 7 días. Reserva con anticipación para fines de semana.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Cuajimalpa"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de Cuajimalpa, desde el moderno corredor Santa Fe hasta los pueblos con historia de la zona alta de la alcaldía."
        copy2="Para zonas de alta altitude como San Mateo Tlaltenango, contáctanos para confirmar disponibilidad y tiempo de entrega. Generalmente podemos atenderte sin problema."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Cuajimalpa"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Cuajimalpa tiene accesos por la autopista México-Toluca y el Periférico. Para Santa Fe usamos preferentemente el Boulevard Manuel Ávila Camacho. Para Cuajimalpa Centro planificamos rutas que evitan el tráfico de la autopista."
        copy2="En Santa Fe coordinamos accesos con las administraciones de los edificios residenciales. Para Torres y condominios con horarios de carga, es importante avisarnos con anticipación para programar la entrega en el horario permitido."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido en el precio para las colonias principales de Cuajimalpa: Santa Fe, Cuajimalpa Centro, Contadero y El Molinito.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Cuajimalpa"
        subtitle="Selección ideal para los jardines y espacios de Santa Fe y el Contadero."
        copy1="Cuajimalpa tiene una mezcla de modernos desarrollos en Santa Fe y zonas con terrenos amplios en el Contadero. Cada espacio tiene sus particularidades — nosotros las conocemos."
        copy2="¿Terreno con pendiente o espacio irregular? Contáctanos y te asesoramos sobre el modelo que mejor se adapta a las condiciones de tu jardín."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/castillo-blanco/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#546E7A,#37474F);">
            <span class="inflable-rec-card__tag">Santa Fe premium</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo Blanco</h3>
            <p class="inflable-rec-card__desc">El modelo elegante para residencias y eventos en Santa Fe. Diseño neutro y sofisticado que encaja en cualquier decoración de fiesta.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/dragones-rojos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#B71C1C,#E53935);">
            <span class="inflable-rec-card__tag">Más rentado</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Dragones Rojos</h3>
            <p class="inflable-rec-card__desc">El favorito para los jardines amplios del Contadero y Cuajimalpa Centro. Alta capacidad y diversión para grupos grandes de niños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/mini-castillo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#7C3AED,#9C27B0);">
            <span class="inflable-rec-card__tag">Terrazas y patios</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Mini Castillo</h3>
            <p class="inflable-rec-card__desc">Para espacios más compactos en Santa Fe o Cuajimalpa. Solo 3×3m de base. Ideal cuando el jardín tiene espacio limitado.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Cuajimalpa"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Cuajimalpa y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Cuajimalpa?"
    subtitle="Cotiza tu inflable con entrega incluida en Santa Fe, Cuajimalpa Centro, Contadero y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
