---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Coyoacán | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Coyoacán con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Coyoacán. Instalación profesional y precios accesibles.";

const colonias = [
  "Coyoacán Centro",
  "Pedregal de Santo Domingo",
  "Villa Coapa",
  "Copilco",
  "Churubusco",
  "Del Carmen",
  "La Candelaria",
  "Ajusco",
  "Romero de Terreros",
  "Nueva Díaz Ordaz",
  "Barrio del Niño Jesús",
  "Los Reyes Coyoacán"
];

const faqs = [
  { question: "¿Pueden instalar inflables en patios pequeños en Coyoacán Centro?", answer: "Sí. Para las casas coloniales con patios del Centro de Coyoacán tenemos el Mini Castillo (3×3m) y los Gusanitos para bebés. Evaluamos el espacio vía foto por WhatsApp antes de confirmar la reserva." },
  { question: "¿El acceso a fraccionamientos del Pedregal es complicado?", answer: "No. Llevamos años entregando en los fraccionamientos cerrados del Pedregal. Solo necesitamos el nombre del residente y número de acceso para registrar nuestro vehículo en caseta de seguridad con 24h de anticipación." },
  { question: "¿Llevan inflables de agua para el verano en Coyoacán?", answer: "Sí. Los combinados con alberca inflable y toboganes de agua son muy populares en los jardines de Villa Coapa y el Pedregal de mayo a septiembre. Disponibles sujeto a temporada — consulta al cotizar." },
  { question: "¿Cubren Pedregal de San Ángel y los límites con Tlalpan?", answer: "Sí. Toda la zona del Pedregal hasta los límites de Coyoacán con Tlalpan y Álvaro Obregón está cubierta con entrega sin costo adicional. Si tu colonia limita con otra alcaldía, escríbenos y confirmamos en minutos." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Coyoacán" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Coyoacán</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Coyoacán</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Coyoacán</span></h1>
          <p class="hero__desc">Renta de inflables en Coyoacán CDMX. Entrega incluida en Coyoacán Centro, Pedregal, Villa Coapa, Copilco y más. Instalación profesional en los jardines y espacios de la alcaldía bohemia.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Coyoacán es una de las alcaldías con mayor identidad cultural de la CDMX, y sus amplios jardines y casas con patio la hacen perfecta para eventos con inflables. Desde el Centro de Coyoacán hasta Villa Coapa y el Pedregal, BRINCOLINS cubre toda la alcaldía con puntualidad y servicio impecable.</p>
          <p class="hero__copy-text">Conocemos los accesos de los fraccionamientos cerrados del Pedregal, las calles empedradas del centro histórico de Coyoacán y las amplias avenidas de Villa Coapa. Nuestro servicio incluye instalación completa y retiro sin costo. Para tu próximo evento en Coyoacán, escríbenos y te cotizamos al instante.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Coyoacán"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos toda la alcaldía Coyoacán, incluyendo colonias históricas, residenciales y populares. Desde el centro bohemio hasta las zonas modernas de Villa Coapa."
        copy2="Si tu colonia está dentro de Coyoacán o en zonas limítrofes con Tlalpan o Benito Juárez, contáctanos. Es muy probable que podamos atenderte sin costo de envío."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Coyoacán"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="Coyoacán tiene una red vial particular con calles angostas en el centro histórico y avenidas amplias hacia Villa Coapa. Nuestros equipos conocen bien la zona y planifican la ruta con anticipación para llegar a tiempo."
        copy2="Para eventos en el Centro de Coyoacán o zonas con calles angostas, usamos vehículos de menor tamaño cuando es necesario. Tu comodidad y la puntualidad de entrega son nuestra prioridad."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío incluido en el precio para toda la alcaldía Coyoacán. Sin cargos adicionales de flete.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Coyoacán"
        subtitle="Selección ideal para los jardines y espacios de la alcaldía."
        copy1="Coyoacán tiene gran variedad de espacios: desde patios coloniales compactos en el Centro hasta amplios jardines en el Pedregal. Tenemos el modelo perfecto para cada tipo de espacio."
        copy2="¿No sabes cuál elegir? Mándanos una foto de tu espacio por WhatsApp y te recomendamos el inflable ideal para tu evento en Coyoacán."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/extremo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="inflable-rec-card__tag">Jardines grandes</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Inflable Extremo</h3>
            <p class="inflable-rec-card__desc">Circuito de obstáculos, tobogán y zona de escalar. Perfecto para los amplios jardines del Pedregal y Villa Coapa. Capacidad para 6–8 niños simultáneamente.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/castillo-princesas/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#E91E8C,#C2185B);">
            <span class="inflable-rec-card__tag">Favorito niñas</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Castillo de Princesas</h3>
            <p class="inflable-rec-card__desc">El más solicitado para cumpleaños de niñas en Coyoacán. Colores vibrantes y diseño temático que hace brillar cualquier festejo familiar.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/mini-castillo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#7C3AED,#9C27B0);">
            <span class="inflable-rec-card__tag">Espacios compactos</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Mini Castillo</h3>
            <p class="inflable-rec-card__desc">Ideal para los patios coloniales del Centro de Coyoacán. Solo necesita 3×3m libres — la solución perfecta para casas históricas con espacio limitado.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Coyoacán"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Coyoacán y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Coyoacán?"
    subtitle="Cotiza tu inflable con entrega incluida en Coyoacán Centro, Pedregal, Villa Coapa y toda la alcaldía."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card {
      display: block;
      text-decoration: none;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.08);
      transition: transform 0.2s, box-shadow 0.2s;
      background: var(--color-bg-card, #fff);
      color: inherit;
    }
    .inflable-rec-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.12);
    }
    .inflable-rec-card__head {
      height: 88px;
      display: flex;
      align-items: flex-end;
      padding: 10px 14px;
    }
    .inflable-rec-card__tag {
      background: rgba(0,0,0,0.3);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 3px 8px;
      border-radius: 20px;
    }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name {
      font-size: 1rem;
      font-weight: 700;
      margin: 0 0 6px;
    }
    .inflable-rec-card__desc {
      font-size: 0.875rem;
      color: var(--color-text-muted, #666);
      line-height: 1.5;
      margin-bottom: 12px;
    }
    .inflable-rec-card__cta {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-primary, #FF3D00);
    }
  </style>
</PageLayout>
