---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import FaqItem from "@/components/FaqItem.astro";

const title = "Renta de Inflables en Cuauhtémoc | Inflables para Fiestas | CDMX";
const description = "Renta de inflables en Cuauhtémoc con entrega incluida. Inflables para fiestas infantiles, cumpleaños y eventos familiares en Cuauhtémoc. Instalación profesional y precios accesibles.";

const colonias = [
  "Roma Norte",
  "Roma Sur",
  "Condesa",
  "Juárez",
  "Centro Histórico",
  "Doctores",
  "Guerrero",
  "Santa María la Ribera",
  "Tepito",
  "Tabacalera",
  "San Rafael",
  "Buenavista"
];

const faqs = [
  { question: "¿Qué inflable cabe en una terraza o rooftop en Roma Norte o Condesa?", answer: "Para terrazas y rooftops recomendamos el Mini Castillo (3×3m de base) o los Gusanitos para bebés. Son nuestros modelos más compactos. Necesitamos mínimo 3×3m libres y una toma eléctrica a menos de 5m. Mándanos foto del espacio y confirmamos al instante." },
  { question: "¿El tráfico de Roma y Condesa los fines de semana complica la entrega?", answer: "Los domingos en Roma y Condesa hay cierres peatonales parciales. Programamos entregas desde las 8am para llegar antes de la saturación o bien planificamos rutas alternas. Si tienes un horario específico, coordínalo con 48h de anticipación para garantizar puntualidad." },
  { question: "¿Pueden instalar inflables en vecindades o patios del Centro Histórico?", answer: "Sí. Muchas vecindades del Centro Histórico tienen patios interiores amplios perfectos para nuestros modelos compactos. Solo necesitamos confirmar el acceso vehicular para descargar. Evaluamos vía foto antes de confirmar si el espacio es apto." },
  { question: "¿Tienen inflables para bebés menores de 3 años para primer año en Condesa?", answer: "Sí. Los Gusanitos y el Mini Jungla son perfectos para fiestas de primer año y bebés en departamentos con terraza o azotea. Suaves, seguros, sin bordes duros, y diseñados específicamente para los más pequeños de la familia." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cobertura", href: "/cobertura/" },
    { name: "Cuauhtémoc" }
  ]}
  faqItems={faqs}
>
  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/cobertura/">Cobertura</a><span class="breadcrumbs__sep">/</span>
      <span>Cuauhtémoc</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Cuauhtémoc</span>
          <h1 class="hero__title">Renta de Inflables en <span class="highlight">Cuauhtémoc</span></h1>
          <p class="hero__desc">Renta de inflables en la alcaldía Cuauhtémoc CDMX. Entrega incluida en Centro Histórico, Roma Norte, Condesa, Juárez, Tepito y más. Instalación profesional en la zona más céntrica de la capital.</p>
          <div class="hero__ctas">
            <a href="/contacto/"
               class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La alcaldía Cuauhtémoc es el corazón de la Ciudad de México y una de las zonas con mayor densidad de eventos en toda la capital. Desde las azoteas de la Colonia Roma hasta los jardines de Condesa y los eventos familiares en Guerrero, BRINCOLINS cubre toda la alcaldía con puntualidad y servicio de calidad.</p>
          <p class="hero__copy-text">Sabemos que en el centro de la ciudad los accesos pueden ser complicados: calles de sentido único, estacionamiento limitado y edificios con normativas de carga. Nuestros equipos tienen experiencia en todas estas situaciones y coordinan previamente para que tu inflable llegue sin contratiempos. Entrega incluida, instalación profesional y retiro al finalizar.</p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Colonias"
        title="Colonias con cobertura en Cuauhtémoc"
        subtitle="Entrega directa en estas colonias y zonas."
        copy1="Cubrimos todas las colonias de la alcaldía Cuauhtémoc, desde las icónicas Roma y Condesa hasta los barrios históricos como Tepito, Guerrero y Santa María la Ribera."
        copy2="La alcaldía Cuauhtémoc tiene gran diversidad de espacios: azoteas en condominios de Roma, patios en Guerrero y jardines en Santa María la Ribera. Tenemos inflables para cada tipo de espacio."
      />
      <div class="coverage__badges">
        {colonias.map(c => <span class="coverage__badge">{c}</span>)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Entrega"
        title="Servicio de entrega en Cuauhtémoc"
        subtitle="Puntualidad y profesionalismo garantizados."
        copy1="La alcaldía Cuauhtémoc es muy accesible desde cualquier punto de la ciudad. Sin embargo, hay horarios con alta congestión vial en ciertas zonas. Recomendamos programar la entrega fuera de horas pico para garantizar la puntualidad."
        copy2="Para edificios en Roma y Condesa con políticas de acceso específicas, coordinamos con la administración o con el solicitante para cumplir con los reglamentos internos del inmueble."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#00C853,#2E7D32);">
            <span class="why-card__img-label">GRATIS</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Costo de envío</h3>
            <p class="why-card__desc">Envío completamente incluido en todas las colonias de la alcaldía Cuauhtémoc.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación rápida</h3>
            <p class="why-card__desc">Montaje profesional en menos de 2 horas desde la llegada.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background:linear-gradient(135deg,#FF3D00,#FF6D00);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención permanente</h3>
            <p class="why-card__desc">WhatsApp disponible todo el día para confirmar y resolver dudas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Recomendados"
        title="Inflables más rentados en Cuauhtémoc"
        subtitle="Modelos compactos perfectos para azoteas, terrazas y patios en Roma, Condesa y Centro."
        copy1="La alcaldía Cuauhtémoc se caracteriza por departamentos, edificios y vecindades con espacios acotados. Nuestros modelos compactos están diseñados exactamente para estos casos."
        copy2="¿Tienes un rooftop en Roma Norte o una terraza en Condesa? Envíanos foto del espacio y te decimos en segundos qué modelo funciona para tu evento."
      />
      <div class="grid-3" style="max-width:900px;margin:0 auto;">
        <a href="/inflables/mini-castillo/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#7C3AED,#9C27B0);">
            <span class="inflable-rec-card__tag">Espacios compactos</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Mini Castillo</h3>
            <p class="inflable-rec-card__desc">El favorito para terrazas y azoteas en Roma y Condesa. Solo necesita 3×3m libres. Ideal para niños de 2–7 años en departamentos con espacio reducido.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/gusanitos/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#2E7D32,#00C853);">
            <span class="inflable-rec-card__tag">Bebés y primer año</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Gusanitos</h3>
            <p class="inflable-rec-card__desc">El modelo más popular para fiestas de primer año en departamentos de Condesa y Juárez. Suave, seguro y perfecto para los más pequeños.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
        <a href="/inflables/mini-jungla/" class="inflable-rec-card">
          <div class="inflable-rec-card__head" style="background:linear-gradient(135deg,#1565C0,#0288D1);">
            <span class="inflable-rec-card__tag">Temático compacto</span>
          </div>
          <div class="inflable-rec-card__body">
            <h3 class="inflable-rec-card__name">Mini Jungla</h3>
            <p class="inflable-rec-card__desc">Tobogán y zona de brinco en formato compacto con temática de selva. Perfecto para cumpleaños en departamentos de Santa María la Ribera y San Rafael.</p>
            <span class="inflable-rec-card__cta">Ver inflable →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre Cuauhtémoc"
        subtitle="Dudas comunes sobre entrega de inflables en esta zona."
        copy1="Hemos atendido cientos de eventos en Cuauhtémoc y conocemos las particularidades de cada colonia. Aquí respondemos las preguntas más frecuentes de nuestros clientes en la zona."
        copy2="¿Tienes otra duda? Escríbenos por WhatsApp y te respondemos en minutos con toda la información que necesitas para tu evento."
      />
      <div style="max-width:800px;margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Evento en Cuauhtémoc?"
    subtitle="Cotiza tu inflable con entrega incluida en Roma, Condesa, Centro Histórico y toda la alcaldía Cuauhtémoc."
    btnText="Solicitar cotización"
    btnHref="/contacto/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="cool"
  />

  <style>
    .inflable-rec-card { display: block; text-decoration: none; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.08);  background: var(--color-bg-card, #fff); color: inherit; }
    .inflable-rec-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
    .inflable-rec-card__head { height: 88px; display: flex; align-items: flex-end; padding: 10px 14px; }
    .inflable-rec-card__tag { background: rgba(0,0,0,0.3); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; border-radius: 20px; }
    .inflable-rec-card__body { padding: 16px; }
    .inflable-rec-card__name { font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
    .inflable-rec-card__desc { font-size: 0.875rem; color: var(--color-text-muted, #666); line-height: 1.5; margin-bottom: 12px; }
    .inflable-rec-card__cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary, #FF3D00); }
  </style>
</PageLayout>
