---
import PageLayout   from "@/layouts/PageLayout.astro";
import ProductCard  from "@/components/ProductCard.astro";
import FaqItem      from "@/components/FaqItem.astro";
import CtaBanner      from "@/components/CtaBanner.astro";
import SectionHeader  from "@/components/SectionHeader.astro";

const title = "Renta de Inflables para Fiestas en CDMX y Edomex | BRINCOLINS";
const description = "Renta de brincolines e inflables para fiestas infantiles en CDMX y Estado de México. +20 años de experiencia. Entrega, instalación y seguro incluidos. Cotiza ahora.";

const productos = [
  { slug: "mini-castillo", emoji: "🏰", name: "Mini Castillo", description: "El clásico castillo inflable perfecto para fiestas infantiles. Diversión garantizada para los más pequeños.", price: "$800", size: "4×4m", ages: "3-8 años", category: "Castillos", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Un mágico castillo temático de princesas con torres y decoración especial para las niñas.", price: "$900", size: "4×4m", ages: "3-8 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED" },
  { slug: "castillo-unicornio", emoji: "🦄", name: "Castillo Unicornio", description: "Mágico castillo inflable con arcoíris, colores pastel y destellos. El favorito de las niñas soñadoras.", price: "$950", size: "4×4m", ages: "3-8 años", category: "Princesas", categoryColor: "princesas", gradient: "#F06292, #CE93D8" },
  { slug: "castillo-medieval", emoji: "🏯", name: "Castillo Medieval", description: "Imponente castillo con torres almenadas y puente levadizo. Para los pequeños caballeros y guerreros.", price: "$1,000", size: "5×5m", ages: "4-12 años", category: "Castillos", categoryColor: "castillo", gradient: "#B71C1C, #E53935" },
  { slug: "castillo-dragon", emoji: "🐉", name: "Castillo Dragón", description: "Épico castillo dragón con cueva de entrada y tobogán de escape. La aventura más emocionante.", price: "$1,050", size: "5×4m", ages: "4-10 años", category: "Castillos", categoryColor: "castillo", gradient: "#2E7D32, #1B5E20" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Aventura en altamar con tobogán y cañón de espuma. El favorito de los niños aventureros.", price: "$950", size: "5×4m", ages: "4-10 años", category: "Aventura", categoryColor: "pirata", gradient: "#1565C0, #0D47A1" },
  { slug: "casa-brinco-jungla", emoji: "🌴", name: "Casa Brinco Jungla", description: "Temática selvática con animales y vegetación. Ideal para fiestas al aire libre.", price: "$850", size: "4×4m", ages: "3-8 años", category: "Aventura", categoryColor: "jungla", gradient: "#2E7D32, #1B5E20" },
  { slug: "cueva-dinosaurios", emoji: "🦕", name: "Cueva de Dinosaurios", description: "Emocionante cueva prehistórica con T-Rex y tobogán volcánico. Para los fanáticos de los dinosaurios.", price: "$900", size: "5×4m", ages: "3-10 años", category: "Aventura", categoryColor: "jungla", gradient: "#558B2F, #827717" },
  { slug: "nave-espacial", emoji: "🚀", name: "Nave Espacial", description: "Portal galáctico con tobogán de lanzamiento y planetas decorativos. Para los pequeños astronautas.", price: "$1,050", size: "5×5m", ages: "4-12 años", category: "Aventura", categoryColor: "pirata", gradient: "#1A237E, #283593" },
  { slug: "tobogan-acuatico", emoji: "💦", name: "Tobogán Acuático", description: "Diversión refrescante con tobogán y chapoteadero incluido. Perfecto para días calurosos.", price: "$1,200", size: "6×4m", ages: "5-12 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#0288D1, #01579B" },
  { slug: "parque-acuatico", emoji: "🌊", name: "Parque Acuático", description: "Doble tobogán con chapoteadero y zona de salpicaduras. La mayor atracción para fiestas de verano.", price: "$1,500", size: "7×5m", ages: "5-14 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#0277BD, #006064" },
  { slug: "alberca-inflable", emoji: "🏊", name: "Alberca Inflable", description: "Alberca con tobogán suave para los más pequeños. Ideal para fiestas de verano en casa.", price: "$1,000", size: "4×3m", ages: "2-8 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#00BCD4, #0097A7" },
  { slug: "inflable-deportivo", emoji: "⚽", name: "Inflable Deportivo", description: "Cancha de fútbol inflable con porterías. Para los pequeños deportistas de la fiesta.", price: "$1,100", size: "5×5m", ages: "6-14 años", category: "Deportivos", categoryColor: "deportivo", gradient: "#FF6F00, #E65100" },
  { slug: "pista-obstaculos", emoji: "🏁", name: "Pista de Obstáculos", description: "Circuito inflable con túneles, muros y rampas. Ideal para competencias y diversión extrema.", price: "$1,300", size: "8×4m", ages: "5-14 años", category: "Deportivos", categoryColor: "deportivo", gradient: "#E65100, #BF360C" },
  { slug: "ring-boxeo", emoji: "🥊", name: "Ring de Boxeo", description: "Ring inflable con guantes de espuma gigantes. La actividad más emocionante para los niños activos.", price: "$1,100", size: "5×5m", ages: "6-14 años", category: "Deportivos", categoryColor: "deportivo", gradient: "#F57F17, #E65100" },
];

const testimonios = [
  { name: "María González", location: "Coyoacán, CDMX", text: "Excelente servicio. Llegaron puntuales, el inflable estaba impecable y los niños no pararon de brincar. Definitivamente los volveré a contratar." },
  { name: "Roberto Hernández", location: "Naucalpan, Edomex", text: "Contraté el Barco Pirata para el cumpleaños de mi hijo y fue todo un éxito. Muy profesionales, seguros y a un precio justo. 100% recomendados." },
  { name: "Ana Laura Martínez", location: "Polanco, CDMX", text: "Ya es la tercera vez que rento con BRINCOLINS. Siempre puntuales, amables y los inflables en perfectas condiciones. Los mejores de CDMX sin duda." },
  { name: "Carlos Mendoza", location: "Tlalpan, CDMX", text: "Renté el tobogán acuático para la fiesta de verano de mis hijos. Todos los niños del vecindario vinieron a brincar. Servicio de primera." },
  { name: "Laura Sánchez", location: "Ecatepec, Edomex", text: "Pensé que sería complicado pero todo fue muy fácil. Cotización rápida por WhatsApp, llegaron a tiempo y el inflable estaba súper limpio." },
  { name: "Fernando Ríos", location: "Benito Juárez, CDMX", text: "Los precios son justos y el servicio increíble. El castillo de princesas hizo muy feliz a mi hija. Ya estoy planeando la siguiente fiesta con ellos." },
];

const faqs = [
  { question: "¿Cuáles son los precios de renta de inflables?", answer: "Nuestros precios van desde $800 MXN por evento. El precio incluye entrega, instalación, supervisión y recolección. Varía según el modelo y la zona de entrega." },
  { question: "¿Qué incluye el servicio de renta?", answer: "Incluye entrega, instalación profesional, motor/soplador, limpieza del inflable, seguro de responsabilidad civil y recolección al finalizar el evento." },
  { question: "¿Los inflables son seguros para los niños?", answer: "Absolutamente. Todos nuestros inflables cumplen con normas de seguridad, se revisan antes de cada evento y cuentan con seguro de responsabilidad civil." },
  { question: "¿Para qué edades son los inflables?", answer: "Tenemos inflables para niños de 3 a 14 años. Cada inflable tiene una recomendación de edad específica. Nuestro equipo te ayuda a elegir el más adecuado." },
  { question: "¿Cuánto tiempo dura la renta?", answer: "La renta estándar es por evento (hasta 8 horas). Si necesitas más tiempo, podemos ajustar el precio. Consulta por paquetes de día completo." },
  { question: "¿Necesito dejar un depósito?", answer: "Sí, pedimos un anticipo del 50% para reservar la fecha. El resto se paga el día del evento. Aceptamos transferencia, efectivo y tarjeta." },
  { question: "¿Qué pasa si llueve o necesito cancelar?", answer: "En caso de lluvia, reprogramamos sin costo. Para cancelaciones con más de 48 horas de anticipación, devolvemos el 100% del anticipo." },
];

const zonasCDMX = ["Coyoacán", "Benito Juárez", "Miguel Hidalgo", "Álvaro Obregón", "Tlalpan", "Cuauhtémoc", "Azcapotzalco", "Iztapalapa", "Xochimilco", "Gustavo A. Madero", "Iztacalco", "Venustiano Carranza", "Cuajimalpa", "Magdalena Contreras", "Tláhuac", "Milpa Alta"];
const zonasEdomex = ["Naucalpan", "Tlalnepantla", "Ecatepec", "Huixquilucan", "Atizapán", "Cuautitlán Izcalli", "Coacalco", "Metepec", "Toluca", "Texcoco", "Nezahualcóyotl", "Chalco", "Tecámac", "Nicolás Romero", "Tultitlán"];
---

<PageLayout
  title={title}
  description={description}
  pageType="home"
  faqItems={faqs.map(f => ({ question: f.question, answer: f.answer }))}
>

  <!-- HERO — Estilo Inflaty + Gama 2 columnas -->
  <section class="hero">
    <!-- Decorative shapes -->
    <div class="hero__shape hero__shape--1"></div>
    <div class="hero__shape hero__shape--2"></div>
    <div class="hero__shape hero__shape--3"></div>

    <div class="container">
      <div class="hero__grid">
        <!-- Columna izquierda -->
        <div>
          <span class="hero__badge">🎉 +20 años de experiencia en CDMX</span>
          <h1 class="hero__title">
            Renta de <span class="highlight">Inflables</span> para <span class="highlight">Fiestas</span> en CDMX y Estado de México
          </h1>
          <p class="hero__desc">
            Brincolines, toboganes y castillos inflables para fiestas infantiles. Entrega, instalación y seguro incluidos en todos nuestros servicios.
          </p>
          <div class="hero__ctas">
            <a href="https://wa.me/5511111111?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable%20para%20mi%20fiesta."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Cotizar por WhatsApp
            </a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver catálogo</a>
          </div>
          <div class="hero__social-proof">
            <span class="hero__stars">⭐⭐⭐⭐⭐</span>
            <span>+200 familias felices este año</span>
          </div>
        </div>

        <!-- Columna derecha — marketing copy -->
        <div class="hero__copy">
          <p class="hero__copy-text">
            En <strong>BRINCOLINS</strong> llevamos más de 20 años convirtiendo cumpleaños, kermeses y eventos familiares en momentos inolvidables. Contamos con el catálogo más completo de inflables en CDMX y Estado de México: castillos, toboganes, inflables acuáticos, temáticos y deportivos, todos con mantenimiento certificado y seguro de responsabilidad civil incluido.
          </p>
          <p class="hero__copy-text">
            Nuestro servicio es 100% sin complicaciones: cotizas por WhatsApp, confirmamos disponibilidad en minutos, llegamos a tiempo y montamos todo en menos de 2 horas. Tú solo disfruta la fiesta — nosotros nos encargamos del resto. ¿Por qué somos los favoritos de miles de familias en la ZMVM? Porque combinamos precio justo, puntualidad y un inflable limpio y seguro, garantizado.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER — Llamada a la acción colorida -->
  <CtaBanner
    title="Reserva hoy y obtén entrega GRATIS en CDMX y Edomex"
    subtitle="Respondemos en minutos. +500 fiestas al año con +20 años de experiencia."
    btnText="Cotizar por WhatsApp"
    btnHref="https://wa.me/5511111111?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable%20para%20mi%20fiesta."
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

  <!-- CATÁLOGO DE INFLABLES — Estilo Inflaty -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="🎈 Catálogo"
        title="Nuestros Inflables"
        subtitle="Elige el inflable perfecto para tu fiesta. Todos incluyen entrega, instalación y seguro."
        copy1="Contamos con la mayor variedad de brincolines e inflables para renta en CDMX y Estado de México. Desde castillos clásicos hasta toboganes acuáticos y pistas de obstáculos, cada inflable está diseñado para ofrecer horas de diversión segura en fiestas infantiles, cumpleaños, kermeses y eventos escolares."
        copy2="Todos nuestros inflables pasan por un riguroso proceso de limpieza y mantenimiento antes de cada evento. Fabricados con materiales de grado comercial, certificados en seguridad y con capacidad para múltiples niños simultáneamente. Elige el que más te guste y nosotros nos encargamos del resto."
      />
      <div class="grid-4">
        {productos.map(p => <ProductCard {...p} />)}
      </div>
      <div class="text-center mt-3">
        <a href="/inflables/" class="btn btn-secondary">Ver catálogo completo</a>
      </div>
    </div>
  </section>

  <!-- POR QUÉ ELEGIRNOS — Estilo Gama 2 columnas -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="✅ Confianza"
        title="¿Por qué elegirnos?"
        subtitle="Más de dos décadas cuidando la diversión de tus hijos."
        copy1="Somos la empresa de renta de inflables con más trayectoria en la Zona Metropolitana del Valle de México. Con más de 20 años en el mercado y más de 500 eventos al año, hemos perfeccionado cada detalle del servicio: desde la cotización rápida por WhatsApp hasta la instalación profesional en menos de 2 horas."
        copy2="Nuestro compromiso va más allá de entregar un inflable. Cada renta incluye seguro de responsabilidad civil, supervisión de seguridad, motor/soplador profesional y un equipo capacitado que garantiza que tu evento sea memorable. Por eso miles de familias en CDMX y Edomex nos eligen una y otra vez."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">+20</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">+20 años de experiencia</h3>
            <p class="why-card__desc">Miles de fiestas exitosas en CDMX y Estado de México nos respaldan.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">E&I</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Entrega e instalación incluida</h3>
            <p class="why-card__desc">Llevamos, instalamos y recogemos el inflable sin costo extra.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">100%</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Limpieza garantizada</h3>
            <p class="why-card__desc">Cada inflable se entrega perfectamente limpio y desinfectado.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FFD600, #FF6F00);">
            <span class="why-card__img-label">$$$</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Mejores precios</h3>
            <p class="why-card__desc">Precios competitivos con la mejor calidad. Sin costos ocultos.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7C3AED, #9C27B0);">
            <span class="why-card__img-label">SEG</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Seguro incluido</h3>
            <p class="why-card__desc">Todos nuestros inflables cuentan con seguro de responsabilidad civil.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #25D366, #128C7E);">
            <span class="why-card__img-label">24/7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Atención 24/7</h3>
            <p class="why-card__desc">Estamos disponibles por WhatsApp para resolver cualquier duda.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #E91E8C, #7C3AED);">
            <span class="why-card__img-label">2h</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación en 2 horas</h3>
            <p class="why-card__desc">Nuestro equipo profesional instala el inflable rápidamente en tu evento.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #0288D1, #01579B);">
            <span class="why-card__img-label">ZMVM</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Cobertura total CDMX y Edomex</h3>
            <p class="why-card__desc">Cubrimos las 16 alcaldías y principales municipios del Estado de México.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO — 4 pasos estilo Inflaty -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📋 Súper fácil"
        title="¿Cómo funciona?"
        subtitle="Rentar un inflable con nosotros es muy sencillo. Solo sigue estos 4 pasos."
        copy1="Sabemos que organizar una fiesta infantil puede ser estresante. Por eso simplificamos todo el proceso de renta de inflables para que tú solo te preocupes por disfrutar. Desde la primera consulta hasta la recolección del equipo, nuestro equipo se encarga de cada paso con profesionalismo y puntualidad."
        copy2="El proceso es 100% digital y rápido: cotizas por WhatsApp, confirmas disponibilidad en minutos, apartas tu fecha con un anticipo y listo. El día del evento llegamos a la hora acordada, instalamos en tu domicilio y al terminar recogemos todo sin que tengas que mover un dedo."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">1</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Elige tu inflable</h3>
            <p class="why-card__desc">Explora nuestro catálogo y elige el inflable perfecto para tu fiesta.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7C3AED, #9C27B0);">
            <span class="why-card__img-label">2</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Cotiza por WhatsApp</h3>
            <p class="why-card__desc">Envíanos un mensaje y te respondemos en minutos con precio y disponibilidad.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">3</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Agenda tu fecha</h3>
            <p class="why-card__desc">Selecciona fecha y horario. Reserva con un pequeño anticipo del 50%.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">4</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Confirmamos tu reserva</h3>
            <p class="why-card__desc">Recibes confirmación con todos los detalles: hora, dirección y equipo asignado.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF6F00, #E65100);">
            <span class="why-card__img-label">5</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Entrega puntual</h3>
            <p class="why-card__desc">Nuestro equipo llega a la hora acordada con todo el equipo necesario.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #E91E8C, #7C3AED);">
            <span class="why-card__img-label">6</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Instalación profesional</h3>
            <p class="why-card__desc">Montamos e inflamos el equipo. Verificamos seguridad antes de empezar.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #25D366, #128C7E);">
            <span class="why-card__img-label">7</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">¡A brincar!</h3>
