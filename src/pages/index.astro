const testimonios = [
  { name: "Palomita.mx", location: "palomita.mx · CDMX", text: "Llevamos más de un año coordinando eventos junto a BRINCOLINS. Los recomendamos sin dudar a nuestros clientes: llegan puntual, el montaje es profesional y los inflables siempre impecables. Una alianza que funciona de verdad.", isPartner: true, partnerUrl: "", partnerEmoji: "🍿" },
  { name: "MEDEDUL", location: "mededul.com · CDMX", text: "Cuando llegamos a montar la mesa de dulces, BRINCOLINS ya tiene los inflables listos. Esa puntualidad cambia todo en eventos infantiles. Llevamos varios cumpleaños en conjunto y cada vez que los recomendamos a un cliente, el resultado es el mismo: papás felices y niños que no quieren irse. Alianza 100% recomendada.", isPartner: true, partnerUrl: "https://mededul.com", partnerEmoji: "🍬" },
  { name: "DEGLOB", location: "fantasyglobos.com.mx · CDMX", text: "En los cumpleaños donde coincidimos con BRINCOLINS, el resultado siempre es el mismo: nosotros instalamos el arco de globos y el backdrop, ellos instalan los inflables, y los niños tienen todo en el mismo espacio. Su equipo monta ordenado y respeta los tiempos. Ya los recomendamos de forma natural cuando un cliente busca inflables para su fiesta.", isPartner: true, partnerUrl: "", partnerEmoji: "🎈" },
  { name: "MESPIC", location: "mesaspicnic.com · CDMX", text: "En fiestas infantiles al aire libre, los inflables de BRINCOLINS y nuestras bancas de madera se reparten el espacio sin pisarse: los niños juegan en un lado y se sientan a comer en el otro. Su equipo llega temprano, monta ordenado y no interfiere con los demás proveedores. Ya los incluimos en nuestras recomendaciones para quienes buscan inflables.", isPartner: true, partnerUrl: "https://mesaspicnic.com", partnerEmoji: "🧺" },
  { name: "INFLABLEE", location: "inflablee.com · CDMX", text: "Somos colegas en el mismo giro y eso hace que la referencia valga más. Cuando tenemos la agenda llena o un cliente necesita zona que nosotros no cubrimos, BRINCOLINS es a quien llamamos. Mismo estándar de limpieza, puntualidad y supervisión. Se nota que cuidan su operación igual que nosotros la nuestra.", isPartner: true, partnerUrl: "", partnerEmoji: "🎡" },
  { name: "INFLAPY", location: "inflapy.com · CDMX", text: "Treinta años en el giro te enseñan a reconocer quién trabaja bien. BRINCOLINS tiene el estándar que uno espera de un aliado serio: inflables limpios, equipo puntual y operación sin contratiempos. Cuando un cliente nos busca en fechas que ya tenemos comprometidas, es la primera empresa que recomendamos. Y nunca hemos recibido una queja.", isPartner: true, partnerUrl: "https://inflapy.com", partnerEmoji: "🎠" },
  { name: "PANTALLA LED", location: "pantalla-led.com · Edomex", text: "Contraté el Barco Pirata para el cumpleaños de mi hijo y fue todo un éxito. Muy profesionales, seguros y a un precio justo. 100% recomendados.", isPartner: true, partnerUrl: "https://pantalla-led.com/", partnerEmoji: "💡" },
  { name: "Karla Domínguez", location: "Tlalnepantla, Edomex",   text: "Perfecto para la kermesse de la escuela. Coordinaron 3 inflables al mismo tiempo sin ningún problema. Los papás y los niños quedaron encantados." },
];

const faqs = [
  { question: "¿Cuáles son los precios de renta de inflables?", answer: "Nuestros precios van desde $800 MXN por evento (Mini Castillo). Los inflables medianos como Dragones Rojos, Castillo de Princesas, Mini Jungla y Gusanitos van de $1,200 a $1,350 MXN. Los grandes como el Castillo Blanco, el Barco Pirata y el Extremo arrancan en $1,700 MXN. Todos incluyen entrega, instalación, motor inflador, seguro y recolección." },
  { question: "¿Qué incluye el servicio de renta?", answer: "Incluye entrega a domicilio, instalación profesional, motor/soplador silencioso, limpieza y sanitización del inflable, seguro de responsabilidad civil y recolección al finalizar el evento. Sin costos ocultos ni sorpresas." },
  { question: "¿Los inflables son seguros para los niños?", answer: "Absolutamente. Todos nuestros inflables se revisan, limpian y desinfectan antes de cada evento. Cuentan con seguro de responsabilidad civil y están fabricados con materiales de grado comercial certificados en resistencia y seguridad." },
  { question: "¿Para qué edades son los inflables?", answer: "Tenemos inflables para todas las edades: el Mini Castillo es ideal para bebés de 1 a 4 años; los medianos como Dragones Rojos y Castillo de Princesas son perfectos de 3 a 10 años; y los grandes como el Barco Pirata o el Extremo funcionan para niños de 3 a 14 años e incluso adultos." },
  { question: "¿Cuánto tiempo dura la renta?", answer: "La renta estándar es por evento completo, de 4 a 6 horas. Si necesitas más tiempo, consúltanos por WhatsApp y te cotizamos la extensión." },
  { question: "¿Necesito dejar un depósito para reservar?", answer: "Sí, pedimos un anticipo del 50% para apartar la fecha. El saldo restante se paga el día del evento antes de la instalación. Aceptamos transferencia bancaria, efectivo y pago con tarjeta." },
  { question: "¿Qué pasa si llueve o necesito cancelar mi evento?", answer: "En caso de lluvia, reprogramamos tu evento sin costo adicional en la fecha que elijas. Para cancelaciones con más de 48 horas de anticipación, devolvemos el 100% del anticipo. Tu tranquilidad es nuestra prioridad." },
  { question: "¿Tienen inflables para eventos corporativos o kermeses escolares?", answer: "Sí. Contamos con paquetes especiales para kermeses escolares, eventos de team building, family days corporativos y activaciones de marca. Podemos coordinar múltiples inflables simultáneos, incluyendo el Circuito Extremo para adultos. Cotiza tu evento enviándonos los detalles por WhatsApp." },
  { question: "¿Cuánto espacio necesito para instalar un inflable?", answer: "Depende del modelo: el Mini Castillo necesita solo 3×3 metros (con 2.5 m de altura libre) y funciona perfectamente en interiores. Dragones Rojos y Castillo de Princesas requieren 5×5 metros, la Mini Jungla 6×5 y Gusanitos 6×4. El Castillo Blanco necesita 7×6 metros, el Barco Pirata 8×6 y el Circuito Extremo al menos 8×5 metros. Si tienes dudas sobre tu espacio, compártenos una foto y te orientamos." },
  { question: "¿Cubren toda la CDMX y el Estado de México?", answer: "Cubrimos las 16 alcaldías de la Ciudad de México y los principales municipios del Estado de México, incluyendo Naucalpan, Tlalnepantla, Ecatepec, Huixquilucan, Atizapán, Cuautitlán Izcalli, Coacalco, Nezahualcóyotl y más. Consulta tu zona específica en nuestra sección de cobertura o escríbenos directamente." },
];

