  { name: "Iztapalapa", href: "/cobertura/iztapalapa/" },
  { name: "Xochimilco", href: "/cobertura/xochimilco/" },
  { name: "Gustavo A. Madero", href: "/cobertura/gustavo-a-madero/" },
  { name: "Iztacalco", href: "/cobertura/iztacalco/" },
  { name: "Venustiano Carranza", href: "/cobertura/venustiano-carranza/" },
