---
import PageLayout   from "@/layouts/PageLayout.astro";
import ProductCard  from "@/components/ProductCard.astro";
import BlogCard     from "@/components/BlogCard.astro";
import FaqSection   from "@/components/FaqSection.astro";
import CtaBanner      from "@/components/CtaBanner.astro";
import CtaBar         from "@/components/CtaBar.astro";
import SectionHeader  from "@/components/SectionHeader.astro";
import QuickNav       from "@/components/QuickNav.astro";

const title = "Renta de Inflables en CDMX | Inflables para Fiestas | Inflables para Eventos";
const description = "Renta de inflables en CDMX con entrega incluida en toda la ciudad. Inflables para fiestas infantiles, inflables para eventos sociales y más de 8 modelos disponibles. Instalación profesional desde $800 MXN. Cotiza sin compromiso.";

const productos = [
  { slug: "dragones-rojos", emoji: "", name: "Dragones Rojos", description: "El inflable más rentado en CDMX y Estado de México. Dos dragones gigantes de 3 metros con resbaladilla integrada y mallas de seguridad.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "castillo-princesas", emoji: "", name: "Castillo de Princesas", description: "Castillo inflable rosa y turquesa con dos princesas de 3 metros de altura y resbaladilla incluida. El favorito para fiestas de niñas.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/castillo-princesas.avif" },
  { slug: "mini-jungla", emoji: "", name: "Mini Jungla", description: "Inflable temático de safari con animales decorativos de 2 metros y palmeras tropicales. Ideal para exploradores y fiestas al aire libre.", price: "$1,200", size: "4×4×3m", ages: "3-10 años", category: "Aventura", categoryColor: "jungla", gradient: "#2E7D32, #1B5E20", image: "/img/inflables/mini-jungla.avif" },
  { slug: "gusanitos", emoji: "", name: "Gusanitos", description: "Inflable tropical con gusanitos decorativos y palmeras. Amplia área de salto con colores vibrantes verde, morado, amarillo y azul.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Tropical", categoryColor: "jungla", gradient: "#558B2F, #827717", image: "/img/inflables/gusanitos.avif" },
  { slug: "mini-castillo", emoji: "", name: "Mini Castillo", description: "Brincolín compacto diseñado para bebés y niños pequeños. Paredes suaves, fácil supervisión. Perfecto para interiores y espacios reducidos.", price: "$800", size: "2×2×2m", ages: "1-4 años", category: "Chico", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f", image: "/img/inflables/mini-castillo.avif" },
  { slug: "barco-pirata", emoji: "", name: "Barco Pirata", description: "Épico barco pirata con velas, mástil de 4 metros y tobogán gigante. Capacidad para 10-15 niños simultáneamente.", price: "$2,500", size: "7×5×4m", ages: "3-12 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "", name: "Extremo", description: "Circuito de obstáculos de 12 metros con muros para escalar, túneles y tobogán final. Doble carril para carreras simultáneas.", price: "$3,000", size: "12×4×3m", ages: "6+ años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
  { slug: "castillo-blanco", emoji: "", name: "Castillo Blanco", description: "El inflable más elegante para bodas, XV años y eventos formales. Torres decorativas de 3 metros en blanco inmaculado.", price: "$2,800", size: "6×5×4m", ages: "3+ años", category: "Bodas", categoryColor: "bodas", gradient: "#7E57C2, #9575CD", image: "/img/inflables/castillo-blanco.avif" },
];

const testimonios = [
  { name: "María González", location: "Coyoacán, CDMX", text: "Excelente servicio. Llegaron puntuales, el inflable estaba impecable y los niños no pararon de brincar. Definitivamente los volveré a contratar." },
  { name: "Roberto Hernández", location: "Naucalpan, Edomex", text: "Contraté el Barco Pirata para el cumpleaños de mi hijo y fue todo un éxito. Muy profesionales, seguros y a un precio justo. 100% recomendados." },
  { name: "Ana Laura Martínez", location: "Polanco, CDMX", text: "Ya es la tercera vez que rento con BRINCOLINS. Siempre puntuales, amables y los inflables en perfectas condiciones. Los mejores de CDMX sin duda." },
  { name: "Carlos Mendoza", location: "Tlalpan, CDMX", text: "Renté el tobogán acuático para la fiesta de verano de mis hijos. Todos los niños del vecindario vinieron a brincar. Servicio de primera." },
  { name: "Laura Sánchez", location: "Ecatepec, Edomex", text: "Pensé que sería complicado pero todo fue muy fácil. Cotización rápida por WhatsApp, llegaron a tiempo y el inflable estaba súper limpio." },
  { name: "Fernando Ríos", location: "Benito Juárez, CDMX", text: "Los precios son justos y el servicio increíble. El castillo de princesas hizo muy feliz a mi hija. Ya estoy planeando la siguiente fiesta con ellos." },
];

const faqs = [
  { question: "¿Cuáles son los precios de renta de inflables?", answer: "Nuestros precios van desde $800 MXN por evento (Mini Castillo). Los inflables medianos como Dragones Rojos, Castillo de Princesas, Mini Jungla y Gusanitos desde $1,200 MXN. Los grandes como Barco Pirata desde $2,500 MXN y el Extremo desde $3,000 MXN. Todos incluyen entrega, instalación, motor inflador, seguro y recolección." },
  { question: "¿Qué incluye el servicio de renta?", answer: "Incluye entrega a domicilio, instalación profesional, motor/soplador silencioso, limpieza y sanitización del inflable, seguro de responsabilidad civil y recolección al finalizar el evento. Sin costos ocultos ni sorpresas." },
  { question: "¿Los inflables son seguros para los niños?", answer: "Absolutamente. Todos nuestros inflables se revisan, limpian y desinfectan antes de cada evento. Cuentan con seguro de responsabilidad civil y están fabricados con materiales de grado comercial certificados en resistencia y seguridad." },
  { question: "¿Para qué edades son los inflables?", answer: "Tenemos inflables para todas las edades: el Mini Castillo es ideal para bebés de 1 a 4 años; los medianos como Dragones Rojos y Castillo de Princesas son perfectos de 3 a 10 años; y los grandes como el Barco Pirata o el Extremo funcionan para niños de 3 a 14 años e incluso adultos." },
  { question: "¿Cuánto tiempo dura la renta?", answer: "La renta estándar es por evento completo (hasta 8 horas). Si necesitas más tiempo, podemos ajustar el precio con paquetes de día completo o renta multi-día. Consultanos por WhatsApp para más opciones." },
  { question: "¿Necesito dejar un depósito para reservar?", answer: "Sí, pedimos un anticipo del 50% para apartar la fecha. El saldo restante se paga el día del evento antes de la instalación. Aceptamos transferencia bancaria, efectivo y pago con tarjeta." },
  { question: "¿Qué pasa si llueve o necesito cancelar mi evento?", answer: "En caso de lluvia, reprogramamos tu evento sin costo adicional en la fecha que elijas. Para cancelaciones con más de 48 horas de anticipación, devolvemos el 100% del anticipo. Tu tranquilidad es nuestra prioridad." },
  { question: "¿Tienen inflables para eventos corporativos o kermeses escolares?", answer: "Sí. Contamos con paquetes especiales para kermeses escolares, eventos de team building, family days corporativos y activaciones de marca. Podemos coordinar múltiples inflables simultáneos, incluyendo el Circuito Extremo para adultos. Cotiza tu evento enviándonos los detalles por WhatsApp." },
  { question: "¿Cuánto espacio necesito para instalar un inflable?", answer: "Depende del modelo: el Mini Castillo necesita solo 3×3 metros y funciona perfectamente en interiores. Los inflables medianos requieren unos 5×5 metros. El Barco Pirata necesita 8×6 metros y el Circuito Extremo al menos 14×5 metros. Si tienes dudas sobre tu espacio, compártenos una foto y te orientamos." },
  { question: "¿Cubren toda la CDMX y el Estado de México?", answer: "Cubrimos las 16 alcaldías de la Ciudad de México y los principales municipios del Estado de México, incluyendo Naucalpan, Tlalnepantla, Ecatepec, Huixquilucan, Atizapán, Cuautitlán Izcalli, Coacalco, Nezahualcóyotl y más. Consulta tu zona específica en nuestra sección de cobertura o escríbenos directamente." },
];

