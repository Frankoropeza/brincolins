  { name: "Tecámac", href: "/cobertura/tecamac/" },
  { name: "Nicolás Romero", href: "/cobertura/nicolas-romero/" },
  { name: "Tultitlán", href: "/cobertura/tultitlan/" },
];

const categorias = [
  {
    name: "Chicos (1-4 años)",
    badge: "Desde $800",
    desc: "Brincolines compactos y seguros diseñados para bebés y niños pequeños. Paredes suaves, fácil supervisión y espacio reducido.",
    href: "/inflables/mini-castillo/",
    image: "/img/inflables/mini-castillo.avif",
    alt: "Renta de mini castillo inflable para niños pequeños CDMX",
    cta: "Ver inflable para bebés →",
  },
  {
    name: "Medianos (3-10 años)",
    badge: "Desde $1,200 — Los más rentados",
    desc: "Dragones Rojos, Castillo de Princesas, Mini Jungla y Gusanitos. Los favoritos para cumpleaños infantiles en CDMX y Edomex.",
    href: "/inflables/dragones-rojos/",
    image: "/img/inflables/dragones-rojos.avif",
    alt: "Renta de inflables medianos dragones rojos para fiestas infantiles CDMX",
