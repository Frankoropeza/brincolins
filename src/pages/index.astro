---

<PageLayout
  title={title}
  description={description}
  pageType="home"
  faqItems={faqs.map(f => ({ question: f.question, answer: f.answer }))}
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO — H1 cubre las 3 KWs pilar + trust bar
  ═══════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">

        <!-- Columna izquierda -->
        <div>
          <span class="hero__badge">+20 años de experiencia · CDMX y Edomex</span>
          <h1 class="hero__title">
            Renta de <span class="highlight">Inflables</span> para <span class="highlight">Fiestas</span> y <span class="highlight">Eventos</span> en CDMX
          </h1>
          <p class="hero__desc">
            Brincolines, castillos inflables, barcos pirata y circuitos de obstáculos para cumpleaños, kermeses y eventos corporativos. Entrega, instalación, limpieza y seguro incluidos en toda la Zona Metropolitana.
          </p>
          <div class="hero__ctas">
            <a href="/contacto/" class="btn btn-primary btn-lg">Cotizar Renta de Inflables</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver Catálogo de Inflables</a>
          </div>

          <!-- Trust bar — señales EEAT compactas bajo los CTAs -->
          <div class="hero__trust">
            <div class="trust-item">
              <span class="trust-item__stars">★★★★★</span>
              <span class="trust-item__label">4.9 estrellas</span>
            </div>
            <div class="trust-sep" aria-hidden="true"></div>
            <div class="trust-item">
              <span class="trust-item__num">+500</span>
              <span class="trust-item__label">eventos por año</span>
            </div>
            <div class="trust-sep" aria-hidden="true"></div>
            <div class="trust-item">
              <span class="trust-item__num">+20</span>
              <span class="trust-item__label">años de experiencia</span>
            </div>
            <div class="trust-sep" aria-hidden="true"></div>
            <div class="trust-item">
              <span class="trust-item__num">100%</span>
              <span class="trust-item__label">seguro incluido</span>
            </div>
          </div>
        </div>

        <!-- Columna derecha — párrafos de densidad semántica controlada -->
        <div class="hero__copy">
          <p class="hero__copy-text"><strong>BRINCOLINS</strong> es la empresa de referencia en renta de inflables para fiestas infantiles en la <strong>Ciudad de México y Estado de México</strong>. Con más de dos décadas de operación continua y más de <strong>500 eventos atendidos al año</strong>, ofrecemos el catálogo más completo de brincolines e inflables: desde el <strong>Mini Castillo para bebés</strong> desde <strong>$800 MXN</strong> hasta el épico <strong>Barco Pirata de 7 metros</strong> y el circuito de obstáculos <strong>Extremo de 12 metros</strong> — todos fabricados con materiales de grado comercial y certificados en seguridad.</p>
          <p class="hero__copy-text">Cada renta incluye <strong>entrega a domicilio sin costo, instalación profesional, motor inflador silencioso, sanitización certificada y seguro de responsabilidad civil</strong> en las 16 alcaldías de CDMX y los principales municipios del Estado de México. Ya sea un cumpleaños íntimo, una kermesse escolar o un evento corporativo, cotiza sin compromiso por WhatsApp y recibe respuesta en minutos.</p>
        </div>

      </div>
    </div>
  </section>

  <QuickNav />

  <!-- CTA BANNER -->
  <CtaBanner
    title="Reserva hoy y obtén entrega GRATIS en CDMX y Edomex"
    subtitle="Respondemos en minutos. +500 fiestas al año con +20 años de experiencia."
    btnText="Cotizar Renta de Inflables"
    btnHref="/contacto/"
    btnSecondaryText="Ver Catálogo de Inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
  />


  <!-- ═══════════════════════════════════════════════════════════
       MÓDULO PILAR 1 — RENTA DE INFLABLES
       KW Objetivo: "renta de inflables" · Intención: Transaccional
  ═══════════════════════════════════════════════════════════ -->
  <section class="section pilar-section" id="renta-de-inflables">
    <div class="container">
      <div class="pilar-inner">

        <!-- Columna contenido -->
        <div class="pilar-content">
          <span class="section-badge">Servicio Completo</span>
          <h2 class="pilar-title">Todo lo que Incluye Nuestra Renta de Inflables en CDMX</h2>
          <p class="pilar-desc">
            Cuando rentas un inflable con <strong>BRINCOLINS</strong>, recibes un servicio completo de principio a fin. No se te cobrará nada extra por la entrega, la instalación o la recolección al terminar el evento. Llevamos el inflable a tu domicilio, lo instalamos en menos de 30 minutos y al finalizar la fiesta lo recogemos sin que tengas que hacer nada. Nuestro equipo llega puntual y deja el lugar tal como lo encontró.
          </p>

          <!-- Lista de incluidos -->
          <ul class="pilar-features" role="list">
            <li class="pilar-feature">
              <svg class="pilar-feature__icon" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
              <span><strong>Entrega a domicilio</strong> en CDMX y Estado de México sin costo</span>
            </li>
            <li class="pilar-feature">
              <svg class="pilar-feature__icon" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
              <span><strong>Instalación y recolección profesional</strong> — tu equipo se encarga de todo</span>
            </li>
            <li class="pilar-feature">
              <svg class="pilar-feature__icon" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
              <span><strong>Motor inflador silencioso</strong> y extensión eléctrica incluidos</span>
            </li>
            <li class="pilar-feature">
              <svg class="pilar-feature__icon" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
              <span><strong>Limpieza y sanitización certificada</strong> antes de cada evento</span>
            </li>
            <li class="pilar-feature">
              <svg class="pilar-feature__icon" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
              <span><strong>Seguro de responsabilidad civil</strong> incluido en cada renta</span>
            </li>
            <li class="pilar-feature">
              <svg class="pilar-feature__icon" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
              <span><strong>Reprogramación gratuita</strong> en caso de lluvia o imprevisto</span>
            </li>
          </ul>
        </div>

        <!-- Columna precio + CTA -->
        <div class="pilar-aside">
          <div class="price-box">
            <p class="price-box__label">Precio de renta desde</p>
            <p class="price-box__amount">$800 <span>MXN</span></p>
            <p class="price-box__note">Evento completo · hasta 8 horas · todo incluido</p>
            <a href="/contacto/" class="btn btn-primary" style="width:100%; text-align:center;">Cotizar por WhatsApp</a>
            <a href="/inflables/" class="btn btn-outline" style="width:100%; text-align:center; margin-top: .75rem;">Ver catálogo de inflables</a>
          </div>

          <div class="pilar-stat-grid">
            <div class="pilar-stat">
              <span class="pilar-stat__num">+20</span>
              <span class="pilar-stat__txt">años rentando inflables en CDMX</span>
            </div>
            <div class="pilar-stat">
              <span class="pilar-stat__num">+500</span>
              <span class="pilar-stat__txt">eventos atendidos por año</span>
            </div>
            <div class="pilar-stat">
              <span class="pilar-stat__num">16</span>
              <span class="pilar-stat__txt">alcaldías de la Ciudad de México</span>
            </div>
            <div class="pilar-stat">
              <span class="pilar-stat__num">100%</span>
              <span class="pilar-stat__txt">de entregas puntuales garantizadas</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       MÓDULO PILAR 2 — INFLABLES PARA FIESTAS
       KW Objetivo: "inflables para fiestas" · Intención: Comercial
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section--alt pilar-section" id="inflables-para-fiestas">
    <div class="container">
      <span class="section-badge">Para Cada Celebración</span>
