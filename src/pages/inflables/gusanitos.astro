---
import PageLayout from "@/layouts/PageLayout.astro";
import Sidebar from "@/components/Sidebar.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta de Gusanitos Inflable | BRINCOLINS CDMX";
const description = "Renta el inflable Gusanitos para fiestas infantiles en CDMX y Edomex. Gusanitos coloridos con palmeras tropicales. Desde $1,200 MXN con entrega incluida.";

const inflable = {
  slug: "gusanitos",
  emoji: "🐛",
  name: "Gusanitos",
  price: "$1,200",
  priceNum: "1200",
  size: "4×4×3m",
  ages: "4-10 años",
  gradient: "#558B2F, #827717",
  desc: "El inflable Gusanitos destaca por sus coloridos personajes de gusanitos verde y morado con palmeras tropicales decorativas. Con una amplia área de salto en colores verde, morado, amarillo y azul, es uno de los inflables más originales y divertidos de nuestro catálogo. Su diseño vibrante lo hace perfecto para cumpleaños y eventos al aire libre.",
  features: ["Gusanitos decorativos verde y morado", "Palmeras tropicales decorativas", "Amplia área de salto", "Colores vibrantes y llamativos", "Motor inflador silencioso", "Extensión eléctrica incluida"],
  featureImages: ["/img/inflables/gusanitos/gusanitos-brincolin-evento.avif", "/img/inflables/gusanitos/gusanitos-exterior-jardin.avif", "/img/inflables/gusanitos/gusanitos-inflable-fiesta.avif", "/img/inflables/gusanitos/gusanitos-lateral-cdmx.avif", "/img/inflables/gusanitos/gusanitos-renta-cdmx.avif", "/img/inflables/gusanitos/gusanitos-vista-general.avif"],
  capacity: "5-7 niños simultáneamente",
  installTime: "20 minutos",
  requirements: "Espacio mínimo 5×5m, toma de corriente 110V a menos de 15m",
  image: "/img/inflables/gusanitos.avif",
};
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO — 2 columnas: Col1 título+CTAs / Col2 2 párrafos SEO -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">

        <!-- Columna 1: título + CTAs -->
        <div>
          <span class="hero__badge">🐛 Diversión tropical y colorida</span>
          <h1 class="hero__title">Renta <span class="highlight">Gusanitos</span> para tu Fiesta</h1>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Ver disponibilidad</a>
          </div>
        </div>

        <!-- Columna 2: 2 párrafos SEO -->
        <div class="hero__copy">
          <p class="hero__copy-text">El <strong>inflable Gusanitos de BRINCOLINS</strong> es uno de los diseños más originales y coloridos de nuestro catálogo para fiestas infantiles en <strong>CDMX y Estado de México</strong>. Con simpáticos gusanitos decorativos en verde y morado, palmeras tropicales y una amplia zona de salto multicolor, garantiza horas de diversión para niños de 4 a 10 años. Fabricado con <strong>material de grado comercial</strong> y sanitizado antes de cada evento.</p>
          <p class="hero__copy-text">La renta incluye <strong>entrega a domicilio, instalación profesional en 20 minutos, motor inflador silencioso, extensión eléctrica y seguro de responsabilidad civil</strong> sin costo adicional. Perfecto para cumpleaños y eventos al aire libre. Cubrimos las <strong>16 alcaldías de CDMX</strong> y municipios del Estado de México: Naucalpan, Tlalnepantla, Ecatepec y más. Reserva con el 50% de anticipo.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- GALERÍA -->
  <section class="section" style="padding-bottom:0;">
    <div class="container">
      <h2 class="section-title" style="margin-bottom:1.25rem;">Galería de fotos</h2>
      <div class="gallery">
        <a href="/img/inflables/gusanitos/gusanitos-brincolin-evento.avif" class="gallery__item" target="_blank" rel="noopener">
          <img src="/img/inflables/gusanitos/gusanitos-brincolin-evento.avif" alt="gusanitos renta CDMX" loading="lazy" width="400" height="267" />
        </a>
        <a href="/img/inflables/gusanitos/gusanitos-exterior-jardin.avif" class="gallery__item" target="_blank" rel="noopener">
          <img src="/img/inflables/gusanitos/gusanitos-exterior-jardin.avif" alt="gusanitos renta CDMX" loading="lazy" width="400" height="267" />
        </a>
        <a href="/img/inflables/gusanitos/gusanitos-inflable-fiesta.avif" class="gallery__item" target="_blank" rel="noopener">
          <img src="/img/inflables/gusanitos/gusanitos-inflable-fiesta.avif" alt="gusanitos renta CDMX" loading="lazy" width="400" height="267" />
        </a>
        <a href="/img/inflables/gusanitos/gusanitos-lateral-cdmx.avif" class="gallery__item" target="_blank" rel="noopener">
          <img src="/img/inflables/gusanitos/gusanitos-lateral-cdmx.avif" alt="gusanitos renta CDMX" loading="lazy" width="400" height="267" />
        </a>
        <a href="/img/inflables/gusanitos/gusanitos-renta-cdmx.avif" class="gallery__item" target="_blank" rel="noopener">
          <img src="/img/inflables/gusanitos/gusanitos-renta-cdmx.avif" alt="gusanitos renta CDMX" loading="lazy" width="400" height="267" />
        </a>
        <a href="/img/inflables/gusanitos/gusanitos-vista-general.avif" class="gallery__item" target="_blank" rel="noopener">
          <img src="/img/inflables/gusanitos/gusanitos-vista-general.avif" alt="gusanitos renta CDMX" loading="lazy" width="400" height="267" />
        </a>
      </div>
    </div>
  </section>

<!-- Contenido + Sidebar -->
  <div class="page-with-sidebar">
    <main class="page-with-sidebar__main">

      <section class="section">
        <div class="product-info">
          <h2 class="product-info__title">Renta de Gusanitos Inflable en CDMX — Diversión Colorida para Fiestas Infantiles</h2>
          <p class="product-info__desc">{inflable.desc}</p>
          <div class="product-info__specs">
            <div class="product-info__spec"><span class="product-info__label">Medidas</span><strong>{inflable.size}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Edad recomendada</span><strong>{inflable.ages}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Capacidad</span><strong>{inflable.capacity}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Instalación</span><strong>{inflable.installTime}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Precio</span><strong style="color:var(--c-primary);">Desde {inflable.price} MXN</strong></div>
          </div></div>
      </section>

      
      <section class="section section--alt">
        <div class="section-header">
          <h2 class="section-title">Características</h2>
        </div>
        <div class="grid-3">
          {inflable.features.map((f: string, i: number) => {
            const img = inflable.featureImages[i % inflable.featureImages.length];
            return (
              <div class="feature-img-card">
                <div class="feature-img-card__img">
                  <img src={img} alt={f} loading="lazy" width="400" height="267" />
                </div>
                <div class="feature-img-card__body">
                  <p class="feature-img-card__text">{f}</p>
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <h2 class="section-title">Requisitos técnicos</h2>
        </div>
        <div style="max-width:600px; background:var(--c-bg-alt); padding:2rem; border-radius:var(--r-card);">
          <p><strong>Espacio necesario:</strong> {inflable.size} (mínimo)</p>
          <p style="margin-top:.75rem;"><strong>Requisitos:</strong> {inflable.requirements}</p>
          <p style="margin-top:.75rem;"><strong>Tiempo de instalación:</strong> {inflable.installTime}</p>
          <p style="margin-top:.75rem;"><strong>Capacidad:</strong> {inflable.capacity}</p>
        </div>
      </section>

    </main>
    <aside>
      <Sidebar currentSlug={inflable.slug} />
    </aside>
  </div>

  <CtaBanner
    title={`¿Te interesa el ${inflable.name}?`}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="WhatsApp directo"
    btnSecondaryHref={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
    variant="vibrant"
  />

</PageLayout>

<style>
  .gal__title{font-family:var(--font-head);font-weight:800;font-size:clamp(1.3rem,3vw,1.75rem);margin-bottom:.4rem;color:var(--c-heading);}
  .gal__subtitle{color:var(--c-text-muted);font-size:.88rem;margin-bottom:1.25rem;}
  .gal__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:.65rem;}
  .gal__item{display:block;border-radius:var(--r-card);overflow:hidden;aspect-ratio:16/9;}
  .gal__item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s ease;}
  .gal__item:hover img{transform:scale(1.06);}
</style>