---
/**
 * Página de producto — ruta dinámica (jul 2026)
 * ──────────────────────────────────────────────
 * Reemplaza 8 archivos .astro casi idénticos (~1,900 líneas de plantilla
 * copiada). Los datos duros vienen de data/inflables.ts (catálogo canónico)
 * y el contenido editorial de data/productos.ts. Las URLs no cambian:
 * /inflables/<slug>/ se genera igual que antes.
 */
import { INFLABLES } from "@/data/inflables";
import { PRODUCTOS_PAGINAS } from "@/data/productos";
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ProductCard from "@/components/ProductCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import Gallery4x4 from "@/components/Gallery4x4.astro";
import PricingCards from "@/components/PricingCards.astro";
import CtaBar from "@/components/CtaBar.astro";

export function getStaticPaths() {
  return Object.keys(PRODUCTOS_PAGINAS).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const page = PRODUCTOS_PAGINAS[slug!];
const canon = INFLABLES.find((i) => i.slug === slug)!;

const ctaBarItems = [
  { label: "Cotizar ahora", href: "/contacto/", icon: "cotizar" },
  { label: "Ver galería", href: "#galeria", icon: "galeria" },
  { label: "Ver precios", href: "#precios", icon: "precios" },
  { label: "WhatsApp", href: `https://wa.me/5531281706?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${canon.name}.`)}`, icon: "whatsapp" },
];
---

<PageLayout
  title={page.title}
  description={page.description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables/" },
    { name: canon.name },
  ]}
  faqItems={page.faqItems}
  product={{
    name: canon.name,
    slug: canon.slug,
    description: page.description,
    image: canon.image,
    price: canon.priceNumber,
  }}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Inflables",href:"/inflables/"},{label:canon.name}]} />
  </Fragment>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">{page.badge}</span>
          <h1 class="hero__title">Renta <span class="highlight">{canon.name}</span> para tu Fiesta</h1>
          <div class="hero__specs">
            <span class="hero__spec">Tamaño: {canon.size}</span>
            <span class="hero__spec">Edad: {canon.ages}</span>
            <span class="hero__spec">Capacidad: {canon.capacity}</span>
            <span class="hero__spec">Desde {canon.price} MXN</span>
          </div>
          <div class="hero__ctas">
            <a href="/cotizar/" class="btn btn-primary btn-lg">{page.cta}</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver Catálogo de Inflables</a>
          </div>
        </div>
        <div class="hero__img-col">
          <div class="hero__img-wrap">
            <img src={canon.image} alt={`Inflable ${canon.name} — renta BRINCOLINS CDMX`} class="hero__img" width="600" height="450" loading="eager" />
            <div class="hero__img-pill hero__img-pill--top">Desde {canon.price} MXN</div>
            <div class="hero__img-pill hero__img-pill--bottom">⚡ Instalación en {canon.installTime}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <CtaBar items={ctaBarItems} />

  <!-- Gallery -->
  <section class="section" id="galeria">
    <div class="container">
      <SectionHeader badge="Galería" title={`Galería del ${canon.name} en fiestas reales`} subtitle="Imágenes reales de nuestros eventos" copy1={page.galeria.copy1} copy2={page.galeria.copy2} />
      <Gallery4x4 images={page.galleryImages} />
    </div>
  </section>

  <!-- Pricing -->
  <section class="section section--alt" id="precios">
    <div class="container">
      <SectionHeader badge="Paquetes" title={`¿Cuánto cuesta rentar el ${canon.name} en CDMX?`} subtitle="Todos incluyen entrega e instalación en CDMX y Edomex" copy1={page.precios.copy1} copy2={page.precios.copy2} />
      <PricingCards packages={page.pricingPackages} />
    </div>
  </section>

  <!-- Related -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader badge="Más inflables" title="Otros inflables que te pueden interesar" subtitle="Todos con entrega, instalación y seguro incluidos" copy1={page.relacionados.copy1} copy2={page.relacionados.copy2} />
      <div class="grid-4">
        {page.cards.map((c) => (
          <ProductCard slug={c.slug} emoji="" name={c.name} description={c.description} price={c.price} size={c.size} ages={c.ages} category={c.category} categoryColor={c.categoryColor} gradient={c.gradient} image={c.image} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title={`¿Te interesa el ${canon.name}?`}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
    btnText={page.cta}
    btnHref="/cotizar/"
    variant="vibrant"
  />

</PageLayout>
