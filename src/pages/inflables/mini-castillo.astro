---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta de Mini Castillo Inflable | BRINCOLINS CDMX";
const description = "Renta el Mini Castillo inflable para fiestas infantiles en CDMX y Edomex. Compacto e ideal para bebés y primeros cumpleaños. Desde $800 MXN con entrega incluida.";

const inflable = {
  slug: "mini-castillo",
  emoji: "🏰",
  name: "Mini Castillo",
  price: "$800",
  priceNum: "800",
  size: "2×2×2m",
  ages: "1-4 años",
  gradient: "#FF3D00, #ff6d3f",
  desc: "El Mini Castillo es el inflable perfecto para bebés y niños pequeños. Con dimensiones compactas de 2×2 metros y solo 2 metros de altura, cabe perfectamente en departamentos, salones pequeños y jardines reducidos. Sus paredes suaves están diseñadas especialmente para la seguridad de los más pequeños, y su tamaño permite una fácil supervisión desde cualquier ángulo.",
  features: ["Diseño compacto para espacios reducidos", "Paredes suaves para bebés", "Torres decorativas coloridas", "Motor inflador silencioso", "Cabe en interiores y departamentos", "Fácil supervisión desde cualquier ángulo"],
  capacity: "3-4 niños simultáneamente",
  installTime: "15 minutos",
  requirements: "Espacio mínimo 3×3m, toma de corriente 110V, apto para interiores",
  image: "/img/inflables/mini-castillo.avif",
};

const otrosInflables = [
  { slug: "dragones-rojos", emoji: "🐉", name: "Dragones Rojos", description: "El más rentado en CDMX. Dos dragones de 3m con resbaladilla.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Castillo rosa con princesas de 3m y resbaladilla incluida.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/castillo-princesas.avif" },
  { slug: "gusanitos", emoji: "🐛", name: "Gusanitos", description: "Inflable tropical con gusanitos y palmeras decorativas.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Tropical", categoryColor: "jungla", gradient: "#558B2F, #827717", image: "/img/inflables/gusanitos.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <section class="section" style="padding-top:1rem;">
    <div class="container">
      <div class="product-hero__grid">
        <div class="product-hero__image">
          <img src="/img/inflables/mini-castillo.avif" alt="mini-castillo" width="1200" height="675" loading="eager" style="width:100%;height:100%;object-fit:cover;border-radius:var(--r-card);" />
          
          </div>
        </div>
        <div class="product-hero__info">
          <h1>{inflable.emoji} {inflable.name}</h1>
          <p class="product-hero__price">Desde {inflable.price} MXN</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">⏱️ Instalación: {inflable.installTime}</span>
          </div>
          <p style="margin-bottom:1.5rem; color:var(--c-text-muted); line-height:1.7;">{inflable.desc}</p>
          <div class="product-hero__actions">
            <a href="/cotizar" class="btn btn-primary">Cotizar ahora</a>
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa" target="_blank" rel="noopener">
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Características</h2>
      </div>
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Requisitos técnicos</h2>
      </div>
      <div style="max-width:600px; margin:0 auto; background:var(--c-bg-alt); padding:2rem; border-radius:var(--r-card);">
        <p><strong>📐 Espacio necesario:</strong> {inflable.size} (mínimo)</p>
        <p style="margin-top:.75rem;"><strong>⚡ Requisitos:</strong> {inflable.requirements}</p>
        <p style="margin-top:.75rem;"><strong>⏱️ Tiempo de instalación:</strong> {inflable.installTime}</p>
        <p style="margin-top:.75rem;"><strong>👥 Capacidad:</strong> {inflable.capacity}</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Otros inflables que te pueden gustar</h2>
      </div>
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
  title={`¿Te interesa el ${inflable.name}?`}
  subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
  btnText="Solicitar cotización"
  btnHref="/cotizar/"
  btnSecondaryText="WhatsApp directo"
  btnSecondaryHref={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
  variant="vibrant"
/>

</PageLayout>
