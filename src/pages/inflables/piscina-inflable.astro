---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Renta de Piscina Inflable con Bomba | BRINCOLINS CDMX";
const description = "Renta la Piscina Inflable con bomba de agua para fiestas en CDMX y Edomex. Diversión acuática segura para niños de 3-12 años. Desde $1,800 MXN con entrega.";

const inflable = {
  slug: "piscina-inflable",
  emoji: "💧",
  name: "Piscina Inflable",
  price: "$1,800",
  priceNum: "1800",
  size: "5×5×1m",
  ages: "3-12 años",
  gradient: "#0288D1, #0EA5E9",
  desc: "La Piscina Inflable es la opción perfecta para refrescar cualquier fiesta infantil en temporada de calor. Con capacidad para 8 a 10 niños simultáneamente, bomba de recirculación de agua incluida y paredes acolchadas de 1 metro de altura, ofrece diversión acuática segura sin necesidad de alberca fija. Ideal para jardines, patios y eventos al aire libre en toda la CDMX.",
  features: ["Bomba de recirculación de agua incluida", "Paredes acolchadas de 1 metro de altura", "Piso antiderrapante reforzado", "Válvula de drenaje rápido", "Material resistente a rayos UV", "Capacidad para 8-10 niños simultáneamente"],
  capacity: "8-10 niños",
  installTime: "25 minutos",
  requirements: "Espacio mínimo 6×6m, toma de agua y corriente 110V",
  image: "/img/inflables/piscina-inflable.avif",
};

const faqs = [
  { question: "¿Cuánta agua necesita la piscina inflable?", answer: "La piscina requiere aproximadamente 2,000 litros para llenarse a nivel óptimo. El llenado toma entre 30 y 45 minutos dependiendo de la presión de agua disponible. La bomba de recirculación mantiene el agua en movimiento durante todo el evento." },
  { question: "¿Es segura para niños pequeños?", answer: "Sí, la profundidad máxima es de 40 centímetros, ideal para niños desde 3 años. Las paredes acolchadas de 1 metro evitan salpicaduras excesivas y el piso antiderrapante reduce el riesgo de resbalones. Siempre recomendamos supervisión adulta." },
  { question: "¿Qué pasa si no tengo toma de agua cercana?", answer: "Podemos llevar agua en pipas o utilizar mangueras de extensión. Nuestro equipo evalúa tu espacio previamente para encontrar la mejor solución. También contamos con adaptadores para diferentes tipos de llaves y conexiones." },
  { question: "¿Se puede usar en temporada de frío?", answer: "La piscina está diseñada principalmente para temporada de calor (marzo a septiembre). Sin embargo, puede rentarse como área de juegos seca o como piscina de pelotas si prefieres no usar agua. Consúltanos para opciones alternativas." },
];

const otrosInflables = [
  { slug: "dragones-rojos", emoji: "🐉", name: "Dragones Rojos", description: "El inflable más rentado en CDMX.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "mini-jungla", emoji: "🌴", name: "Mini Jungla", description: "Brincolín temático de jungla para los pequeños.", price: "$900", size: "3×3×2.5m", ages: "2-6 años", category: "Chico", categoryColor: "jungla", gradient: "#2E7D32, #66BB6A", image: "/img/inflables/mini-jungla.avif" },
  { slug: "gusanitos", emoji: "🐛", name: "Gusanitos", description: "Túnel inflable de gusanito para bebés y preescolares.", price: "$800", size: "3×2×2m", ages: "1-5 años", category: "Bebés", categoryColor: "jungla", gradient: "#43A047, #FDD835", image: "/img/inflables/gusanitos.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  faqItems={faqs}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables/">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">💧 Diversión acuática</span>
          <h1 class="hero__title">{inflable.emoji} <span class="highlight">{inflable.name}</span></h1>
          <p class="hero__desc">{inflable.desc}</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">💰 Desde {inflable.price} MXN</span>
          </div>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent('Hola BRINCOLINS, me interesa rentar la ' + inflable.name + '. ¿Tienen disponibilidad?')}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Solicitar cotización</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">La Piscina Inflable de BRINCOLINS es la solución ideal para las fiestas de verano en la Ciudad de México. Cuando el calor aprieta, nada supera la alegría de los niños chapoteando en una alberca segura y controlada. Nuestra piscina incluye bomba de recirculación y piso antiderrapante para máxima seguridad acuática.</p>
          <p class="hero__copy-text">Perfecta para cumpleaños en jardín, reuniones familiares de fin de semana y eventos escolares de cierre de ciclo, esta piscina inflable se adapta a cualquier espacio exterior con toma de agua. Ofrecemos entrega, instalación, llenado y recolección en toda la zona metropolitana de la CDMX sin costo adicional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CARACTERÍSTICAS -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="✅ Características"
        title="¿Qué incluye la Piscina Inflable?"
        subtitle="Todo lo que necesitas para la diversión perfecta."
        copy1="Nuestra Piscina Inflable está construida con material PVC de alta resistencia, especialmente tratado para uso acuático prolongado. Las costuras termoselladas garantizan cero filtraciones y el piso antiderrapante proporciona estabilidad para que los niños jueguen con confianza."
        copy2="Cada renta incluye la bomba de recirculación de agua, motor inflador para las paredes y kit de conexión rápida para manguera estándar. El material cuenta con protección UV para resistir la exposición solar directa durante todo el día."
      />
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESO DE RENTA -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📋 Proceso"
        title="¿Cómo rentar este inflable?"
        subtitle="4 pasos simples para tener tu inflable listo."
        copy1="Reservar la Piscina Inflable es muy sencillo. Solo necesitas confirmarnos que cuentas con espacio al aire libre, toma de agua y conexión eléctrica. Nosotros nos encargamos de todo lo demás para que tú disfrutes de la fiesta."
        copy2="Te recomendamos reservar con al menos 3 días de anticipación, especialmente en temporada de calor cuando la demanda es alta. Aceptamos pagos en efectivo, transferencia bancaria y tarjeta de débito."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">1</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Elige tu inflable</h3>
            <p class="why-card__desc">Explora nuestro catálogo y selecciona el inflable perfecto.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7C3AED, #9C27B0);">
            <span class="why-card__img-label">2</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Cotiza por WhatsApp</h3>
            <p class="why-card__desc">Envíanos un mensaje y te respondemos en minutos.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">3</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Reserva tu fecha</h3>
            <p class="why-card__desc">Aparta con 50% de anticipo y asegura disponibilidad.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">4</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">¡A brincar!</h3>
            <p class="why-card__desc">Entregamos, instalamos y recogemos. Tú solo disfruta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes"
        subtitle="Resolvemos tus dudas sobre este inflable."
        copy1="La renta de piscinas inflables genera dudas específicas sobre agua, instalación y seguridad. Aquí encontrarás las respuestas más completas para que planifiques tu evento con total tranquilidad y confianza."
        copy2="Nuestro equipo de atención al cliente está disponible por WhatsApp para resolver cualquier duda adicional. Respondemos en minutos y podemos agendar una visita previa a tu domicilio si lo necesitas."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <!-- INFLABLES RELACIONADOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="🎈 Relacionados"
        title="Otros inflables que te pueden gustar"
        subtitle="Explora más opciones para tu fiesta."
        copy1="Complementa la Piscina Inflable con otro brincolín para crear la fiesta definitiva. Muchos clientes combinan la alberca con un castillo inflable para ofrecer diversión tanto acuática como seca a sus invitados."
        copy2="Pregunta por nuestros paquetes combinados y obtén un precio especial al rentar dos o más inflables para el mismo evento. Tenemos opciones para todos los presupuestos y tamaños de fiesta."
      />
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title={"¿Te interesa la " + inflable.name + "?"}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos por WhatsApp."
    btnText="Cotizar por WhatsApp"
    btnHref={"https://wa.me/5547868402?text=" + encodeURIComponent("Hola BRINCOLINS, me interesa rentar la " + inflable.name + ".")}
    btnSecondaryText="Ver catálogo"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

</PageLayout>
