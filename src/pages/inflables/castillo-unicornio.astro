---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta de Castillo Unicornio Inflable para Fiestas | BRINCOLINS CDMX";
const description = "Renta el Castillo Unicornio inflable para fiestas de princesas en CDMX y Edomex. Colores pastel y arcoíris. Desde $950 MXN con entrega incluida.";

const inflable = {
  slug: "castillo-unicornio",
  emoji: "🦄",
  name: "Castillo Unicornio",
  price: "$950",
  priceNum: "950",
  size: "4×4m",
  ages: "3-8 años",
  gradient: "#F06292, #CE93D8",
  desc: "Mágico castillo unicornio inflable lleno de colores pastel, arcoíris y destellos. El sueño de cualquier niña hecho realidad para su fiesta infantil en CDMX y Estado de México.",
  features: ["Diseño unicornio con arcoíris", "Colores pastel suaves y vibrantes", "Torres de ensueño decoradas", "Entrada con arco de nubes", "Material de primera calidad", "Apto para uso interior y exterior"],
  capacity: "Hasta 8 niños simultáneamente",
  installTime: "25 minutos",
  requirements: "Toma de corriente a menos de 15m, superficie plana de 4×4m",
  image: "/img/inflables/castillo-unicornio.avif",
};

const otrosInflables = [
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", price: "$900", size: "4×4m", ages: "3-8 años", gradient: "#E040FB, #7C3AED" },
  { slug: "mini-castillo", emoji: "🏰", name: "Mini Castillo", price: "$800", size: "4×4m", ages: "3-8 años", gradient: "#FF3D00, #ff6d3f" },
  { slug: "casa-brinco-jungla", emoji: "🌴", name: "Casa Brinco Jungla", price: "$850", size: "4×4m", ages: "3-8 años", gradient: "#2E7D32, #1B5E20" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <section class="section" style="padding-top:1rem;">
    <div class="container">
      <div class="product-hero__grid">
        <div class="product-hero__image">
          <img src="/img/inflables/castillo-unicornio.avif" alt="castillo-unicornio" width="1200" height="675" loading="eager" style="width:100%;height:100%;object-fit:cover;border-radius:var(--r-card);" />
          
          </div>
        </div>
        <div class="product-hero__info">
          <h1>{inflable.emoji} {inflable.name}</h1>
          <p class="product-hero__price">Desde {inflable.price} MXN</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">⏱️ Instalación: {inflable.installTime}</span>
          </div>
          <p style="margin-bottom:1.5rem; color:var(--c-text-muted); line-height:1.7;">{inflable.desc}</p>
          <div class="product-hero__actions">
            <a href="/cotizar" class="btn btn-primary">Cotizar ahora</a>
            <a href={`https://wa.me/5511111111?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa" target="_blank" rel="noopener">
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Características</h2>
      </div>
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Requisitos técnicos</h2>
      </div>
      <div style="max-width:600px; margin:0 auto; background:var(--c-bg-alt); padding:2rem; border-radius:var(--r-card);">
        <p><strong>📐 Espacio necesario:</strong> {inflable.size} (mínimo)</p>
        <p style="margin-top:.75rem;"><strong>⚡ Requisitos:</strong> {inflable.requirements}</p>
        <p style="margin-top:.75rem;"><strong>⏱️ Tiempo de instalación:</strong> {inflable.installTime}</p>
        <p style="margin-top:.75rem;"><strong>👥 Capacidad:</strong> {inflable.capacity}</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Otros inflables que te pueden gustar</h2>
      </div>
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
  title={`¿Te interesa el ${inflable.name}?`}
  subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
  btnText="Solicitar cotización"
  btnHref="/cotizar/"
  btnSecondaryText="WhatsApp directo"
  btnSecondaryHref={`https://wa.me/5511111111?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
  variant="vibrant"
/>

</PageLayout>
