---
import PageLayout  from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ProductCard from "@/components/ProductCard.astro";
import ProductFeature from "@/components/ProductFeature.astro";
import CatalogSidebar from "@/components/CatalogSidebar.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
const title = "Catálogo de Inflables para Fiestas en CDMX y Edomex | BRINCOLINS";
const description = "Catálogo de inflables para fiestas: castillos, barco pirata, extremo y más. Desde $800 MXN con entrega e instalación incluidas en CDMX y Edomex.";

const faqs = [
  { question: "¿Cuáles son los inflables disponibles para rentar?", answer: "Contamos con 8 modelos: Dragones Rojos, Castillo de Princesas, Mini Jungla, Gusanitos, Mini Castillo (para bebés), Barco Pirata, Circuito Extremo y Castillo Blanco (para bodas y XV años). Cada uno tiene precios, dimensiones y edades recomendadas distintas para adaptarse a cualquier evento." },
  { question: "¿Cuál es el inflable más económico?", answer: "El Mini Castillo es el más accesible desde $800 MXN. Está diseñado para bebés y niños de 1 a 4 años, mide 2×2×2.5 metros y es perfecto para interiores y espacios reducidos. Los inflables medianos (Dragones Rojos, Castillo de Princesas, Mini Jungla y Gusanitos) inician desde $1,200 MXN." },
  { question: "¿Cuál es el inflable más popular para cumpleaños?", answer: "Los Dragones Rojos es el más rentado de nuestro catálogo en CDMX y Estado de México. Con sus dos dragones gigantes, resbaladilla integrada y mallas de seguridad, es el favorito para niños de 4 a 10 años. El Castillo de Princesas es el número uno para fiestas de niñas." },
  { question: "¿Qué inflable me recomiendas para niños pequeños?", answer: "El Mini Castillo es ideal para bebés y niños de 1 a 4 años. Tiene paredes suaves, altura manejable y diseño abierto para supervisión constante. Solo mide 2×2×2.5 metros, por lo que cabe en interiores, departamentos y terrazas. Para niños de 3 a 10 años, los inflables medianos como Dragones Rojos o Mini Jungla son perfectos." },
  { question: "¿Qué inflable necesita más espacio?", answer: "El Barco Pirata es el más grande del catálogo y requiere 8×6 metros. El Circuito Extremo necesita al menos 8×5 metros (es una pista de 7 metros) y el Castillo Blanco 7×6. Entre los medianos, Dragones Rojos y Castillo de Princesas necesitan unos 5×5 metros, la Mini Jungla 6×5 y Gusanitos 6×4. El Mini Castillo solo 3×3 metros y funciona en interiores." },
  { question: "¿Hay inflables para adultos o para bodas?", answer: "Sí. El Castillo Blanco es nuestro modelo premium para bodas, XV años, bautizos y eventos formales. Mide 6×5×4 metros, tiene torres decorativas en blanco inmaculado y es apto para adultos y niños (capacidad 8-10 personas). El Circuito Extremo de 7 metros también es muy popular para team building corporativo y adultos." },
  { question: "¿Cuántos niños pueden usar el inflable al mismo tiempo?", answer: "Depende del modelo: el Mini Castillo admite 3-4 niños; los medianos (Dragones Rojos, Princesas, Mini Jungla, Gusanitos) entre 5-7 niños; el Barco Pirata 8-10 niños simultáneamente; el Castillo Blanco 8-10 personas; el Circuito Extremo 6-10 personas, 2-4 por carril en carreras." },
  { question: "¿Todos los inflables incluyen entrega e instalación?", answer: "Sí, todos incluyen entrega a domicilio sin costo extra, instalación profesional en menos de 30 minutos, motor inflador silencioso, limpieza y sanitización certificada, seguro de responsabilidad civil y recolección al finalizar. El precio que ves es el precio final, sin costos ocultos." },
  { question: "¿Cómo aparto mi fecha con un inflable del catálogo?", answer: "Escríbenos por WhatsApp con el inflable que te interesa, la fecha y la zona de entrega. Te confirmamos disponibilidad en minutos. Para apartar la fecha se requiere un anticipo del 50%. Aceptamos transferencia bancaria, efectivo y tarjeta. El saldo se paga el día del evento." },
  { question: "¿Puedo rentar más de un inflable para mi evento?", answer: "Sí, y contamos con paquetes multi-inflable para kermeses escolares, eventos corporativos y ferias. Desde 3 inflables incluimos coordinador de logística sin costo adicional. Cuéntanos las necesidades de tu evento y te armamos un paquete a la medida con precio especial." },
];

const productos = [
  { slug: "dragones-rojos", emoji: "", name: "Dragones Rojos", description: "El inflable más rentado en CDMX y Estado de México. Dos dragones gigantes con resbaladilla integrada y mallas de seguridad.", price: "$1,200", size: "4×4×3.8m", ages: "4-10 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "castillo-princesas", emoji: "", name: "Castillo de Princesas", description: "Castillo inflable rosa y turquesa con dos princesas decorativas y resbaladilla incluida. El favorito para fiestas de niñas.", price: "$1,200", size: "4×4×3.5m", ages: "4-10 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/castillo-princesas.avif" },
  { slug: "mini-jungla", emoji: "", name: "Mini Jungla", description: "Inflable temático de safari con animales decorativos de 2 metros y palmeras tropicales. Ideal para exploradores y fiestas al aire libre.", price: "$1,300", size: "4.5×4×3.5m", ages: "3-10 años", category: "Aventura", categoryColor: "jungla", gradient: "#2E7D32, #1B5E20", image: "/img/inflables/mini-jungla.avif" },
  { slug: "gusanitos", emoji: "", name: "Gusanitos", description: "Inflable tropical con gusanitos decorativos y palmeras. Área de salto alargada de 5×3 m con colores vibrantes verde, morado, amarillo y azul.", price: "$1,350", size: "5×3×2.5m", ages: "4-10 años", category: "Tropical", categoryColor: "jungla", gradient: "#558B2F, #827717", image: "/img/inflables/gusanitos.avif" },
  { slug: "mini-castillo", emoji: "", name: "Mini Castillo", description: "Brincolín compacto diseñado para bebés y niños pequeños. Paredes suaves, fácil supervisión. Perfecto para interiores y espacios reducidos.", price: "$800", size: "2×2×2.5m", ages: "1-4 años", category: "Chico", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f", image: "/img/inflables/mini-castillo.avif" },
  { slug: "barco-pirata", emoji: "", name: "Barco Pirata", description: "Épico barco pirata con velas, mástil de 4 metros y tobogán gigante. Capacidad para 8-10 niños simultáneamente.", price: "$1,800", size: "7×5×4.5m", ages: "4+ años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "", name: "Extremo", description: "Circuito de obstáculos de 7 metros con muros para escalar, túneles y tobogán final. Doble carril para carreras simultáneas.", price: "$1,900", size: "7×4×3.8m", ages: "6+ años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
  { slug: "castillo-blanco", emoji: "", name: "Castillo Blanco", description: "El inflable más elegante para bodas, XV años y eventos formales. Torres decorativas de 3 metros en blanco inmaculado.", price: "$1,700", size: "6×5×4m", ages: "3+ años", category: "Bodas", categoryColor: "bodas", gradient: "#7E57C2, #9575CD", image: "/img/inflables/castillo-blanco.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="category"
  faqItems={faqs}
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables" },
  ]}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Inflables"}]} />
  </Fragment>

  <section class="hero" style="padding:clamp(5rem,8vw,6rem) 0 clamp(2rem,4vw,3rem);">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Catálogo completo</span>
          <h1 class="hero__title">
            Catálogo de <span class="highlight">Inflables</span> y Brincolines para Fiestas en CDMX
          </h1>
          <div class="hero__ctas">
            <a href="/cotizar/" class="btn btn-primary btn-lg">Cotizar Renta de Inflables</a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Ver Precios de Inflables</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            Contamos con la mayor variedad de <strong>inflables para renta</strong> en CDMX y Estado de México, incluida nuestra <a href="/inflables/brincolines/">renta de brincolines</a>. Desde castillos clásicos y brincolines temáticos hasta toboganes y pistas de obstáculos.
          </p>
          <p class="hero__copy-text">
            Todos nuestros inflables pasan por un riguroso proceso de limpieza y mantenimiento antes de cada evento. Fabricados con materiales de grado comercial y certificados en seguridad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section" style="padding-top:1.5rem;">
    <div class="container">
      <SectionHeader
        badge="Catálogo"
        title="Catálogo de Inflables para Fiestas y Eventos en CDMX"
        subtitle="Encuentra el inflable perfecto según el tipo y tamaño de tu evento."
        copy1="Organizamos nuestro catálogo de brincolines e inflables por categorías para que encuentres exactamente lo que buscas en segundos. Desde el Mini Castillo para los más pequeños hasta circuitos de obstáculos para eventos masivos, cada categoría incluye inflables de diferentes tamaños, temas y precios para CDMX y Estado de México."
        copy2="Todos los inflables incluyen entrega, instalación profesional y seguro de responsabilidad civil. Explora la categoría que más te interese y descubre las opciones disponibles con sus precios, dimensiones y edades recomendadas."
      />
      <div class="grid-4">
        {productos.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- ── Sección destacada: ProductFeature + CatalogSidebar ── -->
  <section class="section section--alt featured-section">
    <div class="container">

      <SectionHeader
        badge="🔥 Más rentado"
        title="Conoce nuestro inflable estrella"
        subtitle="Detalle completo · galería de fotos reales · precios transparentes"
        copy1="El inflable Dragones Rojos es el más solicitado de nuestro catálogo en CDMX y Estado de México. Con sus dos dragones gigantes, resbaladilla integrada y colores en rojo y dorado, se convierte en el centro de atención de cualquier fiesta infantil."
        copy2="Disponible desde $1,200 MXN con entrega, instalación, motor inflador y seguro de responsabilidad civil incluidos. Cabe en un espacio de 5×5 metros — ideal para jardines, patios y salones de eventos."
      />

      <!-- Layout main + sidebar -->
      <div class="featured-layout">
        <div class="featured-layout__main">
          <ProductFeature
            name="Dragones Rojos"
            slug="dragones-rojos"
            category="Más popular"
            categoryColor="castillo"
            price="$1,200"
            size="4×4×3.8m"
            ages="4-10 años"
            capacity="5-7 niños"
            installTime="20 minutos"
            description="El inflable más rentado en Ciudad de México y Estado de México. Dos dragones gigantes custodian el castillo, con resbaladilla integrada de alta velocidad y mallas de seguridad en todos los costados. Mide 4×4×3.8 m y está fabricado con PVC de grado comercial — el favorito para cumpleaños de 4 a 10 años."
            features={[
              { icon: "🐉", text: "Dos dragones decorativos custodiando el castillo" },
              { icon: "🛝", text: "Resbaladilla integrada de alta velocidad" },
              { icon: "🔒", text: "Mallas de seguridad perimetrales para supervisión" },
              { icon: "🧼", text: "Sanitización certificada antes de cada evento" },
              { icon: "🚚", text: "Entrega, instalación y motor inflador incluidos" },
              { icon: "📋", text: "Seguro de responsabilidad civil disponible" },
            ]}
            image="/img/inflables/dragones-rojos.avif"
            imageAlt="Inflable Dragones Rojos — el más rentado en CDMX y Estado de México"
            gallery={[
              { src: "/img/inflables/dragones-rojos/castillo-dragones-exterior-jardin.avif", alt: "Inflable Dragones Rojos instalado en jardín exterior" },
              { src: "/img/inflables/dragones-rojos/dragones-frontal-resbaladilla.avif", alt: "Resbaladilla frontal del inflable Dragones Rojos" },
            ]}
          />
        </div>

        <div class="featured-layout__sidebar">
          <CatalogSidebar activeSlug="dragones-rojos" />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Sección destacada: Castillo de Princesas ── -->
  <section class="section featured-section">
    <div class="container">

      <SectionHeader
        badge="👑 Favorito para niñas"
        title="El Castillo de Princesas más solicitado"
        subtitle="Rosa · turquesa · resbaladilla incluida · perfecto para cumpleaños temáticos"
        copy1="Transforma el cumpleaños de tu hija en un cuento de hadas con el Castillo de Princesas. Su diseño en rosa y turquesa con dos princesas decorativas y resbaladilla integrada lo convierten en el inflable más solicitado para fiestas temáticas de niñas."
        copy2="Ideal para niñas de 4 a 10 años con capacidad para 5-7 simultáneamente. Disponible desde $1,200 MXN con entrega, instalación y seguro incluidos en toda la CDMX y Estado de México."
      />

      <div class="featured-layout">
        <div class="featured-layout__main">
          <ProductFeature
            name="Castillo de Princesas"
            slug="castillo-princesas"
            category="Princesas"
            categoryColor="princesas"
            price="$1,200"
            size="4×4×3.5m"
            ages="4-10 años"
            capacity="5-7 niños"
            installTime="20 minutos"
            description="El favorito indiscutible para fiestas de niñas. Castillo inflable de 4×4×3.5 m en rosa y turquesa con dos princesas como decoración principal, resbaladilla integrada y mallas de seguridad perimetrales. El sueño de toda cumpleañera hecho realidad."
            features={[
              { icon: "👸", text: "Dos princesas decorativas como tema principal" },
              { icon: "🛝", text: "Resbaladilla integrada de alta velocidad" },
              { icon: "🌸", text: "Diseño rosa y turquesa temático de princesas" },
              { icon: "🔒", text: "Mallas de seguridad perimetrales para supervisión" },
              { icon: "🚚", text: "Entrega, instalación y motor inflador incluidos" },
              { icon: "🧼", text: "Sanitización certificada antes de cada evento" },
            ]}
            image="/img/inflables/castillo-princesas.avif"
            imageAlt="Castillo de Princesas inflable — el favorito para fiestas de niñas en CDMX"
            gallery={[
              { src: "/img/inflables/castillo-princesas/castillo-princesas-exterior-jardin.avif", alt: "Castillo de Princesas instalado en jardín exterior" },
              { src: "/img/inflables/castillo-princesas/castillo-princesas-renta-cdmx.avif", alt: "Renta de Castillo de Princesas en CDMX" },
            ]}
          />
        </div>

        <div class="featured-layout__sidebar">
          <CatalogSidebar activeSlug="castillo-princesas" />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Sección destacada: Mini Jungla ── -->
  <section class="section section--alt featured-section">
    <div class="container">

      <SectionHeader
        badge="🌿 Aventura tropical"
        title="Mini Jungla — Safari en tu fiesta"
        subtitle="Dinosaurios · palmeras · animales decorativos · ideal para exteriores"
        copy1="La Mini Jungla lleva la aventura selvática a tu fiesta. Con animales decorativos de 2 metros, dinosaurios y palmeras tropicales, es el inflable perfecto para temáticas de safari, naturaleza y exploración. Sus colores vivos destacan en cualquier jardín o terraza."
        copy2="Diseñado para niños de 3 a 10 años con capacidad para 5-7 simultáneamente. Ideal para fiestas al aire libre. Disponible desde $1,300 MXN con instalación profesional en 15 minutos incluida."
      />

      <div class="featured-layout">
        <div class="featured-layout__main">
          <ProductFeature
            name="Mini Jungla"
            slug="mini-jungla"
            category="Aventura"
            categoryColor="jungla"
            price="$1,300"
            size="4.5×4×3.5m"
            ages="3-10 años"
            capacity="5-7 niños"
            installTime="15 minutos"
            description="Inflable temático de safari que transporta a los niños a una aventura tropical. Animales decorativos de 2 metros, palmeras y dinosaurios rodean el área de salto con colores vibrantes de la selva. Ideal para exploradores y fiestas al aire libre con temática de naturaleza."
            features={[
              { icon: "🦕", text: "Animales y dinosaurios decorativos de 2 metros" },
              { icon: "🌴", text: "Palmeras tropicales en el diseño perimetral" },
              { icon: "🛝", text: "Resbaladilla integrada con diseño selvático" },
              { icon: "🔒", text: "Mallas de seguridad para supervisión continua" },
              { icon: "🌤️", text: "Perfecto para jardines, terrazas y espacios al aire libre" },
              { icon: "🚚", text: "Entrega, instalación y motor inflador incluidos" },
            ]}
            image="/img/inflables/mini-jungla.avif"
            imageAlt="Inflable Mini Jungla — temática safari con animales y palmeras tropicales"
            gallery={[
              { src: "/img/inflables/mini-jungla/mini-jungla-dinosaurios-palmeras.avif", alt: "Inflable Mini Jungla con dinosaurios y palmeras tropicales" },
              { src: "/img/inflables/mini-jungla/mini-jungla-exterior-evento.avif", alt: "Mini Jungla instalada en evento al aire libre" },
            ]}
          />
        </div>

        <div class="featured-layout__sidebar">
          <CatalogSidebar activeSlug="mini-jungla" />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Sección destacada: Gusanitos ── -->
  <section class="section featured-section">
    <div class="container">

      <SectionHeader
        badge="🐛 Tropical"
        title="Gusanitos — Colores y diversión desbordante"
        subtitle="Verde · morado · amarillo · azul · el más colorido del catálogo"
        copy1="El Gusanitos es el inflable más colorido y alegre del catálogo. Sus personajes de gusanitos multicolor y palmeras tropicales crean un ambiente festivo irresistible. Su base alargada de 5×3 metros con resbaladilla integrada aprovecha bien los jardines y patios más largos que anchos."
        copy2="Perfecto para niños de 4 a 10 años con capacidad para 5-7 simultáneamente. Disponible desde $1,350 MXN con entrega e instalación incluidas en CDMX y Estado de México."
      />

      <div class="featured-layout">
        <div class="featured-layout__main">
          <ProductFeature
            name="Gusanitos"
            slug="gusanitos"
            category="Tropical"
            categoryColor="jungla"
            price="$1,350"
            size="5×3×2.5m"
            ages="4-10 años"
            capacity="5-7 niños"
            installTime="20 minutos"
            description="El inflable más colorido del catálogo. Gusanitos decorativos y palmeras tropicales rodean un área de salto alargada de 5×3 m con colores vibrantes en verde, morado, amarillo y azul. El brincolin favorito para fiestas con mucho color y energía al aire libre."
            features={[
              { icon: "🐛", text: "Gusanitos decorativos multicolor como personajes principales" },
              { icon: "🌴", text: "Palmeras tropicales integradas en el diseño perimetral" },
              { icon: "🌈", text: "Colores vibrantes: verde, morado, amarillo y azul" },
              { icon: "🛝", text: "Resbaladilla integrada y área de salto alargada 5×3 m" },
              { icon: "🔒", text: "Mallas de seguridad perimetrales para supervisión" },
              { icon: "🚚", text: "Entrega, instalación y motor inflador incluidos" },
            ]}
            image="/img/inflables/gusanitos.avif"
            imageAlt="Inflable Gusanitos — colores tropicales vibrantes para fiestas infantiles"
            gallery={[
              { src: "/img/inflables/gusanitos/gusanitos-exterior-jardin.avif", alt: "Inflable Gusanitos en jardín exterior para fiesta" },
              { src: "/img/inflables/gusanitos/gusanitos-inflable-fiesta.avif", alt: "Gusanitos inflable en fiesta infantil con niños jugando" },
            ]}
          />
        </div>

        <div class="featured-layout__sidebar">
          <CatalogSidebar activeSlug="gusanitos" />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Sección destacada: Mini Castillo ── -->
  <section class="section section--alt featured-section">
    <div class="container">

      <SectionHeader
        badge="🍼 Para los más pequeños"
        title="Mini Castillo — Ideal para bebés y niños"
        subtitle="Compacto · paredes suaves · perfecto para interiores y espacios reducidos"
        copy1="El Mini Castillo es la opción perfecta cuando los invitados son los más pequeños de la casa. Diseñado para bebés y niños de 1 a 4 años con paredes suaves acolchonadas y altura manejable que facilita la supervisión de los padres en todo momento."
        copy2="Su tamaño compacto de 2×2×2.5 metros lo hace ideal para interiores, departamentos y terrazas donde los modelos grandes no caben — solo necesita 3×3 m de piso y 2.5 m de altura libre. Disponible desde $800 MXN — el más accesible del catálogo."
      />

      <div class="featured-layout">
        <div class="featured-layout__main">
          <ProductFeature
            name="Mini Castillo"
            slug="mini-castillo"
            category="Chico"
            categoryColor="castillo"
            price="$800"
            size="2×2×2.5m"
            ages="1-4 años"
            capacity="3-4 niños"
            installTime="15 minutos"
            description="El brincolín compacto diseñado especialmente para bebés y niños pequeños de 1 a 4 años. Paredes suaves, altura manejable y diseño abierto que facilita la supervisión de los padres en todo momento. Perfecto para interiores, departamentos y espacios reducidos donde los modelos grandes no caben."
            features={[
              { icon: "🍼", text: "Diseñado específicamente para bebés y niños de 1-4 años" },
              { icon: "🛡️", text: "Paredes suaves y acolchonadas sin riesgo de golpes" },
              { icon: "👁️", text: "Diseño abierto para supervisión total de los padres" },
              { icon: "🏠", text: "Compacto: cabe en interiores, pasillos y terrazas pequeñas" },
              { icon: "⚡", text: "Instalación rápida: listo en 15 minutos" },
              { icon: "🚚", text: "Entrega, instalación y motor inflador incluidos" },
            ]}
            image="/img/inflables/mini-castillo.avif"
            imageAlt="Mini Castillo inflable — compacto para bebés y niños pequeños de 1 a 4 años"
            gallery={[
              { src: "/img/inflables/mini-castillo/mini-castillo-interior-fiesta.avif", alt: "Mini Castillo instalado en interior de fiesta" },
              { src: "/img/inflables/mini-castillo/mini-castillo-cumpleanos-infantil.avif", alt: "Mini Castillo en cumpleaños infantil" },
            ]}
          />
        </div>

        <div class="featured-layout__sidebar">
          <CatalogSidebar activeSlug="mini-castillo" />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Sección destacada: Barco Pirata ── -->
  <section class="section featured-section">
    <div class="container">

      <SectionHeader
        badge="⚓ El más grande"
        title="Barco Pirata — Aventura épica en tu fiesta"
