---
import PageLayout  from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Catálogo de Inflables para Renta | BRINCOLINS CDMX";
const description = "Explora nuestro catálogo completo de inflables para renta: castillos, toboganes, barcos pirata y más. Desde $800 MXN con entrega incluida en CDMX y Edomex.";

const productos = [
  { slug: "dragones-rojos", emoji: "🐉", name: "Dragones Rojos", description: "El inflable más popular en CDMX. Castillo con dos dragones gigantes y resbaladilla. El favorito de las fiestas.", price: "$1,800", size: "4×4m", ages: "4-12 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "mini-castillo", emoji: "🏰", name: "Mini Castillo", description: "Brincolín compacto ideal para bebés y fiestas en interiores. Perfecto para primeros cumpleaños y espacios reducidos.", price: "$1,200", size: "2×2m", ages: "1-3 años", category: "Chico", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f", image: "/img/inflables/mini-castillo.avif" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Castillo inflable rosa con resbaladilla incluida. Ideal para fiestas temáticas de princesas.", price: "$1,800", size: "4×4m", ages: "3-10 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/castillo-princesas.avif" },
  { slug: "mini-jungla", emoji: "🌴", name: "Mini Jungla", description: "Inflable temático de jungla con obstáculos y lianas. Perfecto para niños exploradores y fiestas safari.", price: "$1,800", size: "4.5×4m", ages: "5-10 años", category: "Aventura", categoryColor: "jungla", gradient: "#2E7D32, #1B5E20", image: "/img/inflables/mini-jungla.avif" },
  { slug: "gusanitos", emoji: "🐛", name: "Gusanitos", description: "Inflable con túneles coloridos interactivos y múltiples entradas. Diversión para todas las edades.", price: "$1,800", size: "5×3m", ages: "3-12 años", category: "Túneles", categoryColor: "jungla", gradient: "#558B2F, #827717", image: "/img/inflables/gusanitos.avif" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Inflable tipo barco pirata de gran tamaño con tobogán de alta velocidad incluido. Aventura épica.", price: "$2,500", size: "7×5m", ages: "4-14 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "🏁", name: "Extremo", description: "Circuito de obstáculos inflable ideal para competencias, carreras y eventos. Diversión extrema garantizada.", price: "$2,300", size: "4.8×3.3m", ages: "6-14 años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
  { slug: "castillo-blanco", emoji: "🤍", name: "Castillo Blanco", description: "Castillo inflable blanco elegante, ideal para bodas, bautizos y eventos formales. Elegancia inflable.", price: "$2,800", size: "6×5m", ages: "Todas", category: "Bodas", categoryColor: "bodas", gradient: "#7E57C2, #9575CD", image: "/img/inflables/castillo-blanco.avif" },
  { slug: "tobogan-acuatico", emoji: "💦", name: "Tobogán Acuático", description: "Diversión refrescante con tobogán y chapoteadero incluido. Perfecto para fiestas en días calurosos.", price: "$2,200", size: "6×4m", ages: "5-12 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#0288D1, #01579B", image: "/img/inflables/tobogan-acuatico.avif" },
  { slug: "parque-acuatico", emoji: "🌊", name: "Parque Acuático", description: "Doble tobogán con chapoteadero y zona de salpicaduras. La mayor atracción para fiestas de verano.", price: "$2,800", size: "7×5m", ages: "5-14 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#0277BD, #006064", image: "/img/inflables/parque-acuatico.avif" },
  { slug: "pista-obstaculos", emoji: "🏁", name: "Pista de Obstáculos", description: "Circuito inflable con túneles, muros y rampas. Ideal para competencias y diversión extrema.", price: "$2,500", size: "8×4m", ages: "5-14 años", category: "Deportivos", categoryColor: "deportivo", gradient: "#E65100, #BF360C", image: "/img/inflables/pista-obstaculos.avif" },
  { slug: "alberca-inflable", emoji: "🏊", name: "Alberca Inflable", description: "Alberca con tobogán suave para los más pequeños. Ideal para fiestas de verano en casa.", price: "$1,500", size: "4×3m", ages: "2-8 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#00BCD4, #0097A7", image: "/img/inflables/alberca-inflable.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="category"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables" },
  ]}
>

  <section class="hero" style="padding:clamp(5rem,8vw,6rem) 0 clamp(2rem,4vw,3rem);">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🎈 Catálogo completo</span>
          <h1 class="hero__title">
            Catálogo de <span class="highlight">Inflables</span>
          </h1>
          <p class="hero__desc">
            Todos nuestros inflables incluyen entrega, instalación, limpieza y seguro. Elige el tuyo.
          </p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Solicitar cotización</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            Contamos con la mayor variedad de <strong>brincolines e inflables para renta</strong> en CDMX y Estado de México. Desde castillos clásicos hasta toboganes acuáticos y pistas de obstáculos.
          </p>
          <p class="hero__copy-text">
            Todos nuestros inflables pasan por un riguroso proceso de limpieza y mantenimiento antes de cada evento. Fabricados con materiales de grado comercial y certificados en seguridad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Inflables</span>
    </nav>
  </div>

  <section class="section" style="padding-top:1.5rem;">
    <div class="container">
      <div class="grid-4">
        {productos.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿No encuentras lo que buscas?"
    subtitle="Tenemos más opciones disponibles. Contáctanos y te ayudamos a encontrar el inflable ideal."
    btnText="Preguntar por WhatsApp"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20busco%20un%20inflable%20especial%20para%20mi%20evento."
    btnSecondaryText="Solicitar cotización"
    btnSecondaryHref="/cotizar/"
    variant="warm"
    whatsapp={true}
    external={true}
  />

</PageLayout>
