---
import PageLayout  from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Catálogo de Inflables para Renta | BRINCOLINS CDMX";
const description = "Catálogo completo de inflables para renta en CDMX y Edomex. Dragones Rojos, Castillo de Princesas, Barco Pirata, Extremo y más. Desde $800 MXN con entrega, instalación y seguro incluidos.";

const productos = [
  { slug: "dragones-rojos", emoji: "🐉", name: "Dragones Rojos", description: "El inflable más rentado en CDMX y Estado de México. Dos dragones gigantes de 3 metros con resbaladilla integrada y mallas de seguridad.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Castillo inflable rosa y turquesa con dos princesas de 3 metros de altura y resbaladilla incluida. El favorito para fiestas de niñas.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/castillo-princesas.avif" },
  { slug: "mini-jungla", emoji: "🌴", name: "Mini Jungla", description: "Inflable temático de safari con animales decorativos de 2 metros y palmeras tropicales. Ideal para exploradores y fiestas al aire libre.", price: "$1,200", size: "4×4×3m", ages: "3-10 años", category: "Aventura", categoryColor: "jungla", gradient: "#2E7D32, #1B5E20", image: "/img/inflables/mini-jungla.avif" },
  { slug: "gusanitos", emoji: "🐛", name: "Gusanitos", description: "Inflable tropical con gusanitos decorativos y palmeras. Amplia área de salto con colores vibrantes verde, morado, amarillo y azul.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Tropical", categoryColor: "jungla", gradient: "#558B2F, #827717", image: "/img/inflables/gusanitos.avif" },
  { slug: "mini-castillo", emoji: "🏰", name: "Mini Castillo", description: "Brincolín compacto diseñado para bebés y niños pequeños. Paredes suaves, fácil supervisión. Perfecto para interiores y espacios reducidos.", price: "$800", size: "2×2×2m", ages: "1-4 años", category: "Chico", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f", image: "/img/inflables/mini-castillo.avif" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Épico barco pirata con velas, mástil de 4 metros y tobogán gigante. Capacidad para 10-15 niños simultáneamente.", price: "$2,500", size: "7×5×4m", ages: "3-12 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "🏁", name: "Extremo", description: "Circuito de obstáculos de 12 metros con muros para escalar, túneles y tobogán final. Doble carril para carreras simultáneas.", price: "$3,000", size: "12×4×3m", ages: "6+ años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
  { slug: "castillo-blanco", emoji: "🤍", name: "Castillo Blanco", description: "El inflable más elegante para bodas, XV años y eventos formales. Torres decorativas de 3 metros en blanco inmaculado.", price: "$2,800", size: "6×5×4m", ages: "3+ años", category: "Bodas", categoryColor: "bodas", gradient: "#7E57C2, #9575CD", image: "/img/inflables/castillo-blanco.avif" },
  { slug: "tobogan-seco-gigante", emoji: "🎢", name: "Tobogán Seco Gigante", description: "Tobogán seco de 6 metros de altura con rampa de descenso ultra rápida. La adrenalina máxima para eventos grandes.", price: "$2,200", size: "6×3×6m", ages: "5-14 años", category: "Tobogán", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/tobogan-seco-gigante.avif" },
  { slug: "piscina-inflable", emoji: "💧", name: "Piscina Inflable", description: "Alberca inflable con bomba de agua incluida. Perfecta para fiestas de verano y eventos al aire libre.", price: "$1,800", size: "5×5×1m", ages: "3-12 años", category: "Acuático", categoryColor: "acuatico", gradient: "#0288D1, #0EA5E9", image: "/img/inflables/piscina-inflable.avif" },
  { slug: "castillo-superhero", emoji: "🦸", name: "Castillo Súper Héroes", description: "Castillo temático con personajes de cómic. Diseño heroico con colores vibrantes y resbaladilla integrada.", price: "$1,500", size: "4×4×3.5m", ages: "4-12 años", category: "Temático", categoryColor: "castillo", gradient: "#1565C0, #E53935", image: "/img/inflables/castillo-superhero.avif" },
  { slug: "obstaculos-extremo-xl", emoji: "🏁", name: "Obstáculos Extremo XL", description: "Circuito de 15 metros con doble carril para competencias simultáneas. El más grande de nuestro catálogo.", price: "$4,500", size: "15×5×4m", ages: "6-15 años", category: "Extremo XL", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/obstaculos-extremo-xl.avif" },
  { slug: "princesas-premium", emoji: "👑", name: "Princesas Premium", description: "Edición premium del castillo de princesas con resbaladilla doble y decoración de lujo. El sueño de toda princesa.", price: "$1,800", size: "5×5×4m", ages: "3-10 años", category: "Premium", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/princesas-premium.avif" },
  { slug: "dinosaurios", emoji: "🦕", name: "Dinosaurios T-Rex", description: "Inflable temático de dinosaurios con T-Rex de 3 metros. Aventura jurásica para los más valientes.", price: "$1,500", size: "5×4×3.5m", ages: "3-12 años", category: "Temático", categoryColor: "jungla", gradient: "#2E7D32, #827717", image: "/img/inflables/dinosaurios.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="category"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables" },
  ]}
>

  <section class="hero" style="padding:clamp(5rem,8vw,6rem) 0 clamp(2rem,4vw,3rem);">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🎈 Catálogo completo</span>
          <h1 class="hero__title">
            Catálogo de <span class="highlight">Inflables</span>
          </h1>
          <p class="hero__desc">
            Todos nuestros inflables incluyen entrega, instalación, limpieza y seguro. Elige el tuyo.
          </p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Solicitar cotización</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            Contamos con la mayor variedad de <strong>brincolines e inflables para renta</strong> en CDMX y Estado de México. Desde castillos clásicos hasta toboganes acuáticos y pistas de obstáculos.
          </p>
          <p class="hero__copy-text">
            Todos nuestros inflables pasan por un riguroso proceso de limpieza y mantenimiento antes de cada evento. Fabricados con materiales de grado comercial y certificados en seguridad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Inflables</span>
    </nav>
  </div>

  <section class="section" style="padding-top:1.5rem;">
    <div class="container">
      <div class="grid-4">
        {productos.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿No encuentras lo que buscas?"
    subtitle="Tenemos más opciones disponibles. Contáctanos y te ayudamos a encontrar el inflable ideal."
    btnText="Preguntar por WhatsApp"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20busco%20un%20inflable%20especial%20para%20mi%20evento."
    btnSecondaryText="Solicitar cotización"
    btnSecondaryHref="/cotizar/"
    variant="warm"
    whatsapp={true}
    external={true}
  />

</PageLayout>
