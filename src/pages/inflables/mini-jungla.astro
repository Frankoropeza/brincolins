---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta de Mini Jungla Inflable | BRINCOLINS CDMX";
const description = "Renta el inflable Mini Jungla para fiestas infantiles en CDMX y Edomex. Aventura safari con animales y palmeras tropicales. Desde $1,200 MXN con entrega incluida.";

const inflable = {
  slug: "mini-jungla",
  emoji: "🌴",
  name: "Mini Jungla",
  price: "$1,200",
  priceNum: "1200",
  size: "4×4×3m",
  ages: "3-10 años",
  gradient: "#2E7D32, #1B5E20",
  desc: "El inflable Mini Jungla transporta a los niños a una aventura selvática con animales decorativos de 2 metros y palmeras tropicales. Su diseño compacto pero dinámico es ideal tanto para exteriores como interiores con techos altos, perfecto para fiestas safari y niños exploradores que aman la naturaleza.",
  features: ["Temática safari con animales de 2 metros", "Palmeras decorativas tropicales", "Diseño compacto y versátil", "Apto para interior y exterior", "Material resistente a uso intensivo", "Instalación rápida en 15 minutos"],
  capacity: "5-7 niños simultáneamente",
  installTime: "15 minutos",
  requirements: "Espacio mínimo 5×5m, toma de corriente 110V a menos de 15m",
  image: "/img/inflables/mini-jungla.avif",
};

const otrosInflables = [
  { slug: "gusanitos", emoji: "🐛", name: "Gusanitos", description: "Inflable tropical con gusanitos y palmeras decorativas.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Tropical", categoryColor: "jungla", gradient: "#558B2F, #827717", image: "/img/inflables/gusanitos.avif" },
  { slug: "dragones-rojos", emoji: "🐉", name: "Dragones Rojos", description: "El más rentado en CDMX. Dos dragones de 3m con resbaladilla.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Barco pirata épico de 7m con tobogán gigante.", price: "$2,500", size: "7×5×4m", ages: "3-12 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO — 2 columnas: Col1 título+CTAs / Col2 2 párrafos SEO -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">

        <!-- Columna 1: título + CTAs -->
        <div>
          <span class="hero__badge">🌴 Aventura safari para niños</span>
          <h1 class="hero__title">Renta <span class="highlight">Mini Jungla</span> para tu Fiesta</h1>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Ver disponibilidad</a>
          </div>
        </div>

        <!-- Columna 2: 2 párrafos SEO -->
        <div class="hero__copy">
          <p class="hero__copy-text">El <strong>inflable Mini Jungla de BRINCOLINS</strong> transporta a los niños a una emocionante aventura selvática en la <strong>Ciudad de México y Estado de México</strong>. Con animales decorativos de 2 metros de altura y palmeras tropicales, es la opción ideal para fiestas temáticas de safari y niños exploradores. Fabricado con <strong>material de grado comercial resistente</strong> y desinfectado con protocolo certificado antes de cada evento.</p>
          <p class="hero__copy-text">La renta incluye <strong>entrega a domicilio, instalación en 15 minutos, motor inflador silencioso, extensión eléctrica y seguro de responsabilidad civil</strong>. Apto para interior y exterior, es versátil para cualquier tipo de espacio. Cubrimos las <strong>16 alcaldías de CDMX</strong> y municipios del Edomex como Naucalpan, Ecatepec y Tlalnepantla. Reserva con el 50% de anticipo — respuesta inmediata por WhatsApp.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- FOTO DEL PRODUCTO -->
  <section style="padding:0 0 2rem;">
    <div class="container">
      <img src={inflable.image} alt="Renta de inflable Mini Jungla safari en CDMX" width="1200" height="675"
           loading="eager" style="width:100%;max-height:500px;object-fit:cover;border-radius:var(--r-card);display:block;" />
    </div>
  </section>


  <!-- GALERÍA DE IMÁGENES -->
  <section style="padding:0 0 2rem;">
    <div class="container">
      <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:1.25rem;color:var(--c-heading)">Galería de fotos</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;">
        <img src="/img/inflables/mini-jungla-v3.avif" alt="Mini jungla inflable exterior profesional CDMX" width="1200" height="675" loading="lazy" style="width:100%;height:240px;object-fit:cover;border-radius:var(--r-card);" />
        <img src="/img/inflables/mini-jungla-v4.avif" alt="Renta mini jungla safari inflable CDMX" width="1200" height="675" loading="lazy" style="width:100%;height:240px;object-fit:cover;border-radius:var(--r-card);" />
      </div>
    </div>
  </section>

  <!-- INFO DEL PRODUCTO -->
  <section class="section">
    <div class="container">
      <div class="product-info">
        <p class="product-info__desc">{inflable.desc}</p>
        <div class="product-info__specs">
          <div class="product-info__spec"><span class="product-info__label">Medidas</span><strong>{inflable.size}</strong></div>
          <div class="product-info__spec"><span class="product-info__label">Edad recomendada</span><strong>{inflable.ages}</strong></div>
          <div class="product-info__spec"><span class="product-info__label">Capacidad</span><strong>{inflable.capacity}</strong></div>
          <div class="product-info__spec"><span class="product-info__label">Instalación</span><strong>{inflable.installTime}</strong></div>
          <div class="product-info__spec"><span class="product-info__label">Precio</span><strong style="color:var(--c-primary);">Desde {inflable.price} MXN</strong></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Características</h2>
      </div>
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Requisitos técnicos</h2>
      </div>
      <div style="max-width:600px; margin:0 auto; background:var(--c-bg-alt); padding:2rem; border-radius:var(--r-card);">
        <p><strong>Espacio necesario:</strong> {inflable.size} (mínimo)</p>
        <p style="margin-top:.75rem;"><strong>Requisitos:</strong> {inflable.requirements}</p>
        <p style="margin-top:.75rem;"><strong>Tiempo de instalación:</strong> {inflable.installTime}</p>
        <p style="margin-top:.75rem;"><strong>Capacidad:</strong> {inflable.capacity}</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Otros inflables que te pueden gustar</h2>
      </div>
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title={`¿Te interesa el ${inflable.name}?`}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="WhatsApp directo"
    btnSecondaryHref={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
    variant="vibrant"
  />

</PageLayout>
