---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Toboganes Inflables para Renta en CDMX | BRINCOLINS CDMX";
const description = "Renta de toboganes inflables en CDMX y Edomex. Toboganes secos y acuáticos desde $2,200 MXN con entrega, instalación y seguro. Diversión garantizada.";

const productos = [
  { slug: "tobogan-seco-gigante", emoji: "🎢", name: "Tobogán Seco Gigante", description: "Tobogán inflable de 6 metros de altura con doble carril para deslizarse. Emoción vertical garantizada para niños y adolescentes por igual.", price: "$2,200", size: "6×3×6m", ages: "5-14 años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/tobogan-seco-gigante.avif" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Épico barco pirata con velas, mástil de 4 metros y tobogán gigante. Capacidad para 10-15 niños simultáneamente.", price: "$2,500", size: "7×5×4m", ages: "3-12 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "🏁", name: "Extremo", description: "Circuito de obstáculos de 12 metros con muros para escalar, túneles y tobogán final. Doble carril para carreras simultáneas.", price: "$3,000", size: "12×4×3m", ages: "6+ años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
];

const faqs = [
  { question: "¿Qué altura tiene el tobogán más grande?", answer: "Nuestro Tobogán Seco Gigante alcanza los 6 metros de altura, equivalente a un edificio de dos pisos. Cuenta con escalera reforzada con agarraderas laterales y superficie de deslizamiento de alta velocidad con frenado progresivo al final." },
  { question: "¿Los toboganes son seguros para niños pequeños?", answer: "Recomendamos los toboganes para niños a partir de 5 años. La escalera requiere cierta coordinación motriz y la velocidad de deslizamiento puede asustar a los más pequeños. Para menores de 5 años, sugerimos nuestros brincolines clásicos." },
  { question: "¿Cuánto espacio necesito para instalar un tobogán inflable?", answer: "El Tobogán Seco Gigante requiere un área de 8×5 metros con al menos 7 metros de altura libre (uso en exteriores). Es fundamental contar con superficie plana y sin cables aéreos ni ramas de árboles cercanas." },
  { question: "¿Se pueden usar los toboganes con agua?", answer: "El Tobogán Seco Gigante está diseñado exclusivamente para uso seco. Sin embargo, el Barco Pirata puede adaptarse para uso con agua bajo condiciones específicas. Pregúntanos por WhatsApp para más detalles según tu evento." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="category"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: "Toboganes Inflables" },
  ]}
  faqItems={faqs}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables/">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Toboganes Inflables</span>
    </nav>
  </div>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🎢 Toboganes</span>
          <h1 class="hero__title">Toboganes <span class="highlight">Inflables</span> para Renta</h1>
          <p class="hero__desc">Adrenalina vertical para tu evento. Toboganes de hasta 6 metros de altura con doble carril y frenado seguro.</p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver todo el catálogo</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            Los <strong>toboganes inflables</strong> llevan la emoción de tu fiesta a otro nivel, literalmente. Con alturas que alcanzan los 6 metros, estos inflables generan una experiencia que combina la escalada, la velocidad del descenso y las risas interminables de los participantes.
          </p>
          <p class="hero__copy-text">
            Cada tobogán cuenta con escaleras reforzadas con agarraderas antideslizantes, superficies de deslizamiento de alta velocidad y zonas de frenado progresivo al final del recorrido. La estructura está diseñada para soportar uso intensivo durante todo el evento sin perder firmeza.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="🎈 Catálogo"
        title="Nuestros Toboganes Inflables"
        subtitle="Desde toboganes compactos hasta circuitos con deslizadero final."
        copy1="Nuestra selección de toboganes inflables incluye desde el imponente Tobogán Seco Gigante de 6 metros hasta el versátil Barco Pirata con su deslizadero integrado. Cada modelo ofrece una experiencia de descenso única que mantiene a los niños formados para repetir una y otra vez."
        copy2="Los toboganes son ideales para eventos con niños mayores de 5 años que buscan emociones más intensas que un brincolín tradicional. El doble carril del circuito Extremo permite organizar carreras entre amigos, añadiendo un elemento competitivo que eleva la energía de la fiesta."
      />
      <div class="grid-4">
        {productos.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- POR QUÉ ELEGIR ESTA CATEGORÍA -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="✅ Ventajas"
        title="¿Por qué elegir un tobogán inflable?"
        subtitle="La atracción estrella que convierte tu evento en algo inolvidable."
        copy1="Un tobogán inflable transforma instantáneamente cualquier jardín o explanada en un parque de diversiones. Su presencia imponente genera expectativa desde que los invitados llegan, y la emoción del descenso crea recuerdos que duran años."
        copy2="A diferencia de los brincolines tradicionales, los toboganes ofrecen una experiencia más dinámica con escalada, deslizamiento y la satisfacción de conquistar la altura. Son perfectos para eventos donde asisten niños de diferentes edades que necesitan retos variados."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #E65100, #BF360C);">
            <span class="why-card__img-label">⚡</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Máxima emoción</h3>
            <p class="why-card__desc">Hasta 6 metros de altura para deslizarse a toda velocidad. La atracción que todos quieren repetir en tu fiesta.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0D47A1);">
            <span class="why-card__img-label">🏗️</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Estructura reforzada</h3>
            <p class="why-card__desc">Escaleras con agarraderas, costuras de triple refuerzo y anclajes industriales que garantizan estabilidad total.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #2E7D32, #1B5E20);">
            <span class="why-card__img-label">🎯</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Frenado progresivo</h3>
            <p class="why-card__desc">Zona de frenado al final del recorrido que reduce la velocidad gradualmente para un aterrizaje suave y seguro.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7E57C2, #9575CD);">
            <span class="why-card__img-label">👥</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Doble carril disponible</h3>
            <p class="why-card__desc">Algunos modelos ofrecen carriles paralelos para carreras entre amigos. Duplica la diversión y reduce tiempos de espera.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes"
        subtitle="Resolvemos tus dudas sobre toboganes inflables."
        copy1="Los toboganes inflables requieren consideraciones especiales de espacio y altura. Aquí encontrarás las respuestas a las preguntas más comunes para asegurarte de que tu evento sea un éxito total."
        copy2="Nuestro equipo técnico evalúa cada ubicación antes de confirmar la instalación para garantizar que el tobogán se coloque de manera óptima y segura. Escríbenos por WhatsApp con fotos de tu espacio y te asesoramos sin compromiso."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Listo para rentar tu tobogán inflable?"
    subtitle="Cotiza sin compromiso. Respondemos en minutos por WhatsApp."
    btnText="Cotizar por WhatsApp"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
    btnSecondaryText="Ver catálogo completo"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

</PageLayout>
