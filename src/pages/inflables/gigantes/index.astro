---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Inflables Gigantes XXL para Renta en CDMX | BRINCOLINS CDMX";
const description = "Renta de inflables gigantes XXL en CDMX y Edomex. Modelos de hasta 15 metros para eventos grandes desde $2,200 MXN. Entrega, instalación y seguro incluidos.";

const productos = [
  { slug: "obstaculos-extremo-xl", emoji: "🏁", name: "Obstáculos Extremo XL", description: "El circuito de obstáculos más grande de nuestro catálogo. 15 metros de pura adrenalina con muros de escalada, túneles dobles y mega tobogán final.", price: "$4,500", size: "15×5×4m", ages: "6-15 años", category: "Extremo XL", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/obstaculos-extremo-xl.avif" },
  { slug: "castillo-blanco", emoji: "🤍", name: "Castillo Blanco", description: "El inflable más elegante para bodas, XV años y eventos formales. Torres decorativas de 3 metros en blanco inmaculado.", price: "$2,800", size: "6×5×4m", ages: "3+ años", category: "Bodas", categoryColor: "bodas", gradient: "#7E57C2, #9575CD", image: "/img/inflables/castillo-blanco.avif" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Épico barco pirata con velas, mástil de 4 metros y tobogán gigante. Capacidad para 10-15 niños simultáneamente.", price: "$2,500", size: "7×5×4m", ages: "3-12 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "tobogan-seco-gigante", emoji: "🎢", name: "Tobogán Seco Gigante", description: "Tobogán inflable de 6 metros de altura con doble carril para deslizarse. Emoción vertical garantizada para niños y adolescentes por igual.", price: "$2,200", size: "6×3×6m", ages: "5-14 años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/tobogan-seco-gigante.avif" },
];

const faqs = [
  { question: "¿Qué espacio necesito para un inflable gigante?", answer: "Depende del modelo. El Extremo XL requiere un área de 17×7 metros, mientras que el Castillo Blanco necesita 8×7 metros. Necesitas al menos 1.5 metros libres alrededor del inflable y acceso vehicular para la descarga del equipo." },
  { question: "¿Los inflables gigantes funcionan con corriente doméstica?", answer: "Los modelos más grandes requieren dos tomas de corriente de 110V con circuito independiente o una conexión de 220V. Nuestro equipo verifica las condiciones eléctricas del lugar antes de confirmar la instalación para evitar sorpresas." },
  { question: "¿Cuánto tiempo tarda la instalación de un inflable gigante?", answer: "La instalación de un inflable gigante toma entre 45 minutos y 1.5 horas dependiendo del modelo y las condiciones del terreno. Nuestro equipo llega con anticipación suficiente para tener todo listo antes de que comience tu evento." },
  { question: "¿Se pueden instalar en explanadas o estacionamientos?", answer: "Sí, los inflables gigantes pueden instalarse sobre concreto, asfalto o pasto. En superficies duras utilizamos anclajes especiales con pesas de agua o arena en lugar de estacas. Verificamos que la superficie esté limpia y libre de objetos punzantes." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="category"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: "Inflables Gigantes XXL" },
  ]}
  faqItems={faqs}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables/">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Inflables Gigantes XXL</span>
    </nav>
  </div>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🏟️ Gigantes</span>
          <h1 class="hero__title">Inflables <span class="highlight">Gigantes XXL</span> para Renta</h1>
          <p class="hero__desc">Los inflables más grandes e impresionantes de CDMX. Modelos de hasta 15 metros para eventos que necesitan ir en grande.</p>
          <div class="hero__ctas">
            <a href="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver todo el catálogo</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            Cuando tu evento necesita causar un impacto monumental, los <strong>inflables gigantes XXL</strong> son la respuesta. Con dimensiones que van desde los 6 metros de altura hasta los 15 metros de longitud, estos inflables dominan cualquier espacio y se convierten en el punto focal de la celebración.
          </p>
          <p class="hero__copy-text">
            Ideales para eventos con gran cantidad de invitados, kermeses escolares, festivales comunitarios y celebraciones empresariales. Su capacidad superior permite que más participantes disfruten simultáneamente, eliminando las largas filas de espera y manteniendo la diversión constante.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="🎈 Catálogo"
        title="Nuestros Inflables Gigantes XXL"
        subtitle="Los modelos más grandes e impresionantes de todo nuestro catálogo."
        copy1="Nuestra línea gigante incluye el circuito Extremo XL de 15 metros, el majestuoso Castillo Blanco de 6×5 metros, el imponente Barco Pirata con mástil de 4 metros y el vertiginoso Tobogán Seco Gigante de 6 metros de altura. Cada uno diseñado para eventos que no se conforman con poco."
        copy2="Estos inflables están construidos con materiales de grado industrial y sistemas de inflado de alta potencia que mantienen la estructura firme incluso con uso intensivo. Los refuerzos estructurales adicionales y los múltiples puntos de anclaje garantizan estabilidad absoluta."
      />
      <div class="grid-4">
        {productos.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- POR QUÉ ELEGIR ESTA CATEGORÍA -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="✅ Ventajas"
        title="¿Por qué elegir un inflable gigante?"
        subtitle="Máximo impacto visual y capacidad para los eventos más ambiciosos."
        copy1="Un inflable gigante transforma cualquier explanada, jardín amplio o estacionamiento en un verdadero parque de diversiones. Su presencia imponente genera asombro desde la llegada de los invitados y se convierte en el tema de conversación del evento."
        copy2="La capacidad superior de estos modelos significa menos tiempo de espera y más tiempo de diversión para todos. En eventos con 50 o más invitados, un inflable gigante mantiene entretenidos a niños y adultos durante horas sin saturarse."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #E65100, #BF360C);">
            <span class="why-card__img-label">📐</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Dimensiones impresionantes</h3>
            <p class="why-card__desc">Hasta 15 metros de longitud y 6 metros de altura. Inflables que se ven desde lejos y causan impacto inmediato.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0D47A1);">
            <span class="why-card__img-label">👥</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Alta capacidad</h3>
            <p class="why-card__desc">Hasta 15 participantes simultáneos. Ideal para eventos grandes donde la diversión no puede detenerse.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7E57C2, #9575CD);">
            <span class="why-card__img-label">🏗️</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Grado industrial</h3>
            <p class="why-card__desc">Materiales reforzados, costuras de cuádruple sellado y motores de inflado de alta potencia para máxima durabilidad.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #2E7D32, #1B5E20);">
            <span class="why-card__img-label">🎪</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Eventos memorables</h3>
            <p class="why-card__desc">La pieza central perfecta para kermeses, festivales, eventos corporativos y celebraciones que buscan destacar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes"
        subtitle="Resolvemos tus dudas sobre inflables gigantes XXL."
        copy1="Los inflables gigantes tienen requerimientos especiales de espacio, electricidad y logística. Aquí respondemos las preguntas más frecuentes para que planifiques tu evento con toda la información necesaria."
        copy2="Antes de cada instalación, nuestro equipo realiza una visita técnica o solicita fotos del espacio para verificar que las dimensiones, accesos y conexiones eléctricas sean adecuadas. Este servicio de evaluación previa no tiene costo adicional."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title="¿Listo para rentar tu inflable gigante?"
    subtitle="Cotiza sin compromiso. Respondemos en minutos por WhatsApp."
    btnText="Cotizar por WhatsApp"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
    btnSecondaryText="Ver catálogo completo"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

</PageLayout>
