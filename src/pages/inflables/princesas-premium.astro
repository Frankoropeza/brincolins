---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Renta de Princesas Premium Inflable | BRINCOLINS CDMX";
const description = "Renta el inflable Princesas Premium con resbaladilla doble para fiestas en CDMX y Edomex. Edición premium con detalles reales. Desde $1,800 MXN con entrega.";

const inflable = {
  slug: "princesas-premium",
  emoji: "👑",
  name: "Princesas Premium",
  price: "$1,800",
  priceNum: "1800",
  size: "5×5×4m",
  ages: "3-10 años",
  gradient: "#E91E8C, #7C3AED",
  desc: "El inflable Princesas Premium es la versión más espectacular de nuestra línea de princesas. Con dos resbaladillas integradas, torres de 4 metros decoradas con coronas y gemas brillantes, y un área de brinco extra amplia, este castillo de ensueño hace realidad la fantasía de cualquier pequeña princesa. Su paleta en rosa, lila y dorado es simplemente deslumbrante.",
  features: ["Doble resbaladilla integrada de diferentes alturas", "Torres decoradas con coronas y gemas brillantes", "Área de brinco extra amplia de 5×5 metros", "Arco de entrada con decoración de princesas", "Mallas de seguridad en todos los costados", "Motor inflador silencioso de alta potencia incluido"],
  capacity: "8-10 niños",
  installTime: "25 minutos",
  requirements: "Espacio mínimo 6×6m, toma de corriente 110V",
  image: "/img/inflables/princesas-premium.avif",
};

const faqs = [
  { question: "¿En qué se diferencia del Castillo de Princesas normal?", answer: "El Princesas Premium es más grande (5×5m vs 4×4m), tiene doble resbaladilla en lugar de una, torres de 4 metros con detalles de coronas y gemas, y un área de brinco 50% más amplia. Los acabados decorativos son de mayor detalle con impresión digital de alta definición." },
  { question: "¿Es adecuado para fiestas de niñas y niños?", answer: "Aunque su temática es de princesas, muchos niños disfrutan igualmente brincando y deslizándose en las resbaladillas. Sin embargo, si buscas algo más neutral, te recomendamos nuestro Castillo Blanco o Dragones Rojos que son igual de divertidos." },
  { question: "¿Caben niñas de diferentes edades al mismo tiempo?", answer: "El inflable es seguro para niñas de 3 a 10 años brincando juntas. La doble resbaladilla permite que las más grandes usen la más alta y las pequeñas la más baja. Recomendamos un máximo de 8-10 niños simultáneamente para comodidad y seguridad." },
  { question: "¿Puedo decorar el inflable con globos o telas?", answer: "Puedes agregar decoración exterior como arcos de globos o telas en la entrada, siempre que no se fijen con tachuelas, grapas o cinta adhesiva directamente sobre el material del inflable. Usar cinta de tela en los anclajes es la forma más segura de añadir decoración." },
];

const otrosInflables = [
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Castillo rosa con princesas y resbaladilla.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/castillo-princesas.avif" },
  { slug: "castillo-blanco", emoji: "🏰", name: "Castillo Blanco", description: "Elegante castillo blanco para todo tipo de evento.", price: "$1,200", size: "4×4×3m", ages: "3-10 años", category: "Clásico", categoryColor: "castillo", gradient: "#757575, #BDBDBD", image: "/img/inflables/castillo-blanco.avif" },
  { slug: "gusanitos", emoji: "🐛", name: "Gusanitos", description: "Túnel inflable de gusanito para bebés y preescolares.", price: "$800", size: "3×2×2m", ages: "1-5 años", category: "Bebés", categoryColor: "jungla", gradient: "#43A047, #FDD835", image: "/img/inflables/gusanitos.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  faqItems={faqs}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables/">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">👑 Edición premium</span>
          <h1 class="hero__title">{inflable.emoji} <span class="highlight">{inflable.name}</span></h1>
          <p class="hero__desc">{inflable.desc}</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">💰 Desde {inflable.price} MXN</span>
          </div>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent('Hola BRINCOLINS, me interesa rentar el ' + inflable.name + '. ¿Tienen disponibilidad?')}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Solicitar cotización</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">El inflable Princesas Premium de BRINCOLINS lleva la magia de los cuentos de hadas a tu fiesta infantil en la Ciudad de México. Con su impresionante diseño de castillo rosa y lila, doble resbaladilla y espacio generoso para hasta 10 niñas brincando al mismo tiempo, es la pieza central que toda cumpleañera sueña para su celebración.</p>
          <p class="hero__copy-text">Esta edición premium supera en tamaño, acabados y capacidad a nuestro castillo de princesas estándar, convirtiéndolo en la opción preferida para fiestas con muchos invitados. Entregamos en toda la CDMX y zona metropolitana con instalación profesional incluida, para que solo te preocupes de disfrutar el momento mágico junto a tu princesa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CARACTERÍSTICAS -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="✅ Características"
        title="¿Qué incluye el Princesas Premium?"
        subtitle="Todo lo que necesitas para la diversión perfecta."
        copy1="El Princesas Premium está confeccionado con lona comercial de primera calidad con impresión digital fotográfica de alta resolución. Los detalles de coronas, gemas y decoración de princesas conservan su brillo y nitidez evento tras evento, garantizando una presentación impecable."
        copy2="La doble resbaladilla ofrece dos niveles de emoción: una más suave para las pequeñas de 3-5 años y otra más pronunciada para las de 6-10 años. Ambas cuentan con zona de aterrizaje acolchada y bordes elevados para máxima seguridad durante el descenso."
      />
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESO DE RENTA -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📋 Proceso"
        title="¿Cómo rentar este inflable?"
        subtitle="4 pasos simples para tener tu inflable listo."
        copy1="Reservar el Princesas Premium es tan sencillo como enviar un mensaje de WhatsApp. Nuestro equipo te confirma disponibilidad al instante y coordina la entrega en el horario que mejor te convenga para tu celebración especial."
        copy2="El Princesas Premium es uno de nuestros inflables más solicitados, especialmente los fines de semana. Te recomendamos reservar con al menos 5 días de anticipación para garantizar disponibilidad en tu fecha deseada."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">1</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Elige tu inflable</h3>
            <p class="why-card__desc">Explora nuestro catálogo y selecciona el inflable perfecto.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7C3AED, #9C27B0);">
            <span class="why-card__img-label">2</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Cotiza por WhatsApp</h3>
            <p class="why-card__desc">Envíanos un mensaje y te respondemos en minutos.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">3</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Reserva tu fecha</h3>
            <p class="why-card__desc">Aparta con 50% de anticipo y asegura disponibilidad.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">4</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">¡A brincar!</h3>
            <p class="why-card__desc">Entregamos, instalamos y recogemos. Tú solo disfruta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes"
        subtitle="Resolvemos tus dudas sobre este inflable."
        copy1="Queremos que tengas toda la información necesaria antes de rentar el Princesas Premium para la fiesta de tu pequeña. Aquí encontrarás respuestas detalladas a las preguntas más comunes de mamás y papás."
        copy2="Si tienes una duda específica sobre dimensiones, compatibilidad con tu espacio o personalización, no dudes en contactarnos por WhatsApp. Te asesoramos sin compromiso para que elijas la mejor opción."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <!-- INFLABLES RELACIONADOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="🎈 Relacionados"
        title="Otros inflables que te pueden gustar"
        subtitle="Explora más opciones para tu fiesta."
        copy1="Si el Princesas Premium te encanta, conoce también nuestra versión estándar del Castillo de Princesas para presupuestos más ajustados, o el elegante Castillo Blanco que combina con cualquier temática de fiesta."
        copy2="Para fiestas con niños de diferentes edades, puedes combinar el Princesas Premium con un inflable más pequeño como Gusanitos, ideal para los hermanitos menores. Pregunta por descuentos en combos."
      />
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title={"¿Te interesa el " + inflable.name + "?"}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos por WhatsApp."
    btnText="Cotizar por WhatsApp"
    btnHref={"https://wa.me/5547868402?text=" + encodeURIComponent("Hola BRINCOLINS, me interesa rentar el " + inflable.name + ".")}
    btnSecondaryText="Ver catálogo"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

</PageLayout>
