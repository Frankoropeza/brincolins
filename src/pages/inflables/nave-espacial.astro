---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta de Nave Espacial Inflable para Fiestas | BRINCOLINS CDMX";
const description = "Renta la Nave Espacial inflable para fiestas de ciencia en CDMX y Edomex. Desde $1,050 MXN con entrega e instalación incluida.";

const inflable = {
  slug: "nave-espacial",
  emoji: "🚀",
  name: "Nave Espacial",
  price: "$1,050",
  priceNum: "1050",
  size: "5×5m",
  ages: "4-12 años",
  gradient: "#1A237E, #283593",
  desc: "Nave espacial inflable con portal galáctico, tobogán de lanzamiento y decoración de planetas y estrellas. Para los pequeños astronautas que quieren explorar el universo en CDMX.",
  features: ["Diseño nave espacial con planetas", "Portal galáctico de entrada", "Tobogán de lanzamiento lateral", "Estrellas y luces decorativas", "Colores azul marino y plateado", "Material ultraresistente"],
  capacity: "Hasta 8 niños simultáneamente",
  installTime: "30 minutos",
  requirements: "Toma de corriente a menos de 15m, superficie plana de 5×5m",
  image: "/img/inflables/nave-espacial.avif",
};

const otrosInflables = [
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", price: "$950", size: "5×4m", ages: "4-10 años", gradient: "#1565C0, #0D47A1" },
  { slug: "cueva-dinosaurios", emoji: "🦕", name: "Cueva de Dinosaurios", price: "$900", size: "5×4m", ages: "3-10 años", gradient: "#558B2F, #827717" },
  { slug: "pista-obstaculos", emoji: "🏁", name: "Pista de Obstáculos", price: "$1,300", size: "8×4m", ages: "5-14 años", gradient: "#E65100, #BF360C" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <section class="section" style="padding-top:1rem;">
    <div class="container">
      <div class="product-hero__grid">
        <div class="product-hero__image" style={`background: linear-gradient(135deg, ${inflable.gradient});`}>
          <div class="img-placeholder">
            <span style="font-size:5rem;">{inflable.emoji}</span>
            <span class="img-placeholder__text">Foto próximamente</span>
          </div>
        </div>
        <div class="product-hero__info">
          <h1>{inflable.emoji} {inflable.name}</h1>
          <p class="product-hero__price">Desde {inflable.price} MXN</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">⏱️ Instalación: {inflable.installTime}</span>
          </div>
          <p style="margin-bottom:1.5rem; color:var(--c-text-muted); line-height:1.7;">{inflable.desc}</p>
          <div class="product-hero__actions">
            <a href="/cotizar" class="btn btn-primary">Cotizar ahora</a>
            <a href={`https://wa.me/5511111111?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa" target="_blank" rel="noopener">
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Características</h2>
      </div>
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Requisitos técnicos</h2>
      </div>
      <div style="max-width:600px; margin:0 auto; background:var(--c-bg-alt); padding:2rem; border-radius:var(--r-card);">
        <p><strong>📐 Espacio necesario:</strong> {inflable.size} (mínimo)</p>
        <p style="margin-top:.75rem;"><strong>⚡ Requisitos:</strong> {inflable.requirements}</p>
        <p style="margin-top:.75rem;"><strong>⏱️ Tiempo de instalación:</strong> {inflable.installTime}</p>
        <p style="margin-top:.75rem;"><strong>👥 Capacidad:</strong> {inflable.capacity}</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Otros inflables que te pueden gustar</h2>
      </div>
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
  title={`¿Te interesa el ${inflable.name}?`}
  subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
  btnText="Solicitar cotización"
  btnHref="/cotizar/"
  btnSecondaryText="WhatsApp directo"
  btnSecondaryHref={`https://wa.me/5511111111?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
  variant="vibrant"
/>

</PageLayout>
