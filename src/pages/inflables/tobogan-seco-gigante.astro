---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Renta de Tobogán Seco Gigante Inflable | BRINCOLINS CDMX";
const description = "Renta el Tobogán Seco Gigante de 6m de altura para fiestas en CDMX y Edomex. Adrenalina pura para niños y adolescentes. Desde $2,200 MXN con entrega incluida.";

const inflable = {
  slug: "tobogan-seco-gigante",
  emoji: "🎢",
  name: "Tobogán Seco Gigante",
  price: "$2,200",
  priceNum: "2200",
  size: "6×3×6m",
  ages: "5-14 años",
  gradient: "#E65100, #BF360C",
  desc: "El Tobogán Seco Gigante es la atracción más emocionante para fiestas infantiles y eventos juveniles en la Ciudad de México. Con 6 metros de altura, escalada lateral segura y pendiente de descenso acolchada, ofrece una experiencia de adrenalina controlada que fascina a niños y adolescentes por igual. Su estructura de grado comercial garantiza horas de diversión sin parar.",
  features: ["6 metros de altura con pendiente acolchada", "Escalada lateral con agarraderas de seguridad", "Zona de aterrizaje amplia y reforzada", "Mallas de protección en ambos costados", "Material comercial resistente al desgaste", "Motor inflador de alta potencia incluido"],
  capacity: "3-5 niños",
  installTime: "30 minutos",
  requirements: "Espacio mínimo 7×4m, toma de corriente 110V a menos de 15m",
  image: "/img/inflables/tobogan-seco-gigante.avif",
};

const faqs = [
  { question: "¿Es seguro el tobogán de 6 metros para niños?", answer: "Completamente. El Tobogán Seco Gigante cuenta con escalada lateral con agarraderas, mallas de protección en ambos lados y zona de aterrizaje acolchada. Recomendamos supervisión de un adulto durante su uso y está diseñado para niños de 5 a 14 años." },
  { question: "¿Necesito mucho espacio para instalarlo?", answer: "Necesitas un espacio mínimo de 7×4 metros con piso plano, ya sea pasto, concreto o tierra firme. También requieres una toma de corriente 110V a menos de 15 metros. Nuestro equipo evalúa el espacio antes de la instalación." },
  { question: "¿Cuánto tiempo tarda la instalación?", answer: "La instalación completa toma aproximadamente 30 minutos. Nuestro equipo se encarga de todo: transporte, inflado, anclaje de seguridad y prueba de funcionamiento. Al terminar el evento, también nos encargamos del desmontaje." },
  { question: "¿Se puede usar en interiores?", answer: "Sí, siempre que el techo tenga al menos 7 metros de altura libre y el espacio cumpla con las dimensiones mínimas. En salones de eventos es posible, pero debe verificarse previamente. Contáctanos y evaluamos tu espacio sin costo." },
];

const otrosInflables = [
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Barco pirata épico de 7m con tobogán.", price: "$2,500", size: "7×5×4m", ages: "3-12 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "🔥", name: "Extremo", description: "Inflable de obstáculos para los más aventureros.", price: "$2,800", size: "8×4×4m", ages: "5-14 años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
  { slug: "castillo-blanco", emoji: "🏰", name: "Castillo Blanco", description: "Elegante castillo blanco para todo tipo de evento.", price: "$1,200", size: "4×4×3m", ages: "3-10 años", category: "Clásico", categoryColor: "castillo", gradient: "#757575, #BDBDBD", image: "/img/inflables/castillo-blanco.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  faqItems={faqs}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables/">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🎢 Adrenalina pura</span>
          <h1 class="hero__title">{inflable.emoji} <span class="highlight">{inflable.name}</span></h1>
          <p class="hero__desc">{inflable.desc}</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">💰 Desde {inflable.price} MXN</span>
          </div>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent('Hola BRINCOLINS, me interesa rentar el ' + inflable.name + '. ¿Tienen disponibilidad?')}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Solicitar cotización</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">El Tobogán Seco Gigante se ha convertido en la atracción favorita para fiestas de preadolescentes y eventos juveniles en la Ciudad de México. Con sus imponentes 6 metros de altura, este inflable ofrece una experiencia de velocidad y emoción que ningún otro brincolín puede igualar, manteniendo siempre los más altos estándares de seguridad.</p>
          <p class="hero__copy-text">Ideal para cumpleaños, kermeses escolares, eventos corporativos familiares y celebraciones al aire libre, nuestro tobogán gigante incluye entrega, instalación profesional y recolección en toda la CDMX y zona metropolitana. El material de grado comercial resiste el uso intensivo durante todo el día sin perder firmeza ni forma.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CARACTERÍSTICAS -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="✅ Características"
        title="¿Qué incluye el Tobogán Seco Gigante?"
        subtitle="Todo lo que necesitas para la diversión perfecta."
        copy1="Nuestro Tobogán Seco Gigante está fabricado con lona comercial de alta densidad, costuras reforzadas con doble hilera y anclajes de acero inoxidable. Cada componente ha sido diseñado para soportar el uso intensivo de decenas de niños durante todo un evento sin comprometer la seguridad."
        copy2="Incluimos motor inflador de alta potencia que mantiene la estructura firme durante toda la renta. Las mallas laterales permiten visibilidad completa para que los padres supervisen cómodamente mientras los niños disfrutan de la velocidad del descenso."
      />
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESO DE RENTA -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📋 Proceso"
        title="¿Cómo rentar este inflable?"
        subtitle="4 pasos simples para tener tu inflable listo."
        copy1="Rentar el Tobogán Seco Gigante con BRINCOLINS es rápido y sencillo. Nos especializamos en hacer que tu experiencia sea libre de estrés, desde la cotización hasta la recolección del equipo al finalizar tu evento."
        copy2="Nuestro equipo de logística coordina horarios de entrega flexibles para adaptarnos a tus necesidades. Trabajamos los 7 días de la semana y cubrimos toda la CDMX y municipios conurbados del Estado de México."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">1</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Elige tu inflable</h3>
            <p class="why-card__desc">Explora nuestro catálogo y selecciona el inflable perfecto.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7C3AED, #9C27B0);">
            <span class="why-card__img-label">2</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Cotiza por WhatsApp</h3>
            <p class="why-card__desc">Envíanos un mensaje y te respondemos en minutos.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">3</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Reserva tu fecha</h3>
            <p class="why-card__desc">Aparta con 50% de anticipo y asegura disponibilidad.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">4</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">¡A brincar!</h3>
            <p class="why-card__desc">Entregamos, instalamos y recogemos. Tú solo disfruta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes"
        subtitle="Resolvemos tus dudas sobre este inflable."
        copy1="Sabemos que rentar un tobogán de 6 metros genera preguntas importantes sobre seguridad y logística. Aquí respondemos las dudas más comunes de nuestros clientes para que tomes la mejor decisión para tu evento."
        copy2="Si tienes alguna pregunta adicional que no aparece aquí, no dudes en escribirnos por WhatsApp. Nuestro equipo está disponible para resolver cualquier inquietud antes de que realices tu reservación."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <!-- INFLABLES RELACIONADOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="🎈 Relacionados"
        title="Otros inflables que te pueden gustar"
        subtitle="Explora más opciones para tu fiesta."
        copy1="Si el Tobogán Seco Gigante captó tu atención, te encantarán estas otras opciones de nuestra colección. Tenemos inflables para todas las edades, temáticas y tamaños de evento en la Ciudad de México."
        copy2="Puedes combinar varios inflables en un solo paquete y obtener descuentos especiales. Pregunta por nuestras promociones para eventos grandes, kermeses y fiestas con múltiples atracciones."
      />
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title={"¿Te interesa el " + inflable.name + "?"}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos por WhatsApp."
    btnText="Cotizar por WhatsApp"
    btnHref={"https://wa.me/5547868402?text=" + encodeURIComponent("Hola BRINCOLINS, me interesa rentar el " + inflable.name + ".")}
    btnSecondaryText="Ver catálogo"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

</PageLayout>
