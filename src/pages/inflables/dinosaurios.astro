---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Renta de Dinosaurios T-Rex Inflable | BRINCOLINS CDMX";
const description = "Renta el inflable Dinosaurios T-Rex temático para fiestas infantiles en CDMX y Edomex. Aventura jurásica con resbaladilla para niños 3-12 años. Desde $1,500 MXN.";

const inflable = {
  slug: "dinosaurios",
  emoji: "🦕",
  name: "Dinosaurios T-Rex",
  price: "$1,500",
  priceNum: "1500",
  size: "5×4×3.5m",
  ages: "3-12 años",
  gradient: "#2E7D32, #827717",
  desc: "El inflable Dinosaurios T-Rex transporta a los niños a la era jurásica con un diseño espectacular que incluye un T-Rex de 3.5 metros, palmeras tropicales, volcán decorativo y resbaladilla integrada. Es el favorito para fiestas temáticas de dinosaurios y aventureros. Los colores verdes, cafés y naranjas crean un ambiente prehistórico que fascina a niños de todas las edades.",
  features: ["T-Rex decorativo de 3.5 metros de altura", "Resbaladilla integrada con zona de aterrizaje", "Palmeras tropicales y volcán decorativo", "Área de brinco amplia para 6-8 niños", "Mallas de seguridad con visibilidad completa", "Motor inflador silencioso incluido"],
  capacity: "6-8 niños",
  installTime: "25 minutos",
  requirements: "Espacio mínimo 6×5m, toma de corriente 110V",
  image: "/img/inflables/dinosaurios.avif",
};

const faqs = [
  { question: "¿Qué dinosaurios tiene el inflable?", answer: "El inflable cuenta con un T-Rex principal de 3.5 metros como elemento central, además de gráficos decorativos de pterodáctilos, triceratops y huevos de dinosaurio impresos en las paredes laterales. El diseño crea un ambiente jurásico completo que encanta a los pequeños paleontólogos." },
  { question: "¿Es apropiado para niños muy pequeños?", answer: "Sí, el inflable está diseñado para niños desde 3 años. El diseño de los dinosaurios es amigable y colorido, no aterrador. La resbaladilla tiene una pendiente moderada apta para pequeños y el área de brinco es espaciosa para que se muevan con libertad y seguridad." },
  { question: "¿Se puede combinar con decoración de dinosaurios?", answer: "Es el complemento perfecto para una fiesta temática de dinosaurios. Muchos clientes lo combinan con manteles, platos, piñatas y centros de mesa de dinosaurios para crear una experiencia jurásica completa. La entrada del inflable es ideal para colocar un arco de globos temático." },
  { question: "¿Funciona tanto en interiores como exteriores?", answer: "El Dinosaurios T-Rex funciona en ambos espacios. Para interiores, necesitas un techo mínimo de 4 metros de altura y espacio libre de 6×5 metros. En exteriores, se instala sobre pasto, concreto o tierra firme. Solo necesitas una toma de corriente 110V cercana." },
];

const otrosInflables = [
  { slug: "mini-jungla", emoji: "🌴", name: "Mini Jungla", description: "Brincolín temático de jungla para los pequeños.", price: "$900", size: "3×3×2.5m", ages: "2-6 años", category: "Chico", categoryColor: "jungla", gradient: "#2E7D32, #66BB6A", image: "/img/inflables/mini-jungla.avif" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Barco pirata épico de 7m con tobogán.", price: "$2,500", size: "7×5×4m", ages: "3-12 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "🔥", name: "Extremo", description: "Inflable de obstáculos para los más aventureros.", price: "$2,800", size: "8×4×4m", ages: "5-14 años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  faqItems={faqs}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables/">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO 2 columnas -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">🦕 Era jurásica</span>
          <h1 class="hero__title">{inflable.emoji} <span class="highlight">{inflable.name}</span></h1>
          <p class="hero__desc">{inflable.desc}</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">💰 Desde {inflable.price} MXN</span>
          </div>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent('Hola BRINCOLINS, me interesa rentar el ' + inflable.name + '. ¿Tienen disponibilidad?')}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Solicitar cotización</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">El inflable Dinosaurios T-Rex de BRINCOLINS es la aventura prehistórica que todo niño amante de los dinosaurios merece vivir en su fiesta de cumpleaños. Con su imponente T-Rex de 3.5 metros, volcán decorativo y vegetación tropical, este brincolín crea un mundo jurásico donde la imaginación y la diversión no tienen límites.</p>
          <p class="hero__copy-text">Las fiestas temáticas de dinosaurios son una de las tendencias más populares en cumpleaños infantiles en la Ciudad de México. Nuestro inflable se integra perfectamente con cualquier decoración jurásica y es ideal para niños de 3 a 12 años. Incluye entrega, instalación y recolección en toda la CDMX y municipios del Estado de México.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CARACTERÍSTICAS -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="✅ Características"
        title="¿Qué incluye el Dinosaurios T-Rex?"
        subtitle="Todo lo que necesitas para la diversión perfecta."
        copy1="El inflable Dinosaurios T-Rex está fabricado con lona comercial de alta resistencia e impresión digital de calidad fotográfica. El T-Rex tridimensional de 3.5 metros está relleno de aire para mantener su forma imponente durante todo el evento y resistir el contacto con los niños."
        copy2="El diseño incluye detalles cuidados como huellas de dinosaurio en el piso del área de brinco, huevos de dinosaurio decorativos en las esquinas y un volcán en la parte trasera que complementa la ambientación jurásica. Las mallas laterales permiten supervisión visual completa."
      />
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESO DE RENTA -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📋 Proceso"
        title="¿Cómo rentar este inflable?"
        subtitle="4 pasos simples para tener tu inflable listo."
        copy1="Llevar la era jurásica a tu fiesta es más fácil de lo que imaginas. Con un simple mensaje de WhatsApp inicias el proceso de reservación y nuestro equipo se encarga de coordinar todos los detalles logísticos."
        copy2="El Dinosaurios T-Rex es muy solicitado los fines de semana, especialmente para cumpleaños de niños de 4 a 8 años. Reserva con anticipación para asegurar tu fecha y recibe confirmación inmediata de disponibilidad."
      />
      <div class="grid-4">
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #FF3D00, #FF6D00);">
            <span class="why-card__img-label">1</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Elige tu inflable</h3>
            <p class="why-card__desc">Explora nuestro catálogo y selecciona el inflable perfecto.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #7C3AED, #9C27B0);">
            <span class="why-card__img-label">2</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Cotiza por WhatsApp</h3>
            <p class="why-card__desc">Envíanos un mensaje y te respondemos en minutos.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #1565C0, #0288D1);">
            <span class="why-card__img-label">3</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">Reserva tu fecha</h3>
            <p class="why-card__desc">Aparta con 50% de anticipo y asegura disponibilidad.</p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-card__img" style="background: linear-gradient(135deg, #00C853, #2E7D32);">
            <span class="why-card__img-label">4</span>
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">¡A brincar!</h3>
            <p class="why-card__desc">Entregamos, instalamos y recogemos. Tú solo disfruta.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="❓ FAQ"
        title="Preguntas frecuentes"
        subtitle="Resolvemos tus dudas sobre este inflable."
        copy1="Las fiestas de dinosaurios son muy populares y entendemos que quieres que cada detalle sea perfecto. Aquí respondemos las preguntas más frecuentes sobre nuestro inflable Dinosaurios T-Rex para que planifiques tu evento sin preocupaciones."
        copy2="Estamos disponibles por WhatsApp para cualquier consulta adicional sobre compatibilidad con tu espacio, combinaciones con otros inflables o recomendaciones para tu fiesta temática de dinosaurios."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

  <!-- INFLABLES RELACIONADOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="🎈 Relacionados"
        title="Otros inflables que te pueden gustar"
        subtitle="Explora más opciones para tu fiesta."
        copy1="Los fans de los dinosaurios también disfrutan de nuestro inflable Mini Jungla para los más pequeños o el Barco Pirata para una aventura diferente. Cada inflable ofrece una temática única que complementa perfectamente tu celebración."
        copy2="Arma el combo perfecto rentando dos inflables para tu fiesta: el Dinosaurios T-Rex para los niños más grandes y un inflable más pequeño para los hermanitos menores. Consulta nuestros precios especiales por paquete."
      />
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
    title={"¿Te interesa el " + inflable.name + "?"}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos por WhatsApp."
    btnText="Cotizar por WhatsApp"
    btnHref={"https://wa.me/5547868402?text=" + encodeURIComponent("Hola BRINCOLINS, me interesa rentar el " + inflable.name + ".")}
    btnSecondaryText="Ver catálogo"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
    whatsapp={true}
    external={true}
  />

</PageLayout>
