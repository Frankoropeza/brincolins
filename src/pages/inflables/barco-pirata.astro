---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta de Barco Pirata Inflable | BRINCOLINS CDMX";
const description = "Renta el Barco Pirata inflable para fiestas infantiles en CDMX y Edomex. Barco épico de 7m con tobogán gigante. Desde $2,500 MXN con entrega incluida.";

const inflable = {
  slug: "barco-pirata",
  emoji: "🚢",
  name: "Barco Pirata",
  price: "$2,500",
  priceNum: "2500",
  size: "7×5×4m",
  ages: "3-12 años",
  gradient: "#1565C0, #0D47A1",
  desc: "El Barco Pirata es nuestro inflable más épico: un barco pirata de gran escala con velas imponentes, mástil de 4 metros y tobogán gigante. Con capacidad para 10-15 niños jugando simultáneamente, es la atracción perfecta para cumpleaños grandes, eventos escolares, kermeses y festivales. Su diseño temático de aventura pirata cautiva a niños y niñas por igual.",
  features: ["Velas y mástil de 4 metros", "Tobogán gigante integrado", "Capacidad para 10-15 niños", "Diseño temático pirata detallado", "Instalación profesional en 30 minutos", "Seguro de responsabilidad civil incluido"],
  capacity: "10-15 niños simultáneamente",
  installTime: "30 minutos",
  requirements: "Espacio mínimo 8×6m, toma de corriente 110V, uso exterior recomendado",
  image: "/img/inflables/barco-pirata.avif",
};

const otrosInflables = [
  { slug: "extremo", emoji: "🏁", name: "Extremo", description: "Circuito de 12m con obstáculos y doble carril.", price: "$3,000", size: "12×4×3m", ages: "6+ años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
  { slug: "dragones-rojos", emoji: "🐉", name: "Dragones Rojos", description: "El más rentado en CDMX. Dos dragones de 3m con resbaladilla.", price: "$1,200", size: "4×4×3m", ages: "4-10 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "castillo-blanco", emoji: "🤍", name: "Castillo Blanco", description: "Elegante castillo blanco para bodas y eventos formales.", price: "$2,800", size: "6×5×4m", ages: "3+ años", category: "Bodas", categoryColor: "bodas", gradient: "#7E57C2, #9575CD", image: "/img/inflables/castillo-blanco.avif" },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <section class="section" style="padding-top:1rem;">
    <div class="container">
      <div class="product-hero__grid">
        <div class="product-hero__image">
          <img src="/img/inflables/barco-pirata.avif" alt="barco-pirata" width="1200" height="675" loading="eager" style="width:100%;height:100%;object-fit:cover;border-radius:var(--r-card);" />
          
          </div>
        </div>
        <div class="product-hero__info">
          <h1>{inflable.emoji} {inflable.name}</h1>
          <p class="product-hero__price">Desde {inflable.price} MXN</p>
          <div class="product-hero__specs">
            <span class="product-hero__spec">📐 {inflable.size}</span>
            <span class="product-hero__spec">👶 {inflable.ages}</span>
            <span class="product-hero__spec">👥 {inflable.capacity}</span>
            <span class="product-hero__spec">⏱️ Instalación: {inflable.installTime}</span>
          </div>
          <p style="margin-bottom:1.5rem; color:var(--c-text-muted); line-height:1.7;">{inflable.desc}</p>
          <div class="product-hero__actions">
            <a href="/cotizar" class="btn btn-primary">Cotizar ahora</a>
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa" target="_blank" rel="noopener">
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Características</h2>
      </div>
      <div class="grid-3">
        {inflable.features.map((f: string) => (
          <div class="feature-card">
            <div class="feature-card__icon">✅</div>
            <p class="feature-card__desc">{f}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Requisitos técnicos</h2>
      </div>
      <div style="max-width:600px; margin:0 auto; background:var(--c-bg-alt); padding:2rem; border-radius:var(--r-card);">
        <p><strong>📐 Espacio necesario:</strong> {inflable.size} (mínimo)</p>
        <p style="margin-top:.75rem;"><strong>⚡ Requisitos:</strong> {inflable.requirements}</p>
        <p style="margin-top:.75rem;"><strong>⏱️ Tiempo de instalación:</strong> {inflable.installTime}</p>
        <p style="margin-top:.75rem;"><strong>👥 Capacidad:</strong> {inflable.capacity}</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Otros inflables que te pueden gustar</h2>
      </div>
      <div class="grid-3">
        {otrosInflables.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <CtaBanner
  title={`¿Te interesa el ${inflable.name}?`}
  subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
  btnText="Solicitar cotización"
  btnHref="/cotizar/"
  btnSecondaryText="WhatsApp directo"
  btnSecondaryHref={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
  variant="vibrant"
/>

</PageLayout>
