---
import PageLayout from "@/layouts/PageLayout.astro";
import Sidebar from "@/components/Sidebar.astro";
import ProductCard from "@/components/ProductCard.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta de Extremo Inflable | BRINCOLINS CDMX";
const description = "Renta el inflable Extremo para fiestas y eventos en CDMX y Edomex. Circuito de 12m con obstáculos y doble carril. Desde $3,000 MXN con entrega incluida.";

const inflable = {
  slug: "extremo",
  emoji: "🏁",
  name: "Extremo",
  price: "$3,000",
  priceNum: "3000",
  size: "12×4×3m",
  ages: "6+ años",
  gradient: "#E65100, #BF360C",
  desc: "El Extremo es un épico circuito de obstáculos de 12 metros de largo con doble carril para carreras simultáneas. Incluye muros para escalar, túneles para arrastrarse, barreras de salto y un tobogán final de alta velocidad. Ideal para eventos corporativos, team building, fiestas de cumpleaños con niños grandes, eventos escolares y activaciones de marca.",
  features: ["12 metros de circuito de obstáculos", "Doble carril para carreras simultáneas", "Muros para escalar y túneles", "Tobogán final de alta velocidad", "Ideal para eventos corporativos", "Instalación profesional en 30 minutos"],
  featureImages: ["/img/inflables/extremo/alquiler-brincolin-extremo-fiestas-infantiles.avif", "/img/inflables/extremo/alquiler-circuito-extremo-fiestas-mexico.avif", "/img/inflables/extremo/alquiler-circuito-obstaculos-inflable-cdmx.avif", "/img/inflables/extremo/alquiler-inflable-extremo-grande-fiestas.avif", "/img/inflables/extremo/brincolin-extremo-angulo-renta-eventos.avif", "/img/inflables/extremo/extremo-angulo-corporativo.avif", "/img/inflables/extremo/extremo-carrera-cdmx.avif", "/img/inflables/extremo/extremo-circuito-completo.avif", "/img/inflables/extremo/extremo-circuito-renta-cdmx.avif", "/img/inflables/extremo/extremo-frontal-cdmx.avif", "/img/inflables/extremo/extremo-lateral-evento.avif", "/img/inflables/extremo/extremo-pista-obstaculos.avif", "/img/inflables/extremo/extremo-tobogan-doble.avif", "/img/inflables/extremo/extremo-vista-general.avif"],
  capacity: "2-4 personas simultáneamente (doble carril)",
  installTime: "30 minutos",
  requirements: "Espacio mínimo 13×5m, toma de corriente 110V, uso exterior",
  image: "/img/inflables/extremo.avif",
};
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO — 2 columnas: Col1 título+CTAs / Col2 2 párrafos SEO -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">

        <!-- Columna 1: título + CTAs -->
        <div>
          <span class="hero__badge">🏁 Adrenalina para los más grandes</span>
          <h1 class="hero__title">Renta <span class="highlight">Inflable Extremo</span> para tu Evento</h1>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Ver disponibilidad</a>
          </div>
        </div>

        <!-- Columna 2: 2 párrafos SEO -->
        <div class="hero__copy">
          <p class="hero__copy-text">El <strong>inflable Extremo de BRINCOLINS</strong> es un circuito de obstáculos de 12 metros con doble carril, diseñado para los eventos más competitivos en <strong>CDMX y Estado de México</strong>. Con muros para escalar, túneles, barreras de salto y tobogán final de alta velocidad, es la atracción perfecta para niños grandes, adolescentes y adultos. Fabricado con <strong>material de grado comercial reforzado</strong> para soportar uso intensivo.</p>
          <p class="hero__copy-text">La renta incluye <strong>entrega a domicilio, instalación profesional en 30 minutos, motor inflador de alto rendimiento, extensión eléctrica y seguro de responsabilidad civil</strong>. Ideal para eventos corporativos, team building, kermeses y activaciones de marca. Cubrimos las <strong>16 alcaldías de CDMX</strong> y municipios del Edomex. Reserva con el 50% de anticipo — cotiza por WhatsApp y recibe respuesta inmediata.</p>
        </div>

      </div>
    </div>
  </section>


<!-- Contenido + Sidebar -->
  <div class="page-with-sidebar">
    <main class="page-with-sidebar__main">

      <section class="section">
        <div class="product-info">
          <h2 class="product-info__title">Renta de Circuito Extremo Inflable en CDMX — Adrenalina y Diversión sin Límites</h2>
          <p class="product-info__desc">{inflable.desc}</p>
          <div class="product-info__specs">
            <div class="product-info__spec"><span class="product-info__label">Medidas</span><strong>{inflable.size}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Edad recomendada</span><strong>{inflable.ages}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Capacidad</span><strong>{inflable.capacity}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Instalación</span><strong>{inflable.installTime}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Precio</span><strong style="color:var(--c-primary);">Desde {inflable.price} MXN</strong></div>
          </div></div>
      </section>

      
      <section class="section" style="padding-top:0;">
        <div class="product-info">
          <h3 style="font-family:var(--font-head);font-weight:800;font-size:1.05rem;margin-bottom:1rem;color:var(--c-text);">Galería de fotos</h3>
          <div class="gallery">
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-brincolin-extremo-fiestas-infantiles.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-circuito-extremo-fiestas-mexico.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-circuito-obstaculos-inflable-cdmx.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-inflable-extremo-grande-fiestas.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/brincolin-extremo-angulo-renta-eventos.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-angulo-corporativo.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-carrera-cdmx.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-circuito-completo.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-circuito-renta-cdmx.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
      </div>
        </div>
      </section>

      <section class="section section--alt">
        <div class="section-header">
          <h2 class="section-title">Características</h2>
        </div>
        <div class="grid-3">
          {inflable.features.map((f: string, i: number) => {
            const img = inflable.featureImages[i % inflable.featureImages.length];
            return (
              <div class="feature-img-card">
                <div class="feature-img-card__img">
                  <img src={img} alt={f} loading="lazy" width="400" height="267" />
                </div>
                <div class="feature-img-card__body">
                  <p class="feature-img-card__text">{f}</p>
                </div>
              </div>
            );
          })}
        </div>
      </section>

    </main>
    <aside>
      <Sidebar currentSlug={inflable.slug} />
    </aside>
  </div>


  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">🎈 Más inflables</span>
        <h2 class="section-title">Otros inflables que te pueden interesar</h2>
        <p class="section-subtitle">Todos incluyen entrega, instalación y seguro en CDMX y Edomex</p>
      </div>
      <div class="grid-4">
          <ProductCard slug="dragones-rojos" emoji="🐉" name="Dragones Rojos" description="El más rentado. Dos dragones de 3m con resbaladilla y mallas de seguridad." price="$1,200" size="4×4×3m" ages="4-10 años" category="Más popular" categoryColor="castillo" gradient="#B71C1C, #E53935" image="/img/inflables/dragones-rojos.avif" />
          <ProductCard slug="castillo-princesas" emoji="👸" name="Castillo de Princesas" description="Castillo rosa con princesas de 3m y resbaladilla incluida." price="$1,200" size="4×4×3m" ages="4-10 años" category="Princesas" categoryColor="princesas" gradient="#E91E8C, #7C3AED" image="/img/inflables/castillo-princesas.avif" />
          <ProductCard slug="mini-jungla" emoji="🌴" name="Mini Jungla" description="Inflable temático con animales y palmeras tropicales." price="$1,200" size="4×4×3m" ages="3-10 años" category="Aventura" categoryColor="jungla" gradient="#2E7D32, #1B5E20" image="/img/inflables/mini-jungla.avif" />
          <ProductCard slug="gusanitos" emoji="🐛" name="Gusanitos" description="Inflable tropical con gusanitos y colores vibrantes." price="$1,200" size="4×4×3m" ages="4-10 años" category="Tropical" categoryColor="jungla" gradient="#558B2F, #827717" image="/img/inflables/gusanitos.avif" />
      </div>
    </div>
  </section>

  <CtaBanner
    title={`¿Te interesa el ${inflable.name}?`}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="WhatsApp directo"
    btnSecondaryHref={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
    variant="vibrant"
  />

</PageLayout>

<style>
  .gal__title{font-family:var(--font-head);font-weight:800;font-size:clamp(1.3rem,3vw,1.75rem);margin-bottom:.4rem;color:var(--c-heading);}
  .gal__subtitle{color:var(--c-text-muted);font-size:.88rem;margin-bottom:1.25rem;}
  .gal__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:.65rem;}
  .gal__item{display:block;border-radius:var(--r-card);overflow:hidden;aspect-ratio:16/9;}
  .gal__item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s ease;}
  .gal__item:hover img{transform:scale(1.06);}
</style>