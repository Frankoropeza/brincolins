---
import PageLayout from "@/layouts/PageLayout.astro";
import Sidebar from "@/components/Sidebar.astro";
import ProductCard from "@/components/ProductCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta Circuito Extremo Inflable | BRINCOLINS CDMX y Edomex";
const description = "Renta el circuito Extremo inflable de 12 metros para kermeses, eventos escolares y corporativos en CDMX. Doble carril, tobogán, obstáculos. Desde $3,000 MXN.";

const inflable = {
  slug: "extremo",
  emoji: "🏁",
  name: "Extremo",
  price: "$3,000",
  priceNum: "3000",
  size: "12×4×3m",
  ages: "6+ años",
  gradient: "#E65100, #BF360C",
  desc: "El Extremo es un épico circuito de obstáculos de 12 metros de largo con doble carril para carreras simultáneas. Incluye muros para escalar, túneles para arrastrarse, barreras de salto y un tobogán final de alta velocidad. Ideal para eventos corporativos, team building, fiestas de cumpleaños con niños grandes, eventos escolares y activaciones de marca.",
  features: ["12 metros de circuito de obstáculos", "Doble carril para carreras simultáneas", "Muros para escalar y túneles", "Tobogán final de alta velocidad", "Ideal para eventos corporativos", "Instalación profesional en 30 minutos"],
  featureExcerpts: ["El circuito más largo disponible en renta en CDMX — 12 metros de obstáculos que mantienen a todos entretenidos por horas.", "Dos carriles paralelos permiten carreras simultáneas — ideal para competencias, torneos y activaciones grupales.", "Tres zonas de obstáculos: muros verticales para escalar, túneles horizontales y barreras de salto en secuencia.", "Tobogán de descenso rápido al final del recorrido — el premio al completar el circuito de obstáculos.", "Perfecto para team building, kermeses escolares, festivales y activaciones de marca en exteriores.", "Motor industrial de alta potencia para circuitos de uso intensivo. Instalación coordinada por equipo especializado."],
  featureImages: ["/img/inflables/extremo/alquiler-brincolin-extremo-fiestas-infantiles.avif", "/img/inflables/extremo/alquiler-circuito-extremo-fiestas-mexico.avif", "/img/inflables/extremo/alquiler-circuito-obstaculos-inflable-cdmx.avif", "/img/inflables/extremo/alquiler-inflable-extremo-grande-fiestas.avif", "/img/inflables/extremo/brincolin-extremo-angulo-renta-eventos.avif", "/img/inflables/extremo/extremo-angulo-corporativo.avif", "/img/inflables/extremo/extremo-carrera-cdmx.avif", "/img/inflables/extremo/extremo-circuito-completo.avif", "/img/inflables/extremo/extremo-circuito-renta-cdmx.avif", "/img/inflables/extremo/extremo-frontal-cdmx.avif", "/img/inflables/extremo/extremo-lateral-evento.avif", "/img/inflables/extremo/extremo-pista-obstaculos.avif", "/img/inflables/extremo/extremo-tobogan-doble.avif", "/img/inflables/extremo/extremo-vista-general.avif"],
  capacity: "2-4 personas simultáneamente (doble carril)",
  installTime: "30 minutos",
  image: "/img/inflables/extremo.avif",
};
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO — 2 columnas: Col1 título+CTAs / Col2 2 párrafos SEO -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">

        <!-- Columna 1: badge + H1 + CTAs -->
        <div>
          <span class="hero__badge">🏁 Circuito de 12 metros — el más completo</span>
          <h1 class="hero__title">Renta <span class="highlight">Circuito Extremo</span> Inflable en CDMX y Edomex</h1>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Ver disponibilidad</a>
          </div>
        </div>

        <!-- Columna 2: 2 párrafos SEO -->
        <div class="hero__copy">
          <p class="hero__copy-text">El <strong>Extremo de BRINCOLINS</strong> es el circuito de obstáculos inflable más completo disponible en <strong>CDMX y Estado de México</strong>. Con 12 metros de largo, doble carril para carreras simultáneas, muros para escalar, túneles y tobogán final de alta velocidad, es la atracción ideal para <strong>kermeses, eventos escolares, team building corporativo</strong> y fiestas de cumpleaños grandes.</p>
          <p class="hero__copy-text">La renta incluye <strong>entrega, instalación en 30 minutos, motor industrial, extensión eléctrica y seguro de responsabilidad civil</strong>. Requiere espacio exterior mínimo de 13×5m. Atendemos CDMX completa y los principales municipios del Estado de México — cotiza por WhatsApp y recibe respuesta inmediata para asegurar tu fecha.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <div class="page-with-sidebar">
    <main class="page-with-sidebar__main">

      <section class="section">
        <div class="product-info">
          <h2 class="product-info__title">Renta del Circuito Extremo en CDMX — Obstáculos, Carreras y Tobogán Gigante</h2>
          <p class="product-info__desc">{inflable.desc}</p>
          <div class="product-info__specs">
            <div class="product-info__spec"><span class="product-info__label">Medidas</span><strong>{inflable.size}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Edad recomendada</span><strong>{inflable.ages}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Capacidad</span><strong>{inflable.capacity}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Instalación</span><strong>{inflable.installTime}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Precio</span><strong style="color:var(--c-primary);">Desde {inflable.price} MXN</strong></div>
          </div>
        </div>
      </section>

      <section class="section" style="padding-top:0;">
        <div class="product-info">
          <div class="section-header" style="margin-bottom:1.25rem;">
            <span class="section-badge">📸 Fotos reales</span>
            <h2 class="section-title">Galería de fotos</h2>
          </div>
          <div class="gallery">
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-brincolin-extremo-fiestas-infantiles.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-circuito-extremo-fiestas-mexico.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-circuito-obstaculos-inflable-cdmx.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/alquiler-inflable-extremo-grande-fiestas.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/brincolin-extremo-angulo-renta-eventos.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-angulo-corporativo.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-carrera-cdmx.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-circuito-completo.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/extremo/extremo-circuito-renta-cdmx.avif" alt="extremo renta CDMX" loading="lazy" width="400" height="267" /></div>
          </div>
        </div>
      </section>

      <section class="section section--alt">
        <SectionHeader
          badge="✅ Incluido en tu renta"
          title="Características del Inflable"
          subtitle="Todo lo que incluye tu renta del Extremo"
          copy1="El circuito Extremo es el inflable más largo y completo de nuestro catálogo. Con 12 metros de obstáculos en doble carril, muros, túneles y tobogán final, es la atracción ideal para grupos de 6 años en adelante."
          copy2="Incluye motor industrial de alta potencia para uso prolongado, señalización de seguridad, sanitización certificada y seguro de responsabilidad civil. Instalación profesional en 30 minutos para exterior."
        />
        <div class="grid-3">
          {inflable.features.map((f: string, i: number) => {
            const img = inflable.featureImages[i % inflable.featureImages.length];
            const excerpt = inflable.featureExcerpts ? inflable.featureExcerpts[i] : "";
            return (
              <article class="feat-card">
                <div class="feat-card__img">
                  <img src={img} alt={f} loading="lazy" width="400" height="267" />
                  <span class="feat-card__num">{String(i + 1).padStart(2, "0")}</span>
                </div>
                <div class="feat-card__body">
                  <h3 class="feat-card__title">{f}</h3>
                  {excerpt && <p class="feat-card__excerpt">{excerpt}</p>}
                </div>
              </article>
            );
          })}
        </div>
      </section>

    </main>
    <aside>
      <Sidebar currentSlug={inflable.slug} />
    </aside>
  </div>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🎈 Más inflables"
        title="Otros inflables que te pueden interesar"
        subtitle="Todos con entrega, instalación y seguro incluidos en CDMX y Edomex"
        copy1="Para fiestas infantiles más íntimas, nuestros inflables medianos son perfectos: Dragones Rojos, Barco Pirata, Gusanitos y más, desde $1,200 MXN con entrega y instalación en CDMX y Edomex."
        copy2="Para los más pequeños, el Mini Castillo desde $800 MXN es la opción más segura. Para bodas y eventos formales, el Castillo Blanco es nuestra joya premium. Cotiza sin compromiso por WhatsApp."
      />
      <div class="grid-4">
          <ProductCard slug="dragones-rojos" emoji="🐉" name="Dragones Rojos" description="El inflable Dragones Rojos es el más rentado en CDMX y Estado de México. Con dos impresionantes dragones de 3 metros de altura custodiando el castillo, resbaladilla integrada y mallas de seguridad laterales para visibilidad total, es la atracción estrella de cualquier fiesta infantil. Su diseño en rojo y dorado vibrante garantiza horas de diversión segura." price="$1,200" size="4×4×3m" ages="4-10 años" category="Más popular" categoryColor="castillo" gradient="#B71C1C, #E53935" image="/img/inflables/dragones-rojos.avif" />
          <ProductCard slug="castillo-princesas" emoji="👸" name="Castillo de Princesas" description="El Castillo de Princesas es un inflable rosa y turquesa con dos elegantes princesas de 3 metros de altura y resbaladilla incluida. Con mallas de seguridad laterales para supervisión total, es el favorito absoluto para fiestas temáticas de niñas. Su diseño colorido y sus detalles de torres lo convierten en la atracción más fotografiada de cualquier celebración." price="$1,200" size="4×4×3m" ages="4-10 años" category="Princesas" categoryColor="princesas" gradient="#E91E8C, #7C3AED" image="/img/inflables/castillo-princesas.avif" />
          <ProductCard slug="mini-castillo" emoji="🏰" name="Mini Castillo" description="El Mini Castillo es el inflable perfecto para bebés y niños pequeños. Con dimensiones compactas de 2×2 metros y solo 2 metros de altura, cabe perfectamente en departamentos, salones pequeños y jardines reducidos. Sus paredes suaves están diseñadas especialmente para la seguridad de los más pequeños, y su tamaño permite una fácil supervisión desde cualquier ángulo." price="$800" size="2×2×2m" ages="1-4 años" category="Chico" categoryColor="castillo" gradient="#FF3D00, #ff6d3f" image="/img/inflables/mini-castillo.avif" />
          <ProductCard slug="barco-pirata" emoji="🚢" name="Barco Pirata" description="El Barco Pirata es nuestro inflable más épico: un barco pirata de gran escala con velas imponentes, mástil de 4 metros y tobogán gigante. Con capacidad para 10-15 niños jugando simultáneamente, es la atracción perfecta para cumpleaños grandes, eventos escolares, kermeses y festivales. Su diseño temático de aventura pirata cautiva a niños y niñas por igual." price="$2,500" size="7×5×4m" ages="3-12 años" category="Grande" categoryColor="pirata" gradient="#1565C0, #0D47A1" image="/img/inflables/barco-pirata.avif" />
      </div>
    </div>
  </section>

  <CtaBanner
    title={`¿Te interesa el ${inflable.name}?`}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="WhatsApp directo"
    btnSecondaryHref={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
    variant="vibrant"
  />

</PageLayout>
