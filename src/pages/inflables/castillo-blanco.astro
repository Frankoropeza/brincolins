---
import PageLayout from "@/layouts/PageLayout.astro";
import Sidebar from "@/components/Sidebar.astro";
import ProductCard from "@/components/ProductCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";

const title = "Renta Castillo Blanco Inflable para Bodas y XV Años | BRINCOLINS CDMX";
const description = "Renta el Castillo Blanco inflable para bodas, XV años y eventos formales en CDMX y Edomex. Elegante, blanco inmaculado. Desde $2,800 MXN con entrega.";

const inflable = {
  slug: "castillo-blanco",
  emoji: "🤍",
  name: "Castillo Blanco",
  price: "$2,800",
  priceNum: "2800",
  size: "6×5×4m",
  ages: "3+ años",
  gradient: "#7E57C2, #9575CD",
  desc: "El Castillo Blanco es nuestro inflable más elegante, diseñado exclusivamente para bodas, XV años, bautizos y eventos formales. En blanco inmaculado con torres decorativas de 3 metros, combina perfectamente con cualquier tipo de decoración floral o temática. Su tamaño imponente de 6×5 metros y capacidad para 8-10 personas lo convierten en una atracción espectacular que eleva el nivel de cualquier celebración.",
  features: ["Blanco inmaculado elegante", "Torres decorativas de 3 metros", "Combina con cualquier decoración", "Capacidad para 8-10 personas", "Ideal para bodas y XV años", "Sanitización premium incluida"],
  featureExcerpts: ["Acabado en blanco puro sin detalles de colores — el único inflable del catálogo diseñado para eventos formales y elegantes.", "Cuatro torres de 3 metros de altura con detalles sutiles que enmarcan el diseño sin restarle elegancia al evento.", "Perfecto junto a flores blancas, decoración dorada, minimalista o cualquier paleta de colores de boda o XV años.", "Con capacidad para 8-10 personas, es la atracción inclusiva perfecta para eventos donde los adultos también participan.", "El inflable de mayor tamaño del catálogo — 6×5×4m — presencia imponente que eleva el nivel visual del evento.", "Proceso de limpieza y sanitización premium antes de cada evento. Presentación impecable garantizada."],
  featureImages: ["/img/inflables/castillo-blanco/alquiler-castillo-blanco-bodas-decoracion.avif", "/img/inflables/castillo-blanco/alquiler-castillo-blanco-bodas-terraza-cdmx.avif", "/img/inflables/castillo-blanco/alquiler-inflable-blanco-bodas-rosas-cdmx.avif", "/img/inflables/castillo-blanco/brincolin-blanco-bodas-ceremonia-cdmx.avif", "/img/inflables/castillo-blanco/brincolin-blanco-bodas-decoracion-globos.avif"],
  capacity: "8-10 personas simultáneamente",
  installTime: "30 minutos",
  image: "/img/inflables/castillo-blanco.avif",
};
---

<PageLayout
  title={title}
  description={description}
  pageType="product"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Inflables", href: "/inflables" },
    { name: inflable.name },
  ]}
  product={{
    name: inflable.name,
    slug: inflable.slug,
    description: description,
    image: inflable.image,
    price: inflable.priceNum,
  }}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/inflables">Inflables</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{inflable.name}</span>
    </nav>
  </div>

  <!-- HERO — 2 columnas: Col1 título+CTAs / Col2 2 párrafos SEO -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">

        <!-- Columna 1: badge + H1 + CTAs -->
        <div>
          <span class="hero__badge">🤍 El más elegante — para eventos formales</span>
          <h1 class="hero__title">Renta <span class="highlight">Castillo Blanco</span> para Bodas y XV Años en CDMX</h1>
          <div class="hero__ctas">
            <a href={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}. ¿Tienen disponibilidad?`)}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/cotizar/" class="btn btn-outline btn-lg">Ver disponibilidad</a>
          </div>
        </div>

        <!-- Columna 2: 2 párrafos SEO -->
        <div class="hero__copy">
          <p class="hero__copy-text">El <strong>Castillo Blanco de BRINCOLINS</strong> es el inflable más elegante y sofisticado de nuestra flota, diseñado específicamente para <strong>bodas, XV años, bautizos y eventos formales</strong> en CDMX y Estado de México. En blanco inmaculado con torres decorativas de 3 metros, se integra perfectamente con cualquier tipo de decoración floral, temática o minimalista.</p>
          <p class="hero__copy-text">La renta incluye <strong>entrega, instalación discreta en 30 minutos, motor ultra-silencioso, extensión eléctrica y seguro de responsabilidad civil</strong>. El motor ultra-silencioso garantiza que no interfiera con la ceremonia ni la recepción. Cotiza por WhatsApp y asegura la fecha de tu evento especial con el 50% de anticipo.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <div class="page-with-sidebar">
    <main class="page-with-sidebar__main">

      <section class="section">
        <div class="product-info">
          <h2 class="product-info__title">Renta de Castillo Blanco en CDMX — Elegancia para Bodas, XV Años y Eventos Formales</h2>
          <p class="product-info__desc">{inflable.desc}</p>
          <div class="product-info__specs">
            <div class="product-info__spec"><span class="product-info__label">Medidas</span><strong>{inflable.size}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Edad recomendada</span><strong>{inflable.ages}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Capacidad</span><strong>{inflable.capacity}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Instalación</span><strong>{inflable.installTime}</strong></div>
            <div class="product-info__spec"><span class="product-info__label">Precio</span><strong style="color:var(--c-primary);">Desde {inflable.price} MXN</strong></div>
          </div>
        </div>
      </section>

      <section class="section" style="padding-top:0;">
        <div class="product-info">
          <div class="section-header" style="margin-bottom:1.25rem;">
            <span class="section-badge">📸 Fotos reales</span>
            <h2 class="section-title">Galería de fotos</h2>
          </div>
          <div class="gallery">
        <div class="gallery__item"><img src="/img/inflables/castillo-blanco/alquiler-castillo-blanco-bodas-decoracion.avif" alt="castillo-blanco renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/castillo-blanco/alquiler-castillo-blanco-bodas-terraza-cdmx.avif" alt="castillo-blanco renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/castillo-blanco/alquiler-inflable-blanco-bodas-rosas-cdmx.avif" alt="castillo-blanco renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/castillo-blanco/brincolin-blanco-bodas-ceremonia-cdmx.avif" alt="castillo-blanco renta CDMX" loading="lazy" width="400" height="267" /></div>
        <div class="gallery__item"><img src="/img/inflables/castillo-blanco/brincolin-blanco-bodas-decoracion-globos.avif" alt="castillo-blanco renta CDMX" loading="lazy" width="400" height="267" /></div>
          </div>
        </div>
      </section>

      <section class="section section--alt">
        <SectionHeader
          badge="✅ Incluido en tu renta"
          title="Características del Inflable"
          subtitle="Todo lo que incluye tu renta del Castillo Blanco"
          copy1="El Castillo Blanco es el inflable más exclusivo de la flota. Diseñado para bodas, XV años y bautizos, su blanco inmaculado y sus torres de 3 metros se integran perfectamente con cualquier decoración formal de evento."
          copy2="Incluye motor ultra-silencioso para no interferir con ceremonias y recepciones, instalación discreta coordinada por equipo profesional, sanitización premium y seguro de responsabilidad civil."
        />
        <div class="grid-3">
          {inflable.features.map((f: string, i: number) => {
            const img = inflable.featureImages[i % inflable.featureImages.length];
            const excerpt = inflable.featureExcerpts ? inflable.featureExcerpts[i] : "";
            return (
              <article class="feat-card">
                <div class="feat-card__img">
                  <img src={img} alt={f} loading="lazy" width="400" height="267" />
                  <span class="feat-card__num">{String(i + 1).padStart(2, "0")}</span>
                </div>
                <div class="feat-card__body">
                  <h3 class="feat-card__title">{f}</h3>
                  {excerpt && <p class="feat-card__excerpt">{excerpt}</p>}
                </div>
              </article>
            );
          })}
        </div>
      </section>

    </main>
    <aside>
      <Sidebar currentSlug={inflable.slug} />
    </aside>
  </div>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🎈 Más inflables"
        title="Otros inflables que te pueden interesar"
        subtitle="Todos con entrega, instalación y seguro incluidos en CDMX y Edomex"
        copy1="Para fiestas infantiles, nuestros inflables de colores son perfectos: Dragones Rojos, Castillo de Princesas, Mini Jungla, Gusanitos, Barco Pirata y más. Todos con entrega en CDMX y Edomex."
        copy2="Cotiza sin compromiso — respondemos en minutos por WhatsApp. Reserva con el 50% de anticipo para asegurar la disponibilidad en la fecha de tu evento especial."
      />
      <div class="grid-4">
          <ProductCard slug="dragones-rojos" emoji="🐉" name="Dragones Rojos" description="El inflable Dragones Rojos es el más rentado en CDMX y Estado de México. Con dos impresionantes dragones de 3 metros de altura custodiando el castillo, resbaladilla integrada y mallas de seguridad laterales para visibilidad total, es la atracción estrella de cualquier fiesta infantil. Su diseño en rojo y dorado vibrante garantiza horas de diversión segura." price="$1,200" size="4×4×3m" ages="4-10 años" category="Más popular" categoryColor="castillo" gradient="#B71C1C, #E53935" image="/img/inflables/dragones-rojos.avif" />
          <ProductCard slug="castillo-princesas" emoji="👸" name="Castillo de Princesas" description="El Castillo de Princesas es un inflable rosa y turquesa con dos elegantes princesas de 3 metros de altura y resbaladilla incluida. Con mallas de seguridad laterales para supervisión total, es el favorito absoluto para fiestas temáticas de niñas. Su diseño colorido y sus detalles de torres lo convierten en la atracción más fotografiada de cualquier celebración." price="$1,200" size="4×4×3m" ages="4-10 años" category="Princesas" categoryColor="princesas" gradient="#E91E8C, #7C3AED" image="/img/inflables/castillo-princesas.avif" />
          <ProductCard slug="mini-castillo" emoji="🏰" name="Mini Castillo" description="El Mini Castillo es el inflable perfecto para bebés y niños pequeños. Con dimensiones compactas de 2×2 metros y solo 2 metros de altura, cabe perfectamente en departamentos, salones pequeños y jardines reducidos. Sus paredes suaves están diseñadas especialmente para la seguridad de los más pequeños, y su tamaño permite una fácil supervisión desde cualquier ángulo." price="$800" size="2×2×2m" ages="1-4 años" category="Chico" categoryColor="castillo" gradient="#FF3D00, #ff6d3f" image="/img/inflables/mini-castillo.avif" />
          <ProductCard slug="barco-pirata" emoji="🚢" name="Barco Pirata" description="El Barco Pirata es nuestro inflable más épico: un barco pirata de gran escala con velas imponentes, mástil de 4 metros y tobogán gigante. Con capacidad para 10-15 niños jugando simultáneamente, es la atracción perfecta para cumpleaños grandes, eventos escolares, kermeses y festivales. Su diseño temático de aventura pirata cautiva a niños y niñas por igual." price="$2,500" size="7×5×4m" ages="3-12 años" category="Grande" categoryColor="pirata" gradient="#1565C0, #0D47A1" image="/img/inflables/barco-pirata.avif" />
      </div>
    </div>
  </section>

  <CtaBanner
    title={`¿Te interesa el ${inflable.name}?`}
    subtitle="Reserva ahora y asegura tu fecha. Respondemos en minutos."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="WhatsApp directo"
    btnSecondaryHref={`https://wa.me/5547868402?text=${encodeURIComponent(`Hola BRINCOLINS, me interesa rentar el ${inflable.name}.`)}`}
    variant="vibrant"
  />

</PageLayout>
