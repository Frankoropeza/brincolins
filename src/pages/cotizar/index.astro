---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import FaqItem from "@/components/FaqItem.astro";
import { INFLABLES_SELECT_OPTIONS } from "@/data/inflables";

const title = "Cotizar Renta de Inflables en CDMX | Sin Compromiso";
const description = "Cotiza tu inflable para fiestas en CDMX. Llena el formulario y recibe tu presupuesto personalizado por WhatsApp en menos de 30 minutos. Sin compromiso.";

const faqs = [
  { question: "¿Cuánto cuesta rentar un inflable?", answer: "Nuestros precios van desde $800 MXN por evento. El precio final depende del modelo elegido y la zona de entrega. Todos incluyen entrega, instalación, motor y recolección." },
  { question: "¿Cuánto tiempo tarda la cotización?", answer: "Respondemos en menos de 30 minutos durante nuestro horario de atención (8am a 8pm). Por WhatsApp la respuesta suele ser inmediata." },
  { question: "¿Necesito pagar un anticipo para reservar?", answer: "Sí, pedimos un anticipo del 50% para confirmar la reserva de tu fecha. El resto se paga el día del evento. Aceptamos transferencia, efectivo y tarjeta." },
  { question: "¿Puedo cotizar varios inflables para un mismo evento?", answer: "¡Claro! Ofrecemos paquetes especiales cuando rentas más de un inflable. Menciónalo en tu cotización y te haremos un precio especial." },
  { question: "¿La cotización tiene algún costo?", answer: "No, la cotización es completamente gratuita y sin compromiso. Solicítala por formulario o WhatsApp y te responderemos a la brevedad." },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Cotizar" },
  ]}
  faqItems={faqs.map(f => ({ question: f.question, answer: f.answer }))}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Cotizar"}]} />
  </Fragment>

  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Cotización gratuita</span>
          <h1 class="hero__title">Solicita tu <span class="highlight">Cotización</span></h1>
          <div class="hero__ctas">
            <a href="#cotizar-form" class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver catálogo</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            Cotizar tu inflable es rápido y sin compromiso. Completa el formulario con los datos de tu evento y nuestro equipo te enviará una cotización personalizada directo a tu <strong>WhatsApp</strong>. Sin llamadas, sin esperas.
          </p>
          <p class="hero__copy-text">
            Todos nuestros precios incluyen entrega, instalación profesional, motor/soplador, limpieza, seguro de responsabilidad civil y recolección al finalizar. Sin costos ocultos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Formulario"
        title="Datos de tu evento"
        subtitle="Completa el formulario y recibe tu cotización por WhatsApp."
        copy1="Llena los campos con la información de tu evento. Mientras más detalles nos des, más precisa será tu cotización. Respondemos en menos de 30 minutos durante nuestro horario de atención."
        copy2="La cotización es completamente gratuita y sin compromiso. Si tienes dudas sobre qué inflable elegir, selecciona 'No estoy seguro' y nuestro equipo te asesorará."
      />
      <form id="cotizar-form" class="quote-form">
        <div class="quote-form__grid">
          <div class="quote-form__col">
            <div class="form-group">
              <label class="form-label" for="cot-nombre">Nombre completo *</label>
              <input class="form-input" type="text" id="cot-nombre" name="nombre" required placeholder="Ej. María González">
            </div>
            <div class="form-group">
              <label class="form-label" for="cot-telefono">Teléfono / WhatsApp *</label>
              <input class="form-input" type="tel" id="cot-telefono" name="telefono" required placeholder="55 1234 5678">
            </div>
            <div class="form-group">
              <label class="form-label" for="cot-fecha">Fecha del evento *</label>
              <input class="form-input" type="date" id="cot-fecha" name="fecha" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="cot-colonia">Colonia / Zona *</label>
              <input class="form-input" type="text" id="cot-colonia" name="colonia" required placeholder="Ej: Coyoacán, CDMX">
            </div>
          </div>
          <div class="quote-form__col">
            <div class="form-group">
              <label class="form-label" for="cot-inflable">Tipo de inflable *</label>
              <select class="form-select" id="cot-inflable" name="inflable" required>
                <option value="">Selecciona un inflable</option>
                {INFLABLES_SELECT_OPTIONS.map(opt => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="cot-horario">Horario aproximado</label>
              <select class="form-select" id="cot-horario" name="horario">
                <option value="">Selecciona un horario</option>
                <option value="Mañana (9:00 - 12:00)">Mañana (9:00 - 12:00)</option>
                <option value="Mediodía (12:00 - 15:00)">Mediodía (12:00 - 15:00)</option>
                <option value="Tarde (15:00 - 18:00)">Tarde (15:00 - 18:00)</option>
                <option value="Noche (18:00 - 21:00)">Noche (18:00 - 21:00)</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="cot-ninos">Número de niños (aprox.)</label>
              <input class="form-input" type="number" id="cot-ninos" name="ninos" min="1" max="50" placeholder="Ej: 10">
            </div>
            <div class="form-group">
              <label class="form-label" for="cot-notas">Notas adicionales</label>
              <textarea class="form-textarea" id="cot-notas" name="notas" placeholder="Tipo de evento, espacio disponible, etc." rows="3"></textarea>
            </div>
          </div>
        </div>
        <div class="quote-form__footer">
          <button type="submit" class="btn btn-wa btn-lg quote-form__submit">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <use href="#i-wa"/>
            </svg>
            Enviar cotización por WhatsApp
          </button>
          <p class="quote-form__note">Al enviar, se abrirá WhatsApp con tu información para que nuestro equipo te responda al instante.</p>
        </div>
      </form>
    </div>
  </section>

  <script>
    document.getElementById('cotizar-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const data = new FormData(form);
      const nombre = data.get('nombre') || '';
      const telefono = data.get('telefono') || '';
      const fecha = data.get('fecha') || '';
      const colonia = data.get('colonia') || '';
      const inflable = data.get('inflable') || '';
      const horario = data.get('horario') || '';
      const ninos = data.get('ninos') || '';
      const notas = data.get('notas') || '';

      let text = `Hola BRINCOLINS, quiero cotizar un inflable.\n\n`;
      text += `*Nombre:* ${nombre}\n`;
      text += `*Teléfono:* ${telefono}\n`;
      text += `*Fecha:* ${fecha}\n`;
      text += `*Zona:* ${colonia}\n`;
      text += `*Inflable:* ${inflable}\n`;
      if (horario) text += `*Horario:* ${horario}\n`;
      if (ninos) text += `*Niños:* ${ninos}\n`;
      if (notas) text += `*Notas:* ${notas}\n`;

      const encoded = encodeURIComponent(text);
      window.open(`https://wa.me/5531281706?text=${encoded}`, '_blank');
    });
  </script>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="FAQ"
        title="Preguntas frecuentes sobre cotización"
        subtitle="Resolvemos tus dudas antes de cotizar."
        copy1="Sabemos que es normal tener preguntas antes de solicitar una cotización. Aquí respondemos las dudas más comunes sobre precios, tiempos de respuesta y formas de pago."
        copy2="Si después de leer las preguntas frecuentes aún tienes dudas, escríbenos por WhatsApp y te ayudamos al instante. Nuestro equipo está disponible de 8am a 8pm."
      />
      <div style="max-width:800px; margin:0 auto;">
        {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
      </div>
    </div>
  </section>

</PageLayout>
