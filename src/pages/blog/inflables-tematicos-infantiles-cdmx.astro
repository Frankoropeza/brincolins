  <!-- CTA FINAL -->
  <CtaBanner
    title="🎭 ¡Elige tu inflable temático favorito!"
    subtitle="Jungla, princesas, piratas o dragones — tenemos el inflable perfecto para la fiesta de tus sueños. Cotiza ahora."
