---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import CtaBanner  from "@/components/CtaBanner.astro";
import FaqItem    from "@/components/FaqItem.astro";

type BlogPost = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const d = post.data;
const { Content } = await render(post);

// ── Artículos relacionados (misma categoría, luego recientes) ──
const all = (await getCollection("blog")).filter((p) => !p.data.draft);
const byDate = (a: BlogPost, b: BlogPost) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime();
let related = all
  .filter((p) => p.id !== post.id && p.data.category === d.category)
  .sort(byDate)
  .slice(0, 3);
if (related.length < 3) {
  const ids = new Set([post.id, ...related.map((r) => r.id)]);
  related = related.concat(all.filter((p) => !ids.has(p.id)).sort(byDate).slice(0, 3 - related.length));
}

// ── Catálogo destacado para el sidebar ──
const inflablesSidebar = [
  { href: "/inflables/castillo-princesas/", label: "Castillo de Princesas" },
  { href: "/inflables/barco-pirata/",       label: "Barco Pirata" },
  { href: "/inflables/extremo/",            label: "Circuito Extremo" },
  { href: "/inflables/mini-castillo/",      label: "Mini Castillo — desde $800" },
];

// ── Helpers ──
const esc = (s: unknown) => String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;");
const mdInline = (s: unknown) => esc(s).replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
const fechaFmt = new Date(d.publishDate).toLocaleDateString("es-MX", { year: "numeric", month: "long", day: "numeric" });

const heading = d.h1 || d.title;
const SITE = "https://brincolins.com";
const canonical = `${SITE}/blog/${post.id}/`;

// ── WordCount desde el cuerpo Markdown crudo ──
const wordCount = post.body ? post.body.trim().split(/\s+/).length : undefined;

// ── BlogPosting JSON-LD ──
const blogSchema = {
  "@context": "https://schema.org",
  "@type": ["Article", "BlogPosting"],
  "headline": d.title,
  "description": d.description,
  "image": d.heroImage ? `${SITE}${d.heroImage}` : `${SITE}/img/og-brincolins.jpg`,
  "datePublished": d.publishDate,
  "dateModified": d.updatedDate || d.publishDate,
  "author": { "@type": "Organization", "@id": `${SITE}/#org`, "name": d.author || "BRINCOLINS", "url": SITE },
  "publisher": { "@id": `${SITE}/#org` },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
  "articleSection": d.category,
  "inLanguage": "es-MX",
  ...(d.tags?.length ? { "keywords": d.tags.join(", ") } : {}),
  ...(wordCount ? { "wordCount": wordCount } : {}),
};

// ── HowTo JSON-LD (solo posts instructivos con frontmatter `howto`) ──
const howToSchema = d.howto
  ? {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": d.howto.name,
      "description": d.description,
      "image": d.heroImage ? `${SITE}${d.heroImage}` : `${SITE}/img/og-brincolins.jpg`,
      ...(d.howto.totalTime ? { "totalTime": d.howto.totalTime } : {}),
      "step": d.howto.steps.map((s, i) => ({
        "@type": "HowToStep",
        "position": i + 1,
        "name": s.name,
        "text": s.text,
      })),
    }
  : null;
---

<PageLayout
  title={d.title}
  description={d.description}
  canonical={canonical}
  ogImage={d.heroImage || "/img/og-brincolins.jpg"}
  pageType="page"
  faqItems={d.faqs ?? []}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}

  <!-- HERO 2 COLUMNAS -->
  <section class="hero" style="padding:clamp(2rem,4vw,3rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <a href="/blog/" class="art-hero__back">← Volver al blog</a>
          <span class="hero__badge">{d.category}</span>
          <h1 class="hero__title" set:html={mdInline(heading)} />
          <div class="art-hero__meta">
            {d.readTime && (<><span>{d.readTime} lectura</span><span class="art-hero__sep">·</span></>)}
            <span>{d.author}</span>
            <span class="art-hero__sep">·</span>
            <time datetime={d.publishDate}>{fechaFmt}</time>
          </div>
          {d.excerpt && <p class="hero__desc">{d.excerpt}</p>}
          <div class="hero__ctas">
            <a href="/cotizar/" class="btn btn-primary btn-lg">Pedir cotización gratis</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver inflables</a>
          </div>
        </div>
        {d.intro?.length ? (
          <div class="hero__copy">
            {d.intro.map((p) => <p class="hero__copy-text" set:html={mdInline(p)} />)}
          </div>
        ) : null}
      </div>
    </div>
  </section>

  <QuickNav />

  <!-- PORTADA -->
  {d.heroImage && (
    <section style="padding:0 0 1rem;">
      <div class="container">
        <img src={d.heroImage} alt={d.heroImageAlt || heading} width="1200" height="675" loading="eager" fetchpriority="high"
             style="width:100%;max-height:480px;object-fit:cover;border-radius:var(--r-card);display:block;box-shadow:var(--shadow-md);" />
      </div>
    </section>
  )}

  <!-- CONTENIDO + SIDEBAR -->
  <section class="section" style="padding-top:1.5rem;">
    <div class="container">
      <div class="art-layout">
        <article class="art-body">
          <Content />

          {d.galleryImages?.length ? (
            <div class="art-gallery">
              {d.galleryImages.map((src, i) => (
                <img src={src} alt={`${heading} — foto ${i + 1}`} width="600" height="450" loading="lazy" class="art-gallery__img" />
              ))}
            </div>
          ) : null}
        </article>

        <aside class="art-sidebar">
          <div class="art-sidebar__box art-sidebar__box--cta">
            <h2 class="art-sidebar__title">¿Listo para tu fiesta?</h2>
            <p class="art-sidebar__text">Cotiza en minutos por WhatsApp. Entrega, instalación y seguro incluidos en CDMX y Edomex.</p>
            <a href="/cotizar/" class="btn btn-primary" style="width:100%;justify-content:center;">Pedir cotización gratis</a>
          </div>

          {related.length > 0 && (
            <div class="art-sidebar__box art-sidebar__box--links">
              <h2 class="art-sidebar__title">Más artículos</h2>
              {related.map((r) => (
                <a href={`/blog/${r.id}/`} class="art-sidebar__link">→ {r.data.title}</a>
              ))}
            </div>
          )}

          <div class="art-sidebar__box art-sidebar__box--cat">
            <h2 class="art-sidebar__title">Nuestros inflables</h2>
            {inflablesSidebar.map((it) => (
              <a href={it.href} class="art-sidebar__link">→ {it.label}</a>
            ))}
            <a href="/inflables/" class="art-sidebar__link art-sidebar__link--cta">→ Ver catálogo completo</a>
          </div>

          <div class="art-sidebar__box art-sidebar__box--links">
            <h2 class="art-sidebar__title">Recursos útiles</h2>
            <a href="/fiestas-infantiles/" class="art-sidebar__link">→ Inflables para fiestas infantiles</a>
            <a href="/preguntas-frecuentes/" class="art-sidebar__link">→ Preguntas frecuentes</a>
            <a href="/precios/" class="art-sidebar__link">→ Lista de precios 2026</a>
            <a href="/cobertura/" class="art-sidebar__link">→ Zonas de cobertura</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {d.faqs?.length ? (
    <section class="section section--alt">
      <div class="container">
        <div style="max-width:820px; margin:0 auto;">
          <h2 class="section-title" style="text-align:center; margin-bottom:2rem;">Preguntas frecuentes</h2>
          {d.faqs.map((f) => <FaqItem question={f.question} answer={f.answer} />)}
        </div>
      </div>
    </section>
  ) : null}

  <!-- CTA FINAL -->
  <CtaBanner
    title="Reserva tu inflable y haz la fiesta inolvidable"
    subtitle="Respondemos en minutos. Entrega, instalación y seguro incluidos en toda la ZMVM."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
  />
</PageLayout>

<style>
  /* ── Hero del artículo ── */
  .art-hero__back {
    font-size: .85rem; color: var(--c-primary); font-weight: 700;
    text-decoration: none; display: inline-flex; align-items: center;
    gap: .3rem; margin-bottom: .5rem;
  }
  .art-hero__back:hover { gap: .6rem; }
  .art-hero__meta {
    display: flex; align-items: center; gap: .5rem; flex-wrap: wrap;
    font-size: .85rem; color: var(--c-text-muted); margin-bottom: .75rem;
  }
  .art-hero__sep { opacity: .4; }

  /* ── Layout artículo + sidebar ── */
  .art-layout { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 3rem; align-items: start; }
  .art-body { min-width: 0; max-width: 75ch; }

  /* ── Prosa (Markdown renderizado) ── */
  .art-body :global(h2) {
    font-family: var(--font-head); font-weight: 800;
    font-size: clamp(1.25rem, 2.5vw, 1.55rem); color: var(--c-text);
    margin: 2.5rem 0 1rem; padding-top: .65rem; border-top: 3px solid var(--c-primary);
  }
  .art-body :global(h2:first-child) { margin-top: 0; }
  .art-body :global(h3) {
    font-family: var(--font-head); font-weight: 700;
    font-size: clamp(1.1rem, 2vw, 1.25rem); color: var(--c-text); margin: 1.75rem 0 .75rem;
  }
  .art-body :global(p) { font-size: 1rem; line-height: 1.75; color: var(--c-text); margin: 0 0 1.25rem; }
  .art-body :global(strong) { color: var(--c-primary); font-weight: 700; }
  .art-body :global(a) { color: var(--c-primary); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .art-body :global(ul), .art-body :global(ol) { padding-left: 1.5rem; margin: 0 0 1.25rem; display: flex; flex-direction: column; gap: .55rem; }
  .art-body :global(ul li) { list-style: disc; }
  .art-body :global(ol li) { list-style: decimal; }
  .art-body :global(li) { font-size: 1rem; line-height: 1.6; color: var(--c-text); }

  /* Callouts (antes .art-tip) ── blockquote */
  .art-body :global(blockquote) {
    background: #fff8f5; border-left: 4px solid var(--c-primary);
    border-radius: 0 var(--r-card) var(--r-card) 0; padding: 1.1rem 1.4rem;
    margin: 1.5rem 0; color: var(--c-text);
  }
  .art-body :global(blockquote p) { margin: 0; font-size: .95rem; }

  /* Tablas */
  .art-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: .95rem; }
  .art-body :global(th) { text-align: left; padding: .75rem; border-bottom: 2px solid var(--c-border); font-family: var(--font-head); font-weight: 800; }
  .art-body :global(td) { padding: .75rem; border-bottom: 1px solid var(--c-border); color: var(--c-text); }
  .art-body :global(img) { border-radius: var(--r-card); margin: 1.5rem 0; box-shadow: var(--shadow-sm); }

  /* ── Galería ── */
  .art-gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-top: 2.5rem; }
  .art-gallery__img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: var(--r-card); box-shadow: var(--shadow-sm); }

  /* ── Sidebar ── */
  .art-sidebar { display: flex; flex-direction: column; gap: 1.5rem; position: sticky; top: 90px; }
  .art-sidebar__box {
    background: var(--c-bg-alt); border: 1px solid var(--c-border);
    border-radius: var(--r-card); padding: 1.5rem; display: flex; flex-direction: column; gap: .75rem;
  }
  .art-sidebar__box--links, .art-sidebar__box--cat { gap: .4rem; }
  .art-sidebar__title { font-family: var(--font-head); font-weight: 800; font-size: 1rem; color: var(--c-text); margin: 0; }
  .art-sidebar__text { font-size: .9rem; color: var(--c-text-muted); line-height: 1.6; margin: 0; }
  .art-sidebar__link {
    font-size: .88rem; color: var(--c-primary); font-weight: 600; text-decoration: none;
    padding: .4rem 0; display: block; border-bottom: 1px solid var(--c-border); line-height: 1.4;
  }
  .art-sidebar__box--links .art-sidebar__link:last-child,
  .art-sidebar__box--cat .art-sidebar__link:last-child { border-bottom: none; }
  .art-sidebar__link:hover { padding-left: .35rem; }
  .art-sidebar__link--cta { color: var(--c-secondary); font-weight: 800; }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .art-layout { grid-template-columns: 1fr; }
    .art-sidebar { position: static; }
  }
  @media (max-width: 560px) {
    .art-gallery { grid-template-columns: 1fr; }
  }
</style>
