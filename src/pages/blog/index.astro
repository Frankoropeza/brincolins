---
import { getCollection } from "astro:content";
import PageLayout    from "@/layouts/PageLayout.astro";
import Breadcrumbs   from "@/components/Breadcrumbs.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner     from "@/components/CtaBanner.astro";
import BlogCard      from "@/components/BlogCard.astro";

const title       = "Blog de Renta de Inflables | Guías y Consejos para Fiestas | CDMX";
const description = "Guías, consejos y artículos sobre renta de inflables para fiestas y eventos en CDMX. Aprende a elegir el inflable ideal, tips de seguridad y tendencias para fiestas infantiles.";

// ── Fuente única: Content Collection (Markdown) ──
const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const gradients: Record<string, string> = {
  "Guías": "linear-gradient(135deg, #FF3D00, #FF6D00)",
  "Ideas": "linear-gradient(135deg, #7C3AED, #E91E8C)",
  "Consejos": "linear-gradient(135deg, #0288D1, #1565C0)",
  "Precios": "linear-gradient(135deg, #F59E0B, #D97706)",
  "Seguridad": "linear-gradient(135deg, #10B981, #059669)",
  "Eventos": "linear-gradient(135deg, #E65100, #BF360C)",
};
const gradientFor = (cat: string) => gradients[cat] || "linear-gradient(135deg, #FF3D00, #FF6D00)";

const toCard = (p: typeof posts[number]) => ({
  slug: p.id,
  emoji: "",
  category: p.data.category,
  title: p.data.title,
  excerpt: p.data.excerpt || p.data.description,
  readTime: p.data.readTime || "6 min",
  image: p.data.heroImage,
  gradient: gradientFor(p.data.category),
});

const cards = posts.map(toCard);
const [featured, ...resto] = cards;

// ── Categorías reales (conteo dinámico) ──
const counts: Record<string, number> = {};
for (const p of posts) counts[p.data.category] = (counts[p.data.category] || 0) + 1;
const topCats = Object.entries(counts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([name, count]) => {
    const recent = posts.find((p) => p.data.category === name)!;
    return { name, count, href: `/blog/${recent.id}/` };
  });
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Blog" },
  ]}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Blog"}]} />
  </Fragment>

  <!-- HERO -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Blog BRINCOLINS</span>
          <h1 class="hero__title">Guías e Ideas para tu <span class="highlight">Fiesta Perfecta</span></h1>
          <p style="color:var(--c-text-muted);font-size:1.05rem;margin:.75rem 0 1.5rem;line-height:1.7;">
            Consejos prácticos de expertos con más de 20 años en renta de inflables. Todo lo que necesitas para organizar la mejor fiesta en CDMX y Edomex.
          </p>
          <div class="hero__ctas">
            <a href="/cotizar/" class="btn btn-primary btn-lg">Cotizar inflable</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver catálogo</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            En <strong>BRINCOLINS</strong> no solo rentamos inflables — también queremos ayudarte a organizar el evento perfecto. Aquí encontrarás guías detalladas sobre cómo elegir el inflable ideal según la edad de los niños, el espacio disponible y tu presupuesto.
          </p>
          <p class="hero__copy-text">
            También compartimos ideas de decoración, consejos de seguridad y listas de verificación para que la organización de la fiesta sea sin estrés. Nuevo contenido cada mes, siempre enfocado en familias de <strong>CDMX y Estado de México</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTÍCULO DESTACADO -->
  {featured && (
    <section style="padding:0 0 3rem;">
      <div class="container">
        <div class="featured-wrap">
          <a href={`/blog/${featured.slug}/`} class="featured-thumb">
            <img src={featured.image} alt={featured.title} width="1200" height="675" loading="eager" />
            <span class="featured-badge">Artículo destacado</span>
            <span class="blog-cat-pill">{featured.category}</span>
          </a>
          <div class="featured-body">
            <div class="featured-meta">
              <span class="featured-cat-pill">{featured.category}</span>
              <span>⏱ {featured.readTime} lectura</span>
            </div>
            <h2 class="featured-title">
              <a href={`/blog/${featured.slug}/`}>{featured.title}</a>
            </h2>
            <p class="featured-excerpt">{featured.excerpt}</p>
            <a href={`/blog/${featured.slug}/`} class="btn btn-primary" style="align-self:flex-start">
              Leer artículo
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA COMPACTO -->
  <CtaBanner
    title="¿Ya tienes fecha? Reserva tu inflable ahora"
    subtitle="Respondemos en minutos por WhatsApp. Entrega e instalación incluida."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="warm"
    compact={true}
  />

  <!-- TODOS LOS ARTÍCULOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Artículos"
        title="Últimas publicaciones"
        subtitle="Todo lo que necesitas saber para rentar inflables y organizar la mejor fiesta."
        copy1="Nuestro equipo comparte guías detalladas sobre cómo elegir el inflable ideal según la edad de los niños, el espacio disponible y el presupuesto con el que cuentas. Con más de 20 años de experiencia, sabemos lo que funciona."
        copy2="También publicamos ideas de decoración, consejos de seguridad y listas de verificación para que la organización de tu fiesta sea sin estrés. Nuevo contenido cada mes."
      />
      <div class="blog-grid">
        {resto.map(a => <BlogCard {...a} />)}
      </div>
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="Categorías"
        title="Explora por tema"
        subtitle="Encuentra exactamente lo que buscas."
        copy1="Filtra los artículos por categoría para encontrar rápidamente la información que necesitas. Ya sea que vayas a organizar tu primer evento con inflable o seas un maestro de las fiestas infantiles, tenemos contenido para ti."
        copy2="Todos nuestros artículos son escritos por el equipo de BRINCOLINS con más de 20 años de experiencia en renta de inflables para fiestas en la Zona Metropolitana del Valle de México."
      />
      <div class="grid-4">
        {topCats.map(c => (
          <a href={c.href} class="cat-card">
            <span class="cat-card__label">{c.name}</span>
            <span class="cat-card__count">{c.count} {c.count === 1 ? "artículo" : "artículos"}</span>
          </a>
        ))}
        <a href="/inflables/" class="cat-card cat-card--cta">
          <span class="cat-card__label">Ver inflables</span>
          <span class="cat-card__count">Catálogo completo →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <CtaBanner
    title="¿Listo para la mejor fiesta de tu vida?"
    subtitle="Renta tu inflable hoy. Entrega puntual, instalación profesional y seguro incluido."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
  />

</PageLayout>

<style>
  /* ── Blog grid ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.75rem;
  }

  /* ── Featured ── */
  .featured-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .featured-wrap { grid-template-columns: 1fr; }
  }

  .featured-thumb {
    position: relative;
    display: block;
    aspect-ratio: 16/9;
    overflow: hidden;
    text-decoration: none;
  }

  .featured-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--c-primary);
    color: #fff;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.75rem;
    border-radius: var(--r-badge);
  }

  .blog-cat-pill {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background: rgba(255,255,255,0.95);
    color: var(--c-primary);
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: var(--r-badge);
  }

  .featured-body {
    padding: 2rem 2rem 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .featured-body { padding: 1.5rem; }
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }

  .featured-cat-pill {
    background: rgba(255,61,0,0.08);
    color: var(--c-primary);
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem;
    border-radius: var(--r-badge);
  }

  .featured-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    line-height: 1.25;
    color: var(--c-text);
    margin: 0;
  }

  .featured-title a {
    color: inherit;
    text-decoration: none;
  }

  .featured-title a:hover { color: var(--c-primary); }

  .featured-excerpt {
    font-size: 1rem;
    color: var(--c-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Categorías ── */
  .cat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2rem 1.5rem;
    background: var(--c-bg);
    border: 2px solid var(--c-border);
    border-radius: var(--r-card);
    text-decoration: none;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }

  .cat-card:hover {
    border-color: var(--c-primary);
    box-shadow: var(--shadow-primary);
  }

  .cat-card--cta {
    background: linear-gradient(135deg, #FF3D00, #FF6D00);
    border-color: transparent;
  }

  .cat-card--cta .cat-card__label,
  .cat-card--cta .cat-card__count { color: #fff; }

  .cat-card__emoji { font-size: 2.25rem; line-height: 1; }

  .cat-card__label {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 1rem;
    color: var(--c-text);
  }

  .cat-card__count {
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }
</style>
