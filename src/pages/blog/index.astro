---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav   from "@/components/QuickNav.astro";
import CtaBanner  from "@/components/CtaBanner.astro";
import BlogCard   from "@/components/BlogCard.astro";

const PER_PAGE = 12;

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const CAT_META: Record<string, { color: string; gradient: string }> = {
  "Guías":       { color: "#FF3D00", gradient: "linear-gradient(135deg,#FF3D00,#FF6D00)" },
  "Ideas":       { color: "#7C3AED", gradient: "linear-gradient(135deg,#7C3AED,#E91E8C)" },
  "Consejos":    { color: "#0288D1", gradient: "linear-gradient(135deg,#0288D1,#1565C0)" },
  "Precios":     { color: "#D97706", gradient: "linear-gradient(135deg,#F59E0B,#D97706)" },
  "Seguridad":   { color: "#059669", gradient: "linear-gradient(135deg,#10B981,#059669)" },
  "Eventos":     { color: "#E65100", gradient: "linear-gradient(135deg,#E65100,#BF360C)" },
  "Decoración":  { color: "#E91E8C", gradient: "linear-gradient(135deg,#E91E8C,#9C27B0)" },
  "Paquetes":    { color: "#2E7D32", gradient: "linear-gradient(135deg,#2E7D32,#1B5E20)" },
  "Acuáticos":   { color: "#0EA5E9", gradient: "linear-gradient(135deg,#0EA5E9,#0369A1)" },
};
const gradientFor = (cat: string) => CAT_META[cat]?.gradient || "linear-gradient(135deg,#FF3D00,#FF6D00)";
const colorFor    = (cat: string) => CAT_META[cat]?.color    || "#FF3D00";

// Categorías con conteo
const catCounts: Record<string, number> = {};
for (const p of posts) catCounts[p.data.category] = (catCounts[p.data.category] || 0) + 1;
const categories = Object.entries(catCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count, color: colorFor(name) }));

// Artículo destacado = más reciente
const [featuredPost, ...restPosts] = posts;

const toCard = (p: typeof posts[number]) => ({
  slug:     p.id,
  emoji:    "",
  category: p.data.category,
  title:    p.data.title,
  excerpt:  p.data.excerpt || p.data.description,
  readTime: p.data.readTime || "6 min",
  image:    p.data.heroImage,
  gradient: gradientFor(p.data.category),
});

const cards = restPosts.map(toCard);

// Sidebar: recientes (5) y inflables populares
const recentSidebar = posts.slice(0, 5);
const inflablesSidebar = [
  { href: "/inflables/barco-pirata/",        label: "Barco Pirata",           price: "$2,500" },
  { href: "/inflables/extremo/",             label: "Extremo",                price: "$3,000" },
  { href: "/inflables/castillo-princesas/",  label: "Castillo de Princesas",  price: "$1,200" },
  { href: "/inflables/mini-castillo/",       label: "Mini Castillo",          price: "$800"   },
];

const title       = "Blog de Inflables BRINCOLINS | Guías y Consejos para Fiestas en CDMX";
const description = "Guías y consejos de expertos sobre renta de inflables para fiestas en CDMX. Cómo elegir el inflable ideal, precios, seguridad y decoración para tu evento.";
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Blog" },
  ]}
>

  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero" style="padding:clamp(2.5rem,5vw,4rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Blog BRINCOLINS</span>
          <h1 class="hero__title">Guías e Ideas para tu <span class="highlight">Fiesta Perfecta</span></h1>
          <p style="color:var(--c-text-muted);font-size:1.05rem;margin:.75rem 0 1.5rem;line-height:1.7;">
            Consejos prácticos de expertos con más de 20 años en renta de inflables. Todo lo que necesitas para organizar la mejor fiesta en CDMX y Edomex.
          </p>
          <div class="hero__ctas">
            <a href="/cotizar/"   class="btn btn-primary btn-lg">Cotizar inflable</a>
            <a href="/inflables/" class="btn btn-outline  btn-lg">Ver catálogo</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            En <strong>BRINCOLINS</strong> no solo rentamos inflables — también queremos ayudarte a organizar el evento perfecto. Guías detalladas sobre cómo elegir el inflable ideal según la edad, el espacio y tu presupuesto.
          </p>
          <p class="hero__copy-text">
            Ideas de decoración, consejos de seguridad, listas de verificación y las tendencias más recientes en fiestas infantiles de <strong>CDMX y Estado de México</strong>. Nuevo contenido cada mes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <!-- ── ARTÍCULO DESTACADO ────────────────────────────────────────────── -->
  {featuredPost && (
    <section class="section" style="padding-bottom:0;">
      <div class="container">
        <div class="featured-card">
          <a href={`/blog/${featuredPost.id}/`} class="featured-card__thumb">
            {featuredPost.data.heroImage
              ? <img src={featuredPost.data.heroImage} alt={featuredPost.data.title}
                     width="1200" height="675" loading="eager" class="featured-card__img" />
              : <div class="featured-card__gradient"
                     style={`background:${gradientFor(featuredPost.data.category)};`} />
            }
            <div class="featured-card__overlay">
              <span class="pill pill--white">{featuredPost.data.category}</span>
            </div>
            <span class="featured-card__badge">Artículo destacado</span>
          </a>
          <div class="featured-card__body">
            <div class="featured-card__meta">
              <span class="pill" style={`background:${colorFor(featuredPost.data.category)}18;color:${colorFor(featuredPost.data.category)};`}>
                {featuredPost.data.category}
              </span>
              {featuredPost.data.readTime && (
                <span class="featured-card__time">⏱ {featuredPost.data.readTime} lectura</span>
              )}
            </div>
            <h2 class="featured-card__title">
              <a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
            </h2>
            <p class="featured-card__excerpt">{featuredPost.data.excerpt || featuredPost.data.description}</p>
            <div class="featured-card__actions">
              <a href={`/blog/${featuredPost.id}/`} class="btn btn-primary">
                Leer artículo
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="/cotizar/" class="btn btn-outline">Cotizar inflable</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── BODY: ARTÍCULOS + SIDEBAR ────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="blog-body">

        <!-- COLUMNA PRINCIPAL -->
        <div class="blog-main">

          <!-- Barra de filtros -->
          <div class="filter-bar" id="blog-grid-top">
            <div class="filter-strip" role="group" aria-label="Filtrar por categoría">
              <button class="filter-btn active" data-filter="all">
                Todos
                <span class="filter-btn__count">{cards.length}</span>
              </button>
              {categories.map(c => (
                <button class="filter-btn" data-filter={c.name}
                        style={`--cat-color:${c.color};`}>
                  {c.name}
                  <span class="filter-btn__count">{c.count}</span>
                </button>
              ))}
            </div>
            <p class="filter-count" id="card-count" aria-live="polite">
              Mostrando {Math.min(PER_PAGE, cards.length)} de {cards.length} artículos
            </p>
          </div>

          <!-- Grid de artículos -->
          <div class="blog-grid" id="blog-grid" aria-label="Artículos del blog">
            {cards.map((card, i) => (
              <div data-card data-category={card.category} data-index={i}>
                <BlogCard {...card} />
              </div>
            ))}
          </div>

          <!-- Paginación (renderizada por JS) -->
          <nav class="pagination" id="pagination" aria-label="Paginación del blog"></nav>

        </div>

        <!-- SIDEBAR -->
        <aside class="blog-sidebar">

          <!-- CTA -->
          <div class="sb-box sb-box--cta">
            <div class="sb-box__icon">🎈</div>
            <h2 class="sb-box__title">¿Ya tienes fecha?</h2>
            <p class="sb-box__text">Cotiza tu inflable en minutos. Entrega, instalación y seguro incluidos en toda la ZMVM.</p>
            <a href="/cotizar/" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:.25rem;">
              Solicitar cotización gratis
            </a>
            <a href="https://wa.me/5531281706?text=Hola%2C%20quiero%20cotizar%20un%20inflable" class="sb-wa-link" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Escribir por WhatsApp
            </a>
          </div>

          <!-- Categorías -->
          <div class="sb-box">
            <h2 class="sb-box__heading">Categorías</h2>
            <ul class="sb-cat-list">
              {categories.map(c => (
                <li class="sb-cat-item">
                  <button class="sb-cat-btn" data-filter={c.name}
                          style={`--cat-color:${c.color};`}
                          aria-label={`Filtrar por ${c.name}`}>
                    <span class="sb-cat-dot" style={`background:${c.color};`}></span>
                    <span class="sb-cat-name">{c.name}</span>
                    <span class="sb-cat-count">{c.count}</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>

          <!-- Artículos recientes -->
          <div class="sb-box">
            <h2 class="sb-box__heading">Artículos recientes</h2>
            <ul class="sb-recent-list">
              {recentSidebar.map(p => (
                <li class="sb-recent-item">
                  <a href={`/blog/${p.id}/`} class="sb-recent-link">
                    <span class="sb-recent-cat" style={`background:${colorFor(p.data.category)}18;color:${colorFor(p.data.category)};`}>
                      {p.data.category}
                    </span>
                    <span class="sb-recent-title">{p.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Inflables populares -->
          <div class="sb-box">
            <h2 class="sb-box__heading">Inflables populares</h2>
            <ul class="sb-inflable-list">
              {inflablesSidebar.map(it => (
                <li>
                  <a href={it.href} class="sb-inflable-link">
                    <span class="sb-inflable-name">{it.label}</span>
                    <span class="sb-inflable-price">{it.price}</span>
                  </a>
                </li>
              ))}
            </ul>
            <a href="/inflables/" class="sb-catalog-link">Ver catálogo completo →</a>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ── CTA FINAL ─────────────────────────────────────────────────────── -->
  <CtaBanner
    title="¿Listo para la mejor fiesta de tu vida?"
    subtitle="Renta tu inflable hoy. Entrega puntual, instalación profesional y seguro incluido en toda la ZMVM."
    btnText="Solicitar cotización"
    btnHref="/cotizar/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
  />

</PageLayout>

<!-- ── JS: Filtrado + Paginación ─────────────────────────────────────── -->
<script define:vars={{ PER_PAGE }}>
(function () {
  const cards       = [...document.querySelectorAll('[data-card]')];
  const filterBtns  = [...document.querySelectorAll('[data-filter]')];
  const pagNav      = document.getElementById('pagination');
  const countEl     = document.getElementById('card-count');
  const gridTopEl   = document.getElementById('blog-grid-top');

  let currentCat  = 'all';
  let currentPage = 1;

  function filtered() {
    return currentCat === 'all'
      ? cards
      : cards.filter(c => c.dataset.category === currentCat);
  }

  function render() {
    const vis        = filtered();
    const total      = vis.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * PER_PAGE;
    const end   = start + PER_PAGE;

    cards.forEach(c => { (c as HTMLElement).style.display = 'none'; });
    vis.slice(start, end).forEach(c => { (c as HTMLElement).style.display = ''; });

    if (countEl) {
      const showing = Math.min(end, total);
      countEl.textContent = `Mostrando ${showing} de ${total} artículo${total !== 1 ? 's' : ''}`;
    }

    renderPagination(totalPages);
  }

  function renderPagination(totalPages: number) {
    if (!pagNav) return;
    pagNav.innerHTML = '';
    if (totalPages <= 1) return;

    const make = (label: string, page: number | null, disabled: boolean, active: boolean) => {
      const btn = document.createElement('button');
      btn.className = 'page-btn' + (active ? ' page-btn--active' : '');
      btn.textContent = label;
      btn.disabled = disabled;
      btn.setAttribute('aria-label', `Página ${page ?? label}`);
      if (active) btn.setAttribute('aria-current', 'page');
      if (!disabled && page !== null) {
        btn.addEventListener('click', () => {
          currentPage = page;
          render();
          gridTopEl?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
      return btn;
    };

    pagNav.appendChild(make('←', currentPage - 1, currentPage === 1, false));

    // Páginas con ellipsis
    const pages: (number | '…')[] = [];
    if (totalPages <= 7) {
      for (let i = 1; i <= totalPages; i++) pages.push(i);
    } else {
      pages.push(1);
      if (currentPage > 3) pages.push('…');
      for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) pages.push(i);
      if (currentPage < totalPages - 2) pages.push('…');
      pages.push(totalPages);
    }

    pages.forEach(p => {
      if (p === '…') {
        const span = document.createElement('span');
        span.className = 'page-ellipsis';
        span.textContent = '…';
        pagNav.appendChild(span);
      } else {
        pagNav.appendChild(make(String(p), p, false, p === currentPage));
      }
    });

    pagNav.appendChild(make('→', currentPage + 1, currentPage === totalPages, false));
  }

  // Sincronizar todos los botones de filtro (barra superior + sidebar)
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentCat  = (btn as HTMLElement).dataset.filter || 'all';
      currentPage = 1;
      filterBtns.forEach(b => b.classList.remove('active'));
      filterBtns
        .filter(b => (b as HTMLElement).dataset.filter === currentCat)
        .forEach(b => b.classList.add('active'));
      render();
      gridTopEl?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  render();
})();
</script>

<style>
  /* ── Layout blog ── */
  .blog-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 3rem;
    align-items: start;
  }

  /* ── Featured card ── */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: var(--c-bg);
  }

  .featured-card__thumb {
    position: relative;
    display: block;
    aspect-ratio: 4/3;
    overflow: hidden;
    text-decoration: none;
    flex-shrink: 0;
  }

  .featured-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }
  .featured-card__thumb:hover .featured-card__img { transform: scale(1.04); }

  .featured-card__gradient {
    width: 100%; height: 100%;
  }

  .featured-card__overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 2rem 1.25rem .85rem;
    background: linear-gradient(to top, rgba(0,0,0,.55) 0%, transparent 100%);
  }

  .featured-card__badge {
    position: absolute;
    top: .85rem; left: .85rem;
    background: var(--c-primary);
    color: #fff;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    padding: .22rem .7rem;
    border-radius: 99px;
  }

  .featured-card__body {
    padding: 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .featured-card__meta {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
  }

  .featured-card__time {
    font-size: .8rem;
    color: var(--c-text-muted);
  }

  .featured-card__title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    line-height: 1.25;
    color: var(--c-text);
    margin: 0;
  }
  .featured-card__title a { color: inherit; text-decoration: none; }
  .featured-card__title a:hover { color: var(--c-primary); }

  .featured-card__excerpt {
    font-size: 1rem;
    color: var(--c-text-muted);
    line-height: 1.7;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-card__actions {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Pills ── */
  .pill {
    display: inline-block;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: .66rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: .22rem .65rem;
    border-radius: 99px;
  }
  .pill--white { background: rgba(255,255,255,.9); color: #111; }

  /* ── Filter bar ── */
  .filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    padding-top: .5rem;
  }

  .filter-strip {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .38rem .9rem;
    border-radius: 99px;
    border: 1.5px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-text-muted);
    font-family: var(--font-head);
    font-size: .78rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
  }

  .filter-btn:hover {
    border-color: var(--cat-color, var(--c-primary));
    color: var(--cat-color, var(--c-primary));
  }

  .filter-btn.active {
    background: var(--cat-color, var(--c-primary));
    border-color: var(--cat-color, var(--c-primary));
    color: #fff;
  }

  .filter-btn__count {
    background: rgba(0,0,0,.12);
    color: inherit;
    font-size: .68rem;
    font-weight: 800;
    padding: .1rem .4rem;
    border-radius: 99px;
  }

  .filter-btn.active .filter-btn__count { background: rgba(255,255,255,.25); }

  .filter-count {
    font-size: .82rem;
    color: var(--c-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Blog grid ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    min-height: 400px;
  }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .4rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .page-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 .6rem;
    border-radius: 8px;
    border: 1.5px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-text);
    font-family: var(--font-head);
    font-size: .875rem;
    font-weight: 700;
    cursor: pointer;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--c-primary);
    color: var(--c-primary);
  }

  .page-btn--active {
    background: var(--c-primary);
    border-color: var(--c-primary);
    color: #fff;
  }

  .page-btn:disabled {
    opacity: .35;
    cursor: default;
  }

  .page-ellipsis {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    color: var(--c-text-muted);
    font-size: .875rem;
  }

  /* ── Sidebar ── */
  .blog-sidebar {
    display: flex;
    flex-direction: column;
