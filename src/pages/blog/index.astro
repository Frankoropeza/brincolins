---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Blog" },
  ]}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Blog</span>
    </nav>
  </div>

  <!-- HERO -->
  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">📝 Blog BRINCOLINS</span>
          <h1 class="hero__title">Guías e Ideas para tu <span class="highlight">Fiesta Perfecta</span></h1>
          <p style="color:var(--c-text-muted);font-size:1.05rem;margin:.75rem 0 1.5rem;line-height:1.7;">
            Consejos prácticos de expertos con más de 20 años en renta de inflables. Todo lo que necesitas para organizar la mejor fiesta en CDMX y Edomex.
          </p>
          <div class="hero__ctas">
            <a href="/cotizar/" class="btn btn-primary btn-lg">Cotizar inflable</a>
            <a href="/inflables/" class="btn btn-outline btn-lg">Ver catálogo</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            En <strong>BRINCOLINS</strong> no solo rentamos inflables — también queremos ayudarte a organizar el evento perfecto. Aquí encontrarás guías detalladas sobre cómo elegir el inflable ideal según la edad de los niños, el espacio disponible y tu presupuesto.
          </p>
          <p class="hero__copy-text">
            También compartimos ideas de decoración, consejos de seguridad y listas de verificación para que la organización de la fiesta sea sin estrés. Nuevo contenido cada mes, siempre enfocado en familias de <strong>CDMX y Estado de México</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTÍCULO DESTACADO -->
  <section style="padding:0 0 3rem;">
    <div class="container">
      <div class="featured-wrap">
        <a href={`/blog/${featured.slug}/`} class="featured-thumb">
          <img src={featured.image} alt={featured.title} width="1200" height="675" loading="eager" />
          <span class="featured-badge">⭐ Artículo destacado</span>
          <span class="blog-cat-pill">{featured.category}</span>
        </a>
        <div class="featured-body">
          <div class="featured-meta">
            <span class="featured-cat-pill">{featured.category}</span>
            <span>⏱ {featured.readTime} lectura</span>
          </div>
          <h2 class="featured-title">
            <a href={`/blog/${featured.slug}/`}>{featured.title}</a>
          </h2>
          <p class="featured-excerpt">{featured.excerpt}</p>
          <a href={`/blog/${featured.slug}/`} class="btn btn-primary" style="align-self:flex-start">
            Leer artículo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA COMPACTO -->
  <CtaBanner
    title="¿Ya tienes fecha? Reserva tu inflable ahora"
    subtitle="Respondemos en minutos por WhatsApp. Entrega e instalación incluida."
    btnText="Cotizar por WhatsApp"
    btnHref="https://wa.me/5547868402?text=Hola%20BRINCOLINS%2C%20quiero%20cotizar%20un%20inflable."
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="warm"
    whatsapp={true}
    external={true}
    compact={true}
  />

  <!-- TODOS LOS ARTÍCULOS -->
  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📰 Artículos"
        title="Últimas publicaciones"
        subtitle="Todo lo que necesitas saber para rentar inflables y organizar la mejor fiesta."
        copy1="Nuestro equipo comparte guías detalladas sobre cómo elegir el inflable ideal según la edad de los niños, el espacio disponible y el presupuesto con el que cuentas. Con más de 20 años de experiencia, sabemos lo que funciona."
        copy2="También publicamos ideas de decoración, consejos de seguridad y listas de verificación para que la organización de tu fiesta sea sin estrés. Nuevo contenido cada mes."
      />
      <div class="blog-grid">
        {resto.map(a => <BlogCard {...a} />)}
      </div>
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🗂️ Categorías"
        title="Explora por tema"
