  <!-- CTA FINAL -->
  <CtaBanner
    title="¡Organiza la fiesta pirata más épica de CDMX!"
    subtitle="Tobogán inflable, decoración pirata y diversión sin límites. Cotiza ahora y sorprende a todos los invitados."
    btnText="Solicitar cotización"
