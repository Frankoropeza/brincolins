          Pedir asesoría gratis
        </a>
      </div>
      <div class="art-sidebar__box art-sidebar__box--links">
        <h3 class="art-sidebar__title">Más artículos</h3>
        <a href="/blog/renta-castillo-princesas-inflable-cdmx/" class="art-sidebar__link">→ Renta castillo de princesas</a>
        <a href="/blog/inflables-tematicos-ninas-cdmx/" class="art-sidebar__link">→ Inflables temáticos para niñas</a>
        <a href="/blog/decoracion-fiesta-infantil-inflable/" class="art-sidebar__link">→ Decoración para fiesta con inflable</a>
      </div>
      <div class="art-sidebar__box art-sidebar__box--cat">
        <h3 class="art-sidebar__title">Nuestros inflables</h3>
        <a href="/inflables/castillo-princesas/" class="art-sidebar__link">→ Castillo Princesas</a>
        <a href="/inflables/castillo-blanco/" class="art-sidebar__link">→ Castillo Blanco</a>
        <a href="/inflables/mini-castillo/" class="art-sidebar__link">→ Mini Castillo</a>
        <a href="/inflables/" class="art-sidebar__link art-sidebar__link--cta">→ Ver catálogo completo</a>
      </div>
    </aside>
  </div></div></section>

  <section class="section section--alt"><div class="container">
    <div style="max-width:800px; margin:0 auto;">
      <h2 class="section-title" style="text-align:center; margin-bottom:2rem;">Preguntas frecuentes</h2>
      {faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
