---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WaBubble from "@/components/WaBubble.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import FaqItem from "@/components/FaqItem.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Preguntas Frecuentes — Renta de Inflables CDMX | BRINCOLINS";
const description = "Resolvemos todas tus dudas sobre renta de inflables en CDMX y Edomex: qué pasa si llueve, tiempo de instalación, espacio mínimo, cancelaciones, anticipo, seguridad y sanitización.";

// ── FAQ por categorías ──
const categorias = [
  {
    badge: "Precios y reservas",
    titulo: "Precios, Anticipo y Reservas",
    faqs: [
      { question: "¿Cuánto cuesta rentar un inflable en CDMX?", answer: "Desde $800 MXN por evento (hasta 8 horas): Mini Castillo $800, inflables medianos (Dragones Rojos, Castillo de Princesas, Mini Jungla, Gusanitos) $1,200, Barco Pirata $2,500, Castillo Blanco $2,800 y Circuito Extremo $3,000. El precio incluye entrega, instalación, motor, sanitización, seguro de responsabilidad civil y recolección: es el precio final, sin cargos ocultos." },
      { question: "¿Cómo aparto mi fecha y cuánto es el anticipo?", answer: "Escríbenos por WhatsApp al 55 3128 1706 con el modelo, la fecha y la zona de entrega. Confirmamos disponibilidad en minutos. Para apartar la fecha se requiere un anticipo del 50% por transferencia bancaria, efectivo o tarjeta. El saldo se liquida el día del evento, antes de la instalación." },
      { question: "¿Cuál es la política de cancelación?", answer: "Si cancelas con más de 48 horas de anticipación, devolvemos el 100% del anticipo. Con menos de 48 horas, puedes reprogramar tu evento a otra fecha disponible sin costo adicional en lugar de perder el anticipo." },
      { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos reservar con al menos 5 días de anticipación, y 2 semanas para fines de semana. En temporada alta (diciembre, semana santa, fin de cursos) los sábados y domingos se agotan rápido. Si tu fecha es pronto, pregunta de todas formas: a veces hay disponibilidad de último momento." },
      { question: "¿La renta de varios inflables tiene descuento?", answer: "Sí, para kermeses, festivales escolares y eventos grandes que requieren varios inflables preparamos paquetes con precio preferencial. Cotiza por WhatsApp indicando cuántos inflables necesitas y el tipo de evento." },
    ],
  },
  {
    badge: "El día del evento",
    titulo: "Entrega, Instalación y Horarios",
    faqs: [
      { question: "¿Cuánto tiempo tarda la instalación?", answer: "Entre 15 y 30 minutos según el modelo: el Mini Castillo se instala en 15 minutos, los medianos en 20 y los grandes (Barco Pirata, Castillo Blanco, Extremo) en 30. Llegamos con anticipación suficiente para que el inflable esté listo antes de que empiece tu fiesta." },
      { question: "¿Qué pasa si llueve el día de mi evento?", answer: "Reprogramamos tu evento sin costo adicional en la fecha disponible que prefieras. No pierdes tu anticipo. Si la lluvia empieza durante el evento, el operador desinfla el equipo por seguridad y puede reactivarlo cuando pase; los inflables no deben usarse mojados." },
      { question: "¿Cuánto dura la renta?", answer: "La renta estándar es por evento completo, hasta 8 horas. Para kermeses y eventos largos ofrecemos paquetes de día completo (12 horas) y renta multi-día. El horario de entrega se coordina contigo: podemos instalar temprano por la mañana para eventos de mediodía." },
      { question: "¿Necesito tener algo preparado para la instalación?", answer: "Solo tres cosas: el espacio libre y nivelado donde irá el inflable, una toma de corriente doméstica a menos de 30 metros (nosotros llevamos la extensión) y acceso para ingresar el equipo. Todo lo demás lo pone BRINCOLINS." },
      { question: "¿El motor hace mucho ruido o gasta mucha luz?", answer: "Usamos motores infladores silenciosos de grado comercial. El consumo es similar al de una aspiradora doméstica (~1.1 kW). Debe permanecer encendido durante todo el uso del inflable." },
    ],
  },
  {
    badge: "Espacio y logística",
    titulo: "Espacio Mínimo y Tipos de Superficie",
    faqs: [
      { question: "¿Cuánto espacio necesito para instalar un inflable?", answer: "Depende del modelo: el Mini Castillo necesita ~3×3 m (funciona en interiores), los medianos ~5×5 m, el Barco Pirata ~8×6 m y el Circuito Extremo al menos 14×5 m. Considera 1 metro libre alrededor y, para modelos con torres, altura libre suficiente si es bajo techo. Si tienes dudas, mándanos una foto del espacio por WhatsApp y te orientamos al instante." },
      { question: "¿Se puede instalar en cualquier superficie?", answer: "Instalamos sobre pasto, tierra firme, concreto, adoquín y pisos de salón. En superficies duras usamos anclajes con pesos; en pasto y tierra, estacas. No instalamos sobre grava suelta, pendientes pronunciadas ni superficies con vidrios u objetos punzantes." },
      { question: "¿Pueden instalar en azoteas, patios interiores o calles cerradas?", answer: "Sí, siempre que el espacio cumpla las medidas del modelo y haya acceso para el equipo. Para calles cerradas te recomendamos tramitar el permiso vecinal correspondiente. Comparte fotos del lugar por WhatsApp y confirmamos viabilidad de inmediato." },
      { question: "¿Hasta dónde llegan sin costo de envío?", answer: "La entrega es gratuita en las 16 alcaldías de CDMX y los principales municipios del Estado de México: Ecatepec, Naucalpan, Tlalnepantla, Nezahualcóyotl, Huixquilucan, Atizapán, Cuautitlán Izcalli, Coacalco, Tecámac y más. Para zonas más alejadas (por ejemplo Toluca o Texcoco) puede aplicar un cargo de traslado que te confirmamos al cotizar." },
    ],
  },
  {
    badge: "Seguridad",
    titulo: "Seguridad, Limpieza y Seguro",
    faqs: [
      { question: "¿Los inflables son seguros para los niños?", answer: "Sí. Están fabricados con materiales de grado comercial, tienen mallas de seguridad laterales y se instalan con anclajes verificados por nuestro equipo. Cada renta incluye seguro de responsabilidad civil. Recomendamos siempre la supervisión de un adulto y separar turnos por edades." },
      { question: "¿Cómo limpian y desinfectan los inflables?", answer: "Cada inflable pasa por un protocolo de sanitización certificado antes de cada evento: limpieza profunda, desinfección con productos seguros para niños y revisión de costuras, mallas y anclajes. El inflable llega limpio y revisado a tu fiesta." },
      { question: "¿Qué cubre el seguro de responsabilidad civil?", answer: "Todas nuestras rentas incluyen una póliza de responsabilidad civil que protege a los asistentes de tu evento durante el uso del inflable. Es uno de los diferenciales de BRINCOLINS frente a proveedores informales que no ofrecen ninguna protección." },
      { question: "¿Incluyen operador durante el evento?", answer: "Los paquetes de kermeses, eventos escolares y corporativos incluyen operador certificado que gestiona filas, turnos y seguridad durante todo el evento. Para fiestas particulares el operador es opcional; pídelo al cotizar." },
      { question: "¿Cuántos niños pueden usar el inflable a la vez?", answer: "Depende del modelo: el Mini Castillo admite 3-4 niños pequeños, los medianos 5-7 niños, el Barco Pirata 10-15 y el Circuito Extremo 2-4 personas simultáneas en formato de carrera. Respetar la capacidad es clave para la seguridad; el rango exacto viene en la página de cada inflable." },
    ],
  },
];

// Todas las FAQs planas para el schema FAQPage
const allFaqs = categorias.flatMap(c => c.faqs);
---

<BaseLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Preguntas Frecuentes" },
  ]}
  faqItems={allFaqs}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Preguntas Frecuentes"}]} />
  </Fragment>

  <!-- HERO 2 columnas -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Centro de ayuda</span>
          <h1 class="hero__title">Preguntas Frecuentes sobre <span class="highlight">Renta de Inflables</span></h1>
          <p class="hero__desc">Todo lo que necesitas saber antes de rentar un inflable en CDMX o Estado de México: precios, lluvia, instalación, espacio, cancelaciones y seguridad.</p>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">Reunimos en una sola página las respuestas a las dudas que recibimos todos los días: <strong>qué pasa si llueve, cuánto tarda la instalación, cuánto espacio se necesita, cómo funciona el anticipo y qué cubre el seguro</strong>. Son las mismas respuestas que te daría nuestro equipo por WhatsApp.</p>
          <p class="hero__copy-text">Si tu duda no aparece aquí, escríbenos al <strong>55 3128 1706</strong>. Una persona real —no un bot— te responde en minutos, de lunes a viernes de 9:00 a 19:00 y fines de semana de 8:00 a 20:00.</p>
        </div>
      </div>
    </div>
  </section>

  {categorias.map((cat, i) => (
    <section class={`section${i % 2 === 1 ? " section--alt" : ""}`}>
      <div class="container">
        <SectionHeader
          badge={cat.badge}
          title={cat.titulo}
        />
        <div style="max-width:800px; margin:0 auto;">
          {cat.faqs.map(f => <FaqItem question={f.question} answer={f.answer} />)}
        </div>
      </div>
    </section>
  ))}

  <CtaBanner
    title="¿Resolviste tus dudas? Aparta tu fecha"
    subtitle="Cotiza gratis por WhatsApp y recibe respuesta en minutos. Entrega, instalación y seguro incluidos."
    btnText="Cotizar por WhatsApp"
    btnHref="/cotizar/"
    btnSecondaryText="Ver inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
  />

  <WaBubble whatsapp="5531281706" />
</BaseLayout>
