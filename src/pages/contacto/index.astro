---
import PageLayout from "@/layouts/PageLayout.astro";

const title = "Contacto | BRINCOLINS - Renta de Inflables CDMX";
const description = "Contáctanos para rentar inflables en CDMX y Edomex. Teléfono, WhatsApp y email. Atención de Lunes a Domingo de 8am a 8pm.";
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Contacto" },
  ]}
>

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <span>Contacto</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <h1 class="hero__title">Contáctanos</h1>
      <p class="hero__subtitle">Estamos listos para ayudarte a organizar la fiesta perfecta. Escríbenos o llámanos.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <h2 style="margin-bottom:2rem;">Información de contacto</h2>

          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(255,61,0,.1);">📞</div>
            <div>
              <div class="contact-info__label">Teléfono</div>
              <div class="contact-info__value">
                <a href="tel:5511111111" style="color:var(--color-primary); font-weight:600;">55 1111 1111</a>
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(37,211,102,.1);">💬</div>
            <div>
              <div class="contact-info__label">WhatsApp</div>
              <div class="contact-info__value">
                <a href="https://wa.me/5511111111" target="_blank" rel="noopener" style="color:var(--color-wa); font-weight:600;">55 1111 1111</a>
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(124,58,237,.1);">📧</div>
            <div>
              <div class="contact-info__label">Email</div>
              <div class="contact-info__value">
                <a href="mailto:info@brincolins.com" style="color:var(--color-secondary); font-weight:600;">info@brincolins.com</a>
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(0,200,83,.1);">🕐</div>
            <div>
              <div class="contact-info__label">Horario de atención</div>
              <div class="contact-info__value">Lunes a Domingo: 8:00 am - 8:00 pm</div>
            </div>
          </div>

          <div style="margin-top:2rem;">
            <a href="https://wa.me/5511111111?text=Hola%20BRINCOLINS%2C%20quiero%20información%20sobre%20renta%20de%20inflables."
               class="btn btn--wa btn--lg" target="_blank" rel="noopener">
              Escribir por WhatsApp
            </a>
          </div>
        </div>

        <div>
          <h2 style="margin-bottom:2rem;">Envíanos un mensaje</h2>
          <form action="#" method="POST" id="contacto-form">
            <div class="form-group">
              <label class="form-label" for="contact-nombre">Nombre *</label>
              <input class="form-input" type="text" id="contact-nombre" name="nombre" required placeholder="Tu nombre">
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-email">Email *</label>
              <input class="form-input" type="email" id="contact-email" name="email" required placeholder="tu@email.com">
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-telefono">Teléfono</label>
              <input class="form-input" type="tel" id="contact-telefono" name="telefono" placeholder="55 1234 5678">
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-asunto">Asunto *</label>
              <select class="form-select" id="contact-asunto" name="asunto" required>
                <option value="">Selecciona un asunto</option>
                <option value="cotizacion">Cotización de inflable</option>
                <option value="disponibilidad">Consultar disponibilidad</option>
                <option value="cobertura">Consultar zona de cobertura</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-mensaje">Mensaje *</label>
              <textarea class="form-textarea" id="contact-mensaje" name="mensaje" required placeholder="Escribe tu mensaje aquí..."></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--lg" style="width:100%;">Enviar mensaje</button>
          </form>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
