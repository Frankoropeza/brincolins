---
import PageLayout from "@/layouts/PageLayout.astro";
import QuickNav from "@/components/QuickNav.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const title = "Cotiza Renta de Inflables en CDMX | Inflables para Fiestas | Contacto";
const description = "Cotiza renta de inflables para fiestas en CDMX. Respuesta en menos de 30 minutos por WhatsApp. Entrega incluida, instalación profesional y precios accesibles para toda la ciudad.";
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Contacto" },
  ]}
>
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Contacto"}]} />
  </Fragment>

  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">Contacto</span>
          <h1 class="hero__title"><span class="highlight">Contáctanos</span></h1>
          <div class="hero__ctas">
            <a href="/cotizar/" class="btn btn-primary btn-lg">Solicitar cotización</a>
            <a href="tel:+525531281706" class="btn btn-outline btn-lg">Llamar ahora</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            En <strong>BRINCOLINS</strong> la comunicación es clave. Nuestro equipo de atención al cliente está disponible de Lunes a Domingo para resolver tus dudas, brindarte cotizaciones y ayudarte a elegir el inflable perfecto para tu evento.
          </p>
          <p class="hero__copy-text">
            Ya sea por WhatsApp, teléfono o correo electrónico, te respondemos en minutos. Nos encanta ayudar a las familias de CDMX y Estado de México a planear fiestas inolvidables.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav />

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="Información"
        title="Datos de contacto"
        subtitle="Múltiples formas de comunicarte con nosotros."
        copy1="Puedes contactarnos por el canal que prefieras. WhatsApp es nuestra vía más rápida — respondemos en minutos. También puedes llamarnos o enviarnos un correo electrónico."
        copy2="Nuestro horario de atención es de Lunes a Domingo, de 8:00 am a 8:00 pm. Fuera de horario, déjanos un mensaje por WhatsApp y te responderemos a primera hora."
      />
      <div class="contact-grid">
        <div>
          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(255,61,0,.1);"></div>
            <div>
              <div class="contact-info__label">Teléfono</div>
              <div class="contact-info__value">
                <a href="tel:+525531281706" style="color:var(--c-primary); font-weight:600;">55 3128 1706</a>
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(37,211,102,.1);"></div>
            <div>
              <div class="contact-info__label">WhatsApp</div>
              <div class="contact-info__value">
                <a href="https://wa.me/5531281706" target="_blank" rel="nofollow noopener noreferrer" style="color:var(--c-wa); font-weight:600;">55 3128 1706</a>
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(124,58,237,.1);">Email</div>
            <div>
              <div class="contact-info__label">Email</div>
              <div class="contact-info__value">
                <a href="mailto:info@brincolins.com" style="color:var(--c-secondary); font-weight:600;">info@brincolins.com</a>
              </div>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon" style="background:rgba(0,200,83,.1);">Hora</div>
            <div>
              <div class="contact-info__label">Horario de atención</div>
              <div class="contact-info__value">Lunes a Domingo: 8:00 am - 8:00 pm</div>
            </div>
          </div>
        </div>

        <div>
          <h3 style="margin-bottom:1.5rem; font-family:var(--font-head); font-weight:800;">Envíanos un mensaje</h3>
          <form id="contacto-form" class="quote-form" style="box-shadow:none; border:1px solid var(--c-border); padding:1.5rem;">
            <div class="form-group">
              <label class="form-label" for="contact-nombre">Nombre *</label>
              <input class="form-input" type="text" id="contact-nombre" name="nombre" required placeholder="Tu nombre">
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-telefono">Teléfono / WhatsApp *</label>
              <input class="form-input" type="tel" id="contact-telefono" name="telefono" required placeholder="55 1234 5678">
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-asunto">Asunto *</label>
              <select class="form-select" id="contact-asunto" name="asunto" required>
                <option value="">Selecciona un asunto</option>
                <option value="Cotización de inflable">Cotización de inflable</option>
                <option value="Consultar disponibilidad">Consultar disponibilidad</option>
                <option value="Consultar zona de cobertura">Consultar zona de cobertura</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-mensaje">Mensaje *</label>
              <textarea class="form-textarea" id="contact-mensaje" name="mensaje" required placeholder="Escribe tu mensaje aquí..." rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-wa btn-lg" style="width:100%; justify-content:center;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <use href="#i-wa"/>
              </svg>
              Enviar por WhatsApp
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('contacto-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const data = new FormData(form);
      const nombre = data.get('nombre') || '';
      const telefono = data.get('telefono') || '';
      const asunto = data.get('asunto') || '';
      const mensaje = data.get('mensaje') || '';

      let text = `Hola BRINCOLINS, quiero contactarlos.\n\n`;
      text += `*Nombre:* ${nombre}\n`;
      text += `*Teléfono:* ${telefono}\n`;
      text += `*Asunto:* ${asunto}\n`;
      text += `*Mensaje:* ${mensaje}\n`;

      const encoded = encodeURIComponent(text);
      window.open(`https://wa.me/5531281706?text=${encoded}`, '_blank');
    });
  </script>

</PageLayout>
