---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import VenueCard from "@/components/VenueCard.astro";
import ProductCard from "@/components/ProductCard.astro";

const title = "Monkeys Playground — Salón de Fiestas Infantiles en Venustiano Carranza | BRINCOLINS";
const description = "Monkeys Playground: salón de fiestas infantiles en Venustiano Carranza, CDMX. ⭐ 4.6 en Google Maps. Capacidad 50–100 personas. Paquetes todo incluido. Teléfono: 56 2141 9918.";

const salon = {
  name: "Monkeys Playground",
  zone: "Venustiano Carranza",
  address: "Fernando Iglesias Calderón 50, Jardín Balbuena, Venustiano Carranza, 15900 CDMX",
  capacity: "50–100 personas",
  phone: "56 2141 9918",
  rating: "4.6",
  highlight: "Moderno y familiar en Jardín Balbuena",
  gradient: "#FFD600, #FF6F00",
  features: [
    { emoji: "🎪", name: "Playground moderno", desc: "Estructura de juegos de última generación con múltiples niveles, túneles y resbaladillas para máxima diversión.", gradient: "#FFD600, #FF6F00" },
    { emoji: "👶", name: "Área de bebés", desc: "Zona exclusiva para bebés y niños pequeños con juegos suaves, tapetes acolchados y supervisión dedicada.", gradient: "#E91E8C, #FF3D00" },
    { emoji: "❄️", name: "Salón climatizado", desc: "Ambiente climatizado con aire acondicionado para mantener la comodidad de todos los invitados sin importar la temporada.", gradient: "#1565C0, #0288D1" },
    { emoji: "🍽️", name: "Meseros", desc: "Servicio de meseros profesionales que atienden a los invitados durante todo el evento con eficiencia y cortesía.", gradient: "#7C3AED, #9C27B0" },
    { emoji: "🎂", name: "Pastel y dulceros", desc: "Pastel de cumpleaños personalizado y dulceros temáticos incluidos en los paquetes principales.", gradient: "#00C853, #2E7D32" },
    { emoji: "📸", name: "Zona de fotos", desc: "Espacio decorado especialmente para tomar fotos memorables del cumpleañero y sus invitados.", gradient: "#FF3D00, #FF6D00" },
  ],
  horario: "Martes a Domingo · 10:00 – 20:00",
  gmapsQuery: "Monkeys+Playground+Jardin+Balbuena+CDMX",
};

const salonesRelacionados = [
  { slug: "dino-kids", name: "Dino Kids", zone: "V. Carranza", rating: "4.6", capacity: "40–80 personas", phone: "55 9525 2096", gradient: "linear-gradient(135deg, #2E7D32, #558B2F)", label: "🦕", features: ["Temática dinosaurios", "Juegos seguros", "Piñatas incluidas", "Dulceros"], highlight: "Temática prehistórica única" },
  { slug: "tiger-kids", name: "Tiger Kids", zone: "Iztapalapa", rating: "4.7", capacity: "40–100 personas", phone: "55 5745 2919", gradient: "linear-gradient(135deg, #FF3D00, #FF6D00)", label: "🐯", features: ["Juegos infantiles", "Área segura", "Paquetes todo incluido", "Estacionamiento"], highlight: "El mejor calificado de Iztapalapa" },
  { slug: "sipirily-congreso", name: "Sipirily Congreso", zone: "Gustavo A. Madero", rating: "4.5", capacity: "50–120 personas", phone: "55 1742 9513", gradient: "linear-gradient(135deg, #FF6D00, #FFD600)", label: "🎪", features: ["Juegos de altura", "Resbaladillas", "Paquetes completos", "Zona de adultos"], highlight: "Cadena reconocida al norte de CDMX" },
  { slug: "castillo-magico-ari-sandy", name: "Castillo Mágico Ari Sandy", zone: "Coyoacán", rating: "4.6", capacity: "50–120 personas", phone: "55 2107 0282", gradient: "linear-gradient(135deg, #0288D1, #7C3AED)", label: "🏰", features: ["Toboganes gigantes", "Alberca de pelotas", "Laberintos", "Shows infantiles"], highlight: "Clásico de Coyoacán con juegos únicos" },
];

const inflablesPopulares = [
  { slug: "mini-castillo", emoji: "🏰", name: "Mini Castillo", description: "El clásico castillo inflable perfecto para fiestas infantiles.", price: "$800", size: "4×4m", ages: "3-8 años", category: "Castillos", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Mágico castillo temático de princesas con torres y decoración especial.", price: "$900", size: "4×4m", ages: "3-8 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Aventura en altamar con tobogán y cañón de espuma.", price: "$950", size: "5×4m", ages: "4-10 años", category: "Aventura", categoryColor: "pirata", gradient: "#1565C0, #0D47A1" },
  { slug: "tobogan-acuatico", emoji: "💦", name: "Tobogán Acuático", description: "Diversión refrescante con tobogán y chapoteadero incluido.", price: "$1,200", size: "6×4m", ages: "5-12 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#0288D1, #01579B" },
];

const articulos = [
  { slug: "como-elegir-inflable-fiesta-infantil", title: "Cómo elegir el inflable perfecto para tu fiesta" },
  { slug: "ideas-fiesta-infantil-cdmx", title: "10 ideas para organizar una fiesta infantil en CDMX" },
  { slug: "consejos-rentar-inflable-primera-vez", title: "Primera vez rentando un inflable: lo que nadie te dice" },
];

const SITE = "https://brincolins.com";
const salonSlug = "monkeys-playground";

const faqItems = [
  { question: `¿Puedo llevar un inflable de BRINCOLINS a ${salon.name}?`, answer: `Sí, ${salon.name} permite inflables externos. BRINCOLINS se encarga de la entrega, instalación, supervisión durante el evento y recolección al finalizar. Solo necesitamos que el salón cuente con espacio suficiente y una toma de corriente cercana. Te recomendamos confirmar con el salón al momento de reservar.` },
  { question: `¿Cuánto cuesta rentar ${salon.name}?`, answer: `Los precios varían según el paquete elegido, número de invitados y día de la semana. Te recomendamos contactar directamente al salón al ${salon.phone} para obtener la cotización más actualizada. Los paquetes generalmente incluyen decoración, alimentos para niños y adultos, pastel, piñata y acceso a todas las áreas de juego.` },
  { question: `¿Qué tipo de eventos puedo celebrar en ${salon.name}?`, answer: `${salon.name} está especializado en fiestas infantiles, pero también es ideal para bautizos, primeras comuniones, graduaciones de kínder o primaria, baby showers y reuniones familiares. Su versatilidad y capacidad de ${salon.capacity} lo hacen adaptable a distintos tipos de celebraciones.` },
  { question: `¿Con cuánta anticipación debo reservar ${salon.name}?`, answer: `Te recomendamos reservar con al menos 2 a 4 semanas de anticipación, especialmente para fines de semana y temporada alta (diciembre, abril y mayo). En días entre semana hay mayor disponibilidad y algunos salones ofrecen descuentos especiales.` },
  { question: `¿Cuál es el horario de atención de ${salon.name}?`, answer: `${salon.name} atiende de martes a domingo de 10:00 a 20:00 horas. Te sugerimos llamar al ${salon.phone} para confirmar disponibilidad en la fecha y horario que te interesa.` },
  { question: `¿Dónde se ubica ${salon.name} en ${salon.zone}?`, answer: `${salon.name} se encuentra en ${salon.address}. La zona de Jardín Balbuena cuenta con excelente conectividad vial y transporte público. La estación de Metro más cercana es Jardín Balbuena (Línea 9). El salón cuenta con estacionamiento propio para los invitados.` },
];

const salonSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE}/directorio/cdmx/${salonSlug}/`,
  "url": `${SITE}/directorio/cdmx/${salonSlug}/`,
  "name": salon.name,
  "description": description,
  "image": `${SITE}/img/og-brincolins.jpg`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Fernando Iglesias Calderón 50, Jardín Balbuena",
    "addressLocality": salon.zone,
    "addressRegion": "CDMX",
    "postalCode": "15900",
    "addressCountry": "MX",
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 19.4165,
    "longitude": -99.1075,
  },
  "telephone": salon.phone,
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "10:00",
      "closes": "20:00",
    },
  ],
  "priceRange": "$$",
  "currenciesAccepted": "MXN",
  "paymentAccepted": "Efectivo, Tarjeta, Transferencia",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": salon.rating,
    "bestRating": "5",
    "worstRating": "1",
    "reviewCount": 112,
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "María Fernanda López" },
      "datePublished": "2025-09-14",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Excelente salón para la fiesta de mi hija. Las instalaciones están impecables, los juegos son muy seguros y el servicio de meseros fue de primera. Totalmente recomendado.",
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Roberto Hernández García" },
      "datePublished": "2025-11-02",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Celebramos el cumpleaños de nuestro hijo y todo salió perfecto. El playground moderno mantuvo a los niños entretenidos toda la fiesta. El área de bebés fue ideal para los más pequeños.",
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Ana Sofía Martínez Ruiz" },
      "datePublished": "2026-01-18",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Lo mejor de Jardín Balbuena para fiestas infantiles. El salón climatizado fue una gran ventaja en pleno verano. El pastel y los dulceros estaban hermosos. Regresaremos sin duda.",
    },
  ],
};
---

<PageLayout title={title} description={description} pageType="page" canonical={SITE + "/directorio/cdmx/" + salonSlug + "/"} faqItems={faqItems} breadcrumbs={[ { name: "Inicio", href: "/" }, { name: "Directorio", href: "/directorio/" }, { name: "CDMX", href: "/directorio/cdmx/" }, { name: salon.name } ]}>

  <script type="application/ld+json" set:html={JSON.stringify(salonSchema)} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a><span class="breadcrumbs__sep">/</span>
      <a href="/directorio/">Directorio</a><span class="breadcrumbs__sep">/</span>
      <a href="/directorio/cdmx/">CDMX</a><span class="breadcrumbs__sep">/</span>
      <span>{salon.name}</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">⭐ {salon.rating} en Google Maps · {salon.zone}</span>
          <h1 class="hero__title">{salon.name} — Salón de Fiestas <span class="highlight">Infantiles</span></h1>
          <p class="hero__desc">Salón de fiestas infantiles en {salon.zone}, CDMX. {salon.highlight}. Capacidad para {salon.capacity}. Paquetes todo incluido con juegos, alimentos, decoración y más.</p>
          <div class="hero__ctas">
            <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-lg">Llamar al salón</a>
            <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`} class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">WhatsApp del salón</a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text"><strong>{salon.name}</strong> se ha consolidado como uno de los salones de fiestas infantiles con mejor reputación en {salon.zone}. Con una calificación de <strong>{salon.rating} estrellas en Google Maps</strong>, destaca por sus amplias instalaciones, su compromiso con la seguridad de los niños y la calidad de sus paquetes todo incluido que facilitan la organización de cualquier celebración.</p>
          <p class="hero__copy-text">¿Ya reservaste tu fecha? Lleva la diversión al siguiente nivel con un inflable de <strong>BRINCOLINS</strong>. Entregamos, instalamos y recogemos directamente en {salon.name} sin costo adicional. Nuestro catálogo incluye castillos, toboganes, pistas de obstáculos y más.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="page-layout">
        <div class="page-layout__main">

          <div class="salon-ficha">
            <h2 class="salon-ficha__title">Ficha completa de {salon.name}</h2>
            <p class="salon-ficha__subtitle">{salon.highlight} — Toda la información que necesitas para reservar tu evento</p>
            <div class="salon-ficha__grid">
              <div class="salon-ficha__item"><div class="salon-ficha__icon">📍</div><div><strong>Dirección</strong><p>{salon.address}</p></div></div>
              <div class="salon-ficha__item"><div class="salon-ficha__icon">📞</div><div><strong>Teléfono de contacto</strong><p><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`}>{salon.phone}</a></p></div></div>
              <div class="salon-ficha__item"><div class="salon-ficha__icon">🕐</div><div><strong>Horario de atención</strong><p>{salon.horario}</p></div></div>
              <div class="salon-ficha__item"><div class="salon-ficha__icon">👥</div><div><strong>Capacidad</strong><p>{salon.capacity}</p></div></div>
              <div class="salon-ficha__item"><div class="salon-ficha__icon">⭐</div><div><strong>Calificación en Google</strong><p>{salon.rating} / 5.0 — basada en reseñas verificadas</p></div></div>
              <div class="salon-ficha__item"><div class="salon-ficha__icon">🎉</div><div><strong>Tipo de eventos</strong><p>Cumpleaños, bautizos, primeras comuniones, graduaciones, baby showers</p></div></div>
              <div class="salon-ficha__item"><div class="salon-ficha__icon">🅿️</div><div><strong>Estacionamiento</strong><p>Sí — estacionamiento propio incluido para invitados</p></div></div>
              <div class="salon-ficha__item"><div class="salon-ficha__icon">🎈</div><div><strong>Inflables externos</strong><p>Permitidos — BRINCOLINS entrega e instala en el salón</p></div></div>
            </div>
            <div class="salon-ficha__actions">
              <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary">📞 Llamar ahora</a>
              <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`} class="btn btn-wa" target="_blank" rel="noopener noreferrer">WhatsApp</a>
              <a href={`https://www.google.com/maps/search/${salon.gmapsQuery}`} class="btn btn-outline" target="_blank" rel="noopener noreferrer">📍 Ver en Google Maps</a>
            </div>
          </div>

          <div class="salon-editorial">
            <h2>¿Por qué elegir {salon.name} para tu fiesta infantil?</h2>
            <p>Ubicado en la icónica colonia Jardín Balbuena de <strong>Venustiano Carranza</strong>, {salon.name} representa la nueva generación de salones de fiestas infantiles en CDMX. Su <strong>playground moderno</strong> de múltiples niveles cuenta con túneles, resbaladillas, puentes colgantes y zonas de escalada que mantienen a los niños activos y fascinados durante toda la celebración.</p>
            <p>Una de las grandes ventajas de {salon.name} es su <strong>área exclusiva para bebés</strong>, diseñada con materiales suaves y supervisión dedicada para los más pequeños de la familia. El <strong>salón climatizado</strong> garantiza la comodidad de todos los invitados sin importar la época del año, y el servicio de <strong>meseros profesionales</strong> permite que los padres se relajen y disfruten de la fiesta junto a sus hijos.</p>
            <p>Con <strong>{salon.rating} estrellas en Google Maps</strong>, {salon.name} ha ganado la confianza de las familias de Jardín Balbuena y colonias vecinas. Las reseñas resaltan las <strong>instalaciones modernas</strong>, la <strong>higiene impecable</strong> y el <strong>servicio atento y profesional</strong>. Es una excelente opción para quienes buscan un espacio contemporáneo y bien equipado en la zona centro-oriente de la ciudad.</p>

            <h3>Servicios incluidos en los paquetes</h3>
            <p>Los paquetes de {salon.name} están diseñados para ofrecer una experiencia completa. Dependiendo del paquete seleccionado, puedes esperar los siguientes servicios:</p>
          </div>

          <div class="grid-3" style="margin-bottom:2rem;">
            {salon.features.map(f => (
              <article class="product-card">
                <div class="product-card__image" style={`background: linear-gradient(135deg, ${f.gradient});`}><span>{f.emoji}</span></div>
                <div class="product-card__body"><h3 class="product-card__name">{f.name}</h3><p class="product-card__desc">{f.desc}</p></div>
              </article>
            ))}
          </div>

          <div class="salon-editorial">
            <h3>¿Cómo llegar a {salon.name}?</h3>
            <p>{salon.name} se ubica en <strong>{salon.address}</strong>. Jardín Balbuena es una de las colonias mejor comunicadas de la ciudad, con acceso directo desde Fray Servando Teresa de Mier, Circuito Interior y el Eje 3 Sur.</p>
            <p>La estación de Metro más cercana es Jardín Balbuena (Línea 9), que se encuentra a escasas cuadras del salón. También puedes usar el Metrobús o llegar en auto; el salón cuenta con <strong>estacionamiento</strong> para la comodidad de los invitados.</p>
          </div>

          <div class="dir-tip" style="margin-top:2rem;">
            <div class="dir-tip__icon">🎈</div>
            <div class="dir-tip__content">
              <p class="dir-tip__title">¡Complementa tu fiesta en {salon.name} con un inflable!</p>
              <p class="dir-tip__text"><strong>BRINCOLINS</strong> entrega, instala y recoge el inflable directamente en el salón. Solo necesitas confirmar que haya espacio disponible al momento de reservar.</p>
            </div>
            <a href="/cotizar/" class="btn btn-primary">Cotizar inflable</a>
          </div>

        </div>

        <aside class="page-layout__sidebar">
          <div class="sidebar-card sidebar-card--cta">
            <p class="sidebar-card__title">¿Te interesa este salón?</p>
            <p class="sidebar-card__text">Contacta directamente a {salon.name} para consultar disponibilidad y precios.</p>
            <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-sm" style="width:100%; justify-content:center; margin-bottom:0.5rem;">📞 {salon.phone}</a>
            <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`} class="btn btn-wa btn-sm" target="_blank" rel="noopener noreferrer" style="width:100%; justify-content:center;">WhatsApp</a>
          </div>
          <div class="sidebar-card">
            <p class="sidebar-card__title">📰 Artículos de interés</p>
            <div class="sidebar-card__list">
              {articulos.map(a => (<a href={`/blog/${a.slug}/`} class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">{a.title}</p><span class="sidebar-card__arrow">→</span></a>))}
            </div>
            <a href="/blog/" class="sidebar-card__link">Ver todos los artículos →</a>
          </div>
          <div class="sidebar-card">
            <p class="sidebar-card__title">🔗 Explora BRINCOLINS</p>
            <div class="sidebar-card__list">
              <a href="/directorio/cdmx/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">📍 16 salones en CDMX</p><span class="sidebar-card__arrow">→</span></a>
              <a href="/directorio/edomex/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">🏘️ Salones en Edomex</p><span class="sidebar-card__arrow">→</span></a>
              <a href="/inflables/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">🎈 Catálogo de inflables</p><span class="sidebar-card__arrow">→</span></a>
              <a href="/cobertura/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">🗺️ Zona de cobertura</p><span class="sidebar-card__arrow">→</span></a>
              <a href="/cotizar/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">💬 Solicitar cotización</p><span class="sidebar-card__arrow">→</span></a>
            </div>
          </div>
          <div class="sidebar-card sidebar-card--highlight">
            <p class="sidebar-card__title">¿Ya tienes tu salón?</p>
            <p class="sidebar-card__text">Agrega un inflable a tu fiesta en {salon.name}. Entrega e instalación incluida.</p>
            <a href="/cotizar/" class="btn btn-primary btn-sm" style="width:100%; justify-content:center;">Cotizar inflable</a>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader badge="📍 Más salones en CDMX" title="Otros salones que te pueden interesar" subtitle="Explora más opciones de salones de fiestas infantiles verificados en la Ciudad de México." copy1="Si buscas alternativas a Monkeys Playground, aquí encontrarás otros salones con excelente calificación en Google Maps. Todos permiten inflables externos y están dentro de nuestra zona de cobertura." copy2="¿Ya elegiste tu salón? No olvides complementar la fiesta con un inflable de <strong>BRINCOLINS</strong>. Entrega e instalación incluida en cualquier salón de CDMX." />
      <div class="grid-4">{salonesRelacionados.map(s => <VenueCard {...s} />)}</div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader badge="🎈 Inflables para tu fiesta" title="Lleva un inflable a tu fiesta" subtitle={`Complementa tu evento en ${salon.name} con uno de nuestros inflables. Entrega e instalación incluida.`} copy1="Todos nuestros inflables incluyen entrega, instalación, limpieza y seguro. Solo necesitas una toma de corriente y espacio suficiente en el salón. Confirma la disponibilidad de espacio al reservar tu salón." copy2="Desde castillos clásicos hasta toboganes acuáticos y pistas de obstáculos, tenemos opciones para todas las edades y presupuestos. <strong>Cotiza hoy y asegura tu fecha.</strong>" />
      <div class="grid-4">{inflablesPopulares.map(p => <ProductCard {...p} />)}</div>
    </div>
  </section>

  <section class="section">
    <div class="container">
