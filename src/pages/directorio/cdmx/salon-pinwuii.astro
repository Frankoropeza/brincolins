---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import VenueCard from "@/components/VenueCard.astro";
import ProductCard from "@/components/ProductCard.astro";

const title = "Salón Pinwuii — Salón de Fiestas Infantiles en Tlalpan | BRINCOLINS";
const description = "Salón Pinwuii: salón de fiestas infantiles en Tlalpan, CDMX. ⭐ 4.5 en Google Maps. Capacidad 40–80 personas. Paquetes todo incluido. Teléfono: 55 2109 8919.";

const salon = { name: "Salón Pinwuii", zone: "Tlalpan", address: "Palma 34, San Andrés Totoltepec, Tlalpan, 14400 CDMX", capacity: "40–80 personas", phone: "55 2109 8919", rating: "4.5", highlight: "Íntimo y acogedor en San Andrés Totoltepec", gradient: "#7C3AED, #1565C0", features: [
  { emoji: "🏠", name: "Ambiente íntimo", desc: "Espacio acogedor y bien decorado que crea un ambiente cálido e íntimo perfecto para celebraciones familiares.", gradient: "#7C3AED, #1565C0" },
  { emoji: "🎮", name: "Juegos infantiles", desc: "Área de juegos con brincolines, resbaladillas y actividades recreativas adaptadas para niños de todas las edades.", gradient: "#00C853, #2E7D32" },
  { emoji: "💰", name: "Paquetes económicos", desc: "Opciones de paquetes accesibles que incluyen lo esencial sin comprometer la calidad del servicio.", gradient: "#FF6F00, #FFD600" },
  { emoji: "🎨", name: "Decoración temática", desc: "Decoración personalizable incluida en los paquetes, con múltiples temáticas disponibles para elegir.", gradient: "#E91E8C, #FF3D00" },
  { emoji: "🍕", name: "Alimentos incluidos", desc: "Menú para niños y adultos con opciones frescas y variadas, preparadas especialmente para el evento.", gradient: "#1565C0, #0288D1" },
  { emoji: "🎵", name: "Música y sonido", desc: "Equipo de sonido con música ambiental y micrófono disponible para animación y momentos especiales.", gradient: "#9C27B0, #7C3AED" },
], horario: "Martes a Domingo · 10:00 – 20:00", gmapsQuery: "Salon+Pinwuii+Tlalpan+CDMX" };

const salonesRelacionados = [
  { slug: "salon-machinkuepa", name: "Salón Machinkuepa", zone: "Tlalpan", rating: "4.7", capacity: "50–120 personas", phone: "55 8007 0580", gradient: "linear-gradient(135deg, #7C3AED, #9C27B0)", label: "⭐", features: ["Juegos extremos", "Área de bebés", "Decoración incluida", "Salón amplio"], highlight: "Top 1 en Tlalpan por calificación" },
  { slug: "salon-wondertown", name: "Salón Wondertown", zone: "Tlalpan", rating: "4.6", capacity: "40–100 personas", phone: "55 3334 5442", gradient: "linear-gradient(135deg, #9C27B0, #E91E8C)", label: "🌟", features: ["Temáticas personalizadas", "Juegos modernos", "Snack bar", "Música incluida"], highlight: "Temáticas personalizadas en Héroes de Padierna" },
  { slug: "el-rehilete-cardyc-coapa", name: "El Rehilete y CARDYC Coapa", zone: "Tlalpan", rating: "4.7", capacity: "60–150 personas", phone: "55 4337 2422", gradient: "linear-gradient(135deg, #1565C0, #0288D1)", label: "🏆", features: ["Gran capacidad", "Área deportiva", "Jardín amplio", "Banquete incluido"], highlight: "Doble espacio: salón + área deportiva" },
  { slug: "wiby-kids", name: "Wiby Kids", zone: "Xochimilco", rating: "4.4", capacity: "40–80 personas", phone: "55 3368 1406", gradient: "linear-gradient(135deg, #1565C0, #0288D1)", label: "🎭", features: ["Juegos modernos", "Área segura", "Pintacaritas", "Paquetes desde 15 niños"], highlight: "Moderno y seguro en Xochimilco" },
];

const inflablesPopulares = [
  { slug: "dragones-rojos", emoji: "🐉", name: "Dragones Rojos", description: "El inflable más popular en CDMX. Castillo con dragones gigantes y resbaladilla.", price: "$1,800", size: "4×4m", ages: "4-12 años", category: "Más popular", categoryColor: "castillo", gradient: "#B71C1C, #E53935", image: "/img/inflables/dragones-rojos.avif" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Castillo rosa con resbaladilla incluida para fiestas de princesas.", price: "$1,800", size: "4×4m", ages: "3-10 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED", image: "/img/inflables/castillo-princesas.avif" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Barco pirata gigante con tobogán de alta velocidad incluido.", price: "$2,500", size: "7×5m", ages: "4-14 años", category: "Grande", categoryColor: "pirata", gradient: "#1565C0, #0D47A1", image: "/img/inflables/barco-pirata.avif" },
  { slug: "extremo", emoji: "🏁", name: "Extremo", description: "Circuito de obstáculos para competencias y diversión extrema.", price: "$2,300", size: "4.8×3.3m", ages: "6-14 años", category: "Extremo", categoryColor: "extremo", gradient: "#E65100, #BF360C", image: "/img/inflables/extremo.avif" },
];

const articulos = [
  { slug: "como-elegir-inflable-fiesta-infantil", title: "Cómo elegir el inflable perfecto para tu fiesta" },
  { slug: "ideas-fiesta-infantil-cdmx", title: "10 ideas para organizar una fiesta infantil en CDMX" },
  { slug: "consejos-rentar-inflable-primera-vez", title: "Primera vez rentando un inflable: lo que nadie te dice" },
];

const SITE = "https://brincolins.com";
const salonSlug = "salon-pinwuii";

const faqItems = [
  { question: `¿Puedo llevar un inflable de BRINCOLINS a ${salon.name}?`, answer: `Sí, ${salon.name} permite inflables externos. BRINCOLINS se encarga de la entrega, instalación, supervisión durante el evento y recolección al finalizar. Solo necesitamos que el salón cuente con espacio suficiente y una toma de corriente cercana. Te recomendamos confirmar con el salón al momento de reservar.` },
  { question: `¿Cuánto cuesta rentar ${salon.name}?`, answer: `Los precios varían según el paquete elegido, número de invitados y día de la semana. Te recomendamos contactar directamente al salón al ${salon.phone} para obtener la cotización más actualizada. Los paquetes generalmente incluyen decoración, alimentos para niños y adultos, pastel, piñata y acceso a todas las áreas de juego.` },
  { question: `¿Cuál es el teléfono de ${salon.name}?`, answer: `Puedes contactar a ${salon.name} al teléfono ${salon.phone}. También puedes enviar un mensaje por WhatsApp al mismo número para consultar disponibilidad y precios de paquetes.` },
  { question: `¿Cuál es la capacidad de ${salon.name}?`, answer: `${salon.name} tiene capacidad para ${salon.capacity}. Es un espacio íntimo y acogedor en ${salon.zone}, ideal para celebraciones familiares donde cada invitado se siente especial.` },
  { question: `¿Qué tipo de eventos puedo celebrar en ${salon.name}?`, answer: `${salon.name} está especializado en fiestas infantiles, pero también es ideal para bautizos, primeras comuniones, graduaciones de kínder o primaria, baby showers y reuniones familiares. Su versatilidad y capacidad de ${salon.capacity} lo hacen adaptable a distintos tipos de celebraciones.` },
  { question: `¿Dónde se encuentra ${salon.name} en ${salon.zone}?`, answer: `${salon.name} se ubica en ${salon.address}. Está en la zona de San Andrés Totoltepec en ${salon.zone}, accesible desde la carretera Picacho-Ajusco y la Avenida San Fernando. Cuenta con estacionamiento propio para invitados.` },
];

const salonSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE}/directorio/cdmx/${salonSlug}/`,
  "url": `${SITE}/directorio/cdmx/${salonSlug}/`,
  "name": salon.name,
  "description": description,
  "image": `${SITE}/og/directorio-cdmx-${salonSlug}.jpg`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Palma 34, San Andrés Totoltepec",
    "addressLocality": "Tlalpan",
    "addressRegion": "CDMX",
    "postalCode": "14400",
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 19.2800,
    "longitude": -99.1650
  },
  "telephone": salon.phone,
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "10:00", "closes": "20:00" }
  ],
  "priceRange": "$$",
  "currenciesAccepted": "MXN",
  "paymentAccepted": "Efectivo, Tarjeta, Transferencia",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": salon.rating,
    "bestRating": "5",
    "worstRating": "1",
    "reviewCount": 98
  },
  "review": [
    { "@type": "Review", "author": { "@type": "Person", "name": "Mariana López" }, "datePublished": "2025-11-10", "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }, "reviewBody": "Excelente lugar para la fiesta de mi hija. El ambiente es muy acogedor y el trato fue muy personalizado. Los niños se divirtieron muchísimo." },
    { "@type": "Review", "author": { "@type": "Person", "name": "Roberto Sánchez" }, "datePublished": "2025-09-22", "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }, "reviewBody": "Muy buen salón a precio accesible. La decoración estaba increíble y la comida deliciosa. Lo recomiendo para fiestas pequeñas y familiares." },
    { "@type": "Review", "author": { "@type": "Person", "name": "Gabriela Torres" }, "datePublished": "2025-07-15", "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }, "reviewBody": "Me encantó el lugar, muy limpio y bien cuidado. El equipo de Pinwuii nos ayudó con todo. Definitivamente regresaremos para el próximo cumpleaños." }
  ]
};
---

<PageLayout title={title} description={description} canonical={SITE + "/directorio/cdmx/" + salonSlug + "/"} faqItems={faqItems} pageType="page" breadcrumbs={[{ name: "Inicio", href: "/" }, { name: "Directorio", href: "/directorio/" }, { name: "CDMX", href: "/directorio/cdmx/" }, { name: salon.name }]}>
  <script type="application/ld+json" set:html={JSON.stringify(salonSchema)} />
  <div class="container"><nav class="breadcrumbs" aria-label="Ruta de navegación"><a href="/">Inicio</a><span class="breadcrumbs__sep">/</span><a href="/directorio/">Directorio</a><span class="breadcrumbs__sep">/</span><a href="/directorio/cdmx/">CDMX</a><span class="breadcrumbs__sep">/</span><span>{salon.name}</span></nav></div>

  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;"><div class="container"><div class="hero__grid"><div><span class="hero__badge">⭐ {salon.rating} en Google Maps · {salon.zone}</span><h1 class="hero__title">{salon.name} — Salón de Fiestas <span class="highlight">Infantiles</span></h1><p class="hero__desc">Salón de fiestas infantiles en {salon.zone}, CDMX. {salon.highlight}. Capacidad para {salon.capacity}. Paquetes todo incluido con juegos, alimentos, decoración y más.</p><div class="hero__ctas"><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-lg">Llamar al salón</a><a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`} class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">WhatsApp del salón</a></div></div><div class="hero__copy"><p class="hero__copy-text"><strong>{salon.name}</strong> se ha consolidado como uno de los salones de fiestas infantiles con mejor reputación en {salon.zone}. Con una calificación de <strong>{salon.rating} estrellas en Google Maps</strong>, destaca por sus amplias instalaciones, su compromiso con la seguridad de los niños y la calidad de sus paquetes todo incluido que facilitan la organización de cualquier celebración.</p><p class="hero__copy-text">¿Ya reservaste tu fecha? Lleva la diversión al siguiente nivel con un inflable de <strong>BRINCOLINS</strong>. Entregamos, instalamos y recogemos directamente en {salon.name} sin costo adicional. Nuestro catálogo incluye castillos, toboganes, pistas de obstáculos y más.</p></div></div></div></section>

  <!-- Contenido principal + Sidebar -->
  <section class="section section--alt">
    <div class="container">
      <div class="page-layout">

        <!-- MAIN CONTENT -->
        <div class="page-layout__main">

          <!-- Ficha técnica del salón -->
          <div class="salon-ficha">
            <div class="salon-ficha__header">
              <div class="salon-ficha__badge">⭐ {salon.rating} / 5.0</div>
              <div>
                <h2 class="salon-ficha__title">{salon.name}</h2>
                <p class="salon-ficha__subtitle">{salon.highlight}</p>
              </div>
            </div>

            <table class="salon-ficha__table">
              <tbody>
                <tr>
                  <td class="salon-ficha__label">Dirección</td>
                  <td class="salon-ficha__value">{salon.address}</td>
                </tr>
                <tr>
                  <td class="salon-ficha__label">Teléfono</td>
                  <td class="salon-ficha__value"><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="salon-ficha__link">{salon.phone}</a></td>
                </tr>
                <tr>
                  <td class="salon-ficha__label">Horario</td>
                  <td class="salon-ficha__value">{salon.horario}</td>
                </tr>
                <tr>
                  <td class="salon-ficha__label">Capacidad</td>
                  <td class="salon-ficha__value">{salon.capacity}</td>
                </tr>
                <tr>
                  <td class="salon-ficha__label">Eventos</td>
                  <td class="salon-ficha__value">Cumpleaños, bautizos, primeras comuniones, graduaciones, baby showers</td>
                </tr>
                <tr>
                  <td class="salon-ficha__label">Estacionamiento</td>
                  <td class="salon-ficha__value">Sí — estacionamiento propio incluido para invitados</td>
                </tr>
                <tr>
                  <td class="salon-ficha__label">Inflables externos</td>
                  <td class="salon-ficha__value">Permitidos — BRINCOLINS entrega e instala en el salón</td>
                </tr>
                <tr>
                  <td class="salon-ficha__label">Calificación</td>
                  <td class="salon-ficha__value">⭐ {salon.rating} / 5.0 — basada en reseñas verificadas de Google Maps</td>
                </tr>
              </tbody>
            </table>

            <div class="salon-ficha__actions">
              <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary">Llamar ahora</a>
              <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`}
                 class="btn btn-wa" target="_blank" rel="noopener noreferrer">WhatsApp</a>
              <a href={`https://www.google.com/maps/search/${salon.gmapsQuery}`}
                 class="btn btn-outline" target="_blank" rel="noopener noreferrer">Ver en Google Maps</a>
            </div>
          </div>

          <!-- Descripción editorial -->
          <div class="salon-editorial">
            <h2 class="salon-editorial__heading">¿Por qué elegir {salon.name} para tu fiesta infantil?</h2>
            <p>En el pintoresco pueblo de San Andrés Totoltepec, en las faldas del Ajusco en <strong>Tlalpan</strong>, {salon.name} ofrece un <strong>ambiente íntimo y acogedor</strong> que lo diferencia de los grandes salones comerciales. Es el lugar perfecto para familias que prefieren celebraciones más cercanas y personales, donde cada invitado se siente especial y la atención es dedicada.</p>
            <p>Los <strong>paquetes económicos</strong> de {salon.name} incluyen todo lo esencial: <strong>decoración temática</strong> personalizable, área de juegos infantiles con brincolines y resbaladillas, alimentos para niños y adultos, y música con equipo de sonido profesional. A pesar de los precios accesibles, la calidad del servicio es sobresaliente, y cada detalle está cuidado para que los padres no tengan que preocuparse por nada.</p>
            <p>Con <strong>{salon.rating} estrellas en Google Maps</strong>, quienes han celebrado en {salon.name} valoran especialmente la <strong>cercanía del trato</strong>, la <strong>limpieza de las instalaciones</strong> y la <strong>flexibilidad para personalizar</strong> cada evento. San Andrés Totoltepec tiene un encanto especial por su ambiente semi-rural y aire fresco, lo que añade un toque único a cualquier celebración. Ideal para familias del sur de CDMX.</p>
          </div>

          <!-- Servicios -->
          <div class="salon-servicios">
            <h3 class="salon-servicios__heading">Servicios incluidos en los paquetes</h3>
            <p class="salon-servicios__intro">Los paquetes de {salon.name} están diseñados para ofrecer una experiencia completa. Dependiendo del paquete seleccionado, puedes esperar los siguientes servicios:</p>
            <div class="salon-servicios__grid">
              {salon.features.map(f => (
                <article class="product-card">
                  <div class="product-card__image" style={`background: linear-gradient(135deg, ${f.gradient});`}>
                    <span>{f.emoji}</span>
                  </div>
                  <div class="product-card__body">
                    <h3 class="product-card__name">{f.name}</h3>
                    <p class="product-card__desc">{f.desc}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <!-- Cómo llegar -->
          <div class="salon-editorial salon-editorial--location">
            <h3 class="salon-editorial__subheading">¿Cómo llegar a {salon.name}?</h3>
            <p>{salon.name} se ubica en <strong>{salon.address}</strong>. San Andrés Totoltepec está en la zona alta de Tlalpan, accesible desde la carretera Picacho-Ajusco y la Avenida San Fernando.</p>
            <p>Si vienes del centro de la ciudad, puedes tomar Periférico Sur hacia el Ajusco y seguir las indicaciones hacia San Andrés Totoltepec. En transporte público, hay combis y microbuses que salen desde el centro de Tlalpan. El salón cuenta con <strong>estacionamiento</strong> para los invitados que lleguen en auto.</p>
          </div>

          <!-- Tip inflable -->
          <div class="dir-tip" style="margin-top:2rem;">
            <div class="dir-tip__icon">🎈</div>
            <div class="dir-tip__content">
              <p class="dir-tip__title">¡Complementa tu fiesta en {salon.name} con un inflable!</p>
              <p class="dir-tip__text"><strong>BRINCOLINS</strong> entrega, instala y recoge el inflable directamente en el salón. Solo necesitas confirmar que haya espacio disponible al momento de reservar.</p>
            </div>
            <a href="/cotizar/" class="btn btn-primary">Cotizar inflable</a>
          </div>

        </div>

        <!-- SIDEBAR -->
        <aside class="page-layout__sidebar">

          <!-- CTA principal sidebar -->
          <div class="sidebar-card sidebar-card--cta">
            <div class="sidebar-card__cta-badge">Contacto directo</div>
            <p class="sidebar-card__title">¿Te interesa {salon.name}?</p>
            <p class="sidebar-card__text">Consulta disponibilidad y precios directamente con el salón.</p>
            <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-sm sidebar-card__btn">{salon.phone}</a>
            <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`}
               class="btn btn-wa btn-sm sidebar-card__btn" target="_blank" rel="noopener noreferrer">WhatsApp directo</a>
            <a href={`https://www.google.com/maps/search/${salon.gmapsQuery}`}
               class="btn btn-outline btn-sm sidebar-card__btn" target="_blank" rel="noopener noreferrer">Ver en Google Maps</a>
          </div>

          <!-- Artículos de interés -->
          <div class="sidebar-card">
            <p class="sidebar-card__title">Artículos de interés</p>
            <div class="sidebar-card__list">
              {articulos.map(a => (
                <a href={`/blog/${a.slug}/`} class="sidebar-card__list-item sidebar-card__list-item--link">
                  <p class="sidebar-card__list-name">{a.title}</p>
                  <span class="sidebar-card__arrow">→</span>
                </a>
              ))}
            </div>
            <a href="/blog/" class="sidebar-card__link">Ver todos los artículos →</a>
          </div>

          <!-- Links rápidos -->
          <div class="sidebar-card">
            <p class="sidebar-card__title">Explora BRINCOLINS</p>
            <div class="sidebar-card__list">
              <a href="/directorio/cdmx/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">16 salones en CDMX</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/directorio/edomex/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">Salones en Edomex</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/inflables/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">Catálogo de inflables</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/cobertura/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">Zona de cobertura</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/cotizar/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">Solicitar cotización</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
            </div>
          </div>

          <!-- Cotizar inflable -->
          <div class="sidebar-card sidebar-card--highlight">
            <p class="sidebar-card__title">¿Ya tienes tu salón?</p>
            <p class="sidebar-card__text">Agrega un inflable a tu fiesta en {salon.name}. Entrega e instalación incluida.</p>
            <a href="/cotizar/" class="btn btn-primary btn-sm sidebar-card__btn">Cotizar inflable</a>
          </div>

        </aside>

      </div>
    </div>
  </section>

  <section class="section"><div class="container"><SectionHeader badge="📍 Más salones en CDMX" title="Otros salones que te pueden interesar" subtitle="Explora más opciones de salones de fiestas infantiles verificados en la Ciudad de México." copy1="Si buscas alternativas a Salón Pinwuii, aquí encontrarás otros salones con excelente calificación en Google Maps. Todos permiten inflables externos y están dentro de nuestra zona de cobertura." copy2="¿Ya elegiste tu salón? No olvides complementar la fiesta con un inflable de <strong>BRINCOLINS</strong>. Entrega e instalación incluida en cualquier salón de CDMX." /><div class="grid-4">{salonesRelacionados.map(s => <VenueCard {...s} />)}</div></div></section>
  <section class="section section--alt"><div class="container"><SectionHeader badge="🎈 Inflables para tu fiesta" title="Lleva un inflable a tu fiesta" subtitle={`Complementa tu evento en ${salon.name} con uno de nuestros inflables. Entrega e instalación incluida.`} copy1="Todos nuestros inflables incluyen entrega, instalación, limpieza y seguro. Solo necesitas una toma de corriente y espacio suficiente en el salón. Confirma la disponibilidad de espacio al reservar tu salón." copy2="Desde castillos clásicos hasta toboganes acuáticos y pistas de obstáculos, tenemos opciones para todas las edades y presupuestos. <strong>Cotiza hoy y asegura tu fecha.</strong>" /><div class="grid-4">{inflablesPopulares.map(p => <ProductCard {...p} />)}</div></div></section>
