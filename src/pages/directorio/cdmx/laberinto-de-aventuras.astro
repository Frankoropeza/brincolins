---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import VenueCard from "@/components/VenueCard.astro";
import ProductCard from "@/components/ProductCard.astro";

const title = "Laberinto de Aventuras — Salón de Fiestas Infantiles en Azcapotzalco | BRINCOLINS";
const description = "Laberinto de Aventuras: salón de fiestas infantiles en Azcapotzalco, CDMX. ⭐ 4.7 en Google Maps. Capacidad 40–100 personas. Paquetes todo incluido. Teléfono: 55 7652 2817.";

const salon = {
  name: "Laberinto de Aventuras",
  zone: "Azcapotzalco",
  address: "C. Heliópolis 241, Clavería, Azcapotzalco, 02080 CDMX",
  capacity: "40–100 personas",
  phone: "55 7652 2817",
  rating: "4.7",
  highlight: "El favorito de Azcapotzalco",
  gradient: "#00C853, #2E7D32",
  features: [
    { emoji: "🏰", name: "Laberinto temático", desc: "Un laberinto de aventuras único con distintas estaciones temáticas que mantienen a los niños explorando.", gradient: "#00C853, #2E7D32" },
    { emoji: "🎮", name: "Juegos interactivos", desc: "Estaciones de juegos interactivos digitales y físicos que combinan diversión con aprendizaje.", gradient: "#1565C0, #0288D1" },
    { emoji: "💰", name: "Paquetes accesibles", desc: "Opciones de paquetes para todos los presupuestos, desde básicos hasta todo incluido con banquete.", gradient: "#FF6F00, #FFD600" },
    { emoji: "🍺", name: "Zona para adultos", desc: "Área cómoda y separada para que los padres disfruten mientras los niños juegan con total seguridad.", gradient: "#7C3AED, #9C27B0" },
    { emoji: "🎤", name: "Animación incluida", desc: "Animadores profesionales que organizan dinámicas, concursos y actividades durante todo el evento.", gradient: "#E91E8C, #FF3D00" },
    { emoji: "🍔", name: "Servicio de alimentos", desc: "Menú variado con opciones para niños y adultos, incluyendo snacks, comida completa y bebidas.", gradient: "#FF3D00, #FF6D00" },
  ],
  horario: "Martes a Domingo · 10:00 – 20:00",
  gmapsQuery: "Laberinto+de+Aventuras+Azcapotzalco+CDMX",
};

const salonesRelacionados = [
  { slug: "fantasia-extremo-kids", name: "Fantasía Extremo Kids", zone: "Azcapotzalco", rating: "4.7", capacity: "40–80 personas", phone: "55 4182 4596", gradient: "linear-gradient(135deg, #E91E8C, #FF3D00)", label: "🎉", features: ["Juegos extremos", "Alberca de pelotas", "Pintacaritas", "Paquetes desde 20 niños"], highlight: "Diversión extrema para los más aventureros" },
  { slug: "sipirily-congreso", name: "Sipirily Congreso", zone: "Gustavo A. Madero", rating: "4.5", capacity: "50–120 personas", phone: "55 1742 9513", gradient: "linear-gradient(135deg, #FF6D00, #FFD600)", label: "🎪", features: ["Juegos de altura", "Resbaladillas", "Paquetes completos", "Zona de adultos"], highlight: "Cadena reconocida al norte de CDMX" },
  { slug: "tiger-kids", name: "Tiger Kids", zone: "Iztapalapa", rating: "4.7", capacity: "40–100 personas", phone: "55 5745 2919", gradient: "linear-gradient(135deg, #FF3D00, #FF6D00)", label: "🐯", features: ["Juegos infantiles", "Área segura", "Paquetes todo incluido", "Estacionamiento"], highlight: "El mejor calificado de Iztapalapa" },
  { slug: "dino-kids", name: "Dino Kids", zone: "V. Carranza", rating: "4.6", capacity: "40–80 personas", phone: "55 9525 2096", gradient: "linear-gradient(135deg, #2E7D32, #558B2F)", label: "🦕", features: ["Temática dinosaurios", "Juegos seguros", "Piñatas incluidas", "Dulceros"], highlight: "Temática prehistórica única" },
];

const inflablesPopulares = [
  { slug: "mini-castillo", emoji: "🏰", name: "Mini Castillo", description: "El clásico castillo inflable perfecto para fiestas infantiles.", price: "$800", size: "4×4m", ages: "3-8 años", category: "Castillos", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Mágico castillo temático de princesas con torres y decoración especial.", price: "$900", size: "4×4m", ages: "3-8 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Aventura en altamar con tobogán y cañón de espuma.", price: "$950", size: "5×4m", ages: "4-10 años", category: "Aventura", categoryColor: "pirata", gradient: "#1565C0, #0D47A1" },
  { slug: "tobogan-acuatico", emoji: "💦", name: "Tobogán Acuático", description: "Diversión refrescante con tobogán y chapoteadero incluido.", price: "$1,200", size: "6×4m", ages: "5-12 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#0288D1, #01579B" },
];

const articulos = [
  { slug: "como-elegir-inflable-fiesta-infantil", title: "Cómo elegir el inflable perfecto para tu fiesta" },
  { slug: "ideas-fiesta-infantil-cdmx", title: "10 ideas para organizar una fiesta infantil en CDMX" },
  { slug: "consejos-rentar-inflable-primera-vez", title: "Primera vez rentando un inflable: lo que nadie te dice" },
];

const salonSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": salon.name,
  "description": description,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": salon.address,
    "addressLocality": salon.zone,
    "addressRegion": "CDMX",
    "addressCountry": "MX",
  },
  "telephone": salon.phone,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": salon.rating,
    "bestRating": "5",
    "worstRating": "1",
  },
};
---

<PageLayout
  title={title}
  description={description}
  pageType="page"
  breadcrumbs={[
    { name: "Inicio", href: "/" },
    { name: "Directorio", href: "/directorio/" },
    { name: "CDMX", href: "/directorio/cdmx/" },
    { name: salon.name },
  ]}
>

  <script type="application/ld+json" set:html={JSON.stringify(salonSchema)} />

  <div class="container">
    <nav class="breadcrumbs" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/directorio/">Directorio</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/directorio/cdmx/">CDMX</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{salon.name}</span>
    </nav>
  </div>

  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;">
    <div class="container">
      <div class="hero__grid">
        <div>
          <span class="hero__badge">⭐ {salon.rating} en Google Maps · {salon.zone}</span>
          <h1 class="hero__title">{salon.name} — Salón de Fiestas <span class="highlight">Infantiles</span></h1>
          <p class="hero__desc">
            Salón de fiestas infantiles en {salon.zone}, CDMX. {salon.highlight}. Capacidad para {salon.capacity}. Paquetes todo incluido con juegos, alimentos, decoración y más.
          </p>
          <div class="hero__ctas">
            <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-lg">Llamar al salón</a>
            <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`}
               class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
              WhatsApp del salón
            </a>
          </div>
        </div>
        <div class="hero__copy">
          <p class="hero__copy-text">
            <strong>{salon.name}</strong> se ha consolidado como uno de los salones de fiestas infantiles con mejor reputación en {salon.zone}. Con una calificación de <strong>{salon.rating} estrellas en Google Maps</strong>, destaca por sus amplias instalaciones, su compromiso con la seguridad de los niños y la calidad de sus paquetes todo incluido que facilitan la organización de cualquier celebración.
          </p>
          <p class="hero__copy-text">
            ¿Ya reservaste tu fecha? Lleva la diversión al siguiente nivel con un inflable de <strong>BRINCOLINS</strong>. Entregamos, instalamos y recogemos directamente en {salon.name} sin costo adicional. Nuestro catálogo incluye castillos, toboganes, pistas de obstáculos y más.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="page-layout">

        <div class="page-layout__main">

          <div class="salon-ficha">
            <h2 class="salon-ficha__title">Ficha completa de {salon.name}</h2>
            <p class="salon-ficha__subtitle">{salon.highlight} — Toda la información que necesitas para reservar tu evento</p>

            <div class="salon-ficha__grid">
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">📍</div>
                <div>
                  <strong>Dirección</strong>
                  <p>{salon.address}</p>
                </div>
              </div>
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">📞</div>
                <div>
                  <strong>Teléfono de contacto</strong>
                  <p><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`}>{salon.phone}</a></p>
                </div>
              </div>
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">🕐</div>
                <div>
                  <strong>Horario de atención</strong>
                  <p>{salon.horario}</p>
                </div>
              </div>
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">👥</div>
                <div>
                  <strong>Capacidad</strong>
                  <p>{salon.capacity}</p>
                </div>
              </div>
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">⭐</div>
                <div>
                  <strong>Calificación en Google</strong>
                  <p>{salon.rating} / 5.0 — basada en reseñas verificadas</p>
                </div>
              </div>
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">🎉</div>
                <div>
                  <strong>Tipo de eventos</strong>
                  <p>Cumpleaños, bautizos, primeras comuniones, graduaciones, baby showers</p>
                </div>
              </div>
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">🅿️</div>
                <div>
                  <strong>Estacionamiento</strong>
                  <p>Sí — estacionamiento propio incluido para invitados</p>
                </div>
              </div>
              <div class="salon-ficha__item">
                <div class="salon-ficha__icon">🎈</div>
                <div>
                  <strong>Inflables externos</strong>
                  <p>Permitidos — BRINCOLINS entrega e instala en el salón</p>
                </div>
              </div>
            </div>

            <div class="salon-ficha__actions">
              <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary">📞 Llamar ahora</a>
              <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`}
                 class="btn btn-wa" target="_blank" rel="noopener noreferrer">WhatsApp</a>
              <a href={`https://www.google.com/maps/search/${salon.gmapsQuery}`}
                 class="btn btn-outline" target="_blank" rel="noopener noreferrer">📍 Ver en Google Maps</a>
            </div>
          </div>

          <div class="salon-editorial">
            <h2>¿Por qué elegir {salon.name} para tu fiesta infantil?</h2>
            <p>Enclavado en la emblemática colonia Clavería de <strong>Azcapotzalco</strong>, {salon.name} ofrece una experiencia completamente distinta a los salones tradicionales. Su concepto gira alrededor de un <strong>laberinto temático</strong> con múltiples estaciones de juego que los niños recorren como si fueran exploradores, convirtiendo cada fiesta en una verdadera aventura que recordarán por mucho tiempo.</p>
            <p>La colonia Clavería es conocida por su ambiente familiar y sus calles arboladas, y {salon.name} aprovecha esa energía para crear un espacio seguro y divertido. Además de los juegos, el salón cuenta con una <strong>zona para adultos</strong> cómoda y separada, donde los padres pueden relajarse con bebidas y botanas mientras los pequeños disfrutan. Los <strong>paquetes accesibles</strong> permiten que familias de cualquier presupuesto puedan celebrar aquí.</p>
            <p>Con <strong>{salon.rating} estrellas en Google Maps</strong>, los clientes de {salon.name} destacan la <strong>originalidad del concepto</strong>, la <strong>limpieza impecable</strong> del lugar y el <strong>trato amable del personal</strong>. Es el favorito de Azcapotzalco y una opción que cada vez más familias del norte de la ciudad eligen para sus celebraciones infantiles.</p>

            <h3>Servicios incluidos en los paquetes</h3>
            <p>Los paquetes de {salon.name} están diseñados para ofrecer una experiencia completa. Dependiendo del paquete seleccionado, puedes esperar los siguientes servicios:</p>
          </div>

          <div class="grid-3" style="margin-bottom:2rem;">
            {salon.features.map(f => (
              <article class="product-card">
                <div class="product-card__image" style={`background: linear-gradient(135deg, ${f.gradient});`}>
                  <span>{f.emoji}</span>
                </div>
                <div class="product-card__body">
                  <h3 class="product-card__name">{f.name}</h3>
                  <p class="product-card__desc">{f.desc}</p>
                </div>
              </article>
            ))}
          </div>

          <div class="salon-editorial">
            <h3>¿Cómo llegar a {salon.name}?</h3>
            <p>{salon.name} se ubica en <strong>{salon.address}</strong>. La colonia Clavería cuenta con excelente conectividad vial, con acceso rápido desde Avenida Cuitláhuac y Calzada Camarones.</p>
            <p>En transporte público, la estación más cercana del Metro es Cuitláhuac (Línea 2), a pocas cuadras del salón. También puedes llegar en Metrobús por la línea que recorre Avenida de los Maestros. Si vienes en auto, el salón cuenta con <strong>estacionamiento</strong> para los invitados.</p>
          </div>

          <div class="dir-tip" style="margin-top:2rem;">
            <div class="dir-tip__icon">🎈</div>
            <div class="dir-tip__content">
              <p class="dir-tip__title">¡Complementa tu fiesta en {salon.name} con un inflable!</p>
              <p class="dir-tip__text"><strong>BRINCOLINS</strong> entrega, instala y recoge el inflable directamente en el salón. Solo necesitas confirmar que haya espacio disponible al momento de reservar.</p>
            </div>
            <a href="/cotizar/" class="btn btn-primary">Cotizar inflable</a>
          </div>

        </div>

        <aside class="page-layout__sidebar">

          <div class="sidebar-card sidebar-card--cta">
            <p class="sidebar-card__title">¿Te interesa este salón?</p>
            <p class="sidebar-card__text">Contacta directamente a {salon.name} para consultar disponibilidad y precios.</p>
            <a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-sm" style="width:100%; justify-content:center; margin-bottom:0.5rem;">📞 {salon.phone}</a>
            <a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`}
               class="btn btn-wa btn-sm" target="_blank" rel="noopener noreferrer" style="width:100%; justify-content:center;">WhatsApp</a>
          </div>

          <div class="sidebar-card">
            <p class="sidebar-card__title">📰 Artículos de interés</p>
            <div class="sidebar-card__list">
              {articulos.map(a => (
                <a href={`/blog/${a.slug}/`} class="sidebar-card__list-item sidebar-card__list-item--link">
                  <p class="sidebar-card__list-name">{a.title}</p>
                  <span class="sidebar-card__arrow">→</span>
                </a>
              ))}
            </div>
            <a href="/blog/" class="sidebar-card__link">Ver todos los artículos →</a>
          </div>

          <div class="sidebar-card">
            <p class="sidebar-card__title">🔗 Explora BRINCOLINS</p>
            <div class="sidebar-card__list">
              <a href="/directorio/cdmx/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">📍 16 salones en CDMX</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/directorio/edomex/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">🏘️ Salones en Edomex</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/inflables/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">🎈 Catálogo de inflables</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/cobertura/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">🗺️ Zona de cobertura</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
              <a href="/cotizar/" class="sidebar-card__list-item sidebar-card__list-item--link">
                <p class="sidebar-card__list-name">💬 Solicitar cotización</p>
                <span class="sidebar-card__arrow">→</span>
              </a>
            </div>
          </div>

          <div class="sidebar-card sidebar-card--highlight">
            <p class="sidebar-card__title">¿Ya tienes tu salón?</p>
            <p class="sidebar-card__text">Agrega un inflable a tu fiesta en {salon.name}. Entrega e instalación incluida.</p>
            <a href="/cotizar/" class="btn btn-primary btn-sm" style="width:100%; justify-content:center;">Cotizar inflable</a>
          </div>

        </aside>

      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="📍 Más salones en CDMX"
        title="Otros salones que te pueden interesar"
        subtitle="Explora más opciones de salones de fiestas infantiles verificados en la Ciudad de México."
        copy1="Si buscas alternativas a Laberinto de Aventuras, aquí encontrarás otros salones con excelente calificación en Google Maps. Todos permiten inflables externos y están dentro de nuestra zona de cobertura."
        copy2="¿Ya elegiste tu salón? No olvides complementar la fiesta con un inflable de <strong>BRINCOLINS</strong>. Entrega e instalación incluida en cualquier salón de CDMX."
      />
      <div class="grid-4">
        {salonesRelacionados.map(s => <VenueCard {...s} />)}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        badge="🎈 Inflables para tu fiesta"
        title="Lleva un inflable a tu fiesta"
        subtitle={`Complementa tu evento en ${salon.name} con uno de nuestros inflables. Entrega e instalación incluida.`}
        copy1="Todos nuestros inflables incluyen entrega, instalación, limpieza y seguro. Solo necesitas una toma de corriente y espacio suficiente en el salón. Confirma la disponibilidad de espacio al reservar tu salón."
        copy2="Desde castillos clásicos hasta toboganes acuáticos y pistas de obstáculos, tenemos opciones para todas las edades y presupuestos. <strong>Cotiza hoy y asegura tu fecha.</strong>"
      />
      <div class="grid-4">
        {inflablesPopulares.map(p => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        badge="❓ Preguntas frecuentes"
        title={`Sobre ${salon.name}`}
        subtitle="Resolvemos las dudas más comunes sobre este salón de fiestas infantiles."
        copy1="Antes de reservar, es importante que tengas toda la información necesaria. Aquí respondemos las preguntas que más nos hacen sobre este salón y cómo complementar tu evento con un inflable de BRINCOLINS."
        copy2="Si tienes alguna duda adicional, contacta directamente al salón por teléfono o WhatsApp. También puedes escribirnos a nosotros para cotizar un inflable para tu fiesta."
      />
      <div class="faq" style="max-width:800px; margin:0 auto;">
        <div class="faq__item">
          <button class="faq__question" aria-expanded="false">
            <span>¿Puedo llevar un inflable de BRINCOLINS a {salon.name}?</span>
            <span class="faq__icon">+</span>
          </button>
          <div class="faq__answer">
            <p>Sí, {salon.name} permite inflables externos. BRINCOLINS se encarga de la entrega, instalación, supervisión durante el evento y recolección al finalizar. Solo necesitamos que el salón cuente con espacio suficiente y una toma de corriente cercana. Te recomendamos confirmar con el salón al momento de reservar.</p>
          </div>
        </div>
        <div class="faq__item">
          <button class="faq__question" aria-expanded="false">
            <span>¿Cuánto cuesta rentar {salon.name}?</span>
            <span class="faq__icon">+</span>
          </button>
          <div class="faq__answer">
            <p>Los precios varían según el paquete elegido, número de invitados y día de la semana. Te recomendamos contactar directamente al salón al {salon.phone} para obtener la cotización más actualizada. Los paquetes generalmente incluyen decoración, alimentos para niños y adultos, pastel, piñata y acceso a todas las áreas de juego.</p>
          </div>
        </div>
        <div class="faq__item">
          <button class="faq__question" aria-expanded="false">
            <span>¿Qué tipo de eventos puedo celebrar en {salon.name}?</span>
            <span class="faq__icon">+</span>
          </button>
          <div class="faq__answer">
            <p>{salon.name} está especializado en fiestas infantiles, pero también es ideal para bautizos, primeras comuniones, graduaciones de kínder o primaria, baby showers y reuniones familiares. Su versatilidad y capacidad de {salon.capacity} lo hacen adaptable a distintos tipos de celebraciones.</p>
          </div>
        </div>
        <div class="faq__item">
          <button class="faq__question" aria-expanded="false">
            <span>¿Con cuánta anticipación debo reservar?</span>
            <span class="faq__icon">+</span>
          </button>
          <div class="faq__answer">
            <p>Te recomendamos reservar con al menos 2 a 4 semanas de anticipación, especialmente para fines de semana y temporada alta (diciembre, abril y mayo). En días entre semana hay mayor disponibilidad y algunos salones ofrecen descuentos especiales.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner
    title={`¿Te gustó ${salon.name}? ¡Agrega un inflable!`}
    subtitle="Reserva tu inflable para complementar la fiesta. Entrega e instalación incluida en el salón que elijas."
    btnText="Cotizar inflable"
    btnHref="/cotizar/"
    btnSecondaryText="Ver catálogo de inflables"
    btnSecondaryHref="/inflables/"
    variant="vibrant"
  />

</PageLayout>

<style>
  /* ── Page Layout: Main + Sidebar ── */
  .page-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
