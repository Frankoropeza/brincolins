---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CtaBanner from "@/components/CtaBanner.astro";
import VenueCard from "@/components/VenueCard.astro";
import ProductCard from "@/components/ProductCard.astro";

const title = "Salón de eventos Carito — Salón de Fiestas Infantiles en Coyoacán | BRINCOLINS";
const description = "Salón de eventos Carito: salón de fiestas infantiles en Coyoacán, CDMX. ⭐ 4.5 en Google Maps. Capacidad 50–100 personas. Paquetes todo incluido. Teléfono: 55 2382 4005.";

const salon = { name: "Salón de eventos Carito", zone: "Coyoacán", address: "Tepocatl 51, Pedregal de Santo Domingo, Coyoacán, 04369 CDMX", capacity: "50–100 personas", phone: "55 2382 4005", rating: "4.5", highlight: "Económico y bien equipado en Coyoacán", gradient: "#F06292, #CE93D8", features: [
  { emoji: "💰", name: "Precios accesibles", desc: "Paquetes con la mejor relación calidad-precio de Coyoacán, accesibles para todos los presupuestos familiares.", gradient: "#F06292, #CE93D8" },
  { emoji: "🎨", name: "Decoración incluida", desc: "Decoración completa incluida en todos los paquetes con opciones de personalización según la temática deseada.", gradient: "#E91E8C, #FF3D00" },
  { emoji: "🔊", name: "Sonido profesional", desc: "Sistema de sonido de alta calidad con bocinas, micrófono y la posibilidad de conectar tu propia música.", gradient: "#1565C0, #0288D1" },
  { emoji: "🎂", name: "Pastel incluido", desc: "Pastel de cumpleaños incluido en los paquetes principales, con opción de personalizar el diseño y sabor.", gradient: "#7C3AED, #9C27B0" },
  { emoji: "🎮", name: "Área de juegos", desc: "Zona de juegos infantiles con brincolines y actividades recreativas supervisadas para diferentes edades.", gradient: "#00C853, #2E7D32" },
  { emoji: "🍽️", name: "Alimentos variados", desc: "Opciones de menú para niños y adultos con platillos frescos preparados el mismo día del evento.", gradient: "#FF6F00, #FFD600" },
], horario: "Martes a Domingo · 10:00 – 20:00", gmapsQuery: "Salon+de+eventos+Carito+Coyoacan+CDMX" };

const salonesRelacionados = [
  { slug: "castillo-magico-ari-sandy", name: "Castillo Mágico Ari Sandy", zone: "Coyoacán", rating: "4.6", capacity: "50–120 personas", phone: "55 2107 0282", gradient: "linear-gradient(135deg, #0288D1, #7C3AED)", label: "🏰", features: ["Toboganes gigantes", "Alberca de pelotas", "Laberintos", "Shows infantiles"], highlight: "Clásico de Coyoacán con juegos únicos" },
  { slug: "salon-wondertown", name: "Salón Wondertown", zone: "Tlalpan", rating: "4.6", capacity: "40–100 personas", phone: "55 3334 5442", gradient: "linear-gradient(135deg, #9C27B0, #E91E8C)", label: "🌟", features: ["Temáticas personalizadas", "Juegos modernos", "Snack bar", "Música incluida"], highlight: "Temáticas personalizadas en Héroes de Padierna" },
  { slug: "salon-machinkuepa", name: "Salón Machinkuepa", zone: "Tlalpan", rating: "4.7", capacity: "50–120 personas", phone: "55 8007 0580", gradient: "linear-gradient(135deg, #7C3AED, #9C27B0)", label: "⭐", features: ["Juegos extremos", "Área de bebés", "Decoración incluida", "Salón amplio"], highlight: "Top 1 en Tlalpan por calificación" },
  { slug: "jardin-de-eventos-chris", name: "Jardín de Eventos Chris", zone: "Xochimilco", rating: "4.5", capacity: "60–130 personas", phone: "55 5675 1380", gradient: "linear-gradient(135deg, #00C853, #0288D1)", label: "🌿", features: ["Jardín amplio", "Salón techado", "Taquiza disponible", "Estacionamiento"], highlight: "El mejor calificado de Xochimilco" },
];

const inflablesPopulares = [
  { slug: "mini-castillo", emoji: "🏰", name: "Mini Castillo", description: "El clásico castillo inflable perfecto para fiestas infantiles.", price: "$800", size: "4×4m", ages: "3-8 años", category: "Castillos", categoryColor: "castillo", gradient: "#FF3D00, #ff6d3f" },
  { slug: "castillo-princesas", emoji: "👸", name: "Castillo de Princesas", description: "Mágico castillo temático de princesas con torres y decoración especial.", price: "$900", size: "4×4m", ages: "3-8 años", category: "Princesas", categoryColor: "princesas", gradient: "#E91E8C, #7C3AED" },
  { slug: "barco-pirata", emoji: "🚢", name: "Barco Pirata", description: "Aventura en altamar con tobogán y cañón de espuma.", price: "$950", size: "5×4m", ages: "4-10 años", category: "Aventura", categoryColor: "pirata", gradient: "#1565C0, #0D47A1" },
  { slug: "tobogan-acuatico", emoji: "💦", name: "Tobogán Acuático", description: "Diversión refrescante con tobogán y chapoteadero incluido.", price: "$1,200", size: "6×4m", ages: "5-12 años", category: "Acuáticos", categoryColor: "acuatico", gradient: "#0288D1, #01579B" },
];

const articulos = [
  { slug: "como-elegir-inflable-fiesta-infantil", title: "Cómo elegir el inflable perfecto para tu fiesta" },
  { slug: "ideas-fiesta-infantil-cdmx", title: "10 ideas para organizar una fiesta infantil en CDMX" },
  { slug: "consejos-rentar-inflable-primera-vez", title: "Primera vez rentando un inflable: lo que nadie te dice" },
];

const salonSchema = { "@context": "https://schema.org", "@type": "LocalBusiness", "name": salon.name, "description": description, "address": { "@type": "PostalAddress", "streetAddress": salon.address, "addressLocality": salon.zone, "addressRegion": "CDMX", "addressCountry": "MX" }, "telephone": salon.phone, "aggregateRating": { "@type": "AggregateRating", "ratingValue": salon.rating, "bestRating": "5", "worstRating": "1" } };
---

<PageLayout title={title} description={description} pageType="page" breadcrumbs={[{ name: "Inicio", href: "/" }, { name: "Directorio", href: "/directorio/" }, { name: "CDMX", href: "/directorio/cdmx/" }, { name: salon.name }]}>
  <script type="application/ld+json" set:html={JSON.stringify(salonSchema)} />
  <div class="container"><nav class="breadcrumbs" aria-label="Ruta de navegación"><a href="/">Inicio</a><span class="breadcrumbs__sep">/</span><a href="/directorio/">Directorio</a><span class="breadcrumbs__sep">/</span><a href="/directorio/cdmx/">CDMX</a><span class="breadcrumbs__sep">/</span><span>{salon.name}</span></nav></div>

  <section class="hero" style="padding:clamp(3rem,6vw,5rem) 0;"><div class="container"><div class="hero__grid"><div><span class="hero__badge">⭐ {salon.rating} en Google Maps · {salon.zone}</span><h1 class="hero__title">{salon.name} — Salón de Fiestas <span class="highlight">Infantiles</span></h1><p class="hero__desc">Salón de fiestas infantiles en {salon.zone}, CDMX. {salon.highlight}. Capacidad para {salon.capacity}. Paquetes todo incluido con juegos, alimentos, decoración y más.</p><div class="hero__ctas"><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-lg">Llamar al salón</a><a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`} class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">WhatsApp del salón</a></div></div><div class="hero__copy"><p class="hero__copy-text"><strong>{salon.name}</strong> se ha consolidado como uno de los salones de fiestas infantiles con mejor reputación en {salon.zone}. Con una calificación de <strong>{salon.rating} estrellas en Google Maps</strong>, destaca por sus amplias instalaciones, su compromiso con la seguridad de los niños y la calidad de sus paquetes todo incluido que facilitan la organización de cualquier celebración.</p><p class="hero__copy-text">¿Ya reservaste tu fecha? Lleva la diversión al siguiente nivel con un inflable de <strong>BRINCOLINS</strong>. Entregamos, instalamos y recogemos directamente en {salon.name} sin costo adicional. Nuestro catálogo incluye castillos, toboganes, pistas de obstáculos y más.</p></div></div></div></section>

  <section class="section section--alt"><div class="container"><div class="page-layout"><div class="page-layout__main">
    <div class="salon-ficha"><h2 class="salon-ficha__title">Ficha completa de {salon.name}</h2><p class="salon-ficha__subtitle">{salon.highlight} — Toda la información que necesitas para reservar tu evento</p><div class="salon-ficha__grid"><div class="salon-ficha__item"><div class="salon-ficha__icon">📍</div><div><strong>Dirección</strong><p>{salon.address}</p></div></div><div class="salon-ficha__item"><div class="salon-ficha__icon">📞</div><div><strong>Teléfono de contacto</strong><p><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`}>{salon.phone}</a></p></div></div><div class="salon-ficha__item"><div class="salon-ficha__icon">🕐</div><div><strong>Horario de atención</strong><p>{salon.horario}</p></div></div><div class="salon-ficha__item"><div class="salon-ficha__icon">👥</div><div><strong>Capacidad</strong><p>{salon.capacity}</p></div></div><div class="salon-ficha__item"><div class="salon-ficha__icon">⭐</div><div><strong>Calificación en Google</strong><p>{salon.rating} / 5.0 — basada en reseñas verificadas</p></div></div><div class="salon-ficha__item"><div class="salon-ficha__icon">🎉</div><div><strong>Tipo de eventos</strong><p>Cumpleaños, bautizos, primeras comuniones, graduaciones, baby showers</p></div></div><div class="salon-ficha__item"><div class="salon-ficha__icon">🅿️</div><div><strong>Estacionamiento</strong><p>Sí — estacionamiento propio incluido para invitados</p></div></div><div class="salon-ficha__item"><div class="salon-ficha__icon">🎈</div><div><strong>Inflables externos</strong><p>Permitidos — BRINCOLINS entrega e instala en el salón</p></div></div></div><div class="salon-ficha__actions"><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary">📞 Llamar ahora</a><a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`} class="btn btn-wa" target="_blank" rel="noopener noreferrer">WhatsApp</a><a href={`https://www.google.com/maps/search/${salon.gmapsQuery}`} class="btn btn-outline" target="_blank" rel="noopener noreferrer">📍 Ver en Google Maps</a></div></div>

    <div class="salon-editorial">
      <h2>¿Por qué elegir {salon.name} para tu fiesta infantil?</h2>
      <p>En el vibrante Pedregal de Santo Domingo, una de las colonias más grandes y dinámicas de <strong>Coyoacán</strong>, {salon.name} se ha ganado su lugar como la opción más <strong>accesible y bien equipada</strong> de la zona. Su filosofía es clara: que ninguna familia se quede sin celebrar por cuestiones de presupuesto. Los paquetes están diseñados para incluir todo lo necesario a precios que realmente compiten.</p>
      <p>A pesar de sus <strong>precios accesibles</strong>, el salón no escatima en calidad. La <strong>decoración</strong> está incluida en todos los paquetes y puede personalizarse según la temática elegida. El <strong>pastel de cumpleaños</strong> también viene incluido, al igual que el <strong>sonido profesional</strong> con equipo de alta fidelidad. El área de juegos infantiles es segura y entretenida, con brincolines y actividades supervisadas.</p>
      <p>Con <strong>{salon.rating} estrellas en Google Maps</strong>, las familias que han celebrado aquí resaltan el <strong>excelente valor por el precio pagado</strong>, la <strong>amabilidad del personal</strong> y la <strong>buena organización</strong> de cada evento. Es la prueba de que no se necesita un gran presupuesto para tener una fiesta infantil memorable en una de las mejores alcaldías de CDMX.</p>

      <h3>Servicios incluidos en los paquetes</h3>
      <p>Los paquetes de {salon.name} están diseñados para ofrecer una experiencia completa. Dependiendo del paquete seleccionado, puedes esperar los siguientes servicios:</p>
    </div>

    <div class="grid-3" style="margin-bottom:2rem;">{salon.features.map(f => (<article class="product-card"><div class="product-card__image" style={`background: linear-gradient(135deg, ${f.gradient});`}><span>{f.emoji}</span></div><div class="product-card__body"><h3 class="product-card__name">{f.name}</h3><p class="product-card__desc">{f.desc}</p></div></article>))}</div>

    <div class="salon-editorial">
      <h3>¿Cómo llegar a {salon.name}?</h3>
      <p>{salon.name} se ubica en <strong>{salon.address}</strong>. El Pedregal de Santo Domingo está en el sur de Coyoacán, con acceso desde Avenida Aztecas, Canal de Miramontes y la Calzada de Tlalpan.</p>
      <p>En Metro, la estación más cercana es Copilco (Línea 3) o Universidad, desde donde puedes tomar un taxi o transporte de aplicación. Las rutas de microbús que circulan por Aztecas también pasan cerca del salón. Cuenta con <strong>estacionamiento</strong> para los invitados.</p>
    </div>

    <div class="dir-tip" style="margin-top:2rem;"><div class="dir-tip__icon">🎈</div><div class="dir-tip__content"><p class="dir-tip__title">¡Complementa tu fiesta en {salon.name} con un inflable!</p><p class="dir-tip__text"><strong>BRINCOLINS</strong> entrega, instala y recoge el inflable directamente en el salón. Solo necesitas confirmar que haya espacio disponible al momento de reservar.</p></div><a href="/cotizar/" class="btn btn-primary">Cotizar inflable</a></div>
  </div>

  <aside class="page-layout__sidebar">
    <div class="sidebar-card sidebar-card--cta"><p class="sidebar-card__title">¿Te interesa este salón?</p><p class="sidebar-card__text">Contacta directamente a {salon.name} para consultar disponibilidad y precios.</p><a href={`tel:+52${salon.phone.replace(/\s/g, "")}`} class="btn btn-primary btn-sm" style="width:100%; justify-content:center; margin-bottom:0.5rem;">📞 {salon.phone}</a><a href={`https://wa.me/52${salon.phone.replace(/\s/g, "")}?text=${encodeURIComponent(`Hola, me interesa información sobre su salón ${salon.name} para una fiesta infantil.`)}`} class="btn btn-wa btn-sm" target="_blank" rel="noopener noreferrer" style="width:100%; justify-content:center;">WhatsApp</a></div>
    <div class="sidebar-card"><p class="sidebar-card__title">📰 Artículos de interés</p><div class="sidebar-card__list">{articulos.map(a => (<a href={`/blog/${a.slug}/`} class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">{a.title}</p><span class="sidebar-card__arrow">→</span></a>))}</div><a href="/blog/" class="sidebar-card__link">Ver todos los artículos →</a></div>
    <div class="sidebar-card"><p class="sidebar-card__title">🔗 Explora BRINCOLINS</p><div class="sidebar-card__list"><a href="/directorio/cdmx/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">📍 16 salones en CDMX</p><span class="sidebar-card__arrow">→</span></a><a href="/directorio/edomex/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">🏘️ Salones en Edomex</p><span class="sidebar-card__arrow">→</span></a><a href="/inflables/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">🎈 Catálogo de inflables</p><span class="sidebar-card__arrow">→</span></a><a href="/cobertura/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">🗺️ Zona de cobertura</p><span class="sidebar-card__arrow">→</span></a><a href="/cotizar/" class="sidebar-card__list-item sidebar-card__list-item--link"><p class="sidebar-card__list-name">💬 Solicitar cotización</p><span class="sidebar-card__arrow">→</span></a></div></div>
    <div class="sidebar-card sidebar-card--highlight"><p class="sidebar-card__title">¿Ya tienes tu salón?</p><p class="sidebar-card__text">Agrega un inflable a tu fiesta en {salon.name}. Entrega e instalación incluida.</p><a href="/cotizar/" class="btn btn-primary btn-sm" style="width:100%; justify-content:center;">Cotizar inflable</a></div>
  </aside></div></div></section>

  <section class="section"><div class="container"><SectionHeader badge="📍 Más salones en CDMX" title="Otros salones que te pueden interesar" subtitle="Explora más opciones de salones de fiestas infantiles verificados en la Ciudad de México." copy1="Si buscas alternativas a Salón de eventos Carito, aquí encontrarás otros salones con excelente calificación en Google Maps. Todos permiten inflables externos y están dentro de nuestra zona de cobertura." copy2="¿Ya elegiste tu salón? No olvides complementar la fiesta con un inflable de <strong>BRINCOLINS</strong>. Entrega e instalación incluida en cualquier salón de CDMX." /><div class="grid-4">{salonesRelacionados.map(s => <VenueCard {...s} />)}</div></div></section>
  <section class="section section--alt"><div class="container"><SectionHeader badge="🎈 Inflables para tu fiesta" title="Lleva un inflable a tu fiesta" subtitle={`Complementa tu evento en ${salon.name} con uno de nuestros inflables. Entrega e instalación incluida.`} copy1="Todos nuestros inflables incluyen entrega, instalación, limpieza y seguro. Solo necesitas una toma de corriente y espacio suficiente en el salón. Confirma la disponibilidad de espacio al reservar tu salón." copy2="Desde castillos clásicos hasta toboganes acuáticos y pistas de obstáculos, tenemos opciones para todas las edades y presupuestos. <strong>Cotiza hoy y asegura tu fecha.</strong>" /><div class="grid-4">{inflablesPopulares.map(p => <ProductCard {...p} />)}</div></div></section>
  <section class="section"><div class="container"><SectionHeader badge="❓ Preguntas frecuentes" title={`Sobre ${salon.name}`} subtitle="Resolvemos las dudas más comunes sobre este salón de fiestas infantiles." copy1="Antes de reservar, es importante que tengas toda la información necesaria. Aquí respondemos las preguntas que más nos hacen sobre este salón y cómo complementar tu evento con un inflable de BRINCOLINS." copy2="Si tienes alguna duda adicional, contacta directamente al salón por teléfono o WhatsApp. También puedes escribirnos a nosotros para cotizar un inflable para tu fiesta." /><div class="faq" style="max-width:800px; margin:0 auto;"><div class="faq__item"><button class="faq__question" aria-expanded="false"><span>¿Puedo llevar un inflable de BRINCOLINS a {salon.name}?</span><span class="faq__icon">+</span></button><div class="faq__answer"><p>Sí, {salon.name} permite inflables externos. BRINCOLINS se encarga de la entrega, instalación, supervisión durante el evento y recolección al finalizar. Solo necesitamos que el salón cuente con espacio suficiente y una toma de corriente cercana. Te recomendamos confirmar con el salón al momento de reservar.</p></div></div><div class="faq__item"><button class="faq__question" aria-expanded="false"><span>¿Cuánto cuesta rentar {salon.name}?</span><span class="faq__icon">+</span></button><div class="faq__answer"><p>Los precios varían según el paquete elegido, número de invitados y día de la semana. Te recomendamos contactar directamente al salón al {salon.phone} para obtener la cotización más actualizada. Los paquetes generalmente incluyen decoración, alimentos para niños y adultos, pastel, piñata y acceso a todas las áreas de juego.</p></div></div><div class="faq__item"><button class="faq__question" aria-expanded="false"><span>¿Qué tipo de eventos puedo celebrar en {salon.name}?</span><span class="faq__icon">+</span></button><div class="faq__answer"><p>{salon.name} está especializado en fiestas infantiles, pero también es ideal para bautizos, primeras comuniones, graduaciones de kínder o primaria, baby showers y reuniones familiares. Su versatilidad y capacidad de {salon.capacity} lo hacen adaptable a distintos tipos de celebraciones.</p></div></div><div class="faq__item"><button class="faq__question" aria-expanded="false"><span>¿Con cuánta anticipación debo reservar?</span><span class="faq__icon">+</span></button><div class="faq__answer"><p>Te recomendamos reservar con al menos 2 a 4 semanas de anticipación, especialmente para fines de semana y temporada alta (diciembre, abril y mayo). En días entre semana hay mayor disponibilidad y algunos salones ofrecen descuentos especiales.</p></div></div></div></div></section>

  <CtaBanner title={`¿Te gustó ${salon.name}? ¡Agrega un inflable!`} subtitle="Reserva tu inflable para complementar la fiesta. Entrega e instalación incluida en el salón que elijas." btnText="Cotizar inflable" btnHref="/cotizar/" btnSecondaryText="Ver catálogo de inflables" btnSecondaryHref="/inflables/" variant="vibrant" />
</PageLayout>

<style>
  .page-layout { display: grid; grid-template-columns: 1fr 340px; gap: 2.5rem; align-items: start; } @media (max-width: 1024px) { .page-layout { grid-template-columns: 1fr; } } .salon-ficha { background: #fff; border-radius: var(--r-card); padding: 2rem; box-shadow: var(--shadow-sm); border: 1px solid var(--c-border); margin-bottom: 2rem; } .salon-ficha__title { font-family: var(--font-head); font-weight: 900; font-size: 1.3rem; margin: 0 0 0.25rem; } .salon-ficha__subtitle { font-size: 0.9rem; color: var(--c-text-muted); margin: 0 0 1.5rem; line-height: 1.6; } .salon-ficha__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.5rem; } .salon-ficha__item { display: flex; gap: 0.75rem; align-items: flex-start; } .salon-ficha__icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; } .salon-ficha__item strong { display: block; font-family: var(--font-head); font-weight: 800; font-size: 0.8rem; color: var(--c-text); margin-bottom: 0.15rem; } .salon-ficha__item p { font-size: 0.85rem; color: var(--c-text-muted); line-height: 1.5; margin: 0; } .salon-ficha__item a { color: var(--c-primary); text-decoration: none; font-weight: 600; } .salon-ficha__item a:hover { text-decoration: underline; } .salon-ficha__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; } @media (max-width: 640px) { .salon-ficha__grid { grid-template-columns: 1fr; } .salon-ficha__actions { flex-direction: column; } .salon-ficha__actions .btn { width: 100%; justify-content: center; text-align: center; } } .salon-editorial { margin-bottom: 2rem; } .salon-editorial h2 { font-family: var(--font-head); font-weight: 900; font-size: 1.3rem; margin: 0 0 1rem; } .salon-editorial h3 { font-family: var(--font-head); font-weight: 800; font-size: 1.1rem; margin: 1.5rem 0 0.75rem; } .salon-editorial p { font-size: 0.95rem; color: var(--c-text-muted); line-height: 1.8; margin: 0 0 1rem; } .salon-editorial strong { color: var(--c-text); } .sidebar-card { background: #fff; borde