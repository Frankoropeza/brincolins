---
const current = Astro.url.pathname;

const links = [
  { label: "Inflables",  href: "/inflables/",  color: "#FF1F8E" },
  { label: "Servicios",  href: "/servicios/",  color: "#FF8C00" },
  { label: "Precios",    href: "/precios/",    color: "#5C35B1" },
  { label: "Cobertura",  href: "/cobertura/",  color: "#D32F2F" },
  { label: "Blog",       href: "/blog/",       color: "#00ACC1" },
  { label: "Nosotros",   href: "/nosotros/",   color: "#2E7D32" },
];
---

<nav class="qnav">
  {links.map(l => {
    const active = current.startsWith(l.href);
    return (
      <a
        href={l.href}
        class="qnav__item"
        style={`background-color:${l.color};`}
        aria-current={active ? "page" : undefined}
      >
        {l.label}
      </a>
    );
  })}
</nav>

<style is:global>
.qnav {
  display: flex;
  width: 100%;
}

.qnav__item {
  flex: 1 1 0%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.25rem 0.5rem;
  color: #fff !important;
  font-family: var(--font-head, sans-serif);
  font-weight: 900;
  font-size: 1.1rem;
  text-decoration: none !important;
  text-align: center;
  white-space: nowrap;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.qnav__item:hover {
  filter: brightness(0.88);
}

.qnav__item[aria-current="page"] {
  filter: brightness(0.80);
  box-shadow: inset 0 -5px 0 rgba(255,255,255,0.5);
}

@media (max-width: 768px) {
  .qnav__item {
    font-size: 0.72rem;
    padding: 1rem 0.25rem;
    letter-spacing: 0;
  }
}
</style>
