---
/**
 * QuickNav — BRINCOLINS
 * ────────────────────────────────────────────────
 * Barra de navegación rápida bajo el hero. Auto-contextual:
 * muestra enlaces distintos según la sección del sitio.
 * Se puede sobreescribir pasando `links`.
 */
import { textOn } from '@/lib/contrast';

interface Link { label: string; href: string; color: string; }
interface Props { links?: Link[]; }

const current = Astro.url.pathname;

const MAIN: Link[] = [
  { label: "Inflables",          href: "/inflables/",            color: "#FF1F8E" },
  { label: "Fiestas Infantiles", href: "/fiestas-infantiles/",   color: "#DF1C86" },
  { label: "Servicios",          href: "/servicios/",            color: "#FF8C00" },
  { label: "Precios",            href: "/precios/",              color: "#5C35B1" },
  { label: "Cobertura",          href: "/cobertura/",            color: "#D32F2F" },
  { label: "Blog",               href: "/blog/",                 color: "#00ACC1" },
  { label: "FAQ",                href: "/preguntas-frecuentes/", color: "#2E7D32" },
];

const SERVICIOS: Link[] = [
  { label: "Inflables",   href: "/servicios/renta-de-inflables/",    color: "#FF3D00" },
  { label: "Paquetes",    href: "/servicios/paquetes-de-fiesta/",    color: "#2E7D32" },
  { label: "Eventos",     href: "/servicios/inflables-para-eventos/", color: "#1565C0" },
  { label: "Mobiliario",  href: "/servicios/mobiliario-para-fiestas/", color: "#5C35B1" },
  { label: "Iluminación", href: "/servicios/iluminacion-eventos/",   color: "#FF8C00" },
  { label: "Cotizar",     href: "/cotizar/",                         color: "#25D366" },
];

const INFLABLES: Link[] = [
  { label: "Dragones",  href: "/inflables/dragones-rojos/",     color: "#D32F2F" },
  { label: "Princesas", href: "/inflables/castillo-princesas/", color: "#DF1C86" },
  { label: "Pirata",    href: "/inflables/barco-pirata/",       color: "#1565C0" },
  { label: "Extremo",   href: "/inflables/extremo/",            color: "#E65100" },
  { label: "Blanco",    href: "/inflables/castillo-blanco/",    color: "#7E57C2" },
  { label: "Catálogo",  href: "/inflables/",                    color: "#FF3D00" },
];

const COBERTURA: Link[] = [
  { label: "Coyoacán",      href: "/cobertura/coyoacan/",      color: "#FF1F8E" },
  { label: "Benito Juárez", href: "/cobertura/benito-juarez/", color: "#FF8C00" },
  { label: "Iztapalapa",    href: "/cobertura/iztapalapa/",    color: "#5C35B1" },
  { label: "Naucalpan",     href: "/cobertura/naucalpan/",     color: "#D32F2F" },
  { label: "Tlalpan",       href: "/cobertura/tlalpan/",       color: "#00ACC1" },
  { label: "Ver zonas",     href: "/cobertura/",               color: "#2E7D32" },
];

let links = Astro.props.links;
if (!links) {
  if (current.startsWith("/servicios")) links = SERVICIOS;
  else if (current.startsWith("/inflables")) links = INFLABLES;
  else if (current.startsWith("/cobertura")) links = COBERTURA;
  else links = MAIN;
}

/* Contraste automático del texto (WCAG 2.1 AA). Antes el texto era blanco
   fijo: sobre #FF8C00 daba 2.33:1, muy por debajo del 4.5:1 que exige AA
   para texto normal (estos items van a 0.68rem, no aplica texto grande).
   textOn() elige blanco u oscuro según la luminancia del fondo, así el
   naranja sigue siendo naranja. Ver src/lib/contrast.ts. */
---

<nav class="qnav" aria-label="Navegación rápida">
  {links.map(l => {
    const active = current === l.href;
    return (
      <a
        href={l.href}
        class="qnav__item"
        style={`--dot:${l.color}`}
        aria-current={active ? "page" : undefined}
      >
        {l.label}
      </a>
    );
  })}
</nav>

<style is:global>
/* QuickNav — rediseño premium (jul 2026): de barra multicolor (arcoíris)
   a fila de chips sobrios sobre barra blanca. Cada chip lleva un punto del
   color de su categoría (identidad) pero el texto es oscuro y legible.
   Envuelve solo (sin carrusel) en cualquier ancho. El color va por la
   variable --dot (inline desde el componente). */
.qnav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.5rem;
  width: 100%;
  padding: 1.1rem var(--container-px, 1rem);
  background: #fff;
  border-bottom: 1px solid var(--c-border, #e2e8f0);
}

.qnav__item {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.62rem 1.15rem;
  border-radius: 50px;
  background: var(--c-bg-alt, #f8fafc);
  border: 1px solid var(--c-border, #e2e8f0);
  color: var(--c-text, #0f172a);
  font-family: var(--font-head, sans-serif);
  font-weight: 700;
  font-size: 0.92rem;
  line-height: 1;
  letter-spacing: 0;
  text-transform: none;
  text-decoration: none !important;
  white-space: nowrap;
  transition: background .15s ease, border-color .15s ease, color .15s ease;
}

.qnav__item::before {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--dot, var(--c-primary, #FF3D00));
  flex-shrink: 0;
}

.qnav__item:hover {
  background: #fff;
  border-color: var(--c-primary, #FF3D00);
  color: var(--c-primary-text, #C82D00);
}

.qnav__item[aria-current="page"] {
  background: var(--c-primary-deep, #D93000);
  border-color: var(--c-primary-deep, #D93000);
  color: #fff;
}
.qnav__item[aria-current="page"]::before { background: #fff; }

@media (max-width: 768px) {
  .qnav { gap: 0.45rem; padding: 0.9rem 1rem; }
  .qnav__item { font-size: 0.82rem; padding: 0.55rem 0.95rem; }
}
@media (max-width: 380px) {
  .qnav__item { font-size: 0.78rem; padding: 0.5rem 0.8rem; }
}
</style>
