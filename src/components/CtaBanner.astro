---
interface Props {
  /** Headline principal */
  title: string;
  /** Texto descriptivo debajo del headline */
  subtitle?: string;
  /** Texto del boton principal */
  btnText?: string;
  /** URL del boton principal */
  btnHref?: string;
  /** Texto del boton secundario */
  btnSecondaryText?: string;
  /** URL del boton secundario */
  btnSecondaryHref?: string;
  /** Variante de color: 'vibrant' | 'warm' | 'cool' | 'festa' */
  variant?: "vibrant" | "warm" | "cool" | "festa";
  /** Mostrar icono de WhatsApp en el boton principal */
  whatsapp?: boolean;
  /** Abrir enlace principal en nueva pestaña */
  external?: boolean;
  /** Compacto (menos padding, ideal entre secciones) */
  compact?: boolean;
}

const {
  title,
  subtitle,
  btnText,
  btnHref,
  btnSecondaryText,
  btnSecondaryHref,
  variant = "vibrant",
  whatsapp = false,
  external = false,
  compact = false,
} = Astro.props;

const rel = external ? "nofollow noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<section class={`cta-banner cta-banner--${variant}${compact ? " cta-banner--compact" : ""}`}>
  <!-- Decorative shapes -->
  <div class="cta-banner__shape cta-banner__shape--1"></div>
  <div class="cta-banner__shape cta-banner__shape--2"></div>
  <div class="cta-banner__shape cta-banner__shape--3"></div>

  <div class="container">
    <div class="cta-banner__content">
      <div class="cta-banner__text">
        <h2 class="cta-banner__title">{title}</h2>
        {subtitle && <p class="cta-banner__subtitle">{subtitle}</p>}
      </div>
      {(btnText || btnSecondaryText) && (
        <div class="cta-banner__actions">
          {btnText && btnHref && (
            <a href={btnHref} class="cta-banner__btn cta-banner__btn--primary" target={target} rel={rel}>
              {whatsapp && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <use href="#i-wa"/>
                </svg>
              )}
              {btnText}
            </a>
          )}
          {btnSecondaryText && btnSecondaryHref && (
            <a href={btnSecondaryHref} class="cta-banner__btn cta-banner__btn--secondary">
              {btnSecondaryText}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* ── CTA Banner Component ── */
  .cta-banner {
    position: relative;
    overflow: hidden;
    padding: 3rem 0;
    isolation: isolate;
  }

  .cta-banner--compact {
    padding: 2rem 0;
  }

  /* ── Variantes de color ── */
  .cta-banner--vibrant {
    background: linear-gradient(135deg, #FF3D00 0%, #FF6D00 25%, #7C3AED 50%, #E91E8C 75%, #FF3D00 100%);
  }

  .cta-banner--warm {
    background: linear-gradient(135deg, #FF3D00 0%, #FF6F00 30%, #FFD600 60%, #FF3D00 100%);
  }

  .cta-banner--cool {
    background: linear-gradient(135deg, #0288D1 0%, #7C3AED 40%, #1565C0 70%, #0288D1 100%);
  }

  .cta-banner--festa {
    background: linear-gradient(135deg, #FF3D00 0%, #E91E8C 20%, #7C3AED 40%, #0288D1 60%, #00C853 80%, #FFD600 100%);
  }

  /* ── Formas decorativas ── */
  .cta-banner__shape {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  .cta-banner__shape--1 {
    width: 200px;
    height: 200px;
    background: rgba(255, 255, 255, 0.08);
    top: -60px;
    right: 5%;
  }

  .cta-banner__shape--2 {
    width: 120px;
    height: 120px;
    background: rgba(255, 255, 255, 0.06);
    bottom: -40px;
    left: 10%;
  }

  .cta-banner__shape--3 {
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.1);
    top: 20%;
    left: 30%;
  }

  /* ── Layout del contenido ── */
  .cta-banner__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  .cta-banner__text {
    flex: 1;
    min-width: 0;
  }

  .cta-banner__title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    color: #fff;
    line-height: 1.2;
    margin: 0;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .cta-banner__subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    color: rgba(255, 255, 255, 0.9);
    margin: 0.5rem 0 0;
    line-height: 1.5;
    max-width: 600px;
  }

  /* ── Botones ── */
  .cta-banner__actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    border-radius: var(--r-btn);
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
    line-height: 1.2;
    cursor: pointer;
  }

  .cta-banner__btn--primary {
    background: #fff;
    color: var(--c-primary);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
  }

  .cta-banner__btn--primary:hover {
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
  }

  .cta-banner__btn--secondary {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .cta-banner__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: #fff;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .cta-banner__content {
      flex-direction: column;
      text-align: center;
    }

    .cta-banner__subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .cta-banner__actions {
      justify-content: center;
      width: 100%;
    }

    .cta-banner__btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
