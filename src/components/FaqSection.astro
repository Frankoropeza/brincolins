---
/**
 * FaqSection — BRINCOLINS
 * 2 columnas: FAQ acordeón izquierda + formulario cotización WA derecha
 */
interface FaqItem {
  question: string;
  answer:   string;
}

interface Props {
  items:      FaqItem[];
  whatsapp?:  string;
}

const {
  items,
  whatsapp = "5547868402",
} = Astro.props;
---

<div class="faq-layout container">

  <!-- ═══ COLUMNA 1: FAQ ═══ -->
  <div class="faq-layout__faqs">
    {items.map((item) => (
      <details class="faq-item">
        <summary class="faq-item__q">{item.question}</summary>
        <div class="faq-item__a"><p>{item.answer}</p></div>
      </details>
    ))}
  </div>

  <!-- ═══ COLUMNA 2: Formulario cotización ═══ -->
  <div class="faq-layout__contact">
    <div class="faq-contact">
      <h3 class="faq-contact__title">Cotiza tu inflable ahora</h3>
      <p class="faq-contact__desc">Completa el formulario y te respondemos por WhatsApp en minutos. Sin compromiso.</p>

      <form id="faq-cotiza-form" class="faq-form">
        <div class="faq-form__group">
          <label class="faq-form__label" for="fc-nombre">Nombre *</label>
          <input class="faq-form__input" type="text" id="fc-nombre" name="nombre" placeholder="Ej. María González" required />
        </div>
        <div class="faq-form__group">
          <label class="faq-form__label" for="fc-tel">Teléfono / WhatsApp *</label>
          <input class="faq-form__input" type="tel" id="fc-tel" name="telefono" placeholder="Ej. 55 1234 5678" required />
        </div>
        <div class="faq-form__group">
          <label class="faq-form__label" for="fc-fecha">Fecha del evento *</label>
          <input class="faq-form__input" type="date" id="fc-fecha" name="fecha" required />
        </div>
        <div class="faq-form__group">
          <label class="faq-form__label" for="fc-inflable">¿Qué inflable te interesa? *</label>
          <select class="faq-form__select" id="fc-inflable" name="inflable" required>
            <option value="">Selecciona un inflable</option>
            <option value="Dragones Rojos">Dragones Rojos — $1,200</option>
            <option value="Castillo de Princesas">Castillo de Princesas — $1,200</option>
            <option value="Mini Jungla">Mini Jungla — $1,200</option>
            <option value="Gusanitos">Gusanitos — $1,200</option>
            <option value="Mini Castillo">Mini Castillo — $800 (bebés)</option>
            <option value="Barco Pirata">Barco Pirata — $2,500</option>
            <option value="Extremo">Extremo — $3,000</option>
            <option value="Castillo Blanco">Castillo Blanco — $2,800</option>
            <option value="No estoy seguro">No estoy seguro / Quiero asesoría</option>
          </select>
        </div>
        <div class="faq-form__group">
          <label class="faq-form__label" for="fc-zona">Colonia / Zona *</label>
          <input class="faq-form__input" type="text" id="fc-zona" name="zona" placeholder="Ej. Coyoacán, CDMX" required />
        </div>
        <button type="submit" class="faq-form__btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Enviar por WhatsApp
        </button>
        <p class="faq-form__note">Se abrirá WhatsApp con tu información. Respondemos en minutos.</p>
      </form>
    </div>
  </div>

</div>

<script is:inline define:vars={{ whatsapp }}>
  document.getElementById('faq-cotiza-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const f = new FormData(e.target);
    let msg = "Hola BRINCOLINS, quiero cotizar un inflable.\n\n";
    msg += "*Nombre:* " + f.get('nombre') + "\n";
    msg += "*Teléfono:* " + f.get('telefono') + "\n";
    msg += "*Fecha:* " + f.get('fecha') + "\n";
    msg += "*Inflable:* " + f.get('inflable') + "\n";
    msg += "*Zona:* " + f.get('zona') + "\n";
    window.open("https://wa.me/" + whatsapp + "?text=" + encodeURIComponent(msg), '_blank');
  });
</script>

<style>
  .faq-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 3rem;
    align-items: start;
  }

  /* ── FAQ Items ── */
  .faq-layout__faqs {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .faq-item {
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .faq-item__q {
    padding: 1.125rem 1.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--c-text);
  }

  .faq-item__q::-webkit-details-marker { display: none; }

  .faq-item__q::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--c-text-muted);
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .faq-item[open] .faq-item__q::after { content: '−'; }
  .faq-item[open] .faq-item__q { background: #fff8f6; }

  .faq-item__a {
    padding: 0 1.5rem 1.125rem;
    color: var(--c-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .faq-item__a p { margin: 0; }

  /* ── Sidebar formulario ── */
  .faq-contact {
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    position: sticky;
    top: calc(var(--header-height, 70px) + 1.5rem);
  }

  .faq-contact__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--c-text);
    margin: 0 0 0.4rem;
  }

  .faq-contact__desc {
    font-size: 0.85rem;
    color: var(--c-text-muted);
    line-height: 1.55;
    margin: 0 0 1.25rem;
  }

  /* ── Formulario ── */
  .faq-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .faq-form__group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .faq-form__label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-text);
  }

  .faq-form__input,
  .faq-form__select {
    width: 100%;
    padding: 0.6rem 0.875rem;
    border: 1px solid var(--c-border);
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--c-text);
    background: #fff;
    font-family: var(--font-body);
  }

  .faq-form__input:focus,
  .faq-form__select:focus {
    outline: none;
    border-color: var(--c-primary);
  }

  .faq-form__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.875rem 1rem;
    background: #25D366;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 700;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: var(--font-head);
    transition: background 0.2s;
    margin-top: 0.25rem;
  }

  .faq-form__btn:hover { background: #128C7E; }

  .faq-form__note {
    font-size: 0.75rem;
    color: var(--c-text-muted);
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .faq-layout {
      grid-template-columns: 1fr 300px;
      gap: 2rem;
    }
  }

  @media (max-width: 860px) {
    .faq-layout {
      grid-template-columns: 1fr;
    }
    .faq-contact {
      position: static;
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
