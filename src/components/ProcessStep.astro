---
export interface Props {
  number: number;
  emoji:  string;
  title:  string;
  desc:   string;
  color:  string;
}

const { number, emoji, title, desc, color } = Astro.props;
---

<div class="process-step">
  <div class="process-step__number" style={`background: ${color};`}>{number}</div>
  <div class="process-step__emoji">{emoji}</div>
  <h3 class="process-step__title">{title}</h3>
  <p class="process-step__desc">{desc}</p>
</div>
