---
export interface Props {
  slug: string;
  emoji: string;
  name: string;
  description: string;
  price: string;
  size: string;
  ages: string;
  category: string;
  categoryColor?: string;
  gradient: string;
  image?: string;
  whatsapp?: string;
}

const {
  slug,
  emoji,
  name,
  description,
  price,
  size,
  ages,
  category,
  categoryColor = "castillo",
  gradient,
  image,
  whatsapp = "5531281706",
} = Astro.props;

const waMsg = encodeURIComponent(`Hola BRINCOLINS, quiero cotizar el inflable "${name}" para mi fiesta.`);
const waHref = `https://wa.me/${whatsapp}?text=${waMsg}`;
---

<article class={`product-card product-card--${categoryColor}`}>
  <div class="product-card__image product-card__image--photo">
    {image ? (
      <img src={image} alt={name} loading="lazy" width="720" height="480" />
    ) : (
      <div class="product-card__image-fallback" style={`background: linear-gradient(135deg, ${gradient});`}>
        
      </div>
    )}
    <span class="product-card__category">{category}</span>
    <div class="product-card__overlay">
      <div class="product-card__stars">★★★★★</div>
      <span class="product-card__price">{price}</span>
    </div>
  </div>

  <div class="product-card__body">
    <h3 class="product-card__name">{name}</h3>
    <p class="product-card__desc">{description}</p>

    <div class="product-card__info">
      <span class="product-card__tag">{size}</span>
      <span class="product-card__tag">{ages}</span>
    </div>

    <div class="product-card__actions">
      <a href={`/inflables/${slug}/`} class="btn btn-outline btn-sm">Ver detalles</a>
      <a href={waHref} target="_blank" rel="nofollow noopener noreferrer" class="btn btn-wa btn-sm product-card__wa-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><use href="#i-wa"/></svg>
        Cotizar
      </a>
    </div>
  </div>
</article>
