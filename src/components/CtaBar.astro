---
/**
 * CtaBar Component — BRINCOLINS
 * Barra de acciones rápidas debajo del Hero.
 */
interface CtaItem {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  headline?: string;
  items: CtaItem[];
}

const {
  headline,
  items,
} = Astro.props;

const icons: Record<string, string> = {
  cotizar: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>',
  galeria: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
  precios: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>',
  whatsapp: '<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><use href="#i-wa"/></svg>',
};
---

<section class="ctabar" aria-label="Acciones rápidas">
  <div class="container">
    {headline && <p class="ctabar__headline">{headline}</p>}
    <div class="ctabar__grid">
      {items.map((item) => (
        <a href={item.href} class="ctabar__item" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
          {item.icon && icons[item.icon] && (
            <span class="ctabar__icon" set:html={icons[item.icon]} />
          )}
          <span class="ctabar__label">{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ctabar {
    background: #FF3D00;
    padding: 2rem 0;
  }

  .ctabar__headline {
    text-align: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .ctabar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .ctabar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
  }

  .ctabar__item:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .ctabar__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .ctabar__label {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .ctabar__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .ctabar__label { font-size: 0.75rem; }
    .ctabar__icon { display: none; }
  }

  @media (max-width: 400px) {
    .ctabar__grid { grid-template-columns: 1fr; }
    .ctabar__item { padding: 0.75rem 1rem; }
  }
</style>
