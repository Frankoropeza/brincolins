/* Lista nav panel */
.hdr__panel-list {
  flex: 1;
  list-style: none;
  margin: 0;
  padding: 0.5rem 0;
}

.hdr__panel-item {
  border-bottom: 1px solid rgba(0,0,0,0.04);
}

.hdr__panel-item:last-child {
  border-bottom: none;
}

.hdr__panel-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
