}

.hdr__drop-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #ffd0c4;
  flex-shrink: 0;
}

.hdr__drop-link:hover .hdr__drop-dot,
.hdr__drop-link--active .hdr__drop-dot {
  background: var(--hdr-primary);
}

/* ── Dropdown Servicios — más ancho, con icono + desc ── */
.hdr__dropdown--svc {
  min-width: 290px;
}

.hdr__drop-link--rich {
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.6rem 0.85rem;
  white-space: normal;
}

.hdr__drop-icon {
  font-size: 1.25rem;
  line-height: 1;
  flex-shrink: 0;
