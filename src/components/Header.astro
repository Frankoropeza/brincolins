/* ══════════════════════════════════════════
   Responsive
   ══════════════════════════════════════════ */
@media (max-width: 1200px) {
  .hdr__link {
    padding: 0.45rem 0.65rem;
    font-size: 0.83rem;
  }
}

/* ── Escala del logo ──────────────────────────────────────────────
   Cada breakpoint declara el par reposo / --scrolled.

   .hdr--scrolled fija la variable SOBRE el elemento .hdr, así que
   siempre gana a :root sin importar la media query. Por eso cada
   breakpoint debe redeclarar su propio valor scrolled: si se omite,
   hereda el 70px de escritorio y el header NO encoge en móvil.

   Altura resultante del header = logo + 16px (padding .hdr__inner)
   + 3px de borde:
     ≤900px →  91px reposo /  67px scrolled
     ≤640px →  75px reposo /  63px scrolled
     ≤380px →  69px reposo /  59px scrolled
   ───────────────────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .hdr__wa-btn span { display: none; }
  .hdr__wa-btn { padding: 0.5rem; border-radius: 10px; }
  :root          { --hdr-logo-h: 90px; }
  .hdr--scrolled { --hdr-logo-h: 64px; }
}

@media (max-width: 900px) {
  .hdr__nav, .hdr__wa-btn { display: none; }
  .hdr__toggle { display: flex; }
  .hdr__panel { display: flex; }
  :root          { --hdr-logo-h: 72px; }
  .hdr--scrolled { --hdr-logo-h: 48px; }
}

@media (max-width: 640px) {
  :root          { --hdr-logo-h: 56px; }
  .hdr--scrolled { --hdr-logo-h: 44px; }
}

@media (max-width: 480px) {
  .hdr__panel { width: 100%; }
}

@media (max-width: 380px) {
  :root          { --hdr-logo-h: 50px; }
  .hdr--scrolled { --hdr-logo-h: 40px; }
}
</style>

<script is:inline>
(function () {
  var hdr     = document.getElementById('hdr');
  var toggle  = document.getElementById('hdrToggle');
  var panel   = document.getElementById('hdrPanel');
  var overlay = document.getElementById('hdrOverlay');
  var close   = document.getElementById('hdrClose');

  /* ── Mobile panel ── */
  function openPanel() {
    toggle.classList.add('hdr__toggle--open');
    toggle.setAttribute('aria-expanded', 'true');
    panel.classList.add('hdr__panel--open');
    panel.setAttribute('aria-hidden', 'false');
    overlay.classList.add('hdr__overlay--visible');
    document.body.style.overflow = 'hidden';
  }

  function closePanel() {
    toggle.classList.remove('hdr__toggle--open');
    toggle.setAttribute('aria-expanded', 'false');
    panel.classList.remove('hdr__panel--open');
    panel.setAttribute('aria-hidden', 'true');
    overlay.classList.remove('hdr__overlay--visible');
    document.body.style.overflow = '';
  }

  if (toggle) toggle.addEventListener('click', function () {
    panel.classList.contains('hdr__panel--open') ? closePanel() : openPanel();
  });
  if (close)   close.addEventListener('click', closePanel);
  if (overlay) overlay.addEventListener('click', closePanel);

  if (panel) {
    panel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', closePanel);
    });
  }

  /* ── Accordion móvil ── */
  document.querySelectorAll('[data-sub]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      this.classList.toggle('hdr__panel-subtoggle--open');
      var sub = this.nextElementSibling;
      if (sub) sub.classList.toggle('hdr__panel-sub--open');
    });
  });

  /* ── Hover con delay para dropdowns desktop ──
     Reemplaza :hover CSS para evitar que el dropdown se cierre
     al mover el cursor diagonalmente del link al panel.
  ── */
  var CLOSE_DELAY = 150; // ms de gracia al salir

  document.querySelectorAll('.hdr__item--sub, .hdr__item--mega').forEach(function (item) {
    var timer;

    item.addEventListener('mouseenter', function () {
      clearTimeout(timer);
      item.classList.add('hdr__item--open');
    });

    item.addEventListener('mouseleave', function () {
      timer = setTimeout(function () {
        item.classList.remove('hdr__item--open');
      }, CLOSE_DELAY);
    });
  });

  /* ── Sticky shrink on scroll ── */
  if (hdr) {
    var SHRINK_AT = 60;
    function onScroll() {
      hdr.classList.toggle('hdr--scrolled', window.scrollY > SHRINK_AT);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

})();
</script>
