}

/* ══════════════════════════════════════════
   MEGA-MENU — Inflables
   ══════════════════════════════════════════ */
.hdr__mega {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  width: min(480px, calc(100vw - 2rem));
  background: #fff;
  border-radius: 20px;
  border: 2px solid rgba(255,61,0,0.12);
  box-shadow: 0 12px 40px rgba(0,0,0,0.10), 0 4px 12px rgba(255,61,0,0.08);
