---
export interface Props {
  whatsapp?: string;
  currentPath?: string;
}

const {
  whatsapp = "5511111111",
  currentPath = Astro.url.pathname,
} = Astro.props;

const waHref = `https://wa.me/${whatsapp}?text=${encodeURIComponent("Hola BRINCOLINS, quiero información sobre renta de inflables.")}`;

const links = [
  { label: "Inicio", href: "/" },
  { label: "Inflables", href: "/inflables/" },
  { label: "Cotizar", href: "/cotizar/" },
  { label: "Nosotros", href: "/nosotros/" },
  { label: "Cobertura", href: "/cobertura/" },
  { label: "Blog", href: "/blog/" },
  { label: "Contacto", href: "/contacto/" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<a href="#contenido-principal" class="skip-link">Saltar al contenido principal</a>

<!-- TOPBAR -->
<div class="topbar">
  <div class="topbar__inner">
    <span class="topbar__item">📞 55 1111 1111</span>
    <span class="topbar__sep">|</span>
    <span class="topbar__item">⏰ Lun–Dom: 8:00–20:00 hrs</span>
    <span class="topbar__sep">|</span>
    <span class="topbar__item">🚚 Entrega e instalación incluida en CDMX y Edomex</span>
    <span class="topbar__sep topbar__sep--hide">|</span>
    <a href={`mailto:info@brincolins.com`} class="topbar__item topbar__link topbar__sep--hide">✉️ info@brincolins.com</a>
  </div>
</div>

<header class="header" id="site-header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="BRINCOLINS — Inicio">
      <span class="header__logo-emoji">🎪</span>
      BRINCOLINS
    </a>

    <nav class="header__nav" aria-label="Navegación principal">
      {links.map(link => (
        <a
          href={link.href}
          class={`header__link ${isActive(link.href) ? "header__link--active" : ""}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header__cta">
      <a href={waHref} target="_blank" rel="noopener noreferrer" class="btn btn-wa header__wa-btn">
