---
/**
 * Header — BRINCOLINS
 * ─────────────────────────────
 * Desktop: mega-menu Inflables (2 cols agrupadas + CTA), dropdown rico Servicios
 * Mobile: panel acordeón con labels de categoría no-clickeables
 * Config base desde /src/data/header.md
 * Estilos en /src/styles/header.css (extraídos del componente, jul 2026 —
 * eran 857 líneas de <style> dentro de un archivo de 1,399).
 */
import "@/styles/header.css";
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import matter from 'gray-matter';

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

let config: Record<string, any> = {};
let topbarConfig: Record<string, any> = {};
try {
  const raw = readFileSync(join(process.cwd(), 'src/data/header.md'), 'utf-8');
  config = matter(raw).data;
} catch { /* defaults */ }
try {
  const raw2 = readFileSync(join(process.cwd(), 'src/data/topbar.md'), 'utf-8');
  topbarConfig = matter(raw2).data;
} catch { /* defaults */ }

const brand      = config.brand ?? 'BRINCOLINS';
const logoHref   = config.logoHref ?? '/';
const navLinks   = (config.nav ?? []) as NavItem[];
const cta        = config.cta ?? { enabled: false, label: '', href: '' };

const waNum      = topbarConfig.whatsapp ?? '5531281706';
const waMsg      = topbarConfig.waMessage ?? 'Hola, quiero cotizar un inflable.';
const phone      = topbarConfig.phone ?? '';
const schedule   = topbarConfig.schedule ?? '';
const waHref     = `https://wa.me/${waNum}?text=${encodeURIComponent(waMsg)}`;
const waCotizar  = `https://wa.me/${waNum}?text=${encodeURIComponent('Hola BRINCOLINS, quiero cotizar un inflable para mi fiesta.')}`;

const currentPath = Astro.url.pathname;

function isActive(href: string, children?: { href: string }[]): boolean {
  if (href === '/') return currentPath === '/';
  if (currentPath.startsWith(href)) return true;
  if (children?.some(c => currentPath.startsWith(c.href))) return true;
  return false;
}

// Servicios — datos ricos (icono + descripción)
const serviciosItems = [
  { icon: '🎪', label: 'Renta de Inflables',    desc: 'Entrega e instalación incluida',  href: '/servicios/renta-de-inflables/'      },
  { icon: '🎉', label: 'Paquetes de Fiesta',     desc: 'Todo incluido para tu evento',    href: '/servicios/paquetes-de-fiesta/'      },
  { icon: '🪑', label: 'Mobiliario para Fiestas',desc: 'Mesas, sillas y decoración',      href: '/servicios/mobiliario-para-fiestas/' },
  { icon: '💡', label: 'Iluminación para Eventos',desc:'Ambiente y efectos de color',     href: '/servicios/iluminacion-eventos/'     },
  { icon: '🎈', label: 'Inflables para Eventos', desc: 'Corporativos y eventos sociales', href: '/servicios/inflables-para-eventos/'  },
];
---

<header class="hdr" id="hdr" role="banner">
  <div class="hdr__inner">

    {/* ── Logo ── */}
    <a href={logoHref} class="hdr__logo" aria-label={`${brand} — Inicio`}>
      <img
        src="/img/branding/renta-de-inflables.avif"
        alt="Brincolins — Renta de inflables en CDMX"
        class="hdr__logo-img"
        width="430"
        height="212"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    {/* ── Desktop nav ── */}
    <nav class="hdr__nav" aria-label="Navegación principal">
      <ul class="hdr__list">
        {navLinks.map((link) => {

          /* ── INFLABLES — mega-menu ── */
          if (link.href === '/inflables/') return (
            <li class="hdr__item hdr__item--mega">
              <a
                href={link.href}
                class:list={['hdr__link', { 'hdr__link--active': isActive(link.href, link.children) }]}
                aria-haspopup="true"
              >
                {link.label}
                <svg class="hdr__chev" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
                  <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>

              <div class="hdr__mega" role="menu">
                <div class="hdr__mega-inner">

                  {/* Col A — Populares + Temáticos */}
                  <div class="hdr__mega-col">
                    <span class="hdr__mega-cat">🔥 Más populares</span>
                    <a href="/inflables/dragones-rojos/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/dragones-rojos/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Dragones Rojos</span>
                      <span class="hdr__mega-price">$1,200</span>
                    </a>
                    <a href="/inflables/castillo-princesas/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/castillo-princesas/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Castillo de Princesas</span>
                      <span class="hdr__mega-price">$1,200</span>
                    </a>
                    <span class="hdr__mega-cat">🌿 Temáticos</span>
                    <a href="/inflables/mini-jungla/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/mini-jungla/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Mini Jungla</span>
                      <span class="hdr__mega-price">$1,300</span>
                    </a>
                    <a href="/inflables/gusanitos/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/gusanitos/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Gusanitos</span>
                      <span class="hdr__mega-price">$1,350</span>
                    </a>
                  </div>

                  {/* Col B — Por tamaño + Especiales */}
                  <div class="hdr__mega-col">
                    <span class="hdr__mega-cat">📐 Por tamaño</span>
                    <a href="/inflables/mini-castillo/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/mini-castillo/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Mini Castillo</span>
                      <span class="hdr__mega-price">$800</span>
                    </a>
                    <a href="/inflables/barco-pirata/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/barco-pirata/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Barco Pirata</span>
                      <span class="hdr__mega-price">$1,800</span>
                    </a>
                    <a href="/inflables/extremo/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/extremo/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Extremo</span>
                      <span class="hdr__mega-price">$1,900</span>
                    </a>
                    <span class="hdr__mega-cat">💍 Eventos especiales</span>
                    <a href="/inflables/castillo-blanco/" class:list={['hdr__mega-link', { 'hdr__mega-link--active': currentPath.startsWith('/inflables/castillo-blanco/') }]} role="menuitem">
                      <span class="hdr__mega-link-name">Castillo Blanco</span>
                      <span class="hdr__mega-price">$1,700</span>
                    </a>
                  </div>


                </div>
              </div>
            </li>
          );

          /* ── SERVICIOS — dropdown enriquecido ── */
          if (link.href === '/servicios/') return (
            <li class="hdr__item hdr__item--sub">
              <a
                href={link.href}
                class:list={['hdr__link', { 'hdr__link--active': isActive(link.href, link.children) }]}
                aria-haspopup="true"
              >
                {link.label}
                <svg class="hdr__chev" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
                  <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <div class="hdr__dropdown hdr__dropdown--svc" role="menu">
                <ul class="hdr__drop-list">
                  {serviciosItems.map((svc) => (
                    <li role="none">
                      <a
                        href={svc.href}
                        role="menuitem"
                        class:list={['hdr__drop-link hdr__drop-link--rich', { 'hdr__drop-link--active': currentPath.startsWith(svc.href) }]}
                      >
                        <span class="hdr__drop-icon">{svc.icon}</span>
                        <span class="hdr__drop-body">
                          <span class="hdr__drop-name">{svc.label}</span>
                          <span class="hdr__drop-desc">{svc.desc}</span>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          );

          /* ── Resto de items nav ── */
          return (
            <li class:list={['hdr__item', { 'hdr__item--sub': !!link.children }]}>
              <a
                href={link.href}
                class:list={['hdr__link', { 'hdr__link--active': isActive(link.href, link.children) }]}
                aria-haspopup={link.children ? 'true' : undefined}
              >
                {link.label}
                {link.children && (
                  <svg class="hdr__chev" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
                    <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                )}
              </a>
              {link.children && (
                <div class="hdr__dropdown" role="menu">
                  <ul class="hdr__drop-list">
                    {link.children.map((sub) => (
                      <li role="none">
                        <a
                          href={sub.href}
                          role="menuitem"
                          class:list={['hdr__drop-link', { 'hdr__drop-link--active': currentPath === sub.href }]}
                        >
                          <span class="hdr__drop-dot" aria-hidden="true"></span>
                          {sub.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </nav>

    {/* ── Acciones desktop ── */}
    <div class="hdr__actions">
      {waHref && (
        <a href={waHref} target="_blank" rel="nofollow noopener noreferrer" class="hdr__wa-btn" aria-label="Contactar por WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <use href="#i-wa"/>
          </svg>
          <span>WhatsApp</span>
        </a>
      )}
      {cta.enabled && (
        <a href={cta.href} class="hdr__cta">
          {cta.label}
        </a>
      )}
      <button class="hdr__toggle" id="hdrToggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="hdrPanel">
        <span class="hdr__burger" aria-hidden="true"></span>
      </button>
    </div>

  </div>
</header>

{/* ── Overlay ── */}
<div class="hdr__overlay" id="hdrOverlay" aria-hidden="true"></div>

{/* ── Panel móvil ──
    `inert` es imprescindible, no decorativo: el panel cerrado solo está
    desplazado con transform:translateX(100%), y un elemento fuera de
    pantalla SIGUE siendo focusable. Sin inert, un usuario de teclado
    tabulaba por 24 enlaces invisibles y el foco desaparecía de la vista.
    Además, aria-hidden="true" con descendientes focusables es una
    violación WCAG: contradice al árbol de accesibilidad con el de foco.
    inert resuelve ambos — saca el subárbol del foco Y del árbol a11y.
    El JS lo alterna en openPanel/closePanel. */}
<nav class="hdr__panel" id="hdrPanel" aria-label="Menú móvil" aria-hidden="true" inert>

  {/* Cabecera panel */}
  <div class="hdr__panel-head">
    <a href={logoHref} class="hdr__panel-logo-link" onclick="document.getElementById('hdrPanel').classList.remove('hdr__panel--open')">
      <img
        src="/img/branding/renta-de-inflables.avif"
        alt={brand}
        class="hdr__panel-logo"
        width="430"
        height="212"
        loading="lazy"
        decoding="async"
      />
    </a>
    <button class="hdr__panel-close" id="hdrClose" type="button" aria-label="Cerrar menú">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1.5 1.5l15 15M16.5 1.5l-15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  {/* Nav items */}
  <ul class="hdr__panel-list">
    {navLinks.map((link) => {

      /* ── INFLABLES — acordeón con categorías ── */
      if (link.href === '/inflables/') return (
        <li class="hdr__panel-item hdr__panel-item--sub">
          <button class="hdr__panel-link hdr__panel-subtoggle" type="button" data-sub>
            <span>Inflables</span>
            <svg class="hdr__panel-chev" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="hdr__panel-sub hdr__panel-sub--tall">
            {/* Más populares */}
            <span class="hdr__panel-group-label">🔥 Más populares</span>
            <a href="/inflables/dragones-rojos/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/dragones-rojos/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Dragones Rojos</span>
              <span class="hdr__panel-sub-price">$1,200</span>
            </a>
            <a href="/inflables/castillo-princesas/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/castillo-princesas/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Castillo de Princesas</span>
              <span class="hdr__panel-sub-price">$1,200</span>
            </a>
            {/* Temáticos */}
            <span class="hdr__panel-group-label">🌿 Temáticos</span>
            <a href="/inflables/mini-jungla/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/mini-jungla/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Mini Jungla</span>
              <span class="hdr__panel-sub-price">$1,300</span>
            </a>
            <a href="/inflables/gusanitos/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/gusanitos/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Gusanitos</span>
              <span class="hdr__panel-sub-price">$1,350</span>
            </a>
            {/* Por tamaño */}
            <span class="hdr__panel-group-label">📐 Por tamaño</span>
            <a href="/inflables/mini-castillo/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/mini-castillo/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Mini Castillo</span>
              <span class="hdr__panel-sub-price">$800</span>
            </a>
            <a href="/inflables/barco-pirata/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/barco-pirata/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Barco Pirata</span>
              <span class="hdr__panel-sub-price">$1,800</span>
            </a>
            <a href="/inflables/extremo/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/extremo/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Extremo</span>
              <span class="hdr__panel-sub-price">$1,900</span>
            </a>
            {/* Especiales */}
            <span class="hdr__panel-group-label">💍 Especiales</span>
            <a href="/inflables/castillo-blanco/" class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath.startsWith('/inflables/castillo-blanco/') }]}>
              <span class="hdr__panel-subdot" aria-hidden="true"></span>
              <span class="hdr__panel-sub-name">Castillo Blanco</span>
              <span class="hdr__panel-sub-price">$1,700</span>
            </a>
            {/* Ver todos */}
            <a href="/inflables/" class="hdr__panel-sub-viewall">
              Ver todos los inflables
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </li>
      );

      /* ── SERVICIOS — acordeón con iconos ── */
      if (link.href === '/servicios/') return (
        <li class="hdr__panel-item hdr__panel-item--sub">
          <button class="hdr__panel-link hdr__panel-subtoggle" type="button" data-sub>
            <span>Servicios</span>
            <svg class="hdr__panel-chev" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="hdr__panel-sub">
            {serviciosItems.map((svc) => (
              <a
                href={svc.href}
                class:list={['hdr__panel-sublink hdr__panel-sublink--svc', { 'hdr__panel-sublink--active': currentPath.startsWith(svc.href) }]}
              >
                <span class="hdr__panel-svc-icon">{svc.icon}</span>
                <span class="hdr__panel-sub-name">{svc.label}</span>
              </a>
            ))}
            <a href="/servicios/" class="hdr__panel-sub-viewall">
              Ver todos los servicios
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </li>
      );

      /* ── Resto de items ── */
      return (
        <li class:list={['hdr__panel-item', { 'hdr__panel-item--sub': !!link.children }]}>
          {link.children ? (
            <>
              <button class="hdr__panel-link hdr__panel-subtoggle" type="button" data-sub>
                <span>{link.label}</span>
                <svg class="hdr__panel-chev" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                  <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="hdr__panel-sub">
                {link.children.map((sub) => (
                  <a
                    href={sub.href}
                    class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath === sub.href }]}
                  >
                    <span class="hdr__panel-subdot" aria-hidden="true"></span>
                    {sub.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={link.href}
              class:list={['hdr__panel-link', { 'hdr__panel-link--active': isActive(link.href) }]}
            >
              {link.label}
            </a>
          )}
        </li>
      );
    })}
  </ul>

  {/* Pie de panel */}
  <div class="hdr__panel-foot">
    {cta.enabled && (
      <a href={cta.href} class="hdr__panel-cta">{cta.label}</a>
    )}
    {waHref && (
      <a href={waHref} target="_blank" rel="nofollow noopener noreferrer" class="hdr__panel-wa">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <use href="#i-wa"/>
        </svg>
        Escríbenos por WhatsApp
      </a>
    )}
    {phone && (
      <a href={`tel:+52${waNum || phone.replace(/\s/g,'')}`} class="hdr__panel-phone">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        {phone}
      </a>
    )}
    {schedule && <p class="hdr__panel-schedule">{schedule}</p>}
  </div>

</nav>


<script is:inline>
(function () {
  var hdr     = document.getElementById('hdr');
  var toggle  = document.getElementById('hdrToggle');
  var panel   = document.getElementById('hdrPanel');
  var overlay = document.getElementById('hdrOverlay');
  var close   = document.getElementById('hdrClose');

  /* ── Mobile panel ── */
  function openPanel() {
    if (hdr) hdr.classList.remove('hdr--hidden');
    toggle.classList.add('hdr__toggle--open');
    toggle.setAttribute('aria-expanded', 'true');
    panel.classList.add('hdr__panel--open');
    panel.setAttribute('aria-hidden', 'false');
    panel.inert = false;           // devuelve los enlaces al orden de foco
    overlay.classList.add('hdr__overlay--visible');
    document.body.style.overflow = 'hidden';
  }

  function closePanel() {
    toggle.classList.remove('hdr__toggle--open');
    toggle.setAttribute('aria-expanded', 'false');
    panel.classList.remove('hdr__panel--open');
    panel.setAttribute('aria-hidden', 'true');
    panel.inert = true;            // saca los 24 enlaces del foco y del árbol a11y
    overlay.classList.remove('hdr__overlay--visible');
    document.body.style.overflow = '';
  }

  /* Cerrar devolviendo el foco al burger. Sin esto, al cerrar el menú el
     foco se queda en un elemento que acaba de volverse inert y salta al
     inicio del documento: el usuario de teclado pierde su sitio. */
  function closeAndRefocus() {
    var wasOpen = panel.classList.contains('hdr__panel--open');
    closePanel();
    if (wasOpen && toggle) toggle.focus();
  }

  if (toggle) toggle.addEventListener('click', function () {
    panel.classList.contains('hdr__panel--open') ? closeAndRefocus() : openPanel();
  });
  if (close)   close.addEventListener('click', closeAndRefocus);
  if (overlay) overlay.addEventListener('click', closeAndRefocus);

  /* Escape cierra el panel — comportamiento esperado en cualquier overlay */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && panel.classList.contains('hdr__panel--open')) closeAndRefocus();
  });

  if (panel) {
    panel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', closePanel);
    });
  }

  /* ── Accordion móvil ── */
  document.querySelectorAll('[data-sub]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      this.classList.toggle('hdr__panel-subtoggle--open');
      var sub = this.nextElementSibling;
      if (sub) sub.classList.toggle('hdr__panel-sub--open');
    });
  });

  /* ── Hover con delay para dropdowns desktop ──
     Reemplaza :hover CSS para evitar que el dropdown se cierre
     al mover el cursor diagonalmente del link al panel.
  ── */
  var CLOSE_DELAY = 150; // ms de gracia al salir

  document.querySelectorAll('.hdr__item--sub, .hdr__item--mega').forEach(function (item) {
    var timer;

    item.addEventListener('mouseenter', function () {
      clearTimeout(timer);
      item.classList.add('hdr__item--open');
    });

    item.addEventListener('mouseleave', function () {
      timer = setTimeout(function () {
        item.classList.remove('hdr__item--open');
      }, CLOSE_DELAY);
    });
  });

  /* ── Sticky shrink + auto-hide móvil ──
     Shrink: reduce el logo tras 60px de scroll (todos los viewports).
     Auto-hide (≤900px): oculta el header al bajar y lo muestra al subir.
     Umbrales asimétricos (bajar 8px / subir 4px) para que no parpadee
     con el rebote del scroll táctil. Nunca se oculta con el panel
     abierto ni cerca del top. */
  if (hdr) {
    var SHRINK_AT = 60;
    var SHOW_ZONE = 140;   // px superiores donde el header nunca se oculta
    var lastY = window.scrollY;
    var ticking = false;
    var mqMobile = window.matchMedia('(max-width: 900px)');

    function update() {
      var y = window.scrollY;
      hdr.classList.toggle('hdr--scrolled', y > SHRINK_AT);

      if (!mqMobile.matches || (panel && panel.classList.contains('hdr__panel--open'))) {
        hdr.classList.remove('hdr--hidden');
      } else if (y < SHOW_ZONE) {
        hdr.classList.remove('hdr--hidden');
      } else if (y - lastY > 8) {
        hdr.classList.add('hdr--hidden');
      } else if (lastY - y > 4) {
        hdr.classList.remove('hdr--hidden');
      }
      lastY = y;
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    }, { passive: true });
    update();
  }

})();
</script>
