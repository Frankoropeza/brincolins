  opacity: 1;
  color: var(--hdr-primary);
}

/* Submenu panel */
.hdr__panel-sub {
  max-height: 0;
  overflow: hidden;
  background: #fafafa;
  border-top: 1px solid rgba(0,0,0,0.04);
}

