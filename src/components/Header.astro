---
/**
 * Header Component — Brincolins
 * ─────────────────────────────
 * Configurable via /src/data/header.md
 * Features:
 *   - Sticky con shrink on scroll (90px → 70px)
 *   - Logo grande centrado visualmente
 *   - Dropdown mejorado con grid
 *   - WhatsApp CTA en desktop
 *   - Panel móvil full con contacto al pie
 *   - ARIA accesible
 */
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import matter from 'gray-matter';

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

let config: Record<string, any> = {};
let topbarConfig: Record<string, any> = {};
try {
  const raw = readFileSync(join(process.cwd(), 'src/data/header.md'), 'utf-8');
  config = matter(raw).data;
} catch { /* defaults */ }
try {
  const raw2 = readFileSync(join(process.cwd(), 'src/data/topbar.md'), 'utf-8');
  topbarConfig = matter(raw2).data;
} catch { /* defaults */ }

const brand      = config.brand ?? 'BRINCOLINS';
const logoHref   = config.logoHref ?? '/';
const navLinks   = (config.nav ?? []) as NavItem[];
const cta        = config.cta ?? { enabled: false, label: '', href: '' };

const waNum      = topbarConfig.whatsapp ?? '';
const waMsg      = topbarConfig.waMessage ?? 'Hola, quiero cotizar un inflable.';
const phone      = topbarConfig.phone ?? '';
const schedule   = topbarConfig.schedule ?? '';
const waHref     = waNum ? `https://wa.me/${waNum}?text=${encodeURIComponent(waMsg)}` : '';

const currentPath = Astro.url.pathname;

function isActive(href: string, children?: { href: string }[]): boolean {
  if (href === '/') return currentPath === '/';
  if (currentPath.startsWith(href)) return true;
  if (children?.some(c => currentPath.startsWith(c.href))) return true;
  return false;
}
---

<header class="hdr" id="hdr" role="banner">
  <div class="hdr__inner">

    {/* ── Logo ── */}
    <a href={logoHref} class="hdr__logo" aria-label={`${brand} — Inicio`}>
      <img
        src="/img/branding/renta-de-inflables.avif"
        alt="Brincolins — Renta de inflables en CDMX"
        class="hdr__logo-img"
        width="576"
        height="284"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    {/* ── Desktop nav ── */}
    <nav class="hdr__nav" aria-label="Navegación principal">
      <ul class="hdr__list">
        {navLinks.map((link) => (
          <li class:list={['hdr__item', { 'hdr__item--sub': !!link.children }]}>
            <a
              href={link.href}
              class:list={['hdr__link', { 'hdr__link--active': isActive(link.href, link.children) }]}
              aria-haspopup={link.children ? 'true' : undefined}
            >
              {link.label}
              {link.children && (
                <svg class="hdr__chev" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
                  <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
            {link.children && (
              <div class="hdr__dropdown" role="menu">
                <ul class="hdr__drop-list">
                  {link.children.map((sub) => (
                    <li role="none">
                      <a
                        href={sub.href}
                        role="menuitem"
                        class:list={['hdr__drop-link', { 'hdr__drop-link--active': currentPath === sub.href }]}
                      >
                        <span class="hdr__drop-dot" aria-hidden="true"></span>
                        {sub.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    {/* ── Acciones desktop ── */}
    <div class="hdr__actions">
      {waHref && (
        <a href={waHref} target="_blank" rel="nofollow noopener noreferrer" class="hdr__wa-btn" aria-label="Contactar por WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span>WhatsApp</span>
        </a>
      )}
      {cta.enabled && (
        <a href={cta.href} class="hdr__cta">
          {cta.label}
        </a>
      )}
      <button class="hdr__toggle" id="hdrToggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="hdrPanel">
        <span class="hdr__burger" aria-hidden="true"></span>
      </button>
    </div>

  </div>
</header>

{/* ── Overlay ── */}
<div class="hdr__overlay" id="hdrOverlay" aria-hidden="true"></div>

{/* ── Panel móvil ── */}
<nav class="hdr__panel" id="hdrPanel" aria-label="Menú móvil" aria-hidden="true">

  {/* Cabecera panel */}
  <div class="hdr__panel-head">
    <a href={logoHref} class="hdr__panel-logo-link" onclick="document.getElementById('hdrPanel').classList.remove('hdr__panel--open')">
      <img
        src="/img/branding/renta-de-inflables.avif"
        alt={`${brand}`}
        class="hdr__panel-logo"
        width="576"
        height="284"
        loading="lazy"
        decoding="async"
      />
    </a>
    <button class="hdr__panel-close" id="hdrClose" type="button" aria-label="Cerrar menú">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1.5 1.5l15 15M16.5 1.5l-15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  {/* Nav items */}
  <ul class="hdr__panel-list">
    {navLinks.map((link) => (
      <li class:list={['hdr__panel-item', { 'hdr__panel-item--sub': !!link.children }]}>
        {link.children ? (
          <>
            <button class="hdr__panel-link hdr__panel-subtoggle" type="button" data-sub>
              <span>{link.label}</span>
              <svg class="hdr__panel-chev" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul class="hdr__panel-sub">
              {link.children.map((sub) => (
                <li>
                  <a
                    href={sub.href}
                    class:list={['hdr__panel-sublink', { 'hdr__panel-sublink--active': currentPath === sub.href }]}
                  >
                    <span class="hdr__panel-subdot" aria-hidden="true"></span>
                    {sub.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        ) : (
          <a
            href={link.href}
            class:list={['hdr__panel-link', { 'hdr__panel-link--active': isActive(link.href) }]}
          >
            {link.label}
          </a>
        )}
      </li>
    ))}
  </ul>

  {/* Pie de panel: CTA + contacto */}
  <div class="hdr__panel-foot">
    {cta.enabled && (
      <a href={cta.href} class="hdr__panel-cta">{cta.label}</a>
    )}
    {waHref && (
      <a href={waHref} target="_blank" rel="nofollow noopener noreferrer" class="hdr__panel-wa">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Escríbenos por WhatsApp
      </a>
    )}
    {phone && (
      <a href={`tel:+52${waNum || phone.replace(/\s/g,'')}`} class="hdr__panel-phone">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        {phone}
      </a>
    )}
    {schedule && <p class="hdr__panel-schedule">{schedule}</p>}
  </div>

</nav>

<style>
/* ══════════════════════════════════════════
   Variables internas
   ══════════════════════════════════════════ */
:root {
  --hdr-primary: #FF3D00;
  --hdr-text: #1a1a2e;
  --hdr-text-muted: #6b7280;
  --hdr-border: rgba(0,0,0,0.07);
  --hdr-ease: cubic-bezier(0.34, 1.56, 0.64, 1); /* spring bounce */
  --hdr-ease-out: cubic-bezier(0.4, 0, 0.2, 1);
  --hdr-logo-h: 106px;
}

/* ══════════════════════════════════════════
   Header base
   ══════════════════════════════════════════ */
.hdr {
  position: relative;
  z-index: 9000;
  width: 100%;
  background: #fff;
  border-bottom: 3px solid #FF3D00;
}

.hdr--scrolled {
  box-shadow: 0 2px 20px rgba(0,0,0,0.10);
  --hdr-logo-h: 70px;
}

.hdr__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  width: 100%;
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 8px var(--container-px);
}

/* ══════════════════════════════════════════
   Logo
   ══════════════════════════════════════════ */
.hdr__logo {
  flex-shrink: 0;
  display: block;
  text-decoration: none;
  line-height: 0;
}

.hdr__logo-img {
  height: var(--hdr-logo-h);
  width: auto;
  display: block;
  object-fit: contain;
}

/* ══════════════════════════════════════════
   Nav desktop
   ══════════════════════════════════════════ */
.hdr__nav {
  flex: 1;
  display: flex;
  justify-content: center;
  min-width: 0;
}

.hdr__list {
  display: flex;
  align-items: center;
  gap: 0.15rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.hdr__item {
  position: relative;
}

.hdr__item--sub {
  padding-bottom: 8px;
  margin-bottom: -8px;
}

.hdr__link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 0.45rem 0.9rem;
  border-radius: 50px;
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--hdr-text);
  text-decoration: none;
  white-space: nowrap;
  letter-spacing: 0.01em;
  position: relative;
}

.hdr__link:hover {
  color: var(--hdr-primary);
  background: rgba(255, 61, 0, 0.08);
}

.hdr__link--active {
  color: var(--hdr-primary);
  background: rgba(255, 61, 0, 0.08);
}

.hdr__chev {
  opacity: 0.5;
  transition: transform 0.25s var(--hdr-ease-out);
  flex-shrink: 0;
}

.hdr__item--sub:hover .hdr__chev,
.hdr__item--sub:focus-within .hdr__chev {
  transform: rotate(180deg);
  opacity: 1;
  color: var(--hdr-primary);
}

/* ── Dropdown ── */
.hdr__dropdown {
  position: absolute;
  top: calc(100% + 4px);
  left: 50%;
  transform: translateX(-50%);
  min-width: 210px;
  background: #fff;
  border-radius: 20px;
  border: 2px solid rgba(255,61,0,0.12);
  box-shadow: 0 12px 40px rgba(255,61,0,0.10), 0 4px 12px rgba(0,0,0,0.06);
  padding: 0.5rem;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  z-index: 9999;
  overflow: hidden;
}

/* Acento naranja arriba del dropdown */
.hdr__dropdown::before {
  content: '';
  display: block;
  height: 3px;
  background: linear-gradient(90deg, #FF3D00, #FF6B00, #FFB300);
  border-radius: 3px 3px 0 0;
  margin: -0.5rem -0.5rem 0.5rem;
}

.hdr__item--sub:hover .hdr__dropdown,
.hdr__item--sub:focus-within .hdr__dropdown {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.hdr__drop-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.hdr__drop-link {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.55rem 0.85rem;
  border-radius: 12px;
  font-size: 0.86rem;
  font-weight: 600;
  color: var(--hdr-text);
  text-decoration: none;
  white-space: nowrap;
}

.hdr__drop-link:hover,
.hdr__drop-link--active {
  background: rgba(255, 61, 0, 0.07);
  color: var(--hdr-primary);
}

.hdr__drop-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #ffd0c4;
  flex-shrink: 0;
}

.hdr__drop-link:hover .hdr__drop-dot,
.hdr__drop-link--active .hdr__drop-dot {
  background: var(--hdr-primary);
}

/* ══════════════════════════════════════════
   Acciones desktop
   ══════════════════════════════════════════ */
.hdr__actions {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-shrink: 0;
}

/* WhatsApp pill */
.hdr__wa-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.5rem 1.1rem;
  border-radius: 50px;
  font-size: 0.84rem;
  font-weight: 700;
  color: #0e7a6e;
  background: #e8fdf5;
  border: 2px solid rgba(37, 211, 102, 0.3);
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.18s, border-color 0.18s;
}

.hdr__wa-btn:hover {
  background: #d0fae9;
  border-color: rgba(37, 211, 102, 0.55);
}

/* CTA principal */
.hdr__cta {
  display: inline-flex;
  align-items: center;
  padding: 0.6rem 1.4rem;
  border-radius: 50px;
  font-size: 0.875rem;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #FF3D00 0%, #FF6B00 100%);
  text-decoration: none;
  white-space: nowrap;
  box-shadow: 0 4px 0 #c42e00, 0 6px 16px rgba(255,61,0,0.28);
  transition: box-shadow 0.15s;
  letter-spacing: 0.02em;
}

.hdr__cta:hover {
  box-shadow: 0 6px 0 #c42e00, 0 10px 24px rgba(255,61,0,0.35);
}

.hdr__cta:active {
  box-shadow: 0 2px 0 #c42e00, 0 4px 10px rgba(255,61,0,0.25);
}

/* ── Hamburger ── */
.hdr__toggle {
  display: none;
  width: 42px;
  height: 42px;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  cursor: pointer;
  border: 1.5px solid var(--hdr-border);
  background: #fff;
  border-radius: 10px;
  position: relative;
}

.hdr__burger,
.hdr__burger::before,
.hdr__burger::after {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--hdr-text);
  border-radius: 2px;
  position: absolute;
}

.hdr__burger { top: 50%; left: 50%; transform: translate(-50%, -50%); }
.hdr__burger::before { content: ''; top: -6px; left: 0; }
.hdr__burger::after  { content: ''; top:  6px; left: 0; }

.hdr__toggle--open {
  border-color: var(--hdr-primary);
  background: rgba(255,61,0,0.04);
}

.hdr__toggle--open .hdr__burger { background: transparent; }
.hdr__toggle--open .hdr__burger::before { top: 0; transform: rotate(45deg); background: var(--hdr-primary); }
.hdr__toggle--open .hdr__burger::after  { top: 0; transform: rotate(-45deg); background: var(--hdr-primary); }

/* ══════════════════════════════════════════
   Overlay
   ══════════════════════════════════════════ */
.hdr__overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  backdrop-filter: blur(2px);
  z-index: 9100;
  opacity: 0;
}

.hdr__overlay--visible {
  display: block;
  opacity: 1;
}

/* ══════════════════════════════════════════
   Panel móvil
   ══════════════════════════════════════════ */
.hdr__panel {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(88vw, 380px);
  background: #fff;
  z-index: 9200;
  transform: translateX(100%);
  display: none;
  flex-direction: column;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  box-shadow: -8px 0 40px rgba(0,0,0,0.12);
}

.hdr__panel--open {
  transform: translateX(0);
}

/* Cabecera panel */
.hdr__panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 1.25rem;
  height: 72px;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  flex-shrink: 0;
}

.hdr__panel-logo-link {
  display: block;
  line-height: 0;
  text-decoration: none;
}

.hdr__panel-logo {
  height: 52px;
  width: auto;
  display: block;
  object-fit: contain;
}

.hdr__panel-close {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  border: 1px solid rgba(0,0,0,0.1);
  background: transparent;
  color: var(--hdr-text-muted);
  cursor: pointer;
  flex-shrink: 0;
}

.hdr__panel-close:hover {
  background: rgba(255,61,0,0.06);
  border-color: rgba(255,61,0,0.2);
  color: var(--hdr-primary);
}

/* Lista nav panel */
.hdr__panel-list {
  flex: 1;
  list-style: none;
  margin: 0;
  padding: 0.5rem 0;
}

.hdr__panel-item {
  border-bottom: 1px solid rgba(0,0,0,0.04);
}

.hdr__panel-item:last-child {
  border-bottom: none;
}

.hdr__panel-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 52px;
  padding: 0 1.5rem;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--hdr-text);
  text-decoration: none;
  background: none;
  border: none;
  font-family: inherit;
  cursor: pointer;
  text-align: left;
}

.hdr__panel-link:hover {
  color: var(--hdr-primary);
  background: rgba(255,61,0,0.04);
}

.hdr__panel-link--active {
  color: var(--hdr-primary);
  border-left: 3px solid var(--hdr-primary);
  padding-left: calc(1.5rem - 3px);
}

.hdr__panel-chev {
  opacity: 0.4;
  flex-shrink: 0;
}

.hdr__panel-subtoggle--open .hdr__panel-chev {
  transform: rotate(180deg);
  opacity: 1;
  color: var(--hdr-primary);
}

/* Submenu panel */
.hdr__panel-sub {
  max-height: 0;
  overflow: hidden;
  background: #fafafa;
  border-top: 1px solid rgba(0,0,0,0.04);
  list-style: none;
  margin: 0;
  padding: 0;
}

.hdr__panel-sub--open {
  max-height: 600px;
}

.hdr__panel-sublink {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  min-height: 46px;
