/* Hamburger */
.hdr__toggle {
  display: none;
  width: 42px;
  height: 42px;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  cursor: pointer;
  border: 1.5px solid var(--hdr-border);
  background: #fff;
  border-radius: 10px;
  position: relative;
}

.hdr__burger,
.hdr__burger::before,
.hdr__burger::after {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--hdr-text);
  border-radius: 2px;
  position: absolute;
  transition: transform 0.25s ease, background 0.2s;
}

.hdr__burger { top: 50%; left: 50%; transform: translate(-50%, -50%); }
.hdr__burger::before { content: ''; top: -6px; left: 0; }
.hdr__burger::after  { content: ''; top:  6px; left: 0; }

.hdr__toggle--open {
  border-color: var(--hdr-primary);
  background: rgba(255,61,0,0.04);
}

.hdr__toggle--open .hdr__burger { background: transparent; }
.hdr__toggle--open .hdr__burger::before { top: 0; transform: rotate(45deg); background: var(--hdr-primary); }
.hdr__toggle--open .hdr__burger::after  { top: 0; transform: rotate(-45deg); background: var(--hdr-primary); }

/* ══════════════════════════════════════════
   Overlay
   ══════════════════════════════════════════ */
.hdr__overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  backdrop-filter: blur(2px);
  z-index: 9100;
}

.hdr__overlay--visible {
  display: block;
}

/* ══════════════════════════════════════════
   Panel móvil
   ══════════════════════════════════════════ */
.hdr__panel {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(88vw, 380px);
  background: #fff;
  z-index: 9200;
  transform: translateX(100%);
  display: none;
  flex-direction: column;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  box-shadow: -8px 0 40px rgba(0,0,0,0.12);
}

.hdr__panel--open {
  transform: translateX(0);
}

/* Cabecera panel */
.hdr__panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 1.25rem;
  height: 72px;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  flex-shrink: 0;
  position: sticky;
  top: 0;
  background: #fff;
  z-index: 1;
}

.hdr__panel-logo-link {
  display: block;
  line-height: 0;
