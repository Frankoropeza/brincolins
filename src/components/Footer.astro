---
export interface Props {
  phone?:    string;
  whatsapp?: string;
  email?:    string;
}

const {
  phone    = "55 1111 1111",
  whatsapp = "5511111111",
  email    = "info@brincolins.com",
} = Astro.props;
---

<footer class="footer" role="contentinfo">

  <div class="footer__cta-band">
    <div class="container">
      <div class="footer__cta-inner">
        <div class="footer__cta-content">
          <p class="footer__cta-text">¿Lista la fiesta?</p>
          <p class="footer__cta-sub">Cotiza sin compromiso. Respondemos en minutos.</p>
        </div>
        <div class="footer__cta-actions">
          <a href="/cotizar" class="footer__cta-btn footer__cta-btn--primary">Solicitar cotización</a>
          <a href={`https://wa.me/${whatsapp}?text=${encodeURIComponent("Hola BRINCOLINS, quiero cotizar un inflable para mi fiesta.")}`}
             class="footer__cta-btn footer__cta-btn--ghost" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <div class="footer__brand">
          <div>
            <span class="footer__logo-text">🎪 BRINCO<span>LINS</span></span>
            <span class="footer__logo-tag">Renta de Inflables en CDMX y Estado de México</span>
          </div>
          <p class="footer__brand-desc">
            Más de 20 años llevando diversión a fiestas infantiles.
            Entrega, instalación, limpieza y seguro incluidos en todos nuestros servicios.
          </p>
          <div class="footer__contact-grid">
            <a href={`tel:+${whatsapp}`} class="footer__contact-item">
              <span>📞 {phone}</span>
            </a>
            <a href={`https://wa.me/${whatsapp}`} class="footer__contact-item" target="_blank" rel="noopener">
              <span>💬 {phone} (WhatsApp)</span>
            </a>
            <a href={`mailto:${email}`} class="footer__contact-item">
              <span>✉️ {email}</span>
            </a>
          </div>
        </div>

        <div class="footer__col">
          <h3 class="footer__title">Inflables</h3>
          <ul class="footer__list">
            <li><a href="/inflables" class="footer__link">Ver todos los inflables</a></li>
            <li><a href="/inflables/mini-castillo" class="footer__link">Mini Castillo</a></li>
            <li><a href="/inflables/castillo-princesas" class="footer__link">Castillo de Princesas</a></li>
            <li><a href="/inflables/barco-pirata" class="footer__link">Barco Pirata</a></li>
            <li><a href="/inflables/casa-brinco-jungla" class="footer__link">Casa Brinco Jungla</a></li>
            <li><a href="/inflables/tobogan-acuatico" class="footer__link">Tobogán Acuático</a></li>
            <li><a href="/inflables/inflable-deportivo" class="footer__link">Inflable Deportivo</a></li>
          </ul>
        </div>

        <div class="footer__col">
          <h3 class="footer__title">Empresa</h3>
          <ul class="footer__list">
            <li><a href="/nosotros" class="footer__link">Nosotros</a></li>
            <li><a href="/cobertura" class="footer__link">Cobertura</a></li>
            <li><a href="/cotizar" class="footer__link">Cotizar</a></li>
            <li><a href="/contacto" class="footer__link">Contacto</a></li>
          </ul>

          <h3 class="footer__title" style="margin-top:1.5rem">Zonas</h3>
          <ul class="footer__list">
            <li><a href="/cobertura" class="footer__link">CDMX</a></li>
            <li><a href="/cobertura" class="footer__link">Naucalpan / Tlalnepantla</a></li>
            <li><a href="/cobertura" class="footer__link">Ecatepec / Coacalco</a></li>
            <li><a href="/cobertura" class="footer__link">Ver todas las zonas</a></li>
          </ul>
        </div>

      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <div class="footer__bottom-inner">
        <p class="footer__copy">&copy; {new Date().getFullYear()} BRINCOLINS. Todos los derechos reservados.</p>
        <div class="footer__legal">
          <a href="/contacto">Aviso de Privacidad</a>
        </div>
      </div>
    </div>
  </div>

</footer>
